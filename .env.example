EVENTLOOPOS_ENV=development
EVENTLOOPOS_ORCHESTRATOR_URL=http://127.0.0.1:4377
EVENTLOOPOS_ARTIFACT_DIR=artifacts

# Orchestrator daemon
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=4377
ORCHESTRATOR_SEED_FIXTURE=
# fake seeds task_session_blog for local live E2E; off disables task-session API wiring.
ORCHESTRATOR_TASK_SESSIONS=fake
# seeded exposes fake read-only Slack/GitHub MCP sources; config loads ORCHESTRATOR_MCP_SOURCES_PATH; off disables MCP source registry.
ORCHESTRATOR_MCP_SOURCES=seeded
ORCHESTRATOR_MCP_SOURCES_PATH=
# aerospace exposes workspace status/capture/restore-plan; off disables workspace API wiring.
ORCHESTRATOR_WORKSPACE=aerospace

# Set for persistent Postgres-backed HTTP mode.
DATABASE_URL=

# Chrome native host
EVENTLOOPOS_CHROME_EXTENSION_ID=
EVENTLOOPOS_CONTEXT_LOG=artifacts/native-host/context-captures.jsonl
