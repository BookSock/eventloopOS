#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/macos-paper-reminder-feedback-proof-direct [--process-name NAME] [--ax-process-names NAMES] [--hotkey ctrl-option-r] [--expect TEXT] [--runs N] [--budget-ms N] [--manifest PATH]

Presses a macOS eventloopOS hotkey and proves the desktop paper reminder HUD
shows matching transient feedback. Intended for remote Mac labs where direct
shell osascript is more reliable than node-launched osascript.
EOF
}

process_name="${EVENTLOOPOS_QUEUE_PROCESS_NAME:-EventLoopQueueApp}"
ax_process_names="${EVENTLOOPOS_QUEUE_AX_PROCESS_NAMES:-eventloopOS Queue,EventLoopQueueApp}"
hotkey="${EVENTLOOPOS_PAPER_REMINDER_FEEDBACK_HOTKEY:-ctrl-option-r}"
expected_text="${EVENTLOOPOS_PAPER_REMINDER_FEEDBACK_EXPECT:-}"
runs="${EVENTLOOPOS_PAPER_REMINDER_FEEDBACK_RUNS:-1}"
budget_ms="${EVENTLOOPOS_PAPER_REMINDER_FEEDBACK_BUDGET_MS:-1000}"
manifest="artifacts/macos-paper-reminder-feedback/$(date -u +%Y%m%dT%H%M%SZ)/manifest.json"
harness_status_path="${EVENTLOOPOS_QUEUE_HARNESS_STATUS_PATH:-/tmp/eventloopos-queue-harness-status.json}"

while (($#)); do
  case "$1" in
    --process-name) process_name="${2:-}"; shift 2 ;;
    --ax-process-names) ax_process_names="${2:-}"; shift 2 ;;
    --hotkey) hotkey="${2:-}"; shift 2 ;;
    --expect) expected_text="${2:-}"; shift 2 ;;
    --runs) runs="${2:-}"; shift 2 ;;
    --budget-ms) budget_ms="${2:-}"; shift 2 ;;
    --manifest) manifest="${2:-}"; shift 2 ;;
    --harness-status-path) harness_status_path="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

case "$runs" in (*[!0-9]*|"") echo "--runs must be a positive integer" >&2; exit 2 ;; esac
case "$budget_ms" in (*[!0-9]*|"") echo "--budget-ms must be a positive integer" >&2; exit 2 ;; esac
if ((runs <= 0 || budget_ms <= 0)); then
  echo "--runs and --budget-ms must be positive" >&2
  exit 2
fi

key_code_for() {
  case "$1" in
    j) echo 38 ;;
    e) echo 14 ;;
    r) echo 15 ;;
    h) echo 4 ;;
    k) echo 40 ;;
    m) echo 46 ;;
    return|enter) echo 36 ;;
    *) echo "unsupported hotkey key: $1" >&2; return 2 ;;
  esac
}

hotkey_key="${hotkey##*[-+]}"
key_code="$(key_code_for "$hotkey_key")"
modifier_list=()
modifier_prefix="${hotkey%[-+]*}"
if [[ "$modifier_prefix" != "$hotkey" ]]; then
  IFS='-+' read -r -a modifier_parts <<<"$modifier_prefix"
  for modifier in "${modifier_parts[@]}"; do
    case "$modifier" in
      ctrl|control) modifier_list+=("control down") ;;
      option|alt) modifier_list+=("option down") ;;
      shift) modifier_list+=("shift down") ;;
      cmd|command) modifier_list+=("command down") ;;
      *) echo "unsupported hotkey modifier: $modifier" >&2; exit 2 ;;
    esac
  done
fi
modifier_part=""
if ((${#modifier_list[@]} > 0)); then
  joined=""
  for item in "${modifier_list[@]}"; do
    if [[ -n "$joined" ]]; then joined+=", "; fi
    joined+="$item"
  done
  modifier_part=" using {$joined}"
fi

now_ms() {
  node -e 'process.stdout.write(String(Date.now()))'
}

feedback_of() {
  node -e '
const input = process.argv[1] || "";
const match = input.match(/feedback=([^|]+)/);
process.stdout.write((match ? match[1] : "").replace(/\s+/g, " ").trim());
' "$1"
}

feedback_seq_of() {
  node -e '
const input = process.argv[1] || "";
const match = input.match(/feedback_seq=([0-9]+)/);
process.stdout.write(match ? match[1] : "");
' "$1"
}

hud_feedback_of() {
  node -e '
const input = process.argv[1] || "";
const match = input.match(/^present:[^:]+:(.*)$/s);
process.stdout.write((match ? match[1] : "").replace(/\s+/g, " ").trim());
' "$1"
}

feedback_changed() {
  local before="$1"
  local before_seq="$2"
  local after="$3"
  local after_seq="$4"
  if [[ -n "$after" && "$after" != "$before" ]]; then
    return 0
  fi
  if [[ -n "$before_seq" && -n "$after_seq" && "$after_seq" -gt "$before_seq" ]]; then
    return 0
  fi
  return 1
}

matches_expected() {
  local text="$1"
  if [[ -z "$expected_text" ]]; then
    [[ -n "$text" ]]
    return
  fi
  [[ "$text" == *"$expected_text"* ]]
}

read_status() {
  if [[ -n "$harness_status_path" && -s "$harness_status_path" ]]; then
    node -e '
const fs = require("fs");
const file = process.argv[1];
try {
  const payload = JSON.parse(fs.readFileSync(file, "utf8"));
  if (payload && payload.kind === "eventloopos.queue_harness_status" && typeof payload.status === "string") {
    process.stdout.write(payload.status);
    process.exit(0);
  }
} catch {}
process.exit(1);
' "$harness_status_path" 2>/dev/null && return 0
  fi
  osascript <<APPLESCRIPT
tell application "System Events"
  if not (exists process "$process_name") then error "process not found: $process_name"
  tell process "$process_name"
    repeat with candidateWindow in windows
      set allElements to entire contents of candidateWindow
      repeat with candidateElement in allElements
        try
          set candidateValue to value of candidateElement as string
          if candidateValue contains "eventloopOS harness status" then return candidateValue
        end try
        try
          set candidateName to name of candidateElement as string
          if candidateName contains "eventloopOS harness status" then return candidateName
        end try
      end repeat
    end repeat
  end tell
end tell
error "eventloopOS harness status not found"
APPLESCRIPT
}

read_status_retry() {
  local timeout_ms="$1"
  local start_ms current_ms output
  start_ms="$(now_ms)"
  while true; do
    if output="$(read_status 2>&1)"; then
      printf '%s' "$output"
      return 0
    fi
    current_ms="$(now_ms)"
    if ((current_ms - start_ms > timeout_ms)); then
      printf '%s' "$output"
      return 1
    fi
    sleep 0.1
  done
}

read_hud_feedback() {
  osascript - "$ax_process_names" "$expected_text" <<'APPLESCRIPT'
on run argv
  set processListText to item 1 of argv
  set expectedText to item 2 of argv
  set AppleScript's text item delimiters to ","
  set processNames to text items of processListText
  set AppleScript's text item delimiters to ""
  tell application "System Events"
    repeat with candidateProcessName in processNames
      set processNameText to my trimText(candidateProcessName as string)
      if processNameText is not "" and (exists process processNameText) then
        tell process processNameText
          repeat with candidateWindow in windows
            set windowName to ""
            try
              set windowName to name of candidateWindow as string
            end try
            if windowName is "eventloopOS Paper Reminder" then
              set allElements to entire contents of candidateWindow
              repeat with candidateElement in allElements
                set identifierText to ""
                set nameText to ""
                set valueText to ""
                try
                  set identifierText to (value of attribute "AXIdentifier" of candidateElement) as string
                end try
                try
                  set nameText to name of candidateElement as string
                end try
                try
                  set valueText to value of candidateElement as string
                end try
                set readableText to my firstNonEmpty({valueText, nameText})
                if identifierText is "paper-reminder-feedback" and readableText is not "" then
                  return "present:identifier:" & readableText
                end if
                if identifierText is "paper-reminder-hud" and (nameText contains "Feedback:" or valueText contains "Feedback:") then
                  return "present:hud:" & my firstNonEmpty({valueText, nameText})
                end if
                if expectedText is not "" and (nameText contains expectedText or valueText contains expectedText) then
                  return "present:expected:" & my firstNonEmpty({valueText, nameText})
                end if
              end repeat
              return "missing:feedback_element"
            end if
          end repeat
        end tell
      end if
    end repeat
  end tell
  return "missing:window"
end run

on firstNonEmpty(valuesToCheck)
  repeat with valueToCheck in valuesToCheck
    set candidate to my trimText(valueToCheck as string)
    if candidate is not "" then return candidate
  end repeat
  return ""
end firstNonEmpty

on trimText(sourceText)
  set sourceText to sourceText as string
  repeat while sourceText begins with space or sourceText begins with tab
    if length of sourceText is 1 then return ""
    set sourceText to text 2 thru -1 of sourceText
  end repeat
  repeat while sourceText ends with space or sourceText ends with tab
    if length of sourceText is 1 then return ""
    set sourceText to text 1 thru -2 of sourceText
  end repeat
  return sourceText
end trimText
APPLESCRIPT
}

press_hotkey() {
  osascript -e "tell application \"System Events\" to key code $key_code$modifier_part"
}

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/eventloopos-paper-reminder-feedback.XXXXXX")"
samples_tsv="$tmp_dir/samples.tsv"
started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
trap 'rm -rf "$tmp_dir"' EXIT

for ((run = 1; run <= runs; run += 1)); do
  ok=1
  latency=""
  before_feedback=""
  before_feedback_seq=""
  after_feedback=""
  after_feedback_seq=""
  hud_feedback=""
  error=""
  if before_status="$(read_status_retry 10000 2>&1)"; then
    before_feedback="$(feedback_of "$before_status")"
    before_feedback_seq="$(feedback_seq_of "$before_status")"
    start_ms="$(now_ms)"
    if press_error="$(press_hotkey 2>&1)"; then
      deadline_ms=$((start_ms + budget_ms * 3))
      status_ready=0
      hud_ready=0
      while true; do
        current_ms="$(now_ms)"
        if ((current_ms > deadline_ms)); then
          ok=0
          error="timed out waiting for paper reminder feedback"
          break
        fi
        if after_status="$(read_status 2>&1)"; then
          after_feedback="$(feedback_of "$after_status")"
          after_feedback_seq="$(feedback_seq_of "$after_status")"
          if feedback_changed "$before_feedback" "$before_feedback_seq" "$after_feedback" "$after_feedback_seq" && matches_expected "$after_feedback"; then
            status_ready=1
          fi
        fi
        if hud_output="$(read_hud_feedback 2>&1)"; then
          hud_feedback="$(hud_feedback_of "$hud_output")"
          if [[ "$hud_output" == present:* ]] && matches_expected "$hud_feedback"; then
            hud_ready=1
          fi
        fi
        if ((status_ready == 1 && hud_ready == 1)); then
          latency=$((current_ms - start_ms))
          break
        fi
        sleep 0.05
      done
    else
      ok=0
      error="$press_error"
    fi
  else
    ok=0
    error="$before_status"
  fi
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$run" "$ok" "$latency" "$before_feedback" "$before_feedback_seq" "$after_feedback" "$after_feedback_seq" "$hud_feedback" "$error" >>"$samples_tsv"
  sleep 0.5
done

finished_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
mkdir -p "$(dirname "$manifest")"
STARTED_AT="$started_at" FINISHED_AT="$finished_at" PROCESS_NAME="$process_name" AX_PROCESS_NAMES="$ax_process_names" HOTKEY="$hotkey" RUNS="$runs" BUDGET_MS="$budget_ms" EXPECTED_TEXT="$expected_text" SAMPLES_TSV="$samples_tsv" MANIFEST="$manifest" HARNESS_STATUS_PATH="$harness_status_path" node <<'NODE'
const fs = require("fs");
const rows = fs.readFileSync(process.env.SAMPLES_TSV, "utf8").trim().split(/\n/).filter(Boolean);
const samples = rows.map((row) => {
  const [run, ok, latency, before, beforeSeq, after, afterSeq, hud, error] = row.split("\t");
  const sample = {
    run: Number(run),
    ok: ok === "1",
    timings_ms: {},
    errors: [],
  };
  if (latency) sample.timings_ms.hotkey_to_paper_reminder_feedback = Number(latency);
  if (before) sample.before_feedback = before;
  if (beforeSeq) sample.before_feedback_seq = Number(beforeSeq);
  if (after) sample.after_feedback = after;
  if (afterSeq) sample.after_feedback_seq = Number(afterSeq);
  if (hud) sample.paper_reminder_feedback = hud;
  if (error) sample.errors.push(error);
  return sample;
});
const values = samples
  .map((sample) => sample.timings_ms.hotkey_to_paper_reminder_feedback)
  .filter((value) => typeof value === "number" && Number.isFinite(value))
  .sort((left, right) => left - right);
const percentile = (p) => values[Math.min(values.length - 1, Math.ceil(values.length * p) - 1)];
const summary = values.length > 0 ? {
  hotkey_to_paper_reminder_feedback: {
    count: values.length,
    min_ms: values[0],
    median_ms: percentile(0.5),
    p95_ms: percentile(0.95),
    max_ms: values[values.length - 1],
  },
} : {};
const p95 = summary.hotkey_to_paper_reminder_feedback?.p95_ms;
const budget = Number(process.env.BUDGET_MS);
const failedBudgets = typeof p95 === "number" && p95 > budget
  ? [{ name: "hotkey_to_paper_reminder_feedback", p95_ms: p95, budget_ms: budget }]
  : [];
const manifest = {
  ok: samples.every((sample) => sample.ok) && failedBudgets.length === 0,
  kind: "eventloopos.macos_paper_reminder_feedback_proof",
  measurement: "direct_shell_osascript_ax_hud_observed",
  started_at: process.env.STARTED_AT,
  finished_at: process.env.FINISHED_AT,
  process_name: process.env.PROCESS_NAME,
  ax_process_names: process.env.AX_PROCESS_NAMES,
  hotkey: process.env.HOTKEY,
  expected_text: process.env.EXPECTED_TEXT || undefined,
  harness_status_path: process.env.HARNESS_STATUS_PATH || undefined,
  runs: Number(process.env.RUNS),
  budgets_ms: { hotkey_to_paper_reminder_feedback: budget },
  failed_budgets: failedBudgets,
  summary,
  samples,
};
fs.writeFileSync(process.env.MANIFEST, `${JSON.stringify(manifest, null, 2)}\n`);
console.log(`macOS paper reminder feedback manifest: ${process.env.MANIFEST}`);
console.log(JSON.stringify({
  ok: manifest.ok,
  runs: manifest.runs,
  failed_budgets: manifest.failed_budgets,
  summary: manifest.summary,
}, null, 2));
process.exit(manifest.ok ? 0 : 1);
NODE
