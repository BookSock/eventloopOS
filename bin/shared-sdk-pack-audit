#!/usr/bin/env node
import assert from "node:assert/strict";
import { execFileSync } from "node:child_process";
import { mkdirSync, mkdtempSync, readFileSync, rmSync, symlinkSync, writeFileSync } from "node:fs";
import os from "node:os";
import path from "node:path";

const repoRoot = path.resolve(import.meta.dirname, "..");
const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: node bin/shared-sdk-pack-audit [--self-test]

Runs an npm package audit for app/shared. The audit verifies that the
@eventloopos/shared SDK package exports only runtime package artifacts and that
main/types/exports point at files included in the package tarball. It also
imports the packed artifact through Node package resolution.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  console.log("shared-sdk-pack-audit self-test passed");
  process.exit(0);
}

const packageJson = readJson(path.join(repoRoot, "app/shared/package.json"));
const packed = packSharedSdkPackage();
const result = auditSharedSdkPackage({ packageJson, packJson: packed.packJson });
if (result.ok) {
  result.import_smoke = runPackedImportSmoke(packed.filename);
  result.ok = result.import_smoke.ok === true;
  if (!result.import_smoke.ok) result.errors.push(...result.import_smoke.errors);
}
rmSync(packed.root, { recursive: true, force: true });
if (!result.ok) {
  console.error(`shared SDK package audit failed:\n- ${result.errors.join("\n- ")}`);
  process.exit(1);
}
console.log(JSON.stringify(result, null, 2));

function auditSharedSdkPackage({ packageJson, packJson }) {
  const files = new Set((packJson.files ?? []).map((file) => file?.path).filter((value) => typeof value === "string"));
  const errors = [];

  if (packageJson.name !== "@eventloopos/shared") errors.push(`unexpected package name: ${packageJson.name}`);
  if (packageJson.type !== "module") errors.push("package must remain ESM (`type: module`)");
  if (!Array.isArray(packageJson.files) || packageJson.files.join(",") !== "dist,README.md") {
    errors.push('package files whitelist must be exactly ["dist", "README.md"]');
  }

  for (const required of ["package.json", "README.md", "dist/index.js", "dist/index.d.ts", "dist/primitives.js", "dist/primitives.d.ts", "dist/schemas.js", "dist/schemas.d.ts", "dist/json-schema.js", "dist/json-schema.d.ts"]) {
    if (!files.has(required)) errors.push(`missing package file: ${required}`);
  }

  for (const forbidden of Array.from(files).filter((file) => /^(src|test)\//.test(file) || /^(tsconfig|vitest)\./.test(file))) {
    errors.push(`package includes non-runtime file: ${forbidden}`);
  }

  for (const exported of exportedPackageFiles(packageJson)) {
    if (!files.has(exported)) errors.push(`export points to file missing from package: ${exported}`);
  }

  return {
    ok: errors.length === 0,
    package_name: packageJson.name,
    file_count: files.size,
    files: Array.from(files).sort(),
    errors,
  };
}

function packSharedSdkPackage() {
  const root = mkdtempSync(path.join(os.tmpdir(), "eventloopos-shared-sdk-pack-"));
  const packJson = JSON.parse(execFileSync("pnpm", ["--dir", "app/shared", "pack", "--pack-destination", root, "--json"], {
    cwd: repoRoot,
    encoding: "utf8",
  }));
  return { root, packJson, filename: packJson.filename };
}

function runPackedImportSmoke(tarballPath) {
  const root = mkdtempSync(path.join(os.tmpdir(), "eventloopos-shared-sdk-import-"));
  try {
    const extractDir = path.join(root, "extract");
    const consumerDir = path.join(root, "consumer");
    const packageDir = path.join(extractDir, "package");
    const consumerModules = path.join(consumerDir, "node_modules");
    mkdirSync(extractDir, { recursive: true });
    mkdirSync(path.join(consumerModules, "@eventloopos"), { recursive: true });
    execFileSync("tar", ["-xzf", tarballPath, "-C", extractDir], { cwd: repoRoot });
    symlinkSync(packageDir, path.join(consumerModules, "@eventloopos", "shared"), "dir");
    symlinkDependency(packageDir, "zod");
    symlinkDependency(packageDir, "zod-to-json-schema");

    const smokePath = path.join(consumerDir, "smoke.mjs");
    writeFileSync(smokePath, `\
import assert from "node:assert/strict";
import { EventSchema } from "@eventloopos/shared";
import { ContractJsonSchemas } from "@eventloopos/shared/json-schema";
import {
  PrimitiveCatalogSchema,
  buildPrimitiveOperationRequest,
  createPrimitiveOperationHttpClient,
  getPrimitiveOperation,
  listPrimitiveOperations,
  primitiveRouteSideEffect,
  summarizePrimitiveCatalog
} from "@eventloopos/shared/primitives";

assert.equal(EventSchema.parse({
  id: "evt_pack_smoke",
  source: "manual",
  source_id: "pack-smoke",
  idempotency_key: "pack-smoke",
  occurred_at: "2026-06-05T00:00:00Z",
  received_at: "2026-06-05T00:00:01Z",
  actor: { id: "agent", type: "agent" },
  type: "pack.smoke",
  title: "Pack smoke",
  summary: "Import smoke",
  raw_ref: { id: "raw_pack_smoke", uri: "artifact://raw/pack-smoke.json" },
  links: [],
  resources: []
}).id, "evt_pack_smoke");
assert.ok(ContractJsonSchemas.Event);
const catalog = PrimitiveCatalogSchema.parse({
  schema_version: 1,
  schemas: {},
  primitives: [{
    id: "pack_smoke",
    title: "Pack Smoke",
    status: "stable_enough",
    summary: "Packed import smoke",
    code: ["dist/index.js"],
    proofs: ["bin/shared-sdk-pack-audit"],
    self_tests: ["pnpm --filter @eventloopos/shared pack:audit"],
    http: [{
      method: "GET",
      path: "/health",
      route_file: "dist/index.js",
      no_request_body: true,
      response_schema: "HealthResponse"
    }]
  }]
});
assert.equal(summarizePrimitiveCatalog(catalog).primitiveCount, 1);
assert.equal(listPrimitiveOperations(catalog).map((operation) => operation.operation).join(","), "pack_smoke_get_health");
assert.equal(listPrimitiveOperations(catalog)[0].sideEffect, "none");
assert.equal(primitiveRouteSideEffect(listPrimitiveOperations(catalog)[0].route), "none");
assert.equal(getPrimitiveOperation(catalog, "pack_smoke_get_health")?.route.path, "/health");
assert.equal(buildPrimitiveOperationRequest({
  catalog,
  operation: "pack_smoke_get_health",
  baseUrl: "http://127.0.0.1:4377"
}).url, "http://127.0.0.1:4377/health");
const operationClient = createPrimitiveOperationHttpClient({
  catalog,
  baseUrl: "http://127.0.0.1:4377",
  fetch: async (url, init) => {
    assert.equal(String(url), "http://127.0.0.1:4377/health");
    assert.equal(init?.method, "GET");
    return new Response(JSON.stringify({
      ok: true,
      service: "eventloop-orchestrator",
      time: "2026-05-10T12:00:00.000Z",
      request_id: "req_health"
    }), { status: 200 });
  }
});
assert.equal((await operationClient.requestOperation("pack_smoke_get_health")).ok, true);
`, "utf8");
    execFileSync(process.execPath, [smokePath], {
      cwd: consumerDir,
      encoding: "utf8",
    });
    return {
      ok: true,
      entrypoints: ["@eventloopos/shared", "@eventloopos/shared/json-schema", "@eventloopos/shared/primitives"],
    };
  } catch (error) {
    return {
      ok: false,
      errors: [error instanceof Error ? error.message : String(error)],
    };
  } finally {
    rmSync(root, { recursive: true, force: true });
  }
}

function symlinkDependency(packageDir, dependencyName) {
  const source = path.join(repoRoot, "app/shared/node_modules", dependencyName);
  const target = path.join(packageDir, "node_modules", dependencyName);
  mkdirSync(path.dirname(target), { recursive: true });
  symlinkSync(source, target, "dir");
}

function exportedPackageFiles(packageJson) {
  const files = new Set();
  addExportFile(files, packageJson.main);
  addExportFile(files, packageJson.types);
  collectExportFiles(files, packageJson.exports);
  return Array.from(files).sort();
}

function collectExportFiles(files, value) {
  if (typeof value === "string") {
    addExportFile(files, value);
    return;
  }
  if (!value || typeof value !== "object" || Array.isArray(value)) return;
  for (const nested of Object.values(value)) collectExportFiles(files, nested);
}

function addExportFile(files, value) {
  if (typeof value !== "string" || !value.trim()) return;
  files.add(value.replace(/^\.\//, ""));
}

function readJson(filePath) {
  return JSON.parse(readFileSync(filePath, "utf8"));
}

function runSelfTest() {
  const packageJson = {
    name: "@eventloopos/shared",
    type: "module",
    files: ["dist", "README.md"],
    main: "./dist/index.js",
    types: "./dist/index.d.ts",
    exports: {
      ".": { import: "./dist/index.js", types: "./dist/index.d.ts" },
      "./primitives": { import: "./dist/primitives.js", types: "./dist/primitives.d.ts" },
    },
  };
  const packJson = {
    files: [
      { path: "package.json" },
      { path: "README.md" },
      { path: "dist/index.js" },
      { path: "dist/index.d.ts" },
      { path: "dist/primitives.js" },
      { path: "dist/primitives.d.ts" },
      { path: "dist/schemas.js" },
      { path: "dist/schemas.d.ts" },
      { path: "dist/json-schema.js" },
      { path: "dist/json-schema.d.ts" },
    ],
  };
  assert.equal(auditSharedSdkPackage({ packageJson, packJson }).ok, true);

  const badSource = auditSharedSdkPackage({
    packageJson,
    packJson: { files: [...packJson.files, { path: "src/index.ts" }] },
  });
  assert.equal(badSource.ok, false);
  assert.match(badSource.errors.join("\n"), /non-runtime file/);

  const badExport = auditSharedSdkPackage({
    packageJson: {
      ...packageJson,
      exports: { ...packageJson.exports, "./missing": { import: "./dist/missing.js" } },
    },
    packJson,
  });
  assert.equal(badExport.ok, false);
  assert.match(badExport.errors.join("\n"), /export points to file missing/);
}
