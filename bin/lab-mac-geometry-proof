#!/usr/bin/env node
import { execFileSync } from "node:child_process";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";

if (process.argv.includes("--self-test")) {
  await runSelfTest();
  process.exit(0);
}

const orchestratorUrl = process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? "http://127.0.0.1:4480";
const stamp = new Date().toISOString().replace(/[-:.]/g, "").slice(0, 15);
const title = process.env.EVENTLOOPOS_GEOMETRY_PROOF_TITLE ?? `eventloopOS Geometry Shared Window Proof ${stamp}.txt`;
const run = path.join(
  "artifacts",
  "lab-runs",
  `${stamp}-geometry-proof`,
);
fs.mkdirSync(run, { recursive: true });

const proofFile = path.join(os.homedir(), "Desktop", title);
fs.writeFileSync(
  proofFile,
  "eventloopOS geometry proof window\nSame real TextEdit window restores to two paper positions.\n",
);
execFileSync("open", ["-a", "TextEdit", proofFile]);
await sleep(1_500);

let initial = await capture();
let target = findTarget(initial);
if (!target) throw new Error("target TextEdit window not captured");
try {
  execFileSync("aerospace", ["layout", "--window-id", String(target.id), "floating"]);
} catch {
  // The eventloopOS AeroSpace fork can report already-floating windows as
  // non-tiling. Restore still proves floating geometry below.
}

const baseWindow = {
  id: target.id,
  app: target.app,
  appBundleId: target.appBundleId,
  title: target.title,
  monitorId: target.monitorId,
  layout: "floating",
};
const paperAFrame = { x: 60, y: 80, width: 560, height: 360 };
const paperBFrame = { x: 900, y: 140, width: 680, height: 520 };
const paperA = {
  backend: "aerospace",
  activeWorkspace: "eventloop-proof-a",
  focusedWindowId: target.id,
  windows: [{ ...baseWindow, workspace: "eventloop-proof-a", frame: paperAFrame }],
};
const paperB = {
  backend: "aerospace",
  activeWorkspace: "eventloop-proof-b",
  focusedWindowId: target.id,
  windows: [{ ...baseWindow, workspace: "eventloop-proof-b", frame: paperBFrame }],
};

const receiptA = await restore(paperA);
const afterA = findTarget(await capture());
assertWindow(afterA, "eventloop-proof-a", paperAFrame, "paperA");

const receiptB = await restore(paperB);
const afterB = findTarget(await capture());
assertWindow(afterB, "eventloop-proof-b", paperBFrame, "paperB");

const receiptA2 = await restore(paperA);
const afterA2 = findTarget(await capture());
assertWindow(afterA2, "eventloop-proof-a", paperAFrame, "paperA2");

const manifest = {
  ok: true,
  run,
  target_id: target.id,
  title,
  paperAFrame,
  paperBFrame,
  afterA,
  afterB,
  afterA2,
  receiptA,
  receiptB,
  receiptA2,
};
fs.writeFileSync(path.join(run, "manifest.json"), JSON.stringify(manifest, null, 2));
console.log(JSON.stringify({ ok: true, run, target_id: target.id, paperA: afterA2.frame, paperB: afterB.frame }, null, 2));

async function capture() {
  const response = await fetch(`${orchestratorUrl}/workspace/capture`, {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: "{}",
  });
  if (!response.ok) throw new Error(`capture HTTP ${response.status}: ${await response.text()}`);
  return (await response.json()).snapshot;
}

async function restore(snapshot) {
  const current = await capture();
  const response = await fetch(`${orchestratorUrl}/workspace/restore`, {
    method: "POST",
    headers: {
      "content-type": "application/json",
      "idempotency-key": `geometry-${snapshot.activeWorkspace}-${Date.now()}`,
    },
    body: JSON.stringify({ confirm_execute: true, snapshot, current_windows: current.windows }),
  });
  const body = await response.json();
  if (!response.ok) throw new Error(`restore HTTP ${response.status}: ${JSON.stringify(body)}`);
  await sleep(1_400);
  return body;
}

function findTarget(snapshot) {
  return snapshot.windows.find((window) => window.app === "TextEdit" && window.title === title);
}

function assertWindow(window, workspace, frame, label) {
  if (!window) throw new Error(`${label}: target window missing`);
  if (window.workspace !== workspace) throw new Error(`${label}: expected workspace ${workspace}, got ${window.workspace}`);
  assertNear(window.frame, frame, label);
}

function assertNear(actual, expected, label) {
  for (const key of ["x", "y", "width", "height"]) {
    if (Math.abs((actual?.[key] ?? -999_999) - expected[key]) > 6) {
      throw new Error(`${label} frame ${key}: expected ${expected[key]}, got ${actual?.[key]}`);
    }
  }
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function runSelfTest() {
  const fake = makeFakeGeometryHarness();
  const target = {
    id: 42,
    app: "TextEdit",
    appBundleId: "com.apple.TextEdit",
    title: "eventloopOS Geometry Shared Window Proof self-test.txt",
    monitorId: 1,
    layout: "floating",
  };
  const paperAFrame = { x: 60, y: 80, width: 560, height: 360 };
  const paperBFrame = { x: 900, y: 140, width: 680, height: 520 };
  fake.setWindow({ ...target, workspace: "eventloop-proof-start", frame: { x: 12, y: 24, width: 400, height: 300 } });

  const paperA = {
    backend: "aerospace",
    activeWorkspace: "eventloop-proof-a",
    focusedWindowId: target.id,
    windows: [{ ...target, workspace: "eventloop-proof-a", frame: paperAFrame }],
  };
  const paperB = {
    backend: "aerospace",
    activeWorkspace: "eventloop-proof-b",
    focusedWindowId: target.id,
    windows: [{ ...target, workspace: "eventloop-proof-b", frame: paperBFrame }],
  };

  await fake.restore(paperA);
  assertSelfTestWindow(fake.capture().windows[0], "eventloop-proof-a", paperAFrame, "paperA");
  await fake.restore(paperB);
  assertSelfTestWindow(fake.capture().windows[0], "eventloop-proof-b", paperBFrame, "paperB");
  await fake.restore(paperA);
  assertSelfTestWindow(fake.capture().windows[0], "eventloop-proof-a", paperAFrame, "paperA2");

  const manifest = fake.manifest({ paperAFrame, paperBFrame });
  if (manifest.restore_count !== 3) throw new Error(`expected 3 restore calls, got ${manifest.restore_count}`);
  if (!manifest.shared_window_id || manifest.shared_window_id !== target.id) {
    throw new Error(`shared window id missing: ${JSON.stringify(manifest)}`);
  }
  if (manifest.workspace_sequence.join(",") !== "eventloop-proof-a,eventloop-proof-b,eventloop-proof-a") {
    throw new Error(`workspace sequence mismatch: ${JSON.stringify(manifest.workspace_sequence)}`);
  }
  console.log("lab-mac-geometry-proof self-test passed");
}

function makeFakeGeometryHarness() {
  let currentWindow;
  const restores = [];
  return {
    setWindow(window) {
      currentWindow = JSON.parse(JSON.stringify(window));
    },
    capture() {
      return {
        backend: "aerospace",
        activeWorkspace: currentWindow.workspace,
        focusedWindowId: currentWindow.id,
        windows: [JSON.parse(JSON.stringify(currentWindow))],
      };
    },
    async restore(snapshot) {
      const window = snapshot.windows[0];
      if (!window || window.id !== currentWindow.id) throw new Error(`restore target mismatch: ${JSON.stringify(snapshot)}`);
      currentWindow = JSON.parse(JSON.stringify(window));
      restores.push({
        activeWorkspace: snapshot.activeWorkspace,
        frame: window.frame,
        windowId: window.id,
      });
      return { ok: true, plan: { commands: [] }, receipt: { commands: [] } };
    },
    manifest(extra) {
      return {
        ok: true,
        kind: "eventloopos.geometry_proof_self_test",
        shared_window_id: currentWindow.id,
        restore_count: restores.length,
        workspace_sequence: restores.map((restore) => restore.activeWorkspace),
        frame_sequence: restores.map((restore) => restore.frame),
        ...extra,
      };
    },
  };
}

function assertSelfTestWindow(window, workspace, frame, label) {
  if (!window) throw new Error(`${label}: missing window`);
  if (window.workspace !== workspace) throw new Error(`${label}: expected workspace ${workspace}, got ${window.workspace}`);
  for (const key of ["x", "y", "width", "height"]) {
    if (window.frame?.[key] !== frame[key]) {
      throw new Error(`${label}: expected frame ${key} ${frame[key]}, got ${window.frame?.[key]}`);
    }
  }
}
