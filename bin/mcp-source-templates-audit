#!/usr/bin/env node
import assert from "node:assert/strict";
import { existsSync, mkdtempSync, readdirSync, rmSync, writeFileSync } from "node:fs";
import { readFile } from "node:fs/promises";
import os from "node:os";
import path from "node:path";
import process from "node:process";

const repoRoot = path.resolve(import.meta.dirname, "..");
const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/mcp-source-templates-audit [--self-test] [root]

Audits config/mcp-sources*.example.json files so source-hook templates stay
read-only, bounded, deduped, and usable without leaking local/private config.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  await runSelfTest();
  console.log("mcp-source-templates-audit self-test passed");
  process.exit(0);
}

const root = path.resolve(args.find((arg) => !arg.startsWith("-")) ?? repoRoot);
const result = await auditMcpSourceTemplates(root);
if (!result.ok) {
  for (const error of result.errors) console.error(error);
  process.exit(1);
}

console.log(`mcp source templates audit passed: ${result.checked_count} files, ${result.source_count} sources`);

export async function auditMcpSourceTemplates(root) {
  const errors = [];
  const configDir = path.join(root, "config");
  let names;
  try {
    names = readdirSync(configDir)
      .filter((name) => /^mcp-sources.*\.example\.json$/.test(name))
      .sort();
  } catch (error) {
    return { ok: false, checked_count: 0, source_count: 0, errors: [`config read failed: ${formatError(error)}`] };
  }

  if (names.length === 0) {
    errors.push("no config/mcp-sources*.example.json templates found");
    return { ok: false, checked_count: 0, source_count: 0, errors };
  }

  let sourceCount = 0;
  for (const name of names) {
    const filePath = path.join(configDir, name);
    let parsed;
    try {
      parsed = JSON.parse(await readFile(filePath, "utf8"));
    } catch (error) {
      errors.push(`${name}: JSON parse failed: ${formatError(error)}`);
      continue;
    }
    sourceCount += auditTemplateFile(root, name, parsed, errors);
  }

  return { ok: errors.length === 0, checked_count: names.length, source_count: sourceCount, errors };
}

function auditTemplateFile(root, fileName, parsed, errors) {
  if (!isRecord(parsed)) {
    errors.push(`${fileName}: root must be an object`);
    return 0;
  }
  if (!Array.isArray(parsed.sources) || parsed.sources.length === 0) {
    errors.push(`${fileName}: sources must be a non-empty array`);
    return 0;
  }

  const ids = new Set();
  for (const [index, source] of parsed.sources.entries()) {
    const prefix = `${fileName}: sources[${index}]`;
    auditSource(root, prefix, source, errors);
    if (isRecord(source) && typeof source.id === "string") {
      if (ids.has(source.id)) errors.push(`${prefix}.id duplicate in template: ${source.id}`);
      ids.add(source.id);
    }
  }
  return parsed.sources.length;
}

function auditSource(root, prefix, source, errors) {
  if (!isRecord(source)) {
    errors.push(`${prefix} must be an object`);
    return;
  }
  const id = readString(source, "id", `${prefix}.id`, errors);
  const server = readRecord(source, "server", `${prefix}.server`, errors);
  const poll = readRecord(source, "poll", `${prefix}.poll`, errors);
  const cursor = readRecord(source, "cursor", `${prefix}.cursor`, errors);
  const riskPolicy = readRecord(source, "riskPolicy", `${prefix}.riskPolicy`, errors);
  readEnum(source, "eventMapper", ["slack_message_to_event", "github_update_to_event", "generic_item_to_event"], `${prefix}.eventMapper`, errors);

  if (server) auditServer(prefix, server, id, errors);
  if (poll) auditPoll(root, prefix, poll, errors);
  if (cursor) auditCursor(prefix, cursor, errors);
  if (riskPolicy) auditRiskPolicy(prefix, riskPolicy, errors);
}

function auditServer(prefix, server, id, errors) {
  readString(server, "name", `${prefix}.server.name`, errors);
  readString(server, "command", `${prefix}.server.command`, errors);
  readStringArray(server, "args", `${prefix}.server.args`, errors);
  const envAllowlist = readStringArray(server, "envAllowlist", `${prefix}.server.envAllowlist`, errors);
  const stderrLogPath = readString(server, "stderrLogPath", `${prefix}.server.stderrLogPath`, errors);

  if (stderrLogPath && !/^var\/log\/mcp\/[a-z0-9_.-]+\.stderr\.log$/.test(stderrLogPath)) {
    errors.push(`${prefix}.server.stderrLogPath must stay under var/log/mcp/*.stderr.log`);
  }
  if (stderrLogPath && id && !stderrLogPath.includes(id)) {
    errors.push(`${prefix}.server.stderrLogPath should include source id ${id}`);
  }

  const seenEnv = new Set();
  for (const item of envAllowlist) {
    if (!/^[A-Z_][A-Z0-9_]*$/.test(item)) {
      errors.push(`${prefix}.server.envAllowlist entry ${item} must be an environment variable name`);
    }
    if (item.includes("=")) {
      errors.push(`${prefix}.server.envAllowlist entry ${item} must not contain an assignment or secret value`);
    }
    if (seenEnv.has(item)) {
      errors.push(`${prefix}.server.envAllowlist entry ${item} must be unique`);
    }
    seenEnv.add(item);
  }
}

function auditPoll(root, prefix, poll, errors) {
  readString(poll, "tool", `${prefix}.poll.tool`, errors);
  const pollArgs = poll.args === undefined ? undefined : readRecord(poll, "args", `${prefix}.poll.args`, errors);
  const timeoutMs = readPositiveInteger(poll, "timeoutMs", `${prefix}.poll.timeoutMs`, errors);
  if (timeoutMs !== undefined && timeoutMs > 30_000) {
    errors.push(`${prefix}.poll.timeoutMs must be <= 30000`);
  }

  if (pollArgs && Array.isArray(pollArgs.script_args)) {
    for (const scriptArg of pollArgs.script_args) {
      if (typeof scriptArg === "string" && scriptArg.startsWith("../../scripts/")) {
        const scriptPath = path.resolve(root, "app/orchestrator", scriptArg);
        if (!existsSync(scriptPath)) {
          errors.push(`${prefix}.poll.args.script_args missing repo script: ${scriptArg}`);
        }
      }
    }
  }
}

function auditCursor(prefix, cursor, errors) {
  const strategy = readEnum(cursor, "strategy", ["field", "hash"], `${prefix}.cursor.strategy`, errors);
  if (strategy === "field") readString(cursor, "field", `${prefix}.cursor.field`, errors);
  const dedupeWindow = readPositiveInteger(cursor, "dedupeWindow", `${prefix}.cursor.dedupeWindow`, errors);
  if (dedupeWindow !== undefined && dedupeWindow > 10_000) {
    errors.push(`${prefix}.cursor.dedupeWindow must be <= 10000`);
  }
  if (cursor.initial !== undefined && typeof cursor.initial !== "string") {
    errors.push(`${prefix}.cursor.initial must be a string when set`);
  }
}

function auditRiskPolicy(prefix, riskPolicy, errors) {
  if (riskPolicy.readOnly !== true) errors.push(`${prefix}.riskPolicy.readOnly must be true`);
  if (riskPolicy.allowWriteTools !== false) errors.push(`${prefix}.riskPolicy.allowWriteTools must be false`);
  if (riskPolicy.maxRiskLevel !== "low") errors.push(`${prefix}.riskPolicy.maxRiskLevel must be low`);
  const fields = readStringArray(riskPolicy, "untrustedTextFields", `${prefix}.riskPolicy.untrustedTextFields`, errors);
  if (fields.length === 0) {
    errors.push(`${prefix}.riskPolicy.untrustedTextFields must list untrusted text fields`);
  }
}

function readRecord(input, key, label, errors) {
  const value = input[key];
  if (!isRecord(value)) {
    errors.push(`${label} must be an object`);
    return undefined;
  }
  return value;
}

function readString(input, key, label, errors) {
  const value = input[key];
  if (typeof value !== "string" || !value.trim()) {
    errors.push(`${label} must be a non-empty string`);
    return "";
  }
  return value;
}

function readStringArray(input, key, label, errors) {
  const value = input[key];
  if (!Array.isArray(value) || value.some((item) => typeof item !== "string" || !item.trim())) {
    errors.push(`${label} must be an array of non-empty strings`);
    return [];
  }
  return value;
}

function readEnum(input, key, allowed, label, errors) {
  const value = input[key];
  if (typeof value !== "string" || !allowed.includes(value)) {
    errors.push(`${label} must be one of ${allowed.join(", ")}`);
    return "";
  }
  return value;
}

function readPositiveInteger(input, key, label, errors) {
  const value = input[key];
  if (typeof value !== "number" || !Number.isInteger(value) || value <= 0) {
    errors.push(`${label} must be a positive integer`);
    return undefined;
  }
  return value;
}

function isRecord(value) {
  return typeof value === "object" && value !== null && !Array.isArray(value);
}

function formatError(error) {
  return error instanceof Error ? error.message : String(error);
}

async function runSelfTest() {
  const tmp = mkdtempSync(path.join(os.tmpdir(), "eventloopos-mcp-source-templates-audit-"));
  try {
    const configDir = path.join(tmp, "config");
    const scriptsDir = path.join(tmp, "scripts");
    await mkdirp(configDir);
    await mkdirp(scriptsDir);
    writeFileSync(path.join(scriptsDir, "poll-demo.mjs"), "console.log('[]');\n");
    writeFileSync(
      path.join(configDir, "mcp-sources.demo.example.json"),
      `${JSON.stringify(
        {
          sources: [
            {
              id: "demo_source",
              server: {
                name: "eventloopos-script-events",
                command: "node",
                args: ["dist/src/mcp_sources/script_events_server.js"],
                envAllowlist: ["PATH", "HOME"],
                stderrLogPath: "var/log/mcp/demo_source.stderr.log"
              },
              poll: {
                tool: "poll_script",
                args: { script_args: ["../../scripts/poll-demo.mjs"] },
                timeoutMs: 5000
              },
              cursor: { strategy: "hash", dedupeWindow: 1000 },
              eventMapper: "generic_item_to_event",
              riskPolicy: {
                readOnly: true,
                allowWriteTools: false,
                maxRiskLevel: "low",
                untrustedTextFields: ["title", "summary", "text"]
              }
            }
          ]
        },
        null,
        2
      )}\n`
    );

    const pass = await auditMcpSourceTemplates(tmp);
    assert.equal(pass.ok, true, pass.errors.join("\n"));

    writeFileSync(
      path.join(configDir, "mcp-sources.bad.example.json"),
      `${JSON.stringify(
        {
          sources: [
            {
              id: "bad_source",
              server: {
                name: "bad",
                command: "node",
                args: [],
                envAllowlist: ["TOKEN=secret"],
                stderrLogPath: "/tmp/bad.log"
              },
              poll: { tool: "poll_script", args: { script_args: ["../../scripts/missing.mjs"] }, timeoutMs: 60000 },
              cursor: { strategy: "field", dedupeWindow: 20000 },
              eventMapper: "generic_item_to_event",
              riskPolicy: { readOnly: false, allowWriteTools: true, maxRiskLevel: "high", untrustedTextFields: [] }
            }
          ]
        },
        null,
        2
      )}\n`
    );
    const fail = await auditMcpSourceTemplates(tmp);
    assert.equal(fail.ok, false);
    assert.ok(fail.errors.some((error) => error.includes("envAllowlist entry TOKEN=secret")));
    assert.ok(fail.errors.some((error) => error.includes("stderrLogPath must stay under")));
    assert.ok(fail.errors.some((error) => error.includes("poll.timeoutMs must be <= 30000")));
    assert.ok(fail.errors.some((error) => error.includes("missing repo script")));
    assert.ok(fail.errors.some((error) => error.includes("riskPolicy.readOnly must be true")));
  } finally {
    rmSync(tmp, { recursive: true, force: true });
  }
}

async function mkdirp(dir) {
  const { mkdir } = await import("node:fs/promises");
  await mkdir(dir, { recursive: true });
}
