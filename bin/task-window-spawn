#!/usr/bin/env node
import http from "node:http";
import { execFile, spawn } from "node:child_process";
import { promisify } from "node:util";

const execFileAsync = promisify(execFile);

const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  printUsage();
  process.exit(0);
}

if (args.includes("--self-test")) {
  await runSelfTest();
  process.exit(0);
}

try {
  const options = parseArgs(args);
  const result = await runTaskWindowSpawn(options);
  console.log(JSON.stringify(result, null, 2));
  process.exit(result.command.exit_code ?? (result.ok ? 0 : 1));
} catch (error) {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(2);
}

function printUsage() {
  console.log(`Usage: bin/task-window-spawn --task-id TASK_ID [options] -- COMMAND [ARGS...]

Runs COMMAND, immediately claims COMMAND's process root for TASK_ID, captures
workspace before/after, and claims any newly-created windows for TASK_ID via
/task-window-claims.

Options:
  --url URL             Orchestrator URL. Default EVENTLOOPOS_ORCHESTRATOR_URL or http://127.0.0.1:4377
  --task-id ID          Required task id, e.g. task_checkout
  --settle-ms MS        Wait after command exits before after-capture. Default 1500
  --wait-ms MS          Poll for matching new windows after settle. Default 5000
  --poll-ms MS          Workspace capture poll interval during wait. Default 100
  --request-timeout-ms MS  HTTP request timeout. Default 5000
  --ttl-ms MS           Claim TTL. Default 1800000
  --source NAME         Claim source. Default task-window-spawn
  --app CONTAINS        Optional app/app_bundle substring filter for new windows
  --title CONTAINS      Optional title substring filter for new windows
  --claim-existing-matching
                         Also claim/move already-open windows matching --app/--title.
                         Requires --app or --title.
`);
}

function parseArgs(argv) {
  const passthroughIndex = argv.indexOf("--");
  if (passthroughIndex < 0) throw new Error("missing -- before command");
  const optionArgs = argv.slice(0, passthroughIndex);
  const commandArgs = argv.slice(passthroughIndex + 1);
  if (commandArgs.length === 0) throw new Error("missing command after --");

  const options = {
    baseUrl: process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? "http://127.0.0.1:4377",
    taskId: undefined,
    settleMs: 1_500,
    waitMs: 5_000,
    pollMs: 100,
    requestTimeoutMs: 5_000,
    ttlMs: 30 * 60 * 1_000,
    source: "task-window-spawn",
    appContains: undefined,
    titleContains: undefined,
    claimExistingMatching: false,
    command: commandArgs[0],
    args: commandArgs.slice(1),
  };

  for (let index = 0; index < optionArgs.length; index += 1) {
    const arg = optionArgs[index];
    switch (arg) {
      case "--url":
        options.baseUrl = readValue(optionArgs, ++index, arg);
        break;
      case "--task-id":
        options.taskId = readValue(optionArgs, ++index, arg);
        break;
      case "--settle-ms":
        options.settleMs = readNonNegativeInteger(readValue(optionArgs, ++index, arg), arg);
        break;
      case "--wait-ms":
        options.waitMs = readNonNegativeInteger(readValue(optionArgs, ++index, arg), arg);
        break;
      case "--poll-ms":
        options.pollMs = readPositiveInteger(readValue(optionArgs, ++index, arg), arg);
        break;
      case "--request-timeout-ms":
        options.requestTimeoutMs = readPositiveInteger(readValue(optionArgs, ++index, arg), arg);
        break;
      case "--ttl-ms":
        options.ttlMs = readPositiveInteger(readValue(optionArgs, ++index, arg), arg);
        break;
      case "--source":
        options.source = readValue(optionArgs, ++index, arg);
        break;
      case "--app":
        options.appContains = readValue(optionArgs, ++index, arg).toLowerCase();
        break;
      case "--title":
        options.titleContains = readValue(optionArgs, ++index, arg).toLowerCase();
        break;
      case "--claim-existing-matching":
        options.claimExistingMatching = true;
        break;
      default:
        throw new Error(`unknown option: ${arg}`);
    }
  }

  if (!options.taskId) throw new Error("--task-id is required");
  validateOptions(options);
  return options;
}

async function runTaskWindowSpawn(options) {
  validateOptions(options);
  const before = await captureWorkspace(options);
  const waitStartedAt = Date.now();
  const rootClaims = [];
  const errors = [];
  const taskWorkspace = await readTaskWorkspace(options, options.taskId).catch(() => undefined);
  const focusWorkspace = before.snapshot?.activeWorkspace;
  const preexisting = await claimExistingMatchingWindows({
    options,
    beforeWindows: before.snapshot?.windows ?? [],
    taskWorkspace,
    focusWorkspace,
    errors,
  });
  let commandDoneAt;
  const commandPromise = runCommand(options.command, options.args, async (child) => {
    if (!isPositiveInteger(child.pid)) return;
    try {
      const claim = await claimWindow(options, {
        task_id: options.taskId,
        process_root_pid: child.pid,
        source: `${options.source}:process_root`,
        ttl_ms: options.ttlMs,
      });
      rootClaims.push({
        process_root_pid: child.pid,
        claim_id: claim.claim?.claim_id,
      });
    } catch (error) {
      errors.push({
        process_root_pid: child.pid,
        error: error instanceof Error ? error.message : String(error),
      });
    }
  }).then((result) => {
    commandDoneAt = Date.now();
    return result;
  });
  const waitResultPromise = watchNewWindows({
    options,
    beforeWindows: before.snapshot?.windows ?? [],
    taskWorkspace,
    focusWorkspace,
    commandDoneAt: () => commandDoneAt,
    errors,
  });
  const command = await commandPromise;
  const waitResult = await waitResultPromise;
  const after = waitResult.after;
  const newWindows = waitResult.newWindows;
  const claimed = waitResult.claimed;
  const moved = waitResult.moved;

  return {
    ok: errors.length === 0 && (command.exit_code === 0 || command.exit_code === null),
    task_id: options.taskId,
    source: options.source,
    command,
    task_workspace: taskWorkspace,
    root_claimed_count: rootClaims.length,
    root_claims: rootClaims,
    waited_ms: Date.now() - waitStartedAt,
    first_new_window_ms: waitResult.firstNewWindowMs,
    capture_attempts: waitResult.captureAttempts,
    before_window_count: before.snapshot?.windows?.length ?? 0,
    after_window_count: after.snapshot?.windows?.length ?? 0,
    preexisting_matching_count: preexisting.matching.length,
    preexisting_claimed_count: preexisting.claimed.length,
    preexisting_claimed: preexisting.claimed,
    preexisting_moved_count: preexisting.moved.length,
    preexisting_moved: preexisting.moved,
    new_window_count: newWindows.length,
    claimed_count: claimed.length,
    claimed,
    moved_count: moved.length,
    moved,
    errors,
  };
}

async function watchNewWindows({ options, beforeWindows, taskWorkspace, focusWorkspace, commandDoneAt, errors }) {
  const startedAt = Date.now();
  let captureAttempts = 0;
  let after;
  let newWindows = [];
  let firstNewWindowMs;
  const seenWindowIds = new Set(beforeWindows.map((window) => String(window.id)));
  const claimed = [];
  const moved = [];

  do {
    captureAttempts += 1;
    after = await captureWorkspace(options);
    const currentNewWindows = findNewWindowsFromSeen(seenWindowIds, after.snapshot?.windows ?? [])
      .filter((window) => windowMatchesFilters(window, options));
    if (currentNewWindows.length > 0 && firstNewWindowMs === undefined) {
      firstNewWindowMs = Math.max(0, Date.now() - startedAt);
    }
    for (const window of currentNewWindows) {
      newWindows.push(window);
      await claimAndMaybeMoveWindow({ options, window, source: options.source, taskWorkspace, focusWorkspace, errors, claimed, moved });
    }
    const doneAt = commandDoneAt();
    if (doneAt !== undefined) {
      const settledAt = doneAt + options.settleMs;
      const timeoutAt = settledAt + options.waitMs;
      const now = Date.now();
      if (now >= settledAt && (newWindows.length > 0 || now >= timeoutAt)) break;
      const nextDeadline = newWindows.length > 0 ? settledAt : timeoutAt;
      await sleep(Math.min(options.pollMs, Math.max(1, nextDeadline - now)));
    } else {
      await sleep(options.pollMs);
    }
  } while (true);

  return { after, newWindows, claimed, moved, captureAttempts, firstNewWindowMs };
}

function validateOptions(options) {
  if (options.claimExistingMatching === true && !options.appContains && !options.titleContains) {
    throw new Error("--claim-existing-matching requires --app or --title");
  }
}

async function claimExistingMatchingWindows({ options, beforeWindows, taskWorkspace, focusWorkspace, errors }) {
  const matching = [];
  const claimed = [];
  const moved = [];
  if (options.claimExistingMatching !== true) return { matching, claimed, moved };

  for (const window of beforeWindows) {
    if (window?.id === undefined) continue;
    if (!windowMatchesFilters(window, options)) continue;
    matching.push(window);
    await claimAndMaybeMoveWindow({
      options,
      window,
      source: `${options.source}:existing_matching`,
      taskWorkspace,
      focusWorkspace,
      errors,
      claimed,
      moved,
    });
  }
  return { matching, claimed, moved };
}

async function claimAndMaybeMoveWindow({ options, window, source, taskWorkspace, focusWorkspace, errors, claimed, moved }) {
  try {
    const claim = await claimWindow(options, {
      task_id: options.taskId,
      window_id: String(window.id),
      app_bundle: readWindowAppBundle(window),
      title_prefix: readWindowTitle(window),
      source,
      ttl_ms: options.ttlMs,
    });
    claimed.push({
      window_id: String(window.id),
      app: window.app,
      app_bundle: readWindowAppBundle(window),
      title: readWindowTitle(window),
      claim_id: claim.claim?.claim_id,
    });
  } catch (error) {
    errors.push({
      window_id: String(window.id),
      error: error instanceof Error ? error.message : String(error),
    });
  }

  if (taskWorkspace && window.workspace !== taskWorkspace) {
    try {
      await runAerospaceCommand(options, ["move-node-to-workspace", "--window-id", String(window.id), taskWorkspace]);
      moved.push({
        window_id: String(window.id),
        from_workspace: window.workspace,
        to_workspace: taskWorkspace,
      });
      if (focusWorkspace && focusWorkspace !== taskWorkspace) {
        await runAerospaceCommand(options, ["workspace", focusWorkspace]).catch(() => undefined);
      }
    } catch (error) {
      errors.push({
        window_id: String(window.id),
        error: error instanceof Error ? error.message : String(error),
      });
    }
  }
}

function runCommand(command, args, onSpawn = async () => {}) {
  return new Promise((resolve) => {
    const child = spawn(command, args, { stdio: "inherit" });
    const spawnHooks = [];
    let settled = false;
    if (isPositiveInteger(child.pid)) {
      spawnHooks.push(Promise.resolve(onSpawn(child)));
    }
    const finish = async (result) => {
      if (settled) return;
      settled = true;
      await Promise.allSettled(spawnHooks);
      resolve(result);
    };
    child.on("error", (error) => {
      finish({ command, args, exit_code: 127, signal: null, error: error.message });
    });
    child.on("close", (code, signal) => {
      finish({ command, args, exit_code: code, signal });
    });
  });
}

async function captureWorkspace(options) {
  return requestJson(options.baseUrl, "/workspace/capture", {
    method: "POST",
    body: {},
    timeoutMs: options.requestTimeoutMs,
  });
}

async function claimWindow(options, body) {
  return requestJson(options.baseUrl, "/task-window-claims", {
    method: "POST",
    body,
    timeoutMs: options.requestTimeoutMs,
  });
}

async function requestJson(baseUrl, route, options = {}) {
  const headers = { ...(options.headers ?? {}) };
  let body;
  if (options.body !== undefined) {
    headers["content-type"] = "application/json";
    body = JSON.stringify(options.body);
  }
  const response = await fetch(new URL(route, baseUrl), {
    method: options.method ?? "GET",
    headers,
    body,
    signal: isPositiveInteger(options.timeoutMs) ? AbortSignal.timeout(options.timeoutMs) : undefined,
  });
  const text = await response.text();
  let parsed;
  try {
    parsed = text ? JSON.parse(text) : {};
  } catch {
    parsed = { raw: text };
  }
  if (!response.ok) {
    throw new Error(`${route} HTTP ${response.status}: ${JSON.stringify(parsed)}`);
  }
  return parsed;
}

function findNewWindows(beforeWindows, afterWindows) {
  const beforeIds = new Set(beforeWindows.map((window) => String(window.id)));
  return afterWindows.filter((window) => window?.id !== undefined && !beforeIds.has(String(window.id)));
}

function findNewWindowsFromSeen(seenWindowIds, afterWindows) {
  const newWindows = [];
  for (const window of afterWindows) {
    if (window?.id === undefined) continue;
    const id = String(window.id);
    if (seenWindowIds.has(id)) continue;
    seenWindowIds.add(id);
    newWindows.push(window);
  }
  return newWindows;
}

function windowMatchesFilters(window, options) {
  if (options.appContains) {
    const haystack = `${window.app ?? ""}\n${readWindowAppBundle(window) ?? ""}`.toLowerCase();
    if (!haystack.includes(options.appContains)) return false;
  }
  if (options.titleContains) {
    if (!String(readWindowTitle(window) ?? "").toLowerCase().includes(options.titleContains)) return false;
  }
  return true;
}

function readWindowAppBundle(window) {
  return readString(window.appBundleId) ?? readString(window.app_bundle) ?? readString(window.app);
}

function readWindowTitle(window) {
  return readString(window.title) ?? readString(window.window_title);
}

function readString(value) {
  return typeof value === "string" && value.trim() ? value.trim() : undefined;
}

function readValue(argv, index, option) {
  const value = argv[index];
  if (!value || value.startsWith("--")) throw new Error(`${option} requires a value`);
  return value;
}

function readPositiveInteger(value, option) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed <= 0) throw new Error(`${option} must be a positive integer`);
  return parsed;
}

function readNonNegativeInteger(value, option) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed < 0) throw new Error(`${option} must be a non-negative integer`);
  return parsed;
}

function isPositiveInteger(value) {
  return typeof value === "number" && Number.isInteger(value) && value > 0;
}

async function readTaskWorkspace(options, taskId) {
  const body = await requestJson(options.baseUrl, `/tasks/${encodeURIComponent(taskId)}`, {
    timeoutMs: options.requestTimeoutMs,
  });
  return readString(body?.task?.aerospace_workspace_id);
}

async function runAerospace(args) {
  await execFileAsync("aerospace", args, { timeout: 5_000 });
}

async function runAerospaceCommand(options, args) {
  const runner = options.runAerospace ?? runAerospace;
  await runner(args);
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function runSelfTest() {
  const claims = [];
  const aerospaceCommands = [];
  let captureCount = 0;
  const server = http.createServer(async (request, response) => {
    const send = (status, body) => {
      response.writeHead(status, { "content-type": "application/json" });
      response.end(JSON.stringify(body));
    };
    if (request.method === "POST" && request.url === "/workspace/capture") {
      captureCount += 1;
      const baseWindow = { id: 1, app: "TextEdit", title: "Notes", workspace: "main" };
      const spawnedWindow = {
        id: 99,
        app: "Google Chrome",
        appBundleId: "com.google.Chrome",
        title: "Checkout smoke report",
        workspace: "main",
      };
      send(200, {
        snapshot: {
          backend: "aerospace",
          activeWorkspace: "main",
          windows: captureCount < 3 ? [baseWindow] : [baseWindow, spawnedWindow],
        },
      });
      return;
    }
    if (request.method === "GET" && request.url === "/tasks/task_checkout") {
      send(200, {
        ok: true,
        task: {
          task_id: "task_checkout",
          aerospace_workspace_id: "task-checkout",
        },
      });
      return;
    }
    if (request.method === "POST" && request.url === "/task-window-claims") {
      const body = await readRequestJson(request);
      claims.push(body);
      send(200, { ok: true, claim: { claim_id: `twc_${body.window_id}`, ...body } });
      return;
    }
    send(404, { ok: false });
  });

  await new Promise((resolve) => server.listen(0, "127.0.0.1", resolve));
  const address = server.address();
  const baseUrl = `http://127.0.0.1:${address.port}`;
  try {
    const result = await runTaskWindowSpawn({
      baseUrl,
      taskId: "task_checkout",
      settleMs: 0,
      waitMs: 1_000,
      pollMs: 1,
      requestTimeoutMs: 5_000,
      ttlMs: 123_000,
      source: "self-test",
      appContains: "chrome",
      titleContains: "checkout",
      runAerospace: async (commandArgs) => {
        aerospaceCommands.push(commandArgs);
      },
      command: process.execPath,
      args: ["-e", ""],
    });
    if (!result.ok) throw new Error(`self-test result not ok: ${JSON.stringify(result)}`);
    if (result.root_claimed_count !== 1) throw new Error(`expected one root claim, got ${result.root_claimed_count}`);
    if (result.claimed_count !== 1) throw new Error(`expected one claim, got ${result.claimed_count}`);
    if (result.capture_attempts < 2) throw new Error(`expected polling captures, got ${result.capture_attempts}`);
    if (!isPositiveInteger(result.first_new_window_ms) && result.first_new_window_ms !== 0) throw new Error(`first new window timing missing: ${JSON.stringify(result)}`);
    if (claims[0]?.task_id !== "task_checkout") throw new Error(`claim task mismatch: ${JSON.stringify(claims[0])}`);
    if (!isPositiveInteger(claims[0]?.process_root_pid)) throw new Error(`root claim pid missing: ${JSON.stringify(claims[0])}`);
    if (claims[0]?.source !== "self-test:process_root") throw new Error(`root claim source mismatch: ${JSON.stringify(claims[0])}`);
    if (claims[1]?.task_id !== "task_checkout") throw new Error(`window claim task mismatch: ${JSON.stringify(claims[1])}`);
    if (claims[1]?.window_id !== "99") throw new Error(`claim window mismatch: ${JSON.stringify(claims[1])}`);
    if (claims[1]?.app_bundle !== "com.google.Chrome") throw new Error(`claim app bundle mismatch: ${JSON.stringify(claims[1])}`);
    if (result.moved_count !== 1) throw new Error(`expected one moved window, got ${result.moved_count}`);
    if (result.moved[0]?.to_workspace !== "task-checkout") throw new Error(`move target mismatch: ${JSON.stringify(result.moved)}`);
    const commandJson = JSON.stringify(aerospaceCommands);
    if (commandJson !== JSON.stringify([
      ["move-node-to-workspace", "--window-id", "99", "task-checkout"],
      ["workspace", "main"],
    ])) {
      throw new Error(`expected move then focus restore, got ${commandJson}`);
    }

    let guardError;
    try {
      await runTaskWindowSpawn({
        baseUrl,
        taskId: "task_checkout",
        settleMs: 0,
        waitMs: 1,
        pollMs: 1,
        requestTimeoutMs: 5_000,
        ttlMs: 123_000,
        source: "self-test-guard",
        appContains: undefined,
        titleContains: undefined,
        claimExistingMatching: true,
        runAerospace: async () => {},
        command: process.execPath,
        args: ["-e", ""],
      });
    } catch (error) {
      guardError = error;
    }
    if (!String(guardError?.message ?? "").includes("--claim-existing-matching requires --app or --title")) {
      throw new Error(`expected claim-existing guard error, got ${guardError?.message}`);
    }

    const existingClaims = [];
    const existingAerospaceCommands = [];
    const existingServer = http.createServer(async (request, response) => {
      const send = (status, body) => {
        response.writeHead(status, { "content-type": "application/json" });
        response.end(JSON.stringify(body));
      };
      if (request.method === "POST" && request.url === "/workspace/capture") {
        send(200, {
          snapshot: {
            backend: "aerospace",
            activeWorkspace: "main",
            windows: [
              {
                id: 77,
                app: "Google Chrome",
                appBundleId: "com.google.Chrome",
                title: "Checkout reuse report",
                workspace: "main",
              },
            ],
          },
        });
        return;
      }
      if (request.method === "GET" && request.url === "/tasks/task_checkout") {
        send(200, { ok: true, task: { task_id: "task_checkout", aerospace_workspace_id: "task-checkout" } });
        return;
      }
      if (request.method === "POST" && request.url === "/task-window-claims") {
        const body = await readRequestJson(request);
        existingClaims.push(body);
        send(200, { ok: true, claim: { claim_id: `twc_existing_${body.window_id ?? body.process_root_pid}`, ...body } });
        return;
      }
      send(404, { ok: false });
    });
    await new Promise((resolve) => existingServer.listen(0, "127.0.0.1", resolve));
    try {
      const existingAddress = existingServer.address();
      const existingResult = await runTaskWindowSpawn({
        baseUrl: `http://127.0.0.1:${existingAddress.port}`,
        taskId: "task_checkout",
        settleMs: 0,
        waitMs: 1,
        pollMs: 1,
        requestTimeoutMs: 5_000,
        ttlMs: 123_000,
        source: "self-test-existing",
        appContains: "chrome",
        titleContains: "reuse",
        claimExistingMatching: true,
        runAerospace: async (commandArgs) => {
          existingAerospaceCommands.push(commandArgs);
        },
        command: process.execPath,
        args: ["-e", ""],
      });
      if (!existingResult.ok) throw new Error(`existing self-test result not ok: ${JSON.stringify(existingResult)}`);
      if (existingResult.preexisting_matching_count !== 1) throw new Error(`expected one existing match, got ${existingResult.preexisting_matching_count}`);
      if (existingResult.preexisting_claimed_count !== 1) throw new Error(`expected one existing claim, got ${existingResult.preexisting_claimed_count}`);
      if (existingResult.preexisting_moved_count !== 1) throw new Error(`expected one existing moved window, got ${existingResult.preexisting_moved_count}`);
      if (existingResult.new_window_count !== 0) throw new Error(`expected no new windows, got ${existingResult.new_window_count}`);
      if (existingClaims[0]?.window_id !== "77") throw new Error(`existing claim window mismatch: ${JSON.stringify(existingClaims[0])}`);
      if (existingClaims[0]?.source !== "self-test-existing:existing_matching") throw new Error(`existing claim source mismatch: ${JSON.stringify(existingClaims[0])}`);
      const existingCommandJson = JSON.stringify(existingAerospaceCommands);
      if (existingCommandJson !== JSON.stringify([
        ["move-node-to-workspace", "--window-id", "77", "task-checkout"],
        ["workspace", "main"],
      ])) {
        throw new Error(`expected existing move then focus restore, got ${existingCommandJson}`);
      }
    } finally {
      existingServer.closeAllConnections?.();
      await new Promise((resolve, reject) => {
        existingServer.close((error) => (error ? reject(error) : resolve()));
      });
    }

    const timeoutServer = http.createServer(async (request, response) => {
      const send = (status, body) => {
        response.writeHead(status, { "content-type": "application/json" });
        response.end(JSON.stringify(body));
      };
      if (request.method === "POST" && request.url === "/workspace/capture") {
        send(200, {
          snapshot: {
            backend: "aerospace",
            activeWorkspace: "main",
            windows: [{ id: 1, app: "TextEdit", title: "Notes", workspace: "main" }],
          },
        });
        return;
      }
      if (request.method === "GET" && request.url === "/tasks/task_checkout") {
        send(200, { ok: true, task: { task_id: "task_checkout" } });
        return;
      }
      if (request.method === "POST" && request.url === "/task-window-claims") {
        setTimeout(() => send(200, { ok: true, claim: { claim_id: "too_late" } }), 100);
        return;
      }
      send(404, { ok: false });
    });
    await new Promise((resolve) => timeoutServer.listen(0, "127.0.0.1", resolve));
    try {
      const timeoutAddress = timeoutServer.address();
      const timeoutResult = await runTaskWindowSpawn({
        baseUrl: `http://127.0.0.1:${timeoutAddress.port}`,
        taskId: "task_checkout",
        settleMs: 0,
        waitMs: 1,
        pollMs: 1,
        requestTimeoutMs: 25,
        ttlMs: 123_000,
        source: "self-test-timeout",
        appContains: undefined,
        titleContains: undefined,
        runAerospace: async () => {},
        command: process.execPath,
        args: ["-e", ""],
      });
      if (timeoutResult.ok) throw new Error(`timeout result should not be ok: ${JSON.stringify(timeoutResult)}`);
      if (!timeoutResult.errors.some((error) => String(error.error).includes("aborted"))) {
        throw new Error(`expected timeout error, got ${JSON.stringify(timeoutResult.errors)}`);
      }
    } finally {
      timeoutServer.closeAllConnections?.();
      await new Promise((resolve, reject) => {
        timeoutServer.close((error) => (error ? reject(error) : resolve()));
      });
    }
    console.log("task-window-spawn self-test passed");
  } finally {
    await new Promise((resolve, reject) => {
      server.close((error) => (error ? reject(error) : resolve()));
    });
  }
}

function readRequestJson(request) {
  return new Promise((resolve, reject) => {
    let data = "";
    request.setEncoding("utf8");
    request.on("data", (chunk) => {
      data += chunk;
    });
    request.on("end", () => {
      try {
        resolve(data ? JSON.parse(data) : {});
      } catch (error) {
        reject(error);
      }
    });
    request.on("error", reject);
  });
}
