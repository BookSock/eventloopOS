#!/usr/bin/env node
import fs from "node:fs";
import os from "node:os";
import path from "node:path";

const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/primitives-catalog-audit [--self-test] [catalog.json]

Validates docs/primitives.catalog.json references so primitive/API docs do not
silently drift from code, route files, proof scripts, and CLI surfaces.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  process.exit(0);
}

const catalogPath = args[0] ?? "docs/primitives.catalog.json";
const result = auditCatalogFile(catalogPath, process.cwd());
if (!result.ok) {
  for (const error of result.errors) console.error(error);
  process.exit(1);
}
console.log(`primitives catalog audit passed: ${catalogPath} (${result.primitive_count} primitives)`);

function auditCatalogFile(catalogPath, repoRoot) {
  const fullPath = path.resolve(repoRoot, catalogPath);
  const errors = [];
  let catalog;
  try {
    catalog = JSON.parse(fs.readFileSync(fullPath, "utf8"));
  } catch (error) {
    return { ok: false, primitive_count: 0, errors: [`catalog parse failed: ${error.message}`] };
  }
  auditCatalog(catalog, repoRoot, errors);
  return {
    ok: errors.length === 0,
    primitive_count: Array.isArray(catalog?.primitives) ? catalog.primitives.length : 0,
    errors,
  };
}

function auditCatalog(catalog, repoRoot, errors) {
  if (!isRecord(catalog)) {
    errors.push("catalog must be an object");
    return;
  }
  if (catalog.schema_version !== 1) errors.push("schema_version must be 1");
  if (!Array.isArray(catalog.primitives) || catalog.primitives.length === 0) {
    errors.push("primitives must be a non-empty array");
    return;
  }
  if (catalog.schemas !== undefined && !isRecord(catalog.schemas)) {
    errors.push("schemas must be an object when present");
  }

  const allowedStatuses = new Set(Array.isArray(catalog.status_labels) ? catalog.status_labels : []);
  const schemaNames = new Set(isRecord(catalog.schemas) ? Object.keys(catalog.schemas) : []);
  const packageScripts = loadPackageScripts(repoRoot);
  auditSharedContractSchemaExports(repoRoot, schemaNames, errors);
  const ids = new Set();
  for (const [index, primitive] of catalog.primitives.entries()) {
    auditPrimitive(primitive, index, repoRoot, allowedStatuses, schemaNames, ids, packageScripts, errors);
  }
  auditObservedRouteCoverage(catalog, repoRoot, errors);
}

function auditSharedContractSchemaExports(repoRoot, schemaNames, errors) {
  if (schemaNames.size === 0) return;
  const sharedSchemasPath = path.resolve(repoRoot, "app/shared/src/schemas.ts");
  if (!fs.existsSync(sharedSchemasPath)) {
    errors.push("shared contract schema source missing: app/shared/src/schemas.ts");
    return;
  }
  const source = fs.readFileSync(sharedSchemasPath, "utf8");
  for (const schemaName of Array.from(schemaNames).sort()) {
    if (!source.includes(`export const ${schemaName}Schema`)) {
      errors.push(`catalog schema ${schemaName} missing shared Zod export ${schemaName}Schema`);
    }
    if (!source.includes(`export type ${schemaName} =`)) {
      errors.push(`catalog schema ${schemaName} missing shared type export`);
    }
    if (!source.includes(`${schemaName}: ${schemaName}Schema`)) {
      errors.push(`catalog schema ${schemaName} missing ContractSchemas registry entry`);
    }
  }
}

function auditPrimitive(primitive, index, repoRoot, allowedStatuses, schemaNames, ids, packageScripts, errors) {
  const prefix = `primitives[${index}]`;
  if (!isRecord(primitive)) {
    errors.push(`${prefix} must be an object`);
    return;
  }

  const id = readNonEmptyString(primitive.id);
  if (!id) errors.push(`${prefix}.id is required`);
  if (id && ids.has(id)) errors.push(`${prefix}.id duplicate: ${id}`);
  if (id) ids.add(id);

  if (!readNonEmptyString(primitive.title)) errors.push(`${prefix}.title is required`);
  if (!readNonEmptyString(primitive.summary)) errors.push(`${prefix}.summary is required`);
  const status = readNonEmptyString(primitive.status);
  if (!status) errors.push(`${prefix}.status is required`);
  if (status && allowedStatuses.size > 0 && !allowedStatuses.has(status)) {
    errors.push(`${prefix}.status unknown: ${status}`);
  }

  const code = arrayOfStrings(primitive.code, `${prefix}.code`, errors);
  const proofs = arrayOfStrings(primitive.proofs, `${prefix}.proofs`, errors);
  if (code.length === 0) errors.push(`${prefix}.code must list at least one code/doc path`);
  if (proofs.length === 0) errors.push(`${prefix}.proofs must list at least one proof path`);

  for (const entry of [...code, ...proofs]) {
    assertPathExists(repoRoot, entry, `${prefix} reference`, errors);
  }

  for (const cli of arrayOfStrings(primitive.cli, `${prefix}.cli`, errors, { optional: true })) {
    if (cli.startsWith("bin/")) assertPathExists(repoRoot, cli, `${prefix}.cli`, errors);
  }

  for (const selfTest of arrayOfStrings(primitive.self_tests, `${prefix}.self_tests`, errors, { optional: true })) {
    assertSelfTestCommandExists(repoRoot, selfTest, `${prefix}.self_tests`, packageScripts, errors);
  }

  const http = primitive.http;
  if (http !== undefined) {
    if (!Array.isArray(http)) {
      errors.push(`${prefix}.http must be an array when present`);
    } else {
      for (const [httpIndex, route] of http.entries()) {
        auditHttpRoute(route, `${prefix}.http[${httpIndex}]`, repoRoot, schemaNames, errors);
      }
    }
  }
}

function auditHttpRoute(route, prefix, repoRoot, schemaNames, errors) {
  if (!isRecord(route)) {
    errors.push(`${prefix} must be an object`);
    return;
  }
  const method = readNonEmptyString(route.method);
  const routePath = readNonEmptyString(route.path);
  const routeFile = readNonEmptyString(route.route_file);
  if (!method) errors.push(`${prefix}.method is required`);
  if (!routePath || !routePath.startsWith("/")) errors.push(`${prefix}.path must start with /`);
  if (!routeFile) {
    errors.push(`${prefix}.route_file is required`);
    return;
  }
  const fullRouteFile = path.resolve(repoRoot, routeFile);
  if (!fs.existsSync(fullRouteFile)) {
    errors.push(`${prefix}.route_file missing: ${routeFile}`);
    return;
  }
  const source = fs.readFileSync(fullRouteFile, "utf8");
  if (method && !routeSourceHasMethod(source, method)) {
    errors.push(`${prefix}.method not found in ${routeFile}: ${method}`);
  }
  const staticNeedle = firstStaticPathNeedle(routePath);
  if (staticNeedle && !routeSourceHasPathNeedle(source, staticNeedle)) {
    errors.push(`${prefix}.path not found in ${routeFile}: ${routePath}`);
  }
  auditSchemaRef(route.request_schema, `${prefix}.request_schema`, schemaNames, errors);
  auditSchemaRef(route.response_schema, `${prefix}.response_schema`, schemaNames, errors);
  if (route.query_parameters !== undefined && route.parameters !== undefined) {
    errors.push(`${prefix} must not define both query_parameters and parameters`);
  }
  const routeParameters = route.query_parameters ?? route.parameters;
  const parameterLabel = route.query_parameters !== undefined ? "query_parameters" : "parameters";
  if (routeParameters !== undefined) {
    if (!Array.isArray(routeParameters)) {
      errors.push(`${prefix}.${parameterLabel} must be an array when present`);
    } else {
      for (const [index, parameter] of routeParameters.entries()) {
        auditQueryParameter(parameter, `${prefix}.${parameterLabel}[${index}]`, errors);
      }
    }
  }
  if (route.no_request_body !== undefined && typeof route.no_request_body !== "boolean") {
    errors.push(`${prefix}.no_request_body must be boolean when present`);
  }
  if (route.no_request_body === true && route.request_schema !== undefined) {
    errors.push(`${prefix} must not define request_schema when no_request_body is true`);
  }
  if (route.no_request_body === true && route.request_body_required !== undefined) {
    errors.push(`${prefix} must not define request_body_required when no_request_body is true`);
  }
  if (route.response_schema === undefined) {
    errors.push(`${prefix}.response_schema is required`);
  }
  if (method && ["POST", "PUT", "PATCH"].includes(method.toUpperCase()) && route.request_schema === undefined && route.no_request_body !== true) {
    errors.push(`${prefix}.request_schema is required for ${method.toUpperCase()} routes unless no_request_body is true`);
  }
}

function auditSchemaRef(value, prefix, schemaNames, errors) {
  if (value === undefined) return;
  if (isRecord(value)) return;
  const schemaName = readNonEmptyString(value);
  if (!schemaName) {
    errors.push(`${prefix} must be a schema object or non-empty schema name`);
    return;
  }
  const componentName = schemaName.startsWith("#/components/schemas/")
    ? schemaName.slice("#/components/schemas/".length)
    : schemaName.startsWith("#/")
      ? undefined
      : schemaName;
  if (componentName && !schemaNames.has(componentName)) {
    errors.push(`${prefix} references missing schema: ${componentName}`);
  }
}

function auditQueryParameter(parameter, prefix, errors) {
  if (!isRecord(parameter)) {
    errors.push(`${prefix} must be an object`);
    return;
  }
  if (!readNonEmptyString(parameter.name)) errors.push(`${prefix}.name is required`);
  if (parameter.in !== undefined && parameter.in !== "query") {
    errors.push(`${prefix}.in must be query when present`);
  }
  if (parameter.description !== undefined && !readNonEmptyString(parameter.description)) {
    errors.push(`${prefix}.description must be non-empty when present`);
  }
  if (parameter.schema !== undefined && !isRecord(parameter.schema)) {
    errors.push(`${prefix}.schema must be an object when present`);
  }
}

function auditObservedRouteCoverage(catalog, repoRoot, errors) {
  const routeObservabilityPath = path.resolve(repoRoot, "app/orchestrator/src/http/route_observability.ts");
  if (!fs.existsSync(routeObservabilityPath)) return;
  const source = fs.readFileSync(routeObservabilityPath, "utf8");
  const requiredPaths = observedRoutePaths(source);
  if (requiredPaths.length === 0) {
    errors.push("observed route coverage source had no route patterns");
    return;
  }

  const catalogPaths = new Set();
  for (const primitive of catalog.primitives) {
    if (!isRecord(primitive) || !Array.isArray(primitive.http)) continue;
    for (const route of primitive.http) {
      if (!isRecord(route)) continue;
      const routePath = readNonEmptyString(route.path);
      if (routePath) catalogPaths.add(routePath);
    }
  }

  for (const routePath of requiredPaths) {
    if (!catalogPaths.has(routePath)) {
      errors.push(`observed route missing from primitive catalog: ${routePath}`);
    }
  }
}

function observedRoutePaths(source) {
  const paths = new Set();
  for (const line of source.split(/\r?\n/)) {
    const match = line.match(/\[\/\^(.+?)\$\/,\s*"[^"]+"\]/);
    if (!match) continue;
    const routePath = observedRegexPatternToCatalogPath(match[1]);
    if (routePath) paths.add(routePath);
  }
  return Array.from(paths).sort();
}

function observedRegexPatternToCatalogPath(pattern) {
  if (!pattern) return undefined;
  return pattern
    .replace(/\\\//g, "/")
    .replace(/\[\^\/\]\+/g, ":id")
    .replace(/\\\./g, ".")
    .trim();
}

function routeSourceHasMethod(source, method) {
  return source.includes(`input.method === "${method}"`)
    || source.includes(`input.method !== "${method}"`)
    || source.includes(`request.method === "${method}"`)
    || source.includes(`request.method !== "${method}"`);
}

function routeSourceHasPathNeedle(source, staticNeedle) {
  return source.includes(staticNeedle) || source.includes(staticNeedle.replace(/\//g, "\\/"));
}

function firstStaticPathNeedle(routePath) {
  if (!routePath) return undefined;
  const dynamicIndex = routePath.indexOf(":");
  const staticPart = dynamicIndex === -1 ? routePath : routePath.slice(0, dynamicIndex);
  return staticPart.replace(/\/+$/, "") || "/";
}

function assertPathExists(repoRoot, value, label, errors) {
  if (!value || value.startsWith("pnpm ")) return;
  const target = path.resolve(repoRoot, value);
  if (!fs.existsSync(target)) errors.push(`${label} missing: ${value}`);
}

function assertSelfTestCommandExists(repoRoot, command, label, packageScripts, errors) {
  const tokens = tokenizeCommand(command);
  if (tokens.length === 0) return;
  if (tokens[0] === "pnpm") {
    assertPnpmRunScriptExists(tokens, label, packageScripts, errors);
    return;
  }
  if (tokens[0] === "node" && tokens[1]) {
    assertPathExists(repoRoot, tokens[1], label, errors);
    return;
  }
  if (tokens[0].startsWith("bin/") || tokens[0].startsWith("examples/")) {
    assertPathExists(repoRoot, tokens[0], label, errors);
  }
}

function assertPnpmRunScriptExists(tokens, label, packageScripts, errors) {
  let filter;
  let scriptName;
  for (let index = 1; index < tokens.length; index += 1) {
    const token = tokens[index];
    if (token === "--filter" || token === "-F") {
      filter = tokens[index + 1];
      index += 1;
      continue;
    }
    if (token.startsWith("--filter=")) {
      filter = token.slice("--filter=".length);
      continue;
    }
    if (token === "run") {
      scriptName = tokens[index + 1];
      break;
    }
  }
  if (!scriptName) {
    errors.push(`${label} pnpm command must include "run <script>": ${tokens.join(" ")}`);
    return;
  }
  const packageName = filter ?? packageScripts.rootName;
  if (!packageName) {
    errors.push(`${label} pnpm command must include --filter or root package name: ${tokens.join(" ")}`);
    return;
  }
  const packageInfo = packageScripts.byName.get(packageName);
  if (!packageInfo) {
    errors.push(`${label} references missing pnpm package: ${packageName}`);
    return;
  }
  if (!packageInfo.scripts.has(scriptName)) {
    errors.push(`${label} references missing pnpm script: ${packageName}#${scriptName}`);
  }
}

function tokenizeCommand(command) {
  const tokens = [];
  let token = "";
  let quote;
  for (let index = 0; index < command.length; index += 1) {
    const char = command[index];
    if (quote) {
      if (char === quote) {
        quote = undefined;
      } else {
        token += char;
      }
      continue;
    }
    if (char === '"' || char === "'") {
      quote = char;
      continue;
    }
    if (/\s/.test(char)) {
      if (token.length > 0) {
        tokens.push(token);
        token = "";
      }
      continue;
    }
    token += char;
  }
  if (token.length > 0) tokens.push(token);
  return tokens;
}

function loadPackageScripts(repoRoot) {
  const byName = new Map();
  let rootName;
  for (const packageJsonPath of packageJsonPaths(repoRoot)) {
    let packageJson;
    try {
      packageJson = JSON.parse(fs.readFileSync(packageJsonPath, "utf8"));
    } catch {
      continue;
    }
    const name = readNonEmptyString(packageJson.name);
    if (!name) continue;
    const scripts = new Set(isRecord(packageJson.scripts) ? Object.keys(packageJson.scripts) : []);
    if (packageJsonPath === path.resolve(repoRoot, "package.json")) rootName = name;
    byName.set(name, {
      path: path.relative(repoRoot, packageJsonPath),
      scripts,
    });
  }
  return { byName, rootName };
}

function packageJsonPaths(repoRoot) {
  const ignoredDirs = new Set([
    ".git",
    ".next",
    ".build",
    "artifacts",
    "build",
    "dist",
    "node_modules",
    "target",
  ]);
  const paths = [];
  const visit = (dir) => {
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      if (entry.isDirectory()) {
        if (!ignoredDirs.has(entry.name)) visit(path.join(dir, entry.name));
        continue;
      }
      if (entry.isFile() && entry.name === "package.json") paths.push(path.join(dir, entry.name));
    }
  };
  visit(repoRoot);
  return paths;
}

function arrayOfStrings(value, label, errors, options = {}) {
  if (value === undefined && options.optional) return [];
  if (!Array.isArray(value)) {
    errors.push(`${label} must be an array`);
    return [];
  }
  const strings = [];
  for (const [index, entry] of value.entries()) {
    if (typeof entry !== "string" || entry.trim().length === 0) {
      errors.push(`${label}[${index}] must be a non-empty string`);
    } else {
      strings.push(entry);
    }
  }
  return strings;
}

function readNonEmptyString(value) {
  return typeof value === "string" && value.trim().length > 0 ? value.trim() : undefined;
}

function isRecord(value) {
  return typeof value === "object" && value !== null && !Array.isArray(value);
}

function runSelfTest() {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-primitives-catalog-audit-"));
  fs.mkdirSync(path.join(root, "app/orchestrator/src/routes"), { recursive: true });
  fs.mkdirSync(path.join(root, "app/orchestrator/src/http"), { recursive: true });
  fs.mkdirSync(path.join(root, "app/shared/src"), { recursive: true });
  fs.mkdirSync(path.join(root, "bin"), { recursive: true });
  fs.writeFileSync(
    path.join(root, "package.json"),
    JSON.stringify({ name: "eventloopos", scripts: { "root-proof": "node bin/proof --self-test" } }, null, 2),
  );
  fs.writeFileSync(
    path.join(root, "app/orchestrator/package.json"),
    JSON.stringify({ name: "@eventloopos/orchestrator", scripts: { "test:runtime-spine": "node --test dist/src/runtime.test.js" } }, null, 2),
  );
  fs.writeFileSync(path.join(root, "code.ts"), "export {}\n");
  fs.writeFileSync(path.join(root, "proof.test.ts"), "export {}\n");
  fs.writeFileSync(path.join(root, "bin/proof"), "#!/usr/bin/env node\n");
  fs.writeFileSync(
    path.join(root, "app/shared/src/schemas.ts"),
    [
      "export const ExampleRequestSchema = {};",
      "export type ExampleRequest = {};",
      "export const ExampleResponseSchema = {};",
      "export type ExampleResponse = {};",
      "export const TickResponseSchema = {};",
      "export type TickResponse = {};",
      "export const ContractSchemas = {",
      "  ExampleRequest: ExampleRequestSchema,",
      "  ExampleResponse: ExampleResponseSchema,",
      "  TickResponse: TickResponseSchema,",
      "};",
      "",
    ].join("\n"),
  );
  fs.writeFileSync(
    path.join(root, "app/orchestrator/src/routes/example.ts"),
    'if (input.method === "POST" && input.pathname === "/example") {}\nif (input.method === "POST" && input.pathname === "/example/tick") {}\n',
  );
  fs.writeFileSync(
    path.join(root, "app/orchestrator/src/http/route_observability.ts"),
    [
      "export function routeNameForPath() {",
      "  const entries = [",
      '    [/^\\/example$/, "example"],',
      "  ];",
      "  return entries;",
      "}",
      "",
    ].join("\n"),
  );

  const good = {
    schema_version: 1,
    status_labels: ["dogfood"],
    primitives: [{
      id: "example",
      title: "Example",
      status: "dogfood",
      summary: "Example primitive.",
      http: [{
        method: "POST",
        path: "/example",
        route_file: "app/orchestrator/src/routes/example.ts",
        request_schema: "ExampleRequest",
        response_schema: "ExampleResponse",
        parameters: [{ name: "task_id", in: "query", schema: { type: "string" } }],
      }, {
        method: "POST",
        path: "/example/tick",
        route_file: "app/orchestrator/src/routes/example.ts",
        no_request_body: true,
        response_schema: "TickResponse",
      }],
      code: ["code.ts"],
      proofs: ["proof.test.ts"],
      cli: ["bin/proof"],
      self_tests: [
        "bin/proof --self-test",
        "node bin/proof --self-test",
        "pnpm run root-proof",
        "pnpm --filter @eventloopos/orchestrator run test:runtime-spine",
      ],
    }],
    schemas: {
      ExampleRequest: { type: "object" },
      ExampleResponse: { type: "object" },
      TickResponse: { type: "object" },
    },
  };
  const goodErrors = [];
  auditCatalog(good, root, goodErrors);
  if (goodErrors.length > 0) throw new Error(`good fixture failed: ${goodErrors.join("; ")}`);

  const bad = {
    schema_version: 1,
    status_labels: ["dogfood"],
    primitives: [{ ...good.primitives[0], id: "bad", code: ["missing.ts"] }],
  };
  const badErrors = [];
  auditCatalog(bad, root, badErrors);
  if (!badErrors.some((error) => error.includes("missing.ts"))) {
    throw new Error(`bad fixture did not fail as expected: ${badErrors.join("; ")}`);
  }

  const badPackage = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      self_tests: ["pnpm --filter @eventloopos/missing run test:runtime-spine"],
    }],
  };
  const badPackageErrors = [];
  auditCatalog(badPackage, root, badPackageErrors);
  if (!badPackageErrors.some((error) => error.includes("missing pnpm package"))) {
    throw new Error(`bad package fixture did not fail as expected: ${badPackageErrors.join("; ")}`);
  }

  const badScript = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      self_tests: ["pnpm --filter @eventloopos/orchestrator run test:missing"],
    }],
  };
  const badScriptErrors = [];
  auditCatalog(badScript, root, badScriptErrors);
  if (!badScriptErrors.some((error) => error.includes("missing pnpm script"))) {
    throw new Error(`bad script fixture did not fail as expected: ${badScriptErrors.join("; ")}`);
  }

  const badSchema = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      http: [{ ...good.primitives[0].http[0], request_schema: "MissingRequest" }],
    }],
  };
  const badSchemaErrors = [];
  auditCatalog(badSchema, root, badSchemaErrors);
  if (!badSchemaErrors.some((error) => error.includes("MissingRequest"))) {
    throw new Error(`bad schema fixture did not fail as expected: ${badSchemaErrors.join("; ")}`);
  }

  const badParameter = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      http: [{ ...good.primitives[0].http[0], parameters: [{ name: "task_id", in: "path" }] }],
    }],
  };
  const badParameterErrors = [];
  auditCatalog(badParameter, root, badParameterErrors);
  if (!badParameterErrors.some((error) => error.includes(".in must be query"))) {
    throw new Error(`bad parameter fixture did not fail as expected: ${badParameterErrors.join("; ")}`);
  }

  const missingRequest = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      http: [{ ...good.primitives[0].http[0], request_schema: undefined }],
    }],
  };
  const missingRequestErrors = [];
  auditCatalog(missingRequest, root, missingRequestErrors);
  if (!missingRequestErrors.some((error) => error.includes(".request_schema is required"))) {
    throw new Error(`missing request schema fixture did not fail as expected: ${missingRequestErrors.join("; ")}`);
  }

  const missingResponse = {
    ...good,
    primitives: [{
      ...good.primitives[0],
      http: [{ ...good.primitives[0].http[0], response_schema: undefined }],
    }],
  };
  const missingResponseErrors = [];
  auditCatalog(missingResponse, root, missingResponseErrors);
  if (!missingResponseErrors.some((error) => error.includes(".response_schema is required"))) {
    throw new Error(`missing response schema fixture did not fail as expected: ${missingResponseErrors.join("; ")}`);
  }

  fs.writeFileSync(
    path.join(root, "app/orchestrator/src/http/route_observability.ts"),
    [
      "export function routeNameForPath() {",
      "  const entries = [",
      '    [/^\\/example$/, "example"],',
      '    [/^\\/example\\/[^/]+\\/extra$/, "example_extra"],',
      "  ];",
      "  return entries;",
      "}",
      "",
    ].join("\n"),
  );
  const badRouteCoverageErrors = [];
  auditCatalog(good, root, badRouteCoverageErrors);
  if (!badRouteCoverageErrors.some((error) => error.includes("/example/:id/extra"))) {
    throw new Error(`bad route coverage fixture did not fail as expected: ${badRouteCoverageErrors.join("; ")}`);
  }

  fs.rmSync(root, { recursive: true, force: true });
  console.log("primitives-catalog-audit self-test passed");
}
