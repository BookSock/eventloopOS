#!/usr/bin/env node
import assert from "node:assert/strict";
import { mkdirSync, writeFileSync } from "node:fs";
import { spawnSync } from "node:child_process";
import path from "node:path";

const repoRoot = path.resolve(import.meta.dirname, "..");
const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/primitives-host-doctor [--json] [--require-live] [--skip-live] [--url URL] [--manifest PATH]

Proves this checkout exposes a usable eventloopOS primitive API surface.
Default mode validates local catalog/OpenAPI/examples, then probes a live
orchestrator if one is reachable. Use --require-live for a host readiness gate.

Environment:
  EVENTLOOPOS_ORCHESTRATOR_URL  default: http://127.0.0.1:4377
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  await runSelfTest();
  console.log("primitives-host-doctor self-test passed");
  process.exit(0);
}

const options = parseArgs(args);
const manifest = await runDoctor(options);
writeManifest(manifest, options.manifestPath);

if (options.json) {
  console.log(JSON.stringify(summaryOutput(manifest, options.manifestPath)));
} else {
  console.log(`primitives host doctor manifest: ${options.manifestPath}`);
  console.log(JSON.stringify(summaryOutput(manifest, options.manifestPath), null, 2));
}

process.exit(manifest.ok ? 0 : 1);

function parseArgs(argv) {
  const runId = utcStamp();
  const manifestPath = readArg(argv, "--manifest") ?? path.join("artifacts", "primitives-host-doctor", runId, "manifest.json");
  return {
    json: argv.includes("--json"),
    requireLive: argv.includes("--require-live"),
    skipLive: argv.includes("--skip-live"),
    url: readArg(argv, "--url") ?? process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? "http://127.0.0.1:4377",
    manifestPath,
  };
}

async function runDoctor(options, deps = {}) {
  const startedAt = new Date().toISOString();
  const commandRunner = deps.commandRunner ?? runCommand;
  const fetcher = deps.fetcher ?? fetchWithTimeout;
  const checks = [];

  checks.push(commandCheck(commandRunner, "catalog_audit", "node", ["bin/primitives-catalog-audit", "docs/primitives.catalog.json"]));
  checks.push(commandCheck(
    commandRunner,
    "strict_readiness",
    "node",
    ["bin/primitives-readiness-report", "--strict", "--json", "docs/primitives.catalog.json"],
    { summarizeJson: summarizePrimitiveReadiness }
  ));
  checks.push(commandCheck(commandRunner, "builder_docs_current", "node", ["bin/primitives-docs-audit", "docs/primitives.catalog.json", "docs/primitives.md"]));
  checks.push(commandCheck(commandRunner, "openapi_current", "node", ["bin/primitives-openapi-export", "--check", "docs/primitives.catalog.json", "docs/primitives.openapi.json"]));
  checks.push(commandCheck(commandRunner, "api_index_current", "node", ["bin/primitives-api-index-export", "--check", "docs/primitives.catalog.json", "docs/primitives.index.json"]));
  checks.push(commandCheck(commandRunner, "shared_sdk_pack_audit", "node", ["bin/shared-sdk-pack-audit"]));
  checks.push(commandCheck(commandRunner, "mcp_source_templates", "node", ["bin/mcp-source-templates-audit", "--include-local"]));
  checks.push(commandCheck(commandRunner, "primitive_self_tests", "node", ["bin/primitives-self-test-runner", "--catalog", "docs/primitives.catalog.json"]));
  checks.push(commandCheck(commandRunner, "discover_primitives_example", "node", ["examples/primitives/discover-primitives.mjs", "--self-test"]));
  checks.push(commandCheck(commandRunner, "primitive_workbench_walkthrough_example", "node", ["examples/primitives/primitive-workbench-walkthrough.mjs", "--self-test"]));
  checks.push(commandCheck(commandRunner, "restore_my_desk_example", "node", ["examples/primitives/restore-my-desk.mjs", "--self-test"]));
  checks.push(commandCheck(commandRunner, "agent_attention_queue_example", "node", ["examples/primitives/agent-attention-queue.mjs", "--self-test"]));
  checks.push(commandCheck(commandRunner, "window_hotkey_router_example", "node", ["examples/primitives/window-hotkey-router.mjs", "--self-test"]));

  const localChecks = await Promise.all(checks);
  const liveChecks = options.skipLive ? [skippedCheck("live_orchestrator", "live checks skipped by --skip-live")] : await runLiveChecks({
    url: options.url,
    requireLive: options.requireLive,
    fetcher,
  });

  const allChecks = [...localChecks, ...liveChecks];
  const failedChecks = allChecks.filter((check) => check.status === "failed");
  const warningChecks = allChecks.filter((check) => check.status === "warning");
  const primitiveReadiness = localChecks.find((check) => check.name === "strict_readiness")?.summary ?? null;
  const fixes = suggestedFixes(allChecks, options);
  const finishedAt = new Date().toISOString();
  return {
    schema_version: 1,
    kind: "eventloopos.primitives_host_doctor",
    started_at: startedAt,
    finished_at: finishedAt,
    duration_ms: Date.parse(finishedAt) - Date.parse(startedAt),
    ok: failedChecks.length === 0,
    passed: failedChecks.length === 0,
    orchestrator_url: options.url,
    require_live: options.requireLive,
    primitive_readiness: primitiveReadiness,
    checks: allChecks,
    failed_checks: failedChecks.map((check) => check.name),
    warning_checks: warningChecks.map((check) => check.name),
    fixes,
  };
}

function commandCheck(commandRunner, name, command, commandArgs, options = {}) {
  const result = commandRunner(command, commandArgs);
  const check = {
    name,
    status: result.status === 0 ? "passed" : "failed",
    command: [command, ...commandArgs],
    exit_code: result.status,
  };
  if (options.summarizeJson && result.stdout?.trim()) {
    try {
      check.summary = options.summarizeJson(JSON.parse(result.stdout));
    } catch (error) {
      check.summary_parse_error = error instanceof Error ? error.message : String(error);
    }
  }
  if (result.stdout?.trim()) check.stdout = result.stdout.trim().slice(-2_000);
  if (result.stderr?.trim()) check.stderr = result.stderr.trim().slice(-2_000);
  return check;
}

function summarizePrimitiveReadiness(report) {
  return {
    ok: report.ok === true,
    strict_ok: report.strict_ok === true,
    primitive_count: Number(report.primitive_count ?? 0),
    status_counts: objectOfNumbers(report.status_counts),
    category_counts: objectOfNumbers(report.category_counts),
    totals: {
      http_routes: Number(report.totals?.http_routes ?? 0),
      cli_commands: Number(report.totals?.cli_commands ?? 0),
      self_tests: Number(report.totals?.self_tests ?? 0),
      proof_refs: Number(report.totals?.proof_refs ?? 0),
      missing_refs: Number(report.totals?.missing_refs ?? 0),
    },
    gap_count: Array.isArray(report.gaps) ? report.gaps.length : 0,
    hardening_gap_count: Array.isArray(report.hardening_gaps) ? report.hardening_gaps.length : 0,
  };
}

function objectOfNumbers(value) {
  if (!value || typeof value !== "object" || Array.isArray(value)) return {};
  return Object.fromEntries(
    Object.entries(value)
      .filter(([, count]) => Number.isFinite(Number(count)))
      .map(([key, count]) => [key, Number(count)])
      .sort(([left], [right]) => left.localeCompare(right))
  );
}

async function runLiveChecks({ url, requireLive, fetcher }) {
  const baseUrl = normalizeUrl(url);
  const probe = await liveEndpointCheck(fetcher, baseUrl, "/health", { requireLive });
  if (probe.status !== "passed") {
    return [{
      ...probe,
      name: "live_orchestrator",
      status: requireLive ? "failed" : "warning",
      required: requireLive,
    }];
  }

  const checks = [
    { name: "live_health", path: "/health" },
    { name: "live_metrics", path: "/metrics" },
    { name: "live_activity", path: "/activity" },
    { name: "live_workspace_status", path: "/workspace/status" },
  ];
  const results = [];
  for (const check of checks) {
    results.push(await liveEndpointCheck(fetcher, baseUrl, check.path, { name: check.name, requireLive }));
  }
  return results;
}

async function liveEndpointCheck(fetcher, baseUrl, endpointPath, { name = endpointPath, requireLive }) {
  const target = new URL(endpointPath, baseUrl).toString();
  try {
    const response = await fetcher(target);
    const status = response.status;
    const body = await response.text();
    const httpOk = status >= 200 && status < 300;
    const responseValidation = httpOk ? validateLiveEndpointBody(endpointPath, body) : { ok: false, reason: "http_status_not_2xx" };
    const passed = httpOk && responseValidation.ok;
    return {
      name,
      status: passed ? "passed" : "failed",
      required: requireLive,
      url: target,
      http_status: status,
      response_json_ok: responseValidation.jsonOk,
      response_contract_ok: responseValidation.contractOk,
      ...(responseValidation.schema ? { response_schema: responseValidation.schema } : {}),
      body_excerpt: body.trim().slice(0, 1_000),
      ...(passed ? {} : {
        diagnosis: {
          reason: responseValidation.reason,
          detail: responseValidation.detail ?? `${endpointPath} returned HTTP ${status}`,
        },
      }),
    };
  } catch (error) {
    const errorCode = error?.cause?.code ?? error?.code;
    return {
      name,
      status: requireLive ? "failed" : "warning",
      required: requireLive,
      url: target,
      error: error instanceof Error ? error.message : String(error),
      ...(errorCode ? { error_code: String(errorCode) } : {}),
      diagnosis: diagnoseLiveFetchError(error, endpointPath),
    };
  }
}

function validateLiveEndpointBody(endpointPath, body) {
  if (!body.trim()) {
    return {
      ok: false,
      jsonOk: false,
      contractOk: false,
      reason: "empty_response",
      detail: `${endpointPath} returned an empty response body.`,
    };
  }
  let payload;
  try {
    payload = JSON.parse(body);
  } catch {
    return {
      ok: false,
      jsonOk: false,
      contractOk: false,
      reason: "invalid_json",
      detail: `${endpointPath} returned non-JSON content.`,
    };
  }
  if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
    return {
      ok: false,
      jsonOk: true,
      contractOk: false,
      reason: "invalid_response_shape",
      detail: `${endpointPath} returned JSON but not an object.`,
    };
  }
  const contract = validateLiveEndpointContract(endpointPath, payload);
  return {
    ...contract,
    jsonOk: true,
  };
}

function validateLiveEndpointContract(endpointPath, payload) {
  if (endpointPath === "/health") {
    const ok = payload.ok === true
      && typeof payload.service === "string"
      && typeof payload.time === "string"
      && typeof payload.request_id === "string";
    return liveContractResult(ok, "HealthResponse", endpointPath, "expected ok=true, service, time, and request_id");
  }
  if (endpointPath === "/metrics") {
    const ok = payload.metrics
      && typeof payload.metrics === "object"
      && !Array.isArray(payload.metrics)
      && typeof payload.generated_at === "string"
      && typeof payload.request_id === "string";
    return liveContractResult(ok, "MetricsResponse", endpointPath, "expected metrics, generated_at, and request_id");
  }
  if (endpointPath === "/activity") {
    const ok = Array.isArray(payload.events)
      && Number.isInteger(payload.count)
      && typeof payload.request_id === "string";
    return liveContractResult(ok, "ActivityResponse", endpointPath, "expected events array, count, and request_id");
  }
  if (endpointPath === "/workspace/status") {
    const ok = payload.status
      && typeof payload.status === "object"
      && !Array.isArray(payload.status)
      && typeof payload.status.available === "boolean"
      && typeof payload.status.backend === "string"
      && typeof payload.execute_supported === "boolean"
      && typeof payload.request_id === "string";
    return liveContractResult(ok, "WorkspaceStatusResponse", endpointPath, "expected status.available, status.backend, execute_supported, and request_id");
  }
  return {
    ok: true,
    contractOk: true,
    schema: "unknown",
  };
}

function liveContractResult(ok, schema, endpointPath, expected) {
  return {
    ok,
    contractOk: ok,
    schema,
    ...(ok ? {} : {
      reason: "response_contract_mismatch",
      detail: `${endpointPath} did not match ${schema}: ${expected}.`,
    }),
  };
}

function diagnoseLiveFetchError(error, endpointPath) {
  const errorCode = error?.cause?.code ?? error?.code;
  const message = error instanceof Error ? error.message : String(error);
  if (error?.name === "TimeoutError" || errorCode === "ETIMEDOUT" || /timed? out/i.test(message)) {
    return {
      reason: "timeout",
      detail: `${endpointPath} did not respond before the 1500ms host-doctor timeout`,
    };
  }
  if (errorCode === "ECONNREFUSED") {
    return {
      reason: "connection_refused",
      detail: "No orchestrator is accepting connections at the configured URL.",
    };
  }
  if (errorCode === "ENOTFOUND") {
    return {
      reason: "host_not_found",
      detail: "Configured orchestrator host could not be resolved.",
    };
  }
  return {
    reason: "fetch_failed",
    detail: message,
  };
}

function suggestedFixes(checks, options) {
  const liveProblem = checks.find((check) => check.name === "live_orchestrator" && ["failed", "warning"].includes(check.status));
  if (!liveProblem) return [];
  const fixes = [
    {
      check: "live_orchestrator",
      reason: liveProblem.diagnosis?.reason ?? "unreachable",
      detail: liveProblem.diagnosis?.detail ?? liveProblem.error ?? "live orchestrator probe failed",
      command: "pnpm --filter @eventloopos/orchestrator start",
    },
    {
      check: "live_orchestrator",
      reason: "verify_url",
      detail: `Re-run against the URL you expect to expose primitives.`,
      command: `node bin/primitives-host-doctor --require-live --url ${shellQuote(options.url)}`,
    },
  ];
  if (!options.requireLive) {
    fixes.push({
      check: "live_orchestrator",
      reason: "optional_live_probe",
      detail: "Use --skip-live when only catalog/SDK/docs readiness matters.",
      command: "node bin/primitives-host-doctor --skip-live",
    });
  }
  return fixes;
}

async function fetchWithTimeout(url) {
  return fetch(url, { signal: AbortSignal.timeout(1_500) });
}

function runCommand(command, commandArgs) {
  return spawnSync(command, commandArgs, {
    cwd: repoRoot,
    encoding: "utf8",
    shell: false,
  });
}

function skippedCheck(name, reason) {
  return { name, status: "skipped", required: false, reason };
}

function writeManifest(manifest, relativePath) {
  const fullPath = path.resolve(repoRoot, relativePath);
  mkdirSync(path.dirname(fullPath), { recursive: true });
  writeFileSync(fullPath, `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
  writeFileSync(path.join(path.dirname(fullPath), "DOCTOR.md"), renderMarkdown(manifest), "utf8");
}

function renderMarkdown(manifest) {
  const lines = [
    "# eventloopOS Primitives Host Doctor",
    "",
    `Generated: ${manifest.finished_at}`,
    `Passed: \`${manifest.ok}\``,
    `Live URL: \`${manifest.orchestrator_url}\``,
    `Require live: \`${manifest.require_live}\``,
    "",
  ];
  if (manifest.primitive_readiness) {
    lines.push("## Primitive Readiness");
    lines.push("");
    lines.push(`- Strict: ${manifest.primitive_readiness.strict_ok ? "passed" : "failed"}`);
    lines.push(`- Primitives: ${manifest.primitive_readiness.primitive_count}`);
    lines.push(`- HTTP routes: ${manifest.primitive_readiness.totals.http_routes}`);
    lines.push(`- CLI commands: ${manifest.primitive_readiness.totals.cli_commands}`);
    lines.push(`- Self-tests: ${manifest.primitive_readiness.totals.self_tests}`);
    lines.push(`- Proof refs: ${manifest.primitive_readiness.totals.proof_refs}`);
    lines.push(`- Status: ${formatCounts(manifest.primitive_readiness.status_counts)}`);
    lines.push(`- Category: ${formatCounts(manifest.primitive_readiness.category_counts)}`);
    lines.push("");
  }
  lines.push("## Checks");
  lines.push("");
  for (const check of manifest.checks) {
    lines.push(`- ${check.status}: ${check.name}`);
    if (check.status === "failed" || check.status === "warning") {
      if (check.error) lines.push(`  - Error: \`${check.error}\``);
      if (check.diagnosis?.detail) lines.push(`  - Diagnosis: ${check.diagnosis.detail}`);
    }
  }
  if (manifest.fixes.length > 0) {
    lines.push("");
    lines.push("## Suggested Fixes");
    lines.push("");
    for (const fix of manifest.fixes) {
      lines.push(`- ${fix.detail}`);
      lines.push(`  - \`${fix.command}\``);
    }
  }
  return `${lines.join("\n")}\n`;
}

function summaryOutput(manifest, manifestPath) {
  return {
    manifest: manifestPath,
    ok: manifest.ok,
    failed_checks: manifest.failed_checks,
    warning_checks: manifest.warning_checks,
    fixes: manifest.fixes,
    check_count: manifest.checks.length,
    primitive_readiness: manifest.primitive_readiness,
    live_required: manifest.require_live,
    orchestrator_url: manifest.orchestrator_url,
  };
}

function formatCounts(counts) {
  const entries = Object.entries(counts ?? {});
  if (entries.length === 0) return "none";
  return entries.map(([key, value]) => `${key}=${value}`).join(", ");
}

function normalizeUrl(value) {
  const parsed = new URL(value);
  if (!parsed.pathname.endsWith("/")) parsed.pathname = `${parsed.pathname}/`;
  return parsed;
}

function readArg(argv, name) {
  const index = argv.indexOf(name);
  if (index === -1) return undefined;
  return argv[index + 1];
}

function utcStamp() {
  return new Date().toISOString().replace(/[-:]/g, "").replace(/\.\d+Z$/, "Z");
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

async function runSelfTest() {
  const readinessStdout = JSON.stringify({
    ok: true,
    strict_ok: true,
    primitive_count: 2,
    status_counts: { dogfood: 1, stable_enough: 1 },
    category_counts: { os_control: 1, runtime: 1 },
    totals: {
      http_routes: 4,
      cli_commands: 1,
      self_tests: 2,
      proof_refs: 6,
      missing_refs: 0,
    },
    gaps: [],
    hardening_gaps: [],
  });
  const commandRunner = (_command, commandArgs) => ({
    status: 0,
    stdout: commandArgs.includes("bin/primitives-readiness-report") ? readinessStdout : "ok\n",
    stderr: "",
  });
  const fetcher = async (url) => ({
    status: 200,
    text: async () => JSON.stringify(successfulLivePayload(new URL(url).pathname)),
  });
  const manifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: true,
    skipLive: false,
  }, { commandRunner, fetcher });
  assert.equal(manifest.ok, true);
  assert.equal(manifest.failed_checks.length, 0);
  assert.ok(manifest.checks.some((check) => check.name === "strict_readiness"));
  assert.ok(manifest.checks.some((check) => check.name === "builder_docs_current"));
  assert.ok(manifest.checks.some((check) => check.name === "api_index_current"));
  assert.ok(manifest.checks.some((check) => check.name === "shared_sdk_pack_audit"));
  assert.ok(manifest.checks.some((check) => check.name === "mcp_source_templates"));
  assert.ok(manifest.checks.some((check) => check.name === "primitive_self_tests"));
  assert.ok(manifest.checks.some((check) => check.name === "primitive_workbench_walkthrough_example"));
  assert.ok(manifest.checks.some((check) => check.name === "live_workspace_status"));
  assert.equal(manifest.primitive_readiness.strict_ok, true);
  assert.equal(manifest.primitive_readiness.primitive_count, 2);
  assert.equal(manifest.primitive_readiness.totals.http_routes, 4);
  assert.equal(summaryOutput(manifest, "manifest.json").primitive_readiness.totals.self_tests, 2);
  assert.match(renderMarkdown(manifest), /Primitive Readiness/);

  const warningManifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: false,
    skipLive: false,
  }, {
    commandRunner,
    fetcher: async () => {
      throw new Error("offline");
    },
  });
  assert.equal(warningManifest.ok, true);
  assert.deepEqual(warningManifest.warning_checks, ["live_orchestrator"]);
  assert.equal(warningManifest.fixes.length, 3);
  assert.equal(warningManifest.checks.at(-1).diagnosis.reason, "fetch_failed");
  assert.match(renderMarkdown(warningManifest), /Suggested Fixes/);

  const requiredOfflineManifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: true,
    skipLive: false,
  }, {
    commandRunner,
    fetcher: async () => {
      const error = new Error("fetch failed");
      error.cause = { code: "ECONNREFUSED" };
      throw error;
    },
  });
  assert.equal(requiredOfflineManifest.ok, false);
  assert.deepEqual(requiredOfflineManifest.failed_checks, ["live_orchestrator"]);
  assert.equal(requiredOfflineManifest.checks.at(-1).error_code, "ECONNREFUSED");
  assert.equal(requiredOfflineManifest.checks.at(-1).diagnosis.reason, "connection_refused");
  assert.equal(summaryOutput(requiredOfflineManifest, "manifest.json").fixes.length, 2);

  const requiredHttpFailureManifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: true,
    skipLive: false,
  }, {
    commandRunner,
    fetcher: async () => ({
      status: 503,
      text: async () => "{\"ok\":false,\"error\":\"starting\"}",
    }),
  });
  assert.equal(requiredHttpFailureManifest.ok, false);
  assert.equal(requiredHttpFailureManifest.checks.at(-1).diagnosis.reason, "http_status_not_2xx");

  const invalidJsonManifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: true,
    skipLive: false,
  }, {
    commandRunner,
    fetcher: async () => ({
      status: 200,
      text: async () => "<html>not json</html>",
    }),
  });
  assert.equal(invalidJsonManifest.ok, false);
  assert.equal(invalidJsonManifest.failed_checks[0], "live_orchestrator");
  assert.equal(invalidJsonManifest.checks.at(-1).diagnosis.reason, "invalid_json");
  assert.equal(invalidJsonManifest.checks.at(-1).response_json_ok, false);

  const contractMismatchManifest = await runDoctor({
    url: "http://127.0.0.1:4377",
    requireLive: true,
    skipLive: false,
  }, {
    commandRunner,
    fetcher: async () => ({
      status: 200,
      text: async () => "{\"ok\":true}",
    }),
  });
  assert.equal(contractMismatchManifest.ok, false);
  assert.equal(contractMismatchManifest.failed_checks[0], "live_orchestrator");
  assert.equal(contractMismatchManifest.checks.at(-1).diagnosis.reason, "response_contract_mismatch");
  assert.equal(contractMismatchManifest.checks.at(-1).response_contract_ok, false);
}

function successfulLivePayload(endpointPath) {
  if (endpointPath === "/health") {
    return {
      ok: true,
      service: "eventloop-orchestrator",
      time: "2026-05-10T12:00:00.000Z",
      request_id: "req_health",
    };
  }
  if (endpointPath === "/metrics") {
    return {
      metrics: { counters: {}, activity_count: 0 },
      generated_at: "2026-05-10T12:00:00.000Z",
      request_id: "req_metrics",
    };
  }
  if (endpointPath === "/activity") {
    return {
      events: [],
      count: 0,
      request_id: "req_activity",
    };
  }
  if (endpointPath === "/workspace/status") {
    return {
      status: {
        available: false,
        backend: "unavailable",
      },
      execute_supported: false,
      request_id: "req_workspace_status",
    };
  }
  return { ok: true };
}
