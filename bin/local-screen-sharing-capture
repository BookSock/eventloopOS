#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/local-screen-sharing-capture [output.png]

Capture only the local macOS Screen Sharing window, not the whole desktop.

Environment:
  SCREEN_SHARING_OWNER   default: Screen Sharing
  SCREEN_SHARING_TITLE   optional title substring, e.g. Zeus
  SCREEN_SHARING_RAISE   default: 0; set 1 to raise/focus before capture
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

owner="${SCREEN_SHARING_OWNER:-Screen Sharing}"
title="${SCREEN_SHARING_TITLE:-}"
raise_requested="${SCREEN_SHARING_RAISE:-${EVENTLOOPOS_SCREEN_SHARING_RAISE:-0}}"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"
output="${1:-artifacts/screen-sharing-captures/$stamp-screen-sharing.png}"

case "$raise_requested" in
  1|true|TRUE|yes|YES|on|ON)
    do_raise=1
    ;;
  0|false|FALSE|no|NO|off|OFF|"")
    do_raise=0
    ;;
  *)
    echo "invalid SCREEN_SHARING_RAISE: $raise_requested (use 0 or 1)" >&2
    exit 2
    ;;
esac

raise_exit=0
if [[ "$do_raise" == "1" ]]; then
  osascript - "$owner" "$title" <<'APPLESCRIPT' >/dev/null 2>&1 || raise_exit=$?
on run argv
  set ownerNeedle to item 1 of argv
  set titleNeedle to ""
  if (count of argv) > 1 then set titleNeedle to item 2 of argv

  tell application "System Events"
    repeat with candidateProcess in application processes
      set candidateName to name of candidateProcess
      if candidateName contains ownerNeedle then
        tell candidateProcess
          set frontmost to true
          repeat with candidateWindow in windows
            set candidateTitle to name of candidateWindow
            if titleNeedle is "" or candidateTitle contains titleNeedle or candidateName contains titleNeedle then
              perform action "AXRaise" of candidateWindow
              exit repeat
            end if
          end repeat
        end tell
        exit repeat
      end if
    end repeat
  end tell
end run
APPLESCRIPT
  sleep 0.2
fi

set +e
window_id="$(
  swift - "$owner" "$title" <<'SWIFT'
import CoreGraphics
import Foundation

let ownerNeedle = CommandLine.arguments.count > 1 ? CommandLine.arguments[1].lowercased() : "screen sharing"
let titleNeedle = CommandLine.arguments.count > 2 ? CommandLine.arguments[2].lowercased() : ""
let options: CGWindowListOption = [.optionOnScreenOnly, .excludeDesktopElements]

guard let windows = CGWindowListCopyWindowInfo(options, kCGNullWindowID) as? [[String: Any]] else {
  exit(1)
}

for window in windows {
  let owner = (window[kCGWindowOwnerName as String] as? String ?? "")
  let title = (window[kCGWindowName as String] as? String ?? "")
  let layer = window[kCGWindowLayer as String] as? Int ?? -1
  guard layer == 0 else { continue }
  let ownerMatch = owner.lowercased().contains(ownerNeedle)
  let titleMatch = titleNeedle.isEmpty || title.lowercased().contains(titleNeedle) || owner.lowercased().contains(titleNeedle)
  guard ownerMatch && titleMatch else { continue }
  if let id = window[kCGWindowNumber as String] as? UInt32 {
    print(id)
    exit(0)
  }
}

exit(2)
SWIFT
)"
lookup_exit=$?
set -e

if [[ "$lookup_exit" -ne 0 || -z "$window_id" ]]; then
  if [[ -n "$title" ]]; then
    echo "Screen Sharing window not found for owner '$owner' and title containing '$title'. Open Screen Sharing, ensure it is not minimized, or set SCREEN_SHARING_TITLE to the visible window title substring." >&2
  else
    echo "Screen Sharing window not found for owner '$owner'. Open Screen Sharing and ensure it is not minimized." >&2
  fi
  exit "$lookup_exit"
fi

mkdir -p "$(dirname "$output")"
screencapture -x -l "$window_id" "$output"

manifest="${output%.png}.json"
cat >"$manifest" <<EOF
{
  "capture_mode": "local_screen_sharing_window",
  "window_id": "$window_id",
  "owner_filter": "$owner",
  "title_filter": "$title",
  "raise_requested": $(if [[ "$do_raise" == "1" ]]; then echo true; else echo false; fi),
  "raise_exit": $raise_exit,
  "output": "$output",
  "captured_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

echo "$output"
