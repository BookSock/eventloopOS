#!/usr/bin/env node
import fs from "node:fs";
import os from "node:os";
import path from "node:path";

const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/primitives-openapi-export [--check] [--self-test] [catalog.json] [openapi.json]

Exports deterministic OpenAPI 3.1 from docs/primitives.catalog.json.
Routes can opt into concrete schemas with request_schema, response_schema,
query_parameters, and root-level schemas entries.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  process.exit(0);
}

const check = args.includes("--check");
const positional = args.filter((arg) => arg !== "--check");
const catalogPath = positional[0] ?? "docs/primitives.catalog.json";
const outputPath = positional[1] ?? "docs/primitives.openapi.json";

const openapi = openapiFromCatalog(readJson(catalogPath));
const rendered = `${JSON.stringify(openapi, null, 2)}\n`;

if (check) {
  let existing;
  try {
    existing = fs.readFileSync(outputPath, "utf8");
  } catch (error) {
    console.error(`OpenAPI file missing: ${outputPath}`);
    process.exit(1);
  }
  if (existing !== rendered) {
    console.error(`OpenAPI export is stale: ${outputPath}`);
    console.error(`Run: bin/primitives-openapi-export ${catalogPath} ${outputPath}`);
    process.exit(1);
  }
  console.log(`primitives OpenAPI check passed: ${outputPath}`);
  process.exit(0);
}

fs.mkdirSync(path.dirname(outputPath), { recursive: true });
fs.writeFileSync(outputPath, rendered);
console.log(`wrote ${outputPath}`);

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function openapiFromCatalog(catalog) {
  if (!isRecord(catalog) || !Array.isArray(catalog.primitives)) {
    throw new Error("catalog must have primitives array");
  }

  const paths = {};
  const tagsByName = new Map();
  const seenOperations = new Set();
  for (const primitive of catalog.primitives) {
    if (!isRecord(primitive)) continue;
    const primitiveId = readString(primitive.id);
    const title = readString(primitive.title);
    if (!primitiveId || !title) continue;
    tagsByName.set(primitiveId, tagForPrimitive(primitive, primitiveId, title));

    if (!Array.isArray(primitive.http)) continue;
    for (const route of primitive.http) {
      if (!isRecord(route)) continue;
      const method = readString(route.method)?.toLowerCase();
      const routePath = readString(route.path);
      if (!method || !routePath) continue;
      const openapiPath = routePath.replace(/:([A-Za-z0-9_]+)/g, "{$1}");
      paths[openapiPath] ??= {};
      if (paths[openapiPath][method]) {
        throw new Error(`duplicate OpenAPI route collision: ${method.toUpperCase()} ${routePath} already exported at ${openapiPath}`);
      }
      const operationIdValue = operationId(primitiveId, method, routePath);
      if (seenOperations.has(operationIdValue)) {
        throw new Error(`duplicate OpenAPI operationId: ${operationIdValue}`);
      }
      seenOperations.add(operationIdValue);
      paths[openapiPath][method] = operationForRoute({
        primitive,
        primitiveId,
        title,
        method,
        routePath,
        openapiPath,
        routeFile: readString(route.route_file),
        operationId: operationIdValue,
        route,
      });
    }
  }

  return {
    openapi: "3.1.0",
    info: {
      title: "eventloopOS Primitive API",
      version: String(catalog.schema_version ?? 1),
      description: "OpenAPI 3.1 export generated from docs/primitives.catalog.json with shared request and response schema coverage.",
      license: catalog.license ? { name: String(catalog.license) } : undefined,
    },
    tags: Array.from(tagsByName.values()).sort((a, b) => a.name.localeCompare(b.name)),
    paths: sortObject(paths),
    components: {
      schemas: {
        FreeformJsonObject: {
          type: "object",
          additionalProperties: true,
        },
        ErrorEnvelope: {
          type: "object",
          additionalProperties: true,
          properties: {
            ok: { type: "boolean", const: false },
            code: { type: "string" },
            message: { type: "string" },
          },
        },
        ...readSchemas(catalog.schemas),
      },
    },
    "x-eventloopos-catalog": {
      schema_version: catalog.schema_version,
      generated_at: catalog.generated_at,
      primitive_count: catalog.primitives.length,
      source: "docs/primitives.catalog.json",
    },
  };
}

function operationForRoute(input) {
  const status = readString(input.primitive.status);
  const summary = `${input.title} ${input.method.toUpperCase()} ${input.routePath}`;
  const operation = {
    operationId: input.operationId ?? operationId(input.primitiveId, input.method, input.routePath),
    tags: [input.primitiveId],
    summary,
    description: readString(input.primitive.summary),
    parameters: pathParameters(input.routePath),
    responses: {
      "200": {
        description: "Successful response. See route implementation and tests for exact envelope.",
        content: {
          "application/json": {
            schema: schemaRefOrFreeform(input.route.response_schema),
          },
        },
      },
      default: {
        description: "Error response.",
        content: {
          "application/json": {
            schema: { $ref: "#/components/schemas/ErrorEnvelope" },
          },
        },
      },
    },
    "x-eventloopos-primitive": input.primitiveId,
    "x-eventloopos-status": status,
    "x-eventloopos-route-file": input.routeFile,
  };
  const budgets = latencyBudgetsForRoute(input.primitive, input.method, input.routePath);
  if (budgets.length > 0) operation["x-eventloopos-latency-budgets"] = budgets;
  const requestSchema = schemaRef(input.route.request_schema);
  if (["post", "put", "patch"].includes(input.method) && input.route.no_request_body !== true) {
    operation.requestBody = {
      required: input.route.request_body_required === true || (requestSchema ? input.route.request_body_required !== false : false),
      content: {
        "application/json": {
          schema: requestSchema ?? { $ref: "#/components/schemas/FreeformJsonObject" },
        },
      },
    };
  }
  const queryParameters = queryParametersForRoute(input.route.query_parameters ?? input.route.parameters);
  if (queryParameters.length > 0) operation.parameters.push(...queryParameters);
  if (operation.parameters.length === 0) delete operation.parameters;
  return operation;
}

function tagForPrimitive(primitive, primitiveId, title) {
  const budgets = latencyBudgetsForPrimitive(primitive);
  return compactRecord({
    name: primitiveId,
    description: `${title}: ${readString(primitive.summary) ?? ""}`.trim(),
    "x-eventloopos-status": readString(primitive.status),
    "x-eventloopos-responsiveness-critical": primitive.responsiveness_critical === true ? true : undefined,
    "x-eventloopos-code": stringList(primitive.code),
    "x-eventloopos-proofs": stringList(primitive.proofs),
    "x-eventloopos-self-tests": stringList(primitive.self_tests),
    "x-eventloopos-cli": stringList(primitive.cli),
    "x-eventloopos-latency-budgets": budgets.length > 0 ? budgets : undefined,
  });
}

function latencyBudgetsForRoute(primitive, method, routePath) {
  const route = `${method.toUpperCase()} ${routePath}`;
  return latencyBudgetsForPrimitive(primitive).filter((budget) => budget.route === route);
}

function latencyBudgetsForPrimitive(primitive) {
  if (!Array.isArray(primitive.latency_budgets)) return [];
  return primitive.latency_budgets
    .filter(isRecord)
    .map((budget) => compactRecord({
      name: readString(budget.name),
      p95_ms: typeof budget.p95_ms === "number" ? budget.p95_ms : undefined,
      scope: readString(budget.scope),
      route: readString(budget.route),
      hotkey: readString(budget.hotkey),
      proof: readString(budget.proof),
    }))
    .filter((budget) => budget.name && typeof budget.p95_ms === "number")
    .sort((a, b) => String(a.route ?? a.hotkey ?? a.name).localeCompare(String(b.route ?? b.hotkey ?? b.name)));
}

function stringList(value) {
  if (!Array.isArray(value)) return undefined;
  const values = value.map(readString).filter(Boolean).sort((a, b) => a.localeCompare(b));
  return values.length > 0 ? values : undefined;
}

function compactRecord(value) {
  const output = {};
  for (const [key, item] of Object.entries(value)) {
    if (item === undefined) continue;
    if (Array.isArray(item) && item.length === 0) continue;
    output[key] = item;
  }
  return output;
}

function pathParameters(routePath) {
  const params = [];
  const seen = new Set();
  for (const match of routePath.matchAll(/:([A-Za-z0-9_]+)/g)) {
    const name = match[1];
    if (!name || seen.has(name)) continue;
    seen.add(name);
    params.push({
      name,
      in: "path",
      required: true,
      schema: { type: "string" },
    });
  }
  return params;
}

function queryParametersForRoute(value) {
  if (!Array.isArray(value)) return [];
  return value
    .filter(isRecord)
    .map((parameter) => {
      const name = readString(parameter.name);
      if (!name) return undefined;
      const parameterLocation = readString(parameter.in);
      if (parameterLocation && parameterLocation !== "query") return undefined;
      return {
        name,
        in: "query",
        required: parameter.required === true,
        description: readString(parameter.description),
        schema: isRecord(parameter.schema) ? sortObject(parameter.schema) : { type: "string" },
      };
    })
    .filter(Boolean);
}

function readSchemas(value) {
  if (!isRecord(value)) return {};
  return sortObject(value);
}

function schemaRefOrFreeform(value) {
  return schemaRef(value) ?? { $ref: "#/components/schemas/FreeformJsonObject" };
}

function schemaRef(value) {
  if (typeof value === "string" && value.trim()) {
    const name = value.trim();
    return { $ref: name.startsWith("#/") ? name : `#/components/schemas/${name}` };
  }
  if (isRecord(value)) return sortObject(value);
  return undefined;
}

function operationId(primitiveId, method, routePath) {
  const slug = routePath
    .replace(/:([A-Za-z0-9_]+)/g, "by_$1")
    .replace(/[^A-Za-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "")
    .toLowerCase();
  return `${primitiveId}_${method}_${slug}`;
}

function sortObject(value) {
  if (Array.isArray(value)) return value.map(sortObject);
  if (!isRecord(value)) return value;
  const output = {};
  for (const key of Object.keys(value).sort()) {
    output[key] = sortObject(value[key]);
  }
  return output;
}

function readString(value) {
  return typeof value === "string" && value.trim() ? value.trim() : undefined;
}

function isRecord(value) {
  return typeof value === "object" && value !== null && !Array.isArray(value);
}

function runSelfTest() {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-primitives-openapi-"));
  const catalogPath = path.join(root, "catalog.json");
  const outputPath = path.join(root, "openapi.json");
  const catalog = {
    schema_version: 1,
    generated_at: "self-test",
    license: "AGPL-3.0-only",
    primitives: [{
      id: "task_control",
      title: "Task Control",
      status: "dogfood",
      summary: "Task primitive.",
      responsiveness_critical: true,
      http: [
        { method: "GET", path: "/tasks/:id/layout", route_file: "routes/tasks.ts" },
        {
          method: "POST",
          path: "/tasks",
          route_file: "routes/tasks.ts",
          request_schema: "CreateTaskRequest",
          request_body_required: false,
          response_schema: "CreateTaskResponse",
          parameters: [{ name: "dry_run", in: "query", schema: { type: "boolean" } }],
        },
        {
          method: "POST",
          path: "/tasks/:id/retry",
          route_file: "routes/tasks.ts",
          no_request_body: true,
          response_schema: "CreateTaskResponse",
        },
      ],
      code: ["routes/tasks.ts"],
      cli: ["eventloopos tasks create"],
      proofs: ["routes/tasks.test.ts"],
      self_tests: ["pnpm --filter @eventloopos/orchestrator test"],
      latency_budgets: [
        { name: "task_create", p95_ms: 250, route: "POST /tasks", scope: "local_orchestrator", proof: "bin/task-latency-proof" },
        { name: "task_focus", p95_ms: 100, hotkey: "Ctrl-Option-J", scope: "macos_app", proof: "bin/hotkey-proof" },
      ],
    }],
    schemas: {
      CreateTaskRequest: {
        type: "object",
        required: ["task_id"],
        properties: { task_id: { type: "string" } },
      },
      CreateTaskResponse: {
        type: "object",
        required: ["ok"],
        properties: { ok: { type: "boolean" } },
      },
    },
  };
  fs.writeFileSync(catalogPath, `${JSON.stringify(catalog, null, 2)}\n`);
  const generated = openapiFromCatalog(catalog);
  fs.writeFileSync(outputPath, `${JSON.stringify(generated, null, 2)}\n`);
  const checked = openapiFromCatalog(readJson(catalogPath));
  if (JSON.stringify(checked) !== JSON.stringify(generated)) {
    throw new Error("self-test export was not deterministic");
  }
  const getLayout = checked.paths["/tasks/{id}/layout"]?.get;
  if (!getLayout || getLayout.parameters?.[0]?.name !== "id") {
    throw new Error("self-test did not convert path parameter");
  }
  const postTasks = checked.paths["/tasks"]?.post;
  if (!postTasks?.requestBody) {
    throw new Error("self-test did not add JSON request body for POST");
  }
  if (postTasks.requestBody.content["application/json"].schema.$ref !== "#/components/schemas/CreateTaskRequest") {
    throw new Error("self-test did not wire request schema ref");
  }
  if (postTasks.requestBody.required !== false) {
    throw new Error("self-test did not allow optional request body");
  }
  if (postTasks.responses["200"].content["application/json"].schema.$ref !== "#/components/schemas/CreateTaskResponse") {
    throw new Error("self-test did not wire response schema ref");
  }
  if (postTasks.parameters?.[0]?.name !== "dry_run") {
    throw new Error("self-test did not wire query parameter");
  }
  const taskTag = checked.tags.find((tag) => tag.name === "task_control");
  if (!taskTag?.["x-eventloopos-responsiveness-critical"]) {
    throw new Error("self-test did not wire responsiveness metadata");
  }
  if (taskTag["x-eventloopos-cli"]?.[0] !== "eventloopos tasks create") {
    throw new Error("self-test did not wire primitive CLI metadata");
  }
  if (postTasks["x-eventloopos-latency-budgets"]?.[0]?.name !== "task_create") {
    throw new Error("self-test did not wire route latency budget metadata");
  }
  const retryTask = checked.paths["/tasks/{id}/retry"]?.post;
  if (!retryTask || retryTask.requestBody) {
    throw new Error("self-test did not omit request body for no_request_body route");
  }
  const duplicateRouteCatalog = structuredClone(catalog);
  duplicateRouteCatalog.primitives[0].http.push({
    method: "GET",
    path: "/tasks/:id/layout",
    route_file: "routes/tasks.ts",
    no_request_body: true,
    response_schema: "CreateTaskResponse",
  });
  assertThrows(() => openapiFromCatalog(duplicateRouteCatalog), /duplicate OpenAPI route collision/);
  fs.rmSync(root, { recursive: true, force: true });
  console.log("primitives-openapi-export self-test passed");
}

function assertThrows(fn, pattern) {
  try {
    fn();
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    if (!pattern.test(message)) {
      throw new Error(`expected error matching ${pattern}, got ${message}`);
    }
    return;
  }
  throw new Error(`expected function to throw ${pattern}`);
}
