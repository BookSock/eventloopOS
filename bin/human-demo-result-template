#!/usr/bin/env node
import fs from "node:fs";
import path from "node:path";
import { renderHumanDemoPassFailTemplate } from "./lib/human-demo-checklist.mjs";

const repoRoot = path.resolve(path.dirname(new URL(import.meta.url).pathname), "..");
const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/human-demo-result-template [--manifest artifacts/lab-runs/.../manifest.json] [--json] [--write|--output path] [--allow-stale-readiness]

Print a prefilled human dogfood result template from the latest Mac Studio
human-demo artifact. Writes require green human-demo readiness latency gates
unless --allow-stale-readiness is used for debugging.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  const manifest = {
    ok: true,
    generated_at: "2026-06-03T20:27:42.336Z",
    proofs: {
      demo_queue: { count: 3 },
      ambient_autosave: { ok: true },
      new_window_autosave: { ok: true },
      foreign_window_containment: { ok: true },
      agent_spawn_window_containment: { ok: true, spawned_app: "Google Chrome" },
      agent_waiting_paper: { ok: true },
      metrics_restore: { ok: true },
      final_ready_customer_restore: { ok: true },
    },
  };
  const rendered = renderTemplate({
    manifestPath: "artifacts/lab-runs/20260603-132623-human-demo/manifest.json",
    screenshotPath: "artifacts/lab-runs/20260603-132623-human-demo/screen-sharing.png",
    readyManifestPath: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/manifest.json",
    readyScreenshotPath: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/screen-sharing.png",
    manifest,
    ready: {
      checks: {
        screen_sharing_capture_ok: true,
        final_handoff_current_feedback_ok: true,
        queue_briefing_strip_visible: true,
        paper_reminder_hud_visible: true,
        queue_latency_ok: true,
        workspace_latency_ok: true,
        paper_reminder_feedback_ok: true,
        master_command_hotkey_ok: true,
        manual_mode_feedback_ok: true,
        hotkey_feedback_latency_ok: true,
      },
      queue_latency_required: true,
      workspace_latency_required: true,
      paper_reminder_feedback_required: true,
      master_command_hotkey_required: true,
      manual_mode_feedback_required: true,
      hotkey_latency_required: true,
      queue_latency: {
        manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/queue-latency.json",
      },
      workspace_latency: {
        manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/workspace-latency.json",
      },
      paper_reminder_feedback: {
        manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/paper-reminder-feedback.json",
      },
      master_command_hotkey: {
        manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/master-command-hotkey.json",
      },
      manual_mode_feedback: {
        enter: {
          manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/manual-mode-enter-feedback.json",
        },
      },
      hotkey_feedback_latency: {
        manifest_path: "artifacts/lab-runs/20260603T205150Z-human-demo-ready/hotkey-latency.json",
      },
    },
  });
  assertIncludes(rendered, "Human demo date: 2026-06-03");
  assertIncludes(rendered, "Proof manifest: artifacts/lab-runs/20260603-132623-human-demo/manifest.json");
  assertIncludes(rendered, "Screenshot: artifacts/lab-runs/20260603-132623-human-demo/screen-sharing.png");
  assertIncludes(rendered, "Readiness manifest: artifacts/lab-runs/20260603T205150Z-human-demo-ready/manifest.json");
  assertIncludes(rendered, "Readiness screenshot: artifacts/lab-runs/20260603T205150Z-human-demo-ready/screen-sharing.png");
  assertIncludes(rendered, "Readiness queue latency: artifacts/lab-runs/20260603T205150Z-human-demo-ready/queue-latency.json ok=true required=true");
  assertIncludes(rendered, "Readiness workspace latency: artifacts/lab-runs/20260603T205150Z-human-demo-ready/workspace-latency.json ok=true required=true");
  assertIncludes(rendered, "Readiness desktop HUD feedback: artifacts/lab-runs/20260603T205150Z-human-demo-ready/paper-reminder-feedback.json ok=true required=true");
  assertIncludes(rendered, "Readiness master command hotkey: artifacts/lab-runs/20260603T205150Z-human-demo-ready/master-command-hotkey.json ok=true required=true");
  assertIncludes(rendered, "Readiness manual mode feedback: artifacts/lab-runs/20260603T205150Z-human-demo-ready/manual-mode-enter-feedback.json ok=true required=true");
  assertIncludes(rendered, "Readiness hotkey latency: artifacts/lab-runs/20260603T205150Z-human-demo-ready/hotkey-latency.json ok=true required=true");
  assertIncludes(rendered, "Automated proof: ok=true, queue_count=3, ambient_autosave=true, new_window_autosave=true, foreign_window_containment=true, agent_spawn_window_containment=true, agent_spawn_app=Google Chrome, agent_waiting_paper=true");
  assertIncludes(rendered, "- Starting state on demo-customer with Queue visible: pass - automated proof: readiness screenshot and queue state green");
  assertIncludes(rendered, "- Moving shared TextEdit is remembered after 2-3 seconds: pass - automated proof: ambient autosave saved moved shared window");
  assertIncludes(rendered, "- Rectangle hotkeys feel usable:");
  assertIncludes(rendered, "- Manual Mode entry/return works: pass - automated proof: Manual Mode hotkey feedback gate green");
  assertEqual(defaultOutputPath(manifest), "artifacts/human-demo-results/20260603T202742Z-human-demo-result.md");
  const staleReadiness = readinessSummary({});
  assertEqual(staleReadiness.ok, false);
  assertEqual(staleReadiness.failed_gates.join(","), "readiness_ok,queue_latency_ok,workspace_latency_ok,manual_mode_feedback_ok");
  const failedFreshnessReadiness = readinessSummary({
    ok: false,
    failed_checks: ["latest_human_demo_proof_fresh"],
    checks: {
      queue_latency_ok: true,
      workspace_latency_ok: true,
      manual_mode_feedback_ok: true,
      hotkey_feedback_latency_ok: true,
    },
    queue_latency_required: true,
    workspace_latency_required: true,
    manual_mode_feedback_required: true,
    hotkey_latency_required: true,
    queue_latency: { manifest_path: "queue.json" },
    workspace_latency: { manifest_path: "workspace.json" },
    manual_mode_feedback: { enter: { manifest_path: "manual.json" } },
    hotkey_feedback_latency: { manifest_path: "hotkey.json" },
  });
  assertEqual(failedFreshnessReadiness.ok, false);
  assertEqual(failedFreshnessReadiness.failed_gates.join(","), "latest_human_demo_proof_fresh");
  console.log("human-demo-result-template self-test passed");
  process.exit(0);
}

const json = args.includes("--json");
const write = args.includes("--write");
const allowStaleReadiness = args.includes("--allow-stale-readiness");
const manifestArg = valueAfter("--manifest");
const outputArg = valueAfter("--output");
const manifestPath = manifestArg ?? latestManifestPath();
if (!manifestPath) {
  console.error("No human-demo manifest found under artifacts/lab-runs. Run bin/lab-mac-human-demo-setup first.");
  process.exit(1);
}

const absoluteManifestPath = path.resolve(repoRoot, manifestPath);
const manifest = readJson(absoluteManifestPath);
const relativeManifestPath = path.relative(repoRoot, absoluteManifestPath);
const screenshotPath = findScreenshotPath(path.dirname(absoluteManifestPath));
const screenshotOk = imageArtifactOk(screenshotPath);
const readyManifestPath = latestReadyManifestPath();
const ready = readyManifestPath ? readJson(path.resolve(repoRoot, readyManifestPath)) : undefined;
const readyScreenshotPath = ready?.screen_sharing_capture?.output ?? "";
const suggestedOutputPath = outputArg ?? defaultOutputPath(manifest);
const outputPath = write || outputArg ? suggestedOutputPath : "";
const template = renderTemplate({
  manifestPath: relativeManifestPath,
  screenshotPath,
  readyManifestPath,
  readyScreenshotPath,
  manifest,
  ready,
});
const readiness = readinessSummary(ready);
const demoTaskSessions = Array.isArray(manifest.task_sessions) ? manifest.task_sessions : [];
const demoTaskSessionsOk = demoTaskSessionBound(manifest, "task_demo_customer")
  && demoTaskSessionBound(manifest, "task_demo_metrics");
if (outputPath) {
  if (!allowStaleReadiness && readiness.ok !== true) {
    console.error("Latest human-demo readiness is not green. Run `bin/human-demo-ready`, then retry.");
    console.error(`Readiness manifest: ${readyManifestPath ?? "(missing)"}`);
    console.error(`Failed readiness gates: ${readiness.failed_gates.join(", ") || "(unknown)"}`);
    console.error("Use --allow-stale-readiness only for debugging.");
    process.exit(1);
  }
  if (!allowStaleReadiness && screenshotOk !== true) {
    console.error("Latest human-demo proof screenshot is missing or invalid. Run `bin/lab-mac-human-demo-setup`, then `bin/human-demo-ready`, then retry.");
    console.error(`Proof manifest: ${relativeManifestPath}`);
    console.error(`Screenshot: ${screenshotPath || "(missing)"}`);
    console.error("Use --allow-stale-readiness only for debugging.");
    process.exit(1);
  }
  const absoluteOutputPath = path.resolve(repoRoot, outputPath);
  fs.mkdirSync(path.dirname(absoluteOutputPath), { recursive: true });
  fs.writeFileSync(absoluteOutputPath, template, "utf8");
}
const result = {
  manifest_path: relativeManifestPath,
  git: manifest.git ?? null,
  screenshot_path: screenshotPath,
  screenshot_ok: screenshotOk,
  readiness_manifest_path: readyManifestPath,
  readiness_screenshot_path: readyScreenshotPath,
  readiness_queue_latency_path: readiness.queue.path,
  readiness_workspace_latency_path: readiness.workspace.path,
  readiness_paper_reminder_feedback_path: readiness.paperReminderFeedback.path,
  readiness_master_command_hotkey_path: readiness.masterCommandHotkey.path,
  readiness_manual_mode_feedback_path: readiness.manualModeFeedback.path,
  readiness_hotkey_latency_path: readiness.hotkey.path,
  readiness_queue_latency_ok: readiness.queue.ok,
  readiness_workspace_latency_ok: readiness.workspace.ok,
  readiness_paper_reminder_feedback_ok: readiness.paperReminderFeedback.ok,
  readiness_master_command_hotkey_ok: readiness.masterCommandHotkey.ok,
  readiness_manual_mode_feedback_ok: readiness.manualModeFeedback.ok,
  readiness_hotkey_latency_ok: readiness.hotkey.ok,
  readiness_ok: readiness.ok,
  readiness_failed_gates: readiness.failed_gates,
  ready_to_write: allowStaleReadiness || (readiness.ok === true && screenshotOk === true),
  suggested_output_path: suggestedOutputPath,
  output_path: outputPath,
  ok: manifest.ok === true,
  queue_count: manifest.proofs?.demo_queue?.count ?? null,
  demo_task_session_count: demoTaskSessions.length,
  demo_task_sessions_ok: demoTaskSessionsOk,
  ambient_autosave_ok: manifest.proofs?.ambient_autosave?.ok === true,
  new_window_autosave_ok: manifest.proofs?.new_window_autosave?.ok === true,
  foreign_window_containment_ok: manifest.proofs?.foreign_window_containment?.ok === true,
  agent_spawn_window_containment_ok: manifest.proofs?.agent_spawn_window_containment?.ok === true,
  agent_spawn_window_containment_app: manifest.proofs?.agent_spawn_window_containment?.spawned_app ?? null,
  agent_spawn_window_containment_chrome_ok: manifest.proofs?.agent_spawn_window_containment?.ok === true
    && manifest.proofs?.agent_spawn_window_containment?.spawned_app === "Google Chrome",
  agent_waiting_paper_ok: manifest.proofs?.agent_waiting_paper?.ok === true,
  generated_at: manifest.generated_at ?? null,
  template,
};

if (json) {
  console.log(JSON.stringify(result, null, 2));
} else if (outputPath) {
  console.log(outputPath);
} else {
  console.log(result.template);
}

function demoTaskSessionBound(manifest, taskId) {
  const sessions = Array.isArray(manifest.task_sessions) ? manifest.task_sessions : [];
  return sessions.some((session) =>
    session?.ok === true
      && session.task_id === taskId
      && typeof session.task_session_id === "string"
      && session.task_session_id.length > 0
  );
}

function valueAfter(flag) {
  const index = args.indexOf(flag);
  if (index === -1) return undefined;
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    console.error(`Missing value for ${flag}`);
    process.exit(2);
  }
  return value;
}

function latestManifestPath() {
  const labRuns = path.join(repoRoot, "artifacts", "lab-runs");
  if (!fs.existsSync(labRuns)) return undefined;
  const candidates = fs.readdirSync(labRuns, { withFileTypes: true })
    .filter((entry) => entry.isDirectory() && entry.name.endsWith("-human-demo"))
    .map((entry) => path.join(labRuns, entry.name, "manifest.json"))
    .filter((candidate) => fs.existsSync(candidate))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(repoRoot, latest) : undefined;
}

function latestReadyManifestPath() {
  const labRuns = path.join(repoRoot, "artifacts", "lab-runs");
  if (!fs.existsSync(labRuns)) return undefined;
  const candidates = fs.readdirSync(labRuns, { withFileTypes: true })
    .filter((entry) => entry.isDirectory() && entry.name.endsWith("-human-demo-ready"))
    .map((entry) => path.join(labRuns, entry.name, "manifest.json"))
    .filter((candidate) => fs.existsSync(candidate))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(repoRoot, latest) : undefined;
}

function defaultOutputPath(manifest) {
  const stamp = (manifest.generated_at ?? new Date().toISOString()).replace(/[-:]/g, "").replace(/\.\d{3}Z$/, "Z");
  return path.join("artifacts", "human-demo-results", `${stamp}-human-demo-result.md`);
}

function readJson(filePath) {
  try {
    return JSON.parse(fs.readFileSync(filePath, "utf8"));
  } catch (error) {
    console.error(`Could not read JSON manifest: ${filePath}`);
    console.error(error instanceof Error ? error.message : String(error));
    process.exit(1);
  }
}

function findScreenshotPath(runDir) {
  for (const name of ["screen-sharing.png", "screen-sharing.jpg"]) {
    const candidate = path.join(runDir, name);
    if (fs.existsSync(candidate)) return path.relative(repoRoot, candidate);
  }
  return "";
}

function imageArtifactOk(relativePath) {
  if (!relativePath) return false;
  try {
    const absolutePath = path.resolve(repoRoot, relativePath);
    const stat = fs.statSync(absolutePath);
    return stat.isFile() && stat.size > 0;
  } catch {
    return false;
  }
}

function renderTemplate({ manifestPath, screenshotPath, readyManifestPath, readyScreenshotPath, manifest, ready }) {
  const date = manifest.generated_at ? manifest.generated_at.slice(0, 10) : "";
  const queueCount = manifest.proofs?.demo_queue?.count ?? "";
  const ambientOk = manifest.proofs?.ambient_autosave?.ok === true ? "true" : "false";
  const newWindowOk = manifest.proofs?.new_window_autosave?.ok === true ? "true" : "false";
  const containmentOk = manifest.proofs?.foreign_window_containment?.ok === true ? "true" : "false";
  const agentSpawn = manifest.proofs?.agent_spawn_window_containment;
  const agentSpawnContainmentOk = agentSpawn?.ok === true ? "true" : "false";
  const agentSpawnApp = agentSpawn?.spawned_app ?? "unknown";
  const agentWaitingOk = manifest.proofs?.agent_waiting_paper?.ok === true ? "true" : "false";
  const readiness = readinessSummary(ready);
  const passFailValues = automatedPassFailValues({ manifest, ready, readiness });
  return `Human demo date: ${date}
Mac: Mac Studio
Proof manifest: ${manifestPath}
Screenshot: ${screenshotPath}
Readiness manifest: ${readyManifestPath ?? ""}
Readiness screenshot: ${readyScreenshotPath ?? ""}
Readiness queue latency: ${readiness.queue.path} ok=${readiness.queue.ok} required=${readiness.queue.required}
Readiness workspace latency: ${readiness.workspace.path} ok=${readiness.workspace.ok} required=${readiness.workspace.required}
Readiness desktop HUD feedback: ${readiness.paperReminderFeedback.path} ok=${readiness.paperReminderFeedback.ok} required=${readiness.paperReminderFeedback.required}
Readiness master command hotkey: ${readiness.masterCommandHotkey.path} ok=${readiness.masterCommandHotkey.ok} required=${readiness.masterCommandHotkey.required}
Readiness manual mode feedback: ${readiness.manualModeFeedback.path} ok=${readiness.manualModeFeedback.ok} required=${readiness.manualModeFeedback.required}
Readiness hotkey latency: ${readiness.hotkey.path} ok=${readiness.hotkey.ok} required=${readiness.hotkey.required}
Automated proof: ok=${manifest.ok === true}, queue_count=${queueCount}, ambient_autosave=${ambientOk}, new_window_autosave=${newWindowOk}, foreign_window_containment=${containmentOk}, agent_spawn_window_containment=${agentSpawnContainmentOk}, agent_spawn_app=${agentSpawnApp}, agent_waiting_paper=${agentWaitingOk}

Pass/fail:
${renderHumanDemoPassFailTemplate(passFailValues)}

Friction:
- 

Ship/block decision:
`;
}

function automatedPassFailValues({ manifest, ready, readiness }) {
  const values = {};
  const proofs = manifest.proofs ?? {};
  setIf(values, "Starting state on demo-customer with Queue visible", ready?.checks?.screen_sharing_capture_ok === true, "readiness screenshot and queue state green");
  setIf(values, "Ctrl-Option-R restores Customer paper", ready?.checks?.hotkey_feedback_latency_ok === true && ready?.checks?.final_handoff_current_feedback_ok === true, "restore hotkey feedback and final handoff green");
  setIf(values, "Moving shared TextEdit is remembered after 2-3 seconds", proofs.ambient_autosave?.ok === true, "ambient autosave saved moved shared window");
  setIf(values, "Automated new scratch window is remembered by current paper", proofs.new_window_autosave?.ok === true, "new scratch window saved into current paper context");
  setIf(values, "Metrics paper brings same TextEdit to metrics position", proofs.metrics_restore?.ok === true, "shared TextEdit restored on Metrics paper");
  setIf(values, "Customer paper brings same TextEdit back to customer position", proofs.final_ready_customer_restore?.ok === true || proofs.ready_customer_restore?.ok === true, "shared TextEdit restored on Customer paper");
  setIf(values, "Background window containment proof passed", proofs.foreign_window_containment?.ok === true, "foreign Metrics window redirected back home");
  setIf(values, "Agent-spawned window containment proof passed", proofs.agent_spawn_window_containment?.ok === true, `agent-spawned ${proofs.agent_spawn_window_containment?.spawned_app ?? "window"} redirected home`);
  setIf(values, "Waiting agent paper appears in queue", proofs.agent_waiting_paper?.ok === true, "waiting agent run created human-needed paper");
  setIf(values, "Paper briefing strip shows current decision", ready?.checks?.queue_briefing_strip_visible === true, "readiness saw Queue briefing strip");
  setIf(values, "Desktop paper reminder HUD is visible", ready?.checks?.paper_reminder_hud_visible === true, "readiness saw desktop HUD");
  setIf(values, "Manual Mode entry/return works", ready?.checks?.manual_mode_feedback_ok === true, "Manual Mode hotkey feedback gate green");
  setIf(values, "Master Command opens with current task hint", ready?.checks?.master_command_hotkey_ok === true, "Master Command hotkey proof green");
  setIf(values, "Queue/HUD hotkey feedback is visible and current", ready?.checks?.paper_reminder_feedback_ok === true && ready?.checks?.hotkey_feedback_latency_ok === true, "Queue and HUD feedback gates green");
  setIf(values, "Queue/master latency readiness gate passed", readiness.queue.ok === true && readiness.masterCommandHotkey.ok === true, "queue latency and Master Command gates green");
  setIf(values, "Workspace capture/restore-plan latency readiness gate passed", readiness.workspace.ok === true, "workspace latency gate green");
  setIf(values, "Hotkey feedback latency readiness gate passed or skipped intentionally", readiness.hotkey.ok === true, readiness.hotkey.required ? "hotkey feedback latency gate green" : "hotkey feedback latency skipped intentionally");
  return values;
}

function setIf(values, label, condition, proof) {
  if (condition) values[label] = `pass - automated proof: ${proof}`;
}

function readinessSummary(ready) {
  const gates = {
    queue: readinessGate(ready, "queue_latency", "queue_latency_ok", "queue_latency_required", true),
    workspace: readinessGate(ready, "workspace_latency", "workspace_latency_ok", "workspace_latency_required", true),
    paperReminderFeedback: readinessGate(ready, "paper_reminder_feedback", "paper_reminder_feedback_ok", "paper_reminder_feedback_required", false),
    masterCommandHotkey: readinessGate(ready, "master_command_hotkey", "master_command_hotkey_ok", "master_command_hotkey_required", false),
    manualModeFeedback: readinessGate(ready, "manual_mode_feedback", "manual_mode_feedback_ok", "manual_mode_feedback_required", true),
    hotkey: readinessGate(ready, "hotkey_feedback_latency", "hotkey_feedback_latency_ok", "hotkey_latency_required", false),
  };
  const failedGates = [];
  if (ready?.ok !== true) {
    if (Array.isArray(ready?.failed_checks) && ready.failed_checks.length > 0) {
      failedGates.push(...ready.failed_checks);
    } else {
      failedGates.push("readiness_ok");
    }
  }
  if (!gates.queue.ok) failedGates.push("queue_latency_ok");
  if (!gates.workspace.ok) failedGates.push("workspace_latency_ok");
  if (!gates.paperReminderFeedback.ok) failedGates.push("paper_reminder_feedback_ok");
  if (!gates.masterCommandHotkey.ok) failedGates.push("master_command_hotkey_ok");
  if (!gates.manualModeFeedback.ok) failedGates.push("manual_mode_feedback_ok");
  if (!gates.hotkey.ok) failedGates.push("hotkey_feedback_latency_ok");
  const uniqueFailedGates = [...new Set(failedGates)];
  return {
    ...gates,
    ok: uniqueFailedGates.length === 0,
    failed_gates: uniqueFailedGates,
  };
}

function readinessGate(ready, sectionKey, checkKey, requiredKey, defaultRequired) {
  const section = ready?.[sectionKey];
  const required = typeof ready?.[requiredKey] === "boolean" ? ready[requiredKey] : defaultRequired;
  const skipped = section?.skipped === true;
  const pathValue = typeof section?.manifest_path === "string"
    ? section.manifest_path
    : typeof section?.enter?.manifest_path === "string"
      ? section.enter.manifest_path
      : "";
  const pathOrSkipped = skipped ? "skipped" : pathValue;
  const checkOk = ready?.checks?.[checkKey] === true || section?.ok === true;
  return {
    path: pathOrSkipped,
    ok: checkOk || required === false,
    required,
  };
}

function assertIncludes(value, expected) {
  if (!value.includes(expected)) {
    throw new Error(`expected output to include ${expected}`);
  }
}

function assertEqual(actual, expected) {
  if (actual !== expected) {
    throw new Error(`expected ${String(expected)}, got ${String(actual)}`);
  }
}
