#!/usr/bin/env node
import assert from "node:assert/strict";
import crypto from "node:crypto";
import fs from "node:fs";
import os from "node:os";
import { spawnSync } from "node:child_process";
import path from "node:path";
import process from "node:process";
import { humanDemoPassFailLabels, renderFilledHumanDemoPassFail } from "./lib/human-demo-checklist.mjs";

const repoRoot = path.resolve(import.meta.dirname, "..");
let artifactRoot = repoRoot;
process.chdir(repoRoot);

const args = process.argv.slice(2);
const jsonOnly = args.includes("--json");
const includeLabStatus = args.includes("--lab-status");
const outputArg = valueAfter("--output");
const positionalArgs = positionalArguments();

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/human-demo-result-verify [artifacts/human-demo-results/...md] [--json] [--lab-status] [--output path]

Verify a filled human demo result artifact. Use --lab-status after Jason's
hands-on pass to also prove the Mac Studio dogfood stack is still healthy.
Writes a verification manifest by default.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  console.log("human-demo-result-verify self-test passed");
  process.exit(0);
}

const resultPath = positionalArgs[0] ?? latestResultPath();
if (!resultPath) {
  console.error("No human demo result found. Run `bin/human-demo-result-template --write`, fill it, then retry.");
  process.exit(1);
}

const absoluteResultPath = path.resolve(repoRoot, resultPath);
const text = fs.readFileSync(absoluteResultPath, "utf8");
const verification = verifyResultText(text);
let labStatus;
if (includeLabStatus) {
  labStatus = runLabStatus();
}

const failedChecks = [
  ...verification.failed_checks,
  ...(labStatus && labStatus.ok !== true ? ["lab_status_ok"] : []),
];
const artifactDir = defaultArtifactDir();
const manifestPath = outputArg ?? path.join(artifactDir, "manifest.json");
const output = {
  schema_version: 1,
  kind: "eventloopos.human_demo_result_verify",
  verified_at: new Date().toISOString(),
  artifact_dir: path.dirname(manifestPath),
  verification_manifest_path: manifestPath,
  result_path: path.relative(repoRoot, absoluteResultPath),
  result_sha256: sha256(text),
  ok: failedChecks.length === 0,
  passed: failedChecks.length === 0,
  failed_checks: failedChecks,
  checks: {
    ...verification.checks,
    ...(labStatus ? { lab_status_ok: labStatus.ok === true } : {}),
  },
  pass_fail: verification.pass_fail,
  friction: verification.friction,
  ship_block_decision: verification.ship_block_decision,
  lab_status: labStatus,
};
writeJsonManifest(manifestPath, output);

if (jsonOnly) {
  console.log(JSON.stringify(output, null, 2));
} else {
  console.log(`human demo result: ${output.result_path}`);
  console.log(`verification manifest: ${output.verification_manifest_path}`);
  console.log(`verified: ${output.ok ? "yes" : "no"}`);
  if (output.failed_checks.length > 0) console.log(`failed checks: ${output.failed_checks.join(", ")}`);
  console.log(JSON.stringify(output, null, 2));
}

process.exit(output.ok ? 0 : 1);

function latestResultPath() {
  const dir = path.join(repoRoot, "artifacts", "human-demo-results");
  if (!fs.existsSync(dir)) return undefined;
  const candidates = fs.readdirSync(dir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith("-human-demo-result.md"))
    .map((entry) => path.join(dir, entry.name))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(repoRoot, latest) : undefined;
}

function valueAfter(flag) {
  const index = args.indexOf(flag);
  if (index === -1) return undefined;
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    console.error(`Missing value for ${flag}`);
    process.exit(2);
  }
  return value;
}

function positionalArguments() {
  const result = [];
  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];
    if (arg === "--output") {
      index += 1;
      continue;
    }
    if (arg.startsWith("--")) continue;
    result.push(arg);
  }
  return result;
}

function defaultArtifactDir() {
  return path.join("artifacts", "human-demo-verifications", `${utcStamp()}-human-demo-result-verify`);
}

function writeJsonManifest(relativePath, value) {
  const absolutePath = path.resolve(repoRoot, relativePath);
  fs.mkdirSync(path.dirname(absolutePath), { recursive: true });
  fs.writeFileSync(absolutePath, `${JSON.stringify(value, null, 2)}\n`, "utf8");
}

function utcStamp() {
  return new Date().toISOString().replace(/[-:]/g, "").replace(/\.\d{3}Z$/, "Z");
}

function verifyResultText(text) {
  const lines = text.split(/\r?\n/);
  const artifactRefs = {
    proof_manifest: fieldOrSectionText(lines, "Proof manifest:", "Screenshot:").trim(),
    proof_screenshot: fieldOrSectionText(lines, "Screenshot:", "Readiness manifest:").trim(),
    readiness_manifest: fieldOrSectionText(lines, "Readiness manifest:", "Readiness screenshot:").trim(),
    readiness_screenshot: fieldOrSectionText(lines, "Readiness screenshot:", "Readiness queue latency:").trim(),
  };
  const passFail = parsePassFail(lines);
  const friction = sectionText(lines, "Friction:", "Ship/block decision:").trim();
  const decision = fieldOrSectionText(lines, "Ship/block decision:", undefined).trim();
  const readinessLatency = {
    queue: fieldOrSectionText(lines, "Readiness queue latency:", "Readiness workspace latency:").trim(),
    workspace: fieldOrSectionText(lines, "Readiness workspace latency:", "Readiness desktop HUD feedback:").trim(),
    paperReminderFeedback: fieldOrSectionText(lines, "Readiness desktop HUD feedback:", "Readiness master command hotkey:").trim(),
    masterCommandHotkey: fieldOrSectionText(lines, "Readiness master command hotkey:", "Readiness manual mode feedback:").trim(),
    manualModeFeedback: fieldOrSectionText(lines, "Readiness manual mode feedback:", "Readiness hotkey latency:").trim(),
    hotkey: fieldOrSectionText(lines, "Readiness hotkey latency:", "Automated proof:").trim(),
  };
  const missingLabels = humanDemoPassFailLabels.filter((label) => !Object.hasOwn(passFail, label));
  const blankLabels = humanDemoPassFailLabels.filter((label) => Object.hasOwn(passFail, label) && passFail[label].trim() === "");
  const blockingLabels = humanDemoPassFailLabels.filter((label) => Object.hasOwn(passFail, label) && passFail[label].trim() !== "" && !isAcceptablePassFail(passFail[label]));
  const artifactChecks = {
    proof_manifest_ok: jsonManifestOk(artifactRefs.proof_manifest),
    proof_screenshot_ok: imageArtifactOk(artifactRefs.proof_screenshot),
    readiness_manifest_ok: jsonManifestOk(artifactRefs.readiness_manifest),
    readiness_screenshot_ok: imageArtifactOk(artifactRefs.readiness_screenshot),
  };
  const checks = {
    ...artifactChecks,
    all_expected_pass_fail_items_present: missingLabels.length === 0,
    all_pass_fail_items_filled: blankLabels.length === 0,
    pass_fail_items_passed_or_accepted: blockingLabels.length === 0,
    readiness_queue_latency_ok: latencyLineOk(readinessLatency.queue),
    readiness_workspace_latency_ok: latencyLineOk(readinessLatency.workspace),
    readiness_desktop_hud_feedback_ok: latencyLineOk(readinessLatency.paperReminderFeedback),
    readiness_master_command_hotkey_ok: latencyLineOk(readinessLatency.masterCommandHotkey),
    readiness_manual_mode_feedback_ok: latencyLineOk(readinessLatency.manualModeFeedback),
    readiness_hotkey_latency_ok: latencyLineOk(readinessLatency.hotkey),
    friction_has_no_blocker: frictionHasNoBlocker(friction),
    ship_block_decision_accepts: decisionAccepts(decision),
  };
  const failedChecks = Object.entries(checks).filter(([, ok]) => ok !== true).map(([key]) => key);
  return {
    checks,
    failed_checks: failedChecks,
    pass_fail: {
      items: passFail,
      missing_labels: missingLabels,
      blank_labels: blankLabels,
      blocking_labels: blockingLabels,
    },
    artifact_refs: artifactRefs,
    readiness_latency: readinessLatency,
    friction,
    ship_block_decision: decision,
  };
}

function parsePassFail(lines) {
  const text = sectionText(lines, "Pass/fail:", "Friction:");
  const items = {};
  for (const line of text.split(/\r?\n/)) {
    const match = line.match(/^\s*-\s*(.+?):\s*(.*)$/);
    if (!match) continue;
    items[match[1].trim()] = match[2].trim();
  }
  return items;
}

function sectionText(lines, startMarker, endMarker) {
  const start = lines.findIndex((line) => line.trim() === startMarker);
  if (start === -1) return "";
  const afterStart = start + 1;
  const end = endMarker
    ? lines.findIndex((line, index) => index > start && line.trim() === endMarker)
    : lines.length;
  return lines.slice(afterStart, end === -1 ? lines.length : end).join("\n");
}

function fieldOrSectionText(lines, startMarker, endMarker) {
  const start = lines.findIndex((line) => line.trim() === startMarker || line.trim().startsWith(startMarker));
  if (start === -1) return "";
  const trimmed = lines[start].trim();
  const inline = trimmed.slice(startMarker.length).trim();
  if (inline) return inline;
  const afterStart = start + 1;
  const end = endMarker
    ? lines.findIndex((line, index) => index > start && line.trim() === endMarker)
    : lines.length;
  return lines.slice(afterStart, end === -1 ? lines.length : end).join("\n");
}

function jsonManifestOk(relativePath) {
  if (!relativePath) return false;
  try {
    const value = JSON.parse(fs.readFileSync(resolveArtifactPath(relativePath), "utf8"));
    return value?.ok === true || value?.passed === true;
  } catch {
    return false;
  }
}

function imageArtifactOk(relativePath) {
  if (!relativePath) return false;
  try {
    const absolutePath = resolveArtifactPath(relativePath);
    const stat = fs.statSync(absolutePath);
    if (!stat.isFile() || stat.size <= 0) return false;
    const dimensions = parseImageDimensions(fs.readFileSync(absolutePath));
    return dimensions.width > 0 && dimensions.height > 0;
  } catch {
    return false;
  }
}

function resolveArtifactPath(relativePath) {
  const absolutePath = path.resolve(artifactRoot, relativePath);
  const relativeToRoot = path.relative(artifactRoot, absolutePath);
  if (relativeToRoot.startsWith("..") || path.isAbsolute(relativeToRoot)) {
    throw new Error(`artifact path escapes repo: ${relativePath}`);
  }
  return absolutePath;
}

function isAcceptablePassFail(value) {
  const normalized = normalize(value);
  if (/\b(pass|passed|ok|yes|works|good|accept|accepted)\b/.test(normalized)) return true;
  const mentionsFailure = /\b(fail|failed|no|broken|miss|missed|wrong)\b/.test(normalized);
  const accepted = /\b(non-blocking|not blocking|accepted|accept|known)\b/.test(normalized);
  return mentionsFailure && accepted;
}

function latencyLineOk(value) {
  const normalized = normalize(value);
  if (!normalized || !/\bok=true\b/.test(normalized)) return false;
  if (/\brequired=true\b/.test(normalized)) {
    return !normalized.includes("skipped");
  }
  return true;
}

function frictionHasNoBlocker(value) {
  const normalized = normalize(value);
  if (normalized === "" || /^-\s*$/.test(value.trim())) return false;
  if (/\b(no friction|none|no blockers|no blocker|non-blocking only|no production blocker|no production-blocking)\b/.test(normalized)) return true;
  const mentionsBlocker = /\b(blocker|blocking|ship block|production blocker|production-blocking)\b/.test(normalized);
  const defused = /\b(no blocker|no blockers|not blocking|non-blocking|accepted)\b/.test(normalized);
  return !mentionsBlocker || defused;
}

function decisionAccepts(value) {
  const normalized = normalize(value);
  if (!/\b(ship|accept|accepted|go|proceed)\b/.test(normalized)) return false;
  const blocks = /\b(block|blocked|do not ship|dont ship|don't ship)\b/.test(normalized);
  const defused = /\b(non-blocking|not blocking|accepted)\b/.test(normalized);
  return !blocks || defused;
}

function normalize(value) {
  return value.toLowerCase().replace(/[._]/g, "-").trim();
}

function sha256(value) {
  return crypto.createHash("sha256").update(value).digest("hex");
}

function runLabStatus() {
  const result = spawnSync("bin/lab-mac-dogfood", ["status"], {
    cwd: repoRoot,
    env: {
      ...process.env,
      LAB_DOGFOOD_PROFILE: process.env.LAB_DOGFOOD_PROFILE ?? "lab-human-demo",
      LAB_DOGFOOD_URL: process.env.LAB_DOGFOOD_URL ?? "http://127.0.0.1:4480",
    },
    encoding: "utf8",
    shell: false,
  });
  return {
    ok: result.status === 0,
    exit_code: result.status ?? 1,
    manifest_path: firstMatch(result.stdout, /dogfood status manifest: (.+?\/manifest\.json)/),
  };
}

function firstMatch(value, pattern) {
  return value.match(pattern)?.[1];
}

function parseImageDimensions(buffer) {
  if (buffer.length >= 24
    && buffer[0] === 0x89
    && buffer[1] === 0x50
    && buffer[2] === 0x4e
    && buffer[3] === 0x47
    && buffer[4] === 0x0d
    && buffer[5] === 0x0a
    && buffer[6] === 0x1a
    && buffer[7] === 0x0a) {
    return {
      format: "png",
      width: buffer.readUInt32BE(16),
      height: buffer.readUInt32BE(20),
    };
  }
  if (buffer.length >= 4 && buffer[0] === 0xff && buffer[1] === 0xd8) {
    for (let offset = 2; offset + 8 < buffer.length;) {
      if (buffer[offset] !== 0xff) {
        offset += 1;
        continue;
      }
      const marker = buffer[offset + 1];
      if (marker === 0xd9 || marker === 0xda) break;
      const segmentLength = buffer.readUInt16BE(offset + 2);
      if (segmentLength < 2) throw new Error("invalid_jpeg_segment");
      if (isJpegStartOfFrame(marker)) {
        return {
          format: "jpeg",
          width: buffer.readUInt16BE(offset + 7),
          height: buffer.readUInt16BE(offset + 5),
        };
      }
      offset += 2 + segmentLength;
    }
  }
  throw new Error("unsupported_image_format");
}

function isJpegStartOfFrame(marker) {
  return (marker >= 0xc0 && marker <= 0xc3)
    || (marker >= 0xc5 && marker <= 0xc7)
    || (marker >= 0xc9 && marker <= 0xcb)
    || (marker >= 0xcd && marker <= 0xcf);
}

function writeTinyPng(filePath) {
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.writeFileSync(filePath, Buffer.from([
    0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a,
    0x00, 0x00, 0x00, 0x0d, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01,
    0x00, 0x00, 0x00, 0x01,
  ]));
}

function runSelfTest() {
  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-human-demo-result-verify-"));
  const previousRepoRoot = process.cwd();
  const previousArtifactRoot = artifactRoot;
  artifactRoot = tempRoot;
  process.chdir(tempRoot);
  fs.mkdirSync(path.join(tempRoot, "artifacts", "lab-runs", "demo"), { recursive: true });
  fs.mkdirSync(path.join(tempRoot, "artifacts", "lab-runs", "ready"), { recursive: true });
  fs.writeFileSync(path.join(tempRoot, "artifacts", "lab-runs", "demo", "manifest.json"), JSON.stringify({ ok: true }), "utf8");
  fs.writeFileSync(path.join(tempRoot, "artifacts", "lab-runs", "ready", "manifest.json"), JSON.stringify({ ok: true }), "utf8");
  writeTinyPng(path.join(tempRoot, "artifacts", "lab-runs", "demo", "screen-sharing.png"));
  writeTinyPng(path.join(tempRoot, "artifacts", "lab-runs", "ready", "screen-sharing.png"));
  const filled = `Human demo date: 2026-06-03
Mac: Mac Studio
Proof manifest: artifacts/lab-runs/demo/manifest.json
Screenshot: artifacts/lab-runs/demo/screen-sharing.png
Readiness manifest: artifacts/lab-runs/ready/manifest.json
Readiness screenshot: artifacts/lab-runs/ready/screen-sharing.png
Readiness queue latency: artifacts/lab-runs/ready/queue-latency.json ok=true required=true
Readiness workspace latency: artifacts/lab-runs/ready/workspace-latency.json ok=true required=true
Readiness desktop HUD feedback: artifacts/lab-runs/ready/paper-reminder-feedback.json ok=true required=true
Readiness master command hotkey: artifacts/lab-runs/ready/master-command-hotkey.json ok=true required=true
Readiness manual mode feedback: artifacts/lab-runs/ready/manual-mode-enter-feedback.json ok=true required=true
Readiness hotkey latency: artifacts/lab-runs/ready/hotkey-latency.json ok=true required=true
Automated proof: ok=true, queue_count=2, ambient_autosave=true

Pass/fail:
${renderFilledHumanDemoPassFail("pass")}

Friction:
- none

Ship/block decision: ship
`;
  const ok = verifyResultText(filled);
  assert.equal(ok.failed_checks.length, 0);
  const missingLatency = verifyResultText(filled.replace("Readiness queue latency: artifacts/lab-runs/ready/queue-latency.json ok=true required=true\n", ""));
  assert.ok(missingLatency.failed_checks.includes("readiness_queue_latency_ok"));
  const missingMasterCommandHotkey = verifyResultText(filled.replace("Readiness master command hotkey: artifacts/lab-runs/ready/master-command-hotkey.json ok=true required=true\n", ""));
  assert.ok(missingMasterCommandHotkey.failed_checks.includes("readiness_master_command_hotkey_ok"));
  const missingManualModeFeedback = verifyResultText(filled.replace("Readiness manual mode feedback: artifacts/lab-runs/ready/manual-mode-enter-feedback.json ok=true required=true\n", ""));
  assert.ok(missingManualModeFeedback.failed_checks.includes("readiness_manual_mode_feedback_ok"));
  const missingScreenshot = verifyResultText(filled.replace("Screenshot: artifacts/lab-runs/demo/screen-sharing.png", "Screenshot: "));
  assert.ok(missingScreenshot.failed_checks.includes("proof_screenshot_ok"));
  const missingReadinessManifest = verifyResultText(filled.replace("Readiness manifest: artifacts/lab-runs/ready/manifest.json", "Readiness manifest: artifacts/lab-runs/ready/missing.json"));
  assert.ok(missingReadinessManifest.failed_checks.includes("readiness_manifest_ok"));
  const skippedRequiredLatency = verifyResultText(filled.replace("Readiness workspace latency: artifacts/lab-runs/ready/workspace-latency.json ok=true required=true", "Readiness workspace latency: skipped ok=true required=true"));
  assert.ok(skippedRequiredLatency.failed_checks.includes("readiness_workspace_latency_ok"));
  const blank = filled.replace("ship", "").replace("pass", "");
  const bad = verifyResultText(blank);
  assert.ok(bad.failed_checks.includes("all_pass_fail_items_filled"));
  assert.ok(bad.failed_checks.includes("ship_block_decision_accepts"));
  artifactRoot = previousArtifactRoot;
  process.chdir(previousRepoRoot);
  fs.rmSync(tempRoot, { recursive: true, force: true });
}
