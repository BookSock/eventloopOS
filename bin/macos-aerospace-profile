#!/usr/bin/env node
import { copyFileSync, existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
import { execFileSync } from "node:child_process";
import os from "node:os";
import path from "node:path";

const action = process.argv[2] ?? "install";
const repoRoot = path.resolve(path.dirname(new URL(import.meta.url).pathname), "..");
const source = path.join(repoRoot, "config/aerospace/eventloopos-floating.toml");
const target = process.env.AEROSPACE_CONFIG_PATH ?? path.join(os.homedir(), ".aerospace.toml");
const hotkeyOverrides = [
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_LEFT_HALF", pattern: /macos-window-snap"\s+left-half/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_RIGHT_HALF", pattern: /macos-window-snap"\s+right-half/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_TOP_HALF", pattern: /macos-window-snap"\s+top-half/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_BOTTOM_HALF", pattern: /macos-window-snap"\s+bottom-half/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_CENTER", pattern: /macos-window-snap"\s+center/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_MAXIMIZE", pattern: /macos-window-snap"\s+maximize/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_TOP_LEFT", pattern: /macos-window-snap"\s+top-left/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_TOP_RIGHT", pattern: /macos-window-snap"\s+top-right/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_BOTTOM_LEFT", pattern: /macos-window-snap"\s+bottom-left/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_BOTTOM_RIGHT", pattern: /macos-window-snap"\s+bottom-right/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_PREV_DISPLAY", pattern: /move-node-to-monitor .*prev/ },
  { env: "EVENTLOOPOS_AEROSPACE_HOTKEY_NEXT_DISPLAY", pattern: /move-node-to-monitor .*next/ },
];

if (action === "--self-test") {
  const profile = readFileSync(source, "utf8");
  assertProfile(profile);
  const custom = renderProfile(profile, {
    EVENTLOOPOS_AEROSPACE_HOTKEY_MAXIMIZE: "ctrl-alt-cmd-enter",
    EVENTLOOPOS_AEROSPACE_HOTKEY_BOTTOM_LEFT: "ctrl-alt-cmd-j",
    EVENTLOOPOS_AEROSPACE_HOTKEY_BOTTOM_RIGHT: "ctrl-alt-cmd-k",
  });
  assertProfile(custom);
  if (!/^ctrl-alt-cmd-enter\s*=.*maximize/m.test(custom)) {
    throw new Error("self-test failed to render custom maximize hotkey");
  }
  assertThrows(() => renderProfile(profile, { EVENTLOOPOS_AEROSPACE_HOTKEY_MAXIMIZE: "ctrl-alt-enter" }));
  console.log("macos-aerospace-profile self-test passed");
  process.exit(0);
}

if (!["install", "status"].includes(action)) {
  console.error("Usage: bin/macos-aerospace-profile [install|status|--self-test]");
  process.exit(2);
}

const sourceProfile = readFileSync(source, "utf8");
assertProfile(sourceProfile);

if (action === "status") {
  if (!existsSync(target)) {
    console.log(`missing: ${target}`);
    process.exit(1);
  }
  const current = readFileSync(target, "utf8");
  assertProfile(current);
  console.log(`eventloopOS AeroSpace floating profile installed: ${target}`);
  process.exit(0);
}

mkdirSync(path.dirname(target), { recursive: true });
const renderedProfile = renderProfile(sourceProfile, process.env);
assertProfile(renderedProfile);
if (existsSync(target)) {
  const backup = `${target}.eventloopos-backup-${new Date().toISOString().replace(/[:.]/g, "-")}`;
  copyFileSync(target, backup);
  console.log(`backed up existing AeroSpace config: ${backup}`);
}
writeFileSync(target, renderedProfile);
console.log(`installed eventloopOS AeroSpace floating profile: ${target}`);

try {
  execFileSync("aerospace", ["reload-config"], { stdio: "inherit" });
  console.log("reloaded AeroSpace config");
} catch (error) {
  console.error("AeroSpace reload failed; launch AeroSpace and run: aerospace reload-config");
  if (error && typeof error === "object" && "status" in error) process.exitCode = Number(error.status) || 1;
}

function assertProfile(profile) {
  if (!/^experimental-force-floating-windows\s*=\s*true$/m.test(profile)) {
    throw new Error("profile must enable experimental-force-floating-windows");
  }
  const bindings = parseMainModeBindings(profile);
  for (const required of [
    /macos-window-snap"\s+left-half/,
    /macos-window-snap"\s+right-half/,
    /macos-window-snap"\s+top-half/,
    /macos-window-snap"\s+bottom-half/,
    /macos-window-snap"\s+center/,
    /macos-window-snap"\s+maximize/,
  ]) {
    if (![...bindings.values()].some((command) => required.test(command))) {
      throw new Error(`profile must include binding matching ${required}`);
    }
  }
  for (const reserved of ["ctrl-alt-j", "ctrl-alt-e", "ctrl-alt-enter", "ctrl-alt-h", "ctrl-alt-r", "ctrl-alt-k", "ctrl-alt-m", "ctrl-alt-shift-m"]) {
    if (bindings.has(reserved)) {
      throw new Error(`profile shadows eventloopOS hotkey: ${reserved}`);
    }
  }
}

function parseMainModeBindings(profile) {
  const bindings = new Map();
  let inMainBinding = false;
  for (const rawLine of profile.split(/\r?\n/)) {
    const line = rawLine.replace(/#.*$/, "").trim();
    if (!line) continue;
    if (line.startsWith("[")) {
      inMainBinding = line === "[mode.main.binding]";
      continue;
    }
    if (!inMainBinding) continue;
    const match = /^([A-Za-z0-9-]+)\s*=\s*(['"])(.*)\2$/.exec(line);
    if (match) bindings.set(match[1], match[3]);
  }
  return bindings;
}

function renderProfile(profile, env) {
  let rendered = profile;
  for (const override of hotkeyOverrides) {
    const hotkey = env[override.env];
    if (!hotkey) continue;
    rendered = moveBinding(rendered, override, normalizeHotkey(hotkey));
  }
  return rendered;
}

function moveBinding(profile, override, hotkey) {
  const reserved = new Set(["ctrl-alt-j", "ctrl-alt-e", "ctrl-alt-enter", "ctrl-alt-h", "ctrl-alt-r", "ctrl-alt-k", "ctrl-alt-m", "ctrl-alt-shift-m"]);
  if (reserved.has(hotkey)) {
    throw new Error(`${override.env}=${hotkey} shadows an eventloopOS paper-loop hotkey`);
  }

  const lines = profile.split(/\r?\n/);
  let inMainBinding = false;
  let matchedLine = -1;
  let command = "";
  for (let index = 0; index < lines.length; index += 1) {
    const rawLine = lines[index] ?? "";
    const trimmed = rawLine.replace(/#.*$/, "").trim();
    if (trimmed.startsWith("[")) {
      inMainBinding = trimmed === "[mode.main.binding]";
      continue;
    }
    if (!inMainBinding) continue;
    const match = /^([A-Za-z0-9-]+)\s*=\s*(['"])(.*)\2$/.exec(trimmed);
    if (!match || !override.pattern.test(match[3] ?? "")) continue;
    matchedLine = index;
    command = `${match[2]}${match[3]}${match[2]}`;
    break;
  }
  if (matchedLine === -1) throw new Error(`could not find binding for ${override.env}`);

  const targetRe = new RegExp(`^\\s*${escapeRegExp(hotkey)}\\s*=`);
  const filtered = lines.filter((line, index) => index === matchedLine || !targetRe.test(line));
  const nextLine = `${hotkey} = ${command}`;
  const adjustedIndex = filtered.indexOf(lines[matchedLine]);
  filtered[adjustedIndex] = nextLine;
  return filtered.join("\n");
}

function normalizeHotkey(raw) {
  const hotkey = raw.trim().toLowerCase();
  if (!/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(hotkey)) {
    throw new Error(`invalid AeroSpace hotkey: ${raw}`);
  }
  return hotkey;
}

function assertThrows(fn) {
  try {
    fn();
  } catch {
    return;
  }
  throw new Error("expected function to throw");
}

function escapeRegExp(value) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}
