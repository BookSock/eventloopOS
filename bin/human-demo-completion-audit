#!/usr/bin/env node
import assert from "node:assert/strict";
import crypto from "node:crypto";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import process from "node:process";
import { humanDemoPassFailLabels, renderFilledHumanDemoPassFail } from "./lib/human-demo-checklist.mjs";

const repoRoot = path.resolve(import.meta.dirname, "..");
process.chdir(repoRoot);

const args = process.argv.slice(2);
const jsonOnly = args.includes("--json");
const strict = args.includes("--strict");
const resultArg = valueAfter("--result");
const verificationArg = valueAfter("--verification");
const readinessMaxAgeHours = positiveNumberOption(
  "--readiness-max-age-hours",
  process.env.EVENTLOOPOS_HUMAN_DEMO_COMPLETION_READINESS_MAX_AGE_HOURS ?? "24",
);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/human-demo-completion-audit [--json] [--strict] [--result path] [--verification path]

Audit whether the macOS human demo completion gate can close. This is a
closeout guard: latest readiness must be green and fresh, Jason's filled result
must exist, verification must pass, verification must match that result, and
verification must include a green Mac Studio lab status check.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  console.log("human-demo-completion-audit self-test passed");
  process.exit(0);
}

const audit = buildAudit(repoRoot, { resultPath: resultArg, verificationPath: verificationArg });

if (jsonOnly) {
  console.log(JSON.stringify(audit, null, 2));
} else {
  console.log(`human demo completion: ${audit.ok ? "complete" : "pending"}`);
  console.log(`status: ${audit.status}`);
  console.log(`readiness: ${audit.readiness_manifest_path ?? "(missing)"}`);
  console.log(`result: ${audit.result_path ?? "(missing)"}`);
  console.log(`verification: ${audit.verification_manifest_path ?? "(missing)"}`);
  if (audit.failed_checks.length > 0) console.log(`failed checks: ${audit.failed_checks.join(", ")}`);
  console.log(JSON.stringify(audit, null, 2));
}

process.exit(strict && audit.ok !== true ? 1 : 0);

function buildAudit(root, options = {}) {
  const readinessPath = latestReadinessManifestPath(root);
  const readiness = readinessPath ? readJson(path.resolve(root, readinessPath)) : undefined;
  const readinessAt = manifestTimestamp(readiness);
  const readinessFreshness = manifestFreshness(readinessAt, readinessMaxAgeHours);
  const expectedResultPath = expectedCurrentResultPath(root, readiness);
  const resultPath = options.resultPath ?? expectedResultPath ?? latestResultPath(root);
  const resultAudit = inspectHumanResult(root, resultPath);
  const verificationPath = options.verificationPath ?? latestVerificationPath(root, resultPath);
  const verification = verificationPath ? readJson(path.resolve(root, verificationPath)) : undefined;
  const currentResultSha256 = resultPath ? fileSha256(path.resolve(root, resultPath)) : undefined;
  const checks = {
    readiness_manifest_present: Boolean(readinessPath),
    readiness_ok: readiness?.ok === true,
    readiness_fresh: readinessFreshness.ok === true,
    human_result_recorded: Boolean(resultPath && fs.existsSync(path.resolve(root, resultPath))),
    human_result_filled: resultAudit.filled === true,
    verification_manifest_present: Boolean(verificationPath),
    verification_ok: verification?.ok === true || verification?.passed === true,
    verification_matches_result: verificationMatchesResult(root, verification, resultPath),
    verification_matches_current_result_content: Boolean(
      currentResultSha256
      && verification?.result_sha256
      && verification.result_sha256 === currentResultSha256,
    ),
    lab_status_checked_and_ok: verification?.checks?.lab_status_ok === true && verification?.lab_status?.ok === true,
  };
  const failedChecks = Object.entries(checks)
    .filter(([, ok]) => ok !== true)
    .map(([key]) => key);
  return {
    schema_version: 1,
    kind: "eventloopos.human_demo_completion_audit",
    generated_at: new Date().toISOString(),
    ok: failedChecks.length === 0,
    status: completionStatus(failedChecks),
    failed_checks: failedChecks,
    checks,
    readiness_manifest_path: readinessPath,
    readiness_observed_at: readinessAt ?? null,
    readiness_generated_at: readinessAt ?? null,
    readiness_freshness: readinessFreshness,
    expected_result_path: expectedResultPath,
    result_path: resultPath,
    result_audit: resultAudit,
    verification_manifest_path: verificationPath,
    verification_verified_at: verification?.verified_at ?? null,
    verification_lab_status_manifest_path: verification?.lab_status?.manifest_path ?? null,
    verification_result_sha256: verification?.result_sha256 ?? null,
    current_result_sha256: currentResultSha256 ?? null,
    next_actions: nextActions(failedChecks, resultPath),
  };
}

function latestReadinessManifestPath(root) {
  const labRuns = path.join(root, "artifacts", "lab-runs");
  if (!fs.existsSync(labRuns)) return undefined;
  const candidates = fs.readdirSync(labRuns, { withFileTypes: true })
    .filter((entry) => entry.isDirectory() && entry.name.endsWith("-human-demo-ready"))
    .map((entry) => path.join(labRuns, entry.name, "manifest.json"))
    .filter((candidate) => fs.existsSync(candidate))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(root, latest) : undefined;
}

function latestResultPath(root) {
  const dir = path.join(root, "artifacts", "human-demo-results");
  if (!fs.existsSync(dir)) return undefined;
  const candidates = fs.readdirSync(dir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith("-human-demo-result.md"))
    .map((entry) => path.join(dir, entry.name))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(root, latest) : undefined;
}

function expectedCurrentResultPath(root, readiness) {
  const fromReadiness = readiness?.latest_human_demo?.suggested_result_path;
  if (typeof fromReadiness === "string" && fromReadiness.trim()) return fromReadiness.trim();
  const latestDemoPath = latestDemoManifestPath(root);
  if (!latestDemoPath) return undefined;
  try {
    const demo = readJson(path.resolve(root, latestDemoPath));
    return defaultResultPathForDemo(demo);
  } catch {
    return undefined;
  }
}

function latestDemoManifestPath(root) {
  const labRuns = path.join(root, "artifacts", "lab-runs");
  if (!fs.existsSync(labRuns)) return undefined;
  const candidates = fs.readdirSync(labRuns, { withFileTypes: true })
    .filter((entry) => entry.isDirectory() && entry.name.endsWith("-human-demo"))
    .map((entry) => path.join(labRuns, entry.name, "manifest.json"))
    .filter((candidate) => fs.existsSync(candidate))
    .sort();
  const latest = candidates.at(-1);
  return latest ? path.relative(root, latest) : undefined;
}

function defaultResultPathForDemo(demo) {
  const stamp = (demo?.generated_at ?? new Date().toISOString()).replace(/[-:]/g, "").replace(/\.\d{3}Z$/, "Z");
  return path.join("artifacts", "human-demo-results", `${stamp}-human-demo-result.md`);
}

function latestVerificationPath(root, resultPath) {
  const dir = path.join(root, "artifacts", "human-demo-verifications");
  if (!fs.existsSync(dir)) return undefined;
  const candidates = fs.readdirSync(dir, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .map((entry) => path.join(dir, entry.name, "manifest.json"))
    .filter((candidate) => fs.existsSync(candidate))
    .sort();
  if (candidates.length === 0) return undefined;
  if (resultPath) {
    const matching = candidates.filter((candidate) => {
      try {
        const manifest = readJson(candidate);
        return verificationMatchesResult(root, manifest, resultPath);
      } catch {
        return false;
      }
    });
    const latestMatching = matching.at(-1);
    if (latestMatching) return path.relative(root, latestMatching);
    return undefined;
  }
  return path.relative(root, candidates.at(-1));
}

function verificationMatchesResult(root, verification, resultPath) {
  if (!verification || !resultPath || !verification.result_path) return false;
  const expected = path.resolve(root, resultPath);
  const actual = path.resolve(root, verification.result_path);
  return actual === expected;
}

function inspectHumanResult(root, resultPath) {
  const defaultAudit = {
    exists: false,
    filled: false,
    blank_pass_fail_labels: [],
    missing_pass_fail_labels: expectedPassFailLabels(),
    friction_filled: false,
    ship_block_decision_filled: false,
  };
  if (!resultPath) return defaultAudit;
  const absolutePath = path.resolve(root, resultPath);
  if (!fs.existsSync(absolutePath)) return defaultAudit;
  const text = fs.readFileSync(absolutePath, "utf8");
  const lines = text.split(/\r?\n/);
  const passFail = parsePassFail(lines);
  const expectedLabels = expectedPassFailLabels();
  const missingPassFailLabels = expectedLabels.filter((label) => !Object.hasOwn(passFail, label));
  const blankPassFailLabels = expectedLabels.filter((label) => Object.hasOwn(passFail, label) && passFail[label].trim() === "");
  const friction = sectionText(lines, "Friction:", "Ship/block decision:").trim();
  const decision = fieldOrSectionText(lines, "Ship/block decision:", undefined).trim();
  const frictionFilled = friction !== "" && friction !== "-";
  const shipBlockDecisionFilled = decision !== "" && decision !== "-";
  return {
    exists: true,
    filled: missingPassFailLabels.length === 0
      && blankPassFailLabels.length === 0
      && frictionFilled
      && shipBlockDecisionFilled,
    blank_pass_fail_labels: blankPassFailLabels,
    missing_pass_fail_labels: missingPassFailLabels,
    friction_filled: frictionFilled,
    ship_block_decision_filled: shipBlockDecisionFilled,
  };
}

function expectedPassFailLabels() {
  return humanDemoPassFailLabels;
}

function parsePassFail(lines) {
  const text = sectionText(lines, "Pass/fail:", "Friction:");
  const items = {};
  for (const line of text.split(/\r?\n/)) {
    const match = line.match(/^\s*-\s*(.+?):\s*(.*)$/);
    if (!match) continue;
    items[match[1].trim()] = match[2].trim();
  }
  return items;
}

function sectionText(lines, startMarker, endMarker) {
  const start = lines.findIndex((line) => line.trim() === startMarker);
  if (start === -1) return "";
  const afterStart = start + 1;
  const end = endMarker
    ? lines.findIndex((line, index) => index > start && line.trim() === endMarker)
    : lines.length;
  return lines.slice(afterStart, end === -1 ? lines.length : end).join("\n");
}

function fieldOrSectionText(lines, startMarker, endMarker) {
  const start = lines.findIndex((line) => line.trim() === startMarker || line.trim().startsWith(startMarker));
  if (start === -1) return "";
  const trimmed = lines[start].trim();
  const inline = trimmed.slice(startMarker.length).trim();
  if (inline) return inline;
  const afterStart = start + 1;
  const end = endMarker
    ? lines.findIndex((line, index) => index > start && line.trim() === endMarker)
    : lines.length;
  return lines.slice(afterStart, end === -1 ? lines.length : end).join("\n");
}

function completionStatus(failedChecks) {
  if (failedChecks.length === 0) return "complete";
  if (failedChecks.includes("human_result_recorded") || failedChecks.includes("human_result_filled")) {
    return "pending_human_result";
  }
  if (
    failedChecks.includes("verification_manifest_present")
    || failedChecks.includes("verification_ok")
    || failedChecks.includes("verification_matches_result")
    || failedChecks.includes("verification_matches_current_result_content")
    || failedChecks.includes("lab_status_checked_and_ok")
  ) {
    return "pending_verification";
  }
  return "pending_readiness";
}

function nextActions(failedChecks, resultPath) {
  if (failedChecks.length === 0) return [];
  const actions = [];
  if (failedChecks.includes("human_result_recorded")) {
    actions.push({
      id: "write_result_template",
      command: "bin/human-demo-result-template --write",
      expected_result_path: resultPath ?? null,
    });
  }
  if (failedChecks.includes("human_result_filled")) {
    actions.push({
      id: "run_and_record_human_walkthrough",
      walkthrough_path: "docs/human-demo-walkthrough.md",
      result_path: resultPath ?? null,
    });
  }
  if (
    failedChecks.includes("verification_manifest_present")
    || failedChecks.includes("verification_ok")
    || failedChecks.includes("verification_matches_result")
    || failedChecks.includes("verification_matches_current_result_content")
    || failedChecks.includes("lab_status_checked_and_ok")
  ) {
    actions.push({
      id: "verify_result_with_lab_status",
      command: resultPath
        ? `bin/human-demo-result-verify ${shellQuote(resultPath)} --lab-status`
        : "bin/human-demo-result-verify artifacts/human-demo-results/<result>.md --lab-status",
      result_path: resultPath ?? null,
    });
  }
  actions.push({
    id: "closeout_audit",
    command: "bin/human-demo-completion-audit --strict",
  });
  return actions;
}

function shellQuote(value) {
  return `'${String(value).replaceAll("'", "'\\''")}'`;
}

function manifestTimestamp(manifest) {
  if (!manifest || typeof manifest !== "object") return undefined;
  for (const key of ["finished_at", "generated_at", "checked_at", "verified_at", "started_at"]) {
    const value = manifest[key];
    if (typeof value === "string" && !Number.isNaN(Date.parse(value))) return value;
  }
  return undefined;
}

function manifestFreshness(timestamp, maxAgeHours, now = new Date()) {
  if (!timestamp) {
    return {
      ok: false,
      reason: "missing_timestamp",
      max_age_hours: maxAgeHours,
    };
  }
  const observedMs = Date.parse(timestamp);
  if (Number.isNaN(observedMs)) {
    return {
      ok: false,
      reason: "invalid_timestamp",
      observed_at: timestamp,
      max_age_hours: maxAgeHours,
    };
  }
  const ageMs = Math.max(0, now.getTime() - observedMs);
  const ageHours = Number((ageMs / 3_600_000).toFixed(2));
  return {
    ok: ageHours <= maxAgeHours,
    reason: ageHours <= maxAgeHours ? "fresh" : "stale",
    observed_at: timestamp,
    age_hours: ageHours,
    max_age_hours: maxAgeHours,
  };
}

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function fileSha256(filePath) {
  if (!fs.existsSync(filePath)) return undefined;
  return crypto.createHash("sha256").update(fs.readFileSync(filePath)).digest("hex");
}

function valueAfter(flag) {
  const index = args.indexOf(flag);
  if (index === -1) return undefined;
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    console.error(`Missing value for ${flag}`);
    process.exit(2);
  }
  return value;
}

function positiveNumberOption(flag, defaultValue) {
  const index = args.indexOf(flag);
  const raw = index === -1 ? defaultValue : args[index + 1];
  const parsed = Number(raw);
  if (!Number.isFinite(parsed) || parsed <= 0) {
    console.error(`Invalid ${flag}: ${String(raw)}`);
    process.exit(2);
  }
  return parsed;
}

function writeJson(filePath, value) {
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`, "utf8");
}

function runSelfTest() {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-human-demo-completion-audit-"));
  const readinessPath = path.join(root, "artifacts", "lab-runs", "20260605T000000Z-human-demo-ready", "manifest.json");
  writeJson(readinessPath, { ok: true, finished_at: new Date().toISOString() });
  const oldResultPath = path.join(root, "artifacts", "human-demo-results", "20260601T000000Z-human-demo-result.md");
  fs.mkdirSync(path.dirname(oldResultPath), { recursive: true });
  fs.writeFileSync(oldResultPath, "stale blank result\n", "utf8");
  writeJson(path.join(root, "artifacts", "human-demo-verifications", "20260601T001100Z-human-demo-result-verify", "manifest.json"), {
    ok: true,
    result_path: path.relative(root, oldResultPath),
    checks: { lab_status_ok: true },
    lab_status: { ok: true },
  });
  const demoPath = path.join(root, "artifacts", "lab-runs", "20260605-001000-human-demo", "manifest.json");
  writeJson(demoPath, { ok: true, generated_at: "2026-06-05T00:10:00.000Z" });

  const pending = buildAudit(root);
  assert.equal(pending.ok, false);
  assert.ok(pending.failed_checks.includes("human_result_recorded"));
  assert.ok(pending.failed_checks.includes("verification_manifest_present"));
  assert.equal(pending.checks.readiness_fresh, true);
  assert.equal(pending.checks.verification_manifest_present, false);
  assert.ok(pending.readiness_observed_at);
  assert.equal(pending.expected_result_path, "artifacts/human-demo-results/20260605T001000Z-human-demo-result.md");
  assert.equal(pending.result_path, pending.expected_result_path);
  assert.equal(pending.verification_manifest_path, undefined);
  assert.deepEqual(pending.next_actions.map((action) => action.id), [
    "write_result_template",
    "run_and_record_human_walkthrough",
    "verify_result_with_lab_status",
    "closeout_audit",
  ]);
  assert.equal(
    pending.next_actions.find((action) => action.id === "verify_result_with_lab_status")?.command,
    "bin/human-demo-result-verify 'artifacts/human-demo-results/20260605T001000Z-human-demo-result.md' --lab-status",
  );

  const resultPath = path.join(root, "artifacts", "human-demo-results", "20260605T001000Z-human-demo-result.md");
  fs.mkdirSync(path.dirname(resultPath), { recursive: true });
  fs.writeFileSync(resultPath, `Human demo date: 2026-06-05

Pass/fail:
${renderFilledHumanDemoPassFail("ok=true")}

Friction:
none

Ship/block decision:
ship
`, "utf8");
  const relativeResultPath = path.relative(root, resultPath);
  const resultSha256 = fileSha256(resultPath);
  const verificationPath = path.join(root, "artifacts", "human-demo-verifications", "20260605T001100Z-human-demo-result-verify", "manifest.json");
  writeJson(verificationPath, {
    ok: true,
    result_path: relativeResultPath,
    result_sha256: resultSha256,
    checks: { lab_status_ok: true },
    lab_status: { ok: true, manifest_path: "artifacts/lab-runs/status/manifest.json" },
  });

  const complete = buildAudit(root);
  assert.equal(complete.ok, true);
  assert.equal(complete.status, "complete");
  assert.deepEqual(complete.next_actions, []);

  writeJson(readinessPath, { ok: true, finished_at: "2000-01-01T00:00:00.000Z" });
  const staleReadiness = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(staleReadiness.ok, false);
  assert.ok(staleReadiness.failed_checks.includes("readiness_fresh"));
  assert.equal(staleReadiness.readiness_freshness.reason, "stale");
  writeJson(readinessPath, { ok: true, started_at: new Date().toISOString() });
  const startedAtReadiness = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(startedAtReadiness.checks.readiness_fresh, true);

  fs.writeFileSync(resultPath, `Pass/fail:
- Starting state on demo-customer with Queue visible:

Friction:
-

Ship/block decision:
`, "utf8");
  const blankResult = buildAudit(root);
  assert.equal(blankResult.ok, false);
  assert.equal(blankResult.status, "pending_human_result");
  assert.ok(blankResult.failed_checks.includes("human_result_filled"));
  assert.ok(blankResult.result_audit.blank_pass_fail_labels.includes("Starting state on demo-customer with Queue visible"));

  fs.writeFileSync(resultPath, `Human demo date: 2026-06-05

Pass/fail:
${renderFilledHumanDemoPassFail("ok=true")}

Friction:
none

Ship/block decision:
ship
`, "utf8");
  const mismatched = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(mismatched.ok, true);
  writeJson(verificationPath, {
    ok: true,
    result_path: "artifacts/human-demo-results/other-human-demo-result.md",
    result_sha256: fileSha256(resultPath),
    checks: { lab_status_ok: true },
    lab_status: { ok: true },
  });
  const mismatch = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(mismatch.ok, false);
  assert.ok(mismatch.failed_checks.includes("verification_matches_result"));

  writeJson(verificationPath, {
    ok: true,
    result_path: relativeResultPath,
    result_sha256: fileSha256(resultPath),
    checks: {},
    lab_status: undefined,
  });
  const missingLab = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(missingLab.ok, false);
  assert.ok(missingLab.failed_checks.includes("lab_status_checked_and_ok"));

  writeJson(verificationPath, {
    ok: true,
    result_path: relativeResultPath,
    result_sha256: fileSha256(resultPath),
    checks: { lab_status_ok: true },
    lab_status: { ok: true },
  });
  fs.appendFileSync(resultPath, "\nEdited after verification.\n", "utf8");
  const staleVerification = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(staleVerification.ok, false);
  assert.ok(staleVerification.failed_checks.includes("verification_matches_current_result_content"));

  writeJson(verificationPath, {
    ok: true,
    result_path: relativeResultPath,
    checks: { lab_status_ok: true },
    lab_status: { ok: true },
  });
  const missingHash = buildAudit(root, {
    resultPath: relativeResultPath,
    verificationPath: path.relative(root, verificationPath),
  });
  assert.equal(missingHash.ok, false);
  assert.ok(missingHash.failed_checks.includes("verification_matches_current_result_content"));

  fs.rmSync(root, { recursive: true, force: true });
}
