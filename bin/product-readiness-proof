}

function updateProduct(fields) {
  const file = writeJson(`product-${Math.random().toString(36).slice(2)}.json`, {
    schema_version: 1,
    kind: "eventloopos.product_readiness_proof",
    mode: "lab",
    profile: "quick",
    started_at: "2026-06-02T00:00:00Z",
    requested_runs: 1,
    required_release_runs: 3,
    capture_video_seconds: 0,
    release_options: {},
    steps: [],
    blockers: [],
    evidence: {},
    ...fields,
  });
  const previousManifest = process.env.MANIFEST;
  process.env.MANIFEST = file;
  vm.runInNewContext(updateManifestBody, { require, process, console });
  if (previousManifest === undefined) {
    delete process.env.MANIFEST;
  } else {
    process.env.MANIFEST = previousManifest;
  }
  return JSON.parse(fs.readFileSync(file, "utf8"));
}

function coverage(manifest, id) {
  const item = manifest.requirement_coverage.find((entry) => entry.id === id);
  assert(item, `missing coverage item: ${id}`);
  return item;
}
