    stop_stack: flag(process.env.STOP_STACK),
    step_timeout_seconds: Number(process.env.STEP_TIMEOUT_SECONDS ?? 0),
    fault_runs: Number(process.env.FAULT_RUNS),
  },
  release_required_artifact_counts: {},
  release_repeat_artifact_counts: {},
  release_repeat_artifact_failures: {},
  release_repeat_artifacts_passed: false,
  profile_gate_passed: false,
  profile_gate_reasons: [],
  passed: false,
  release_ready: false,
  release_ready_reasons: [],
  steps: [],
  evidence: {},
  requirement_coverage: [],
  requirement_coverage_passed: false,
  requirement_coverage_gaps: [],
  blockers: [],
