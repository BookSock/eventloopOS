  function artifactContractStatus(manifestFile, nested, parentManifest) {
    if (nested?.kind === "eventloopos.lab_dogfood_status") {
      return dogfoodStatusArtifactContractStatus(manifestFile, nested);
    }
    if (nested?.kind === "eventloopos.lab_fault_proof") {
      return faultArtifactContractStatus(manifestFile, nested);
    }
    if (nested?.kind === "eventloopos.lab_connectivity_proof") {
      return connectivityArtifactContractStatus(manifestFile, nested);
    }
    if (nested?.kind === "eventloopos.lab_orphan_proof") {
      return orphanArtifactContractStatus(manifestFile, nested);
    }
    if (nested?.kind === "eventloopos.lab_window_churn_guard") {
      return windowChurnArtifactContractStatus(manifestFile, nested);
    }
    return scenarioArtifactContractStatus(manifestFile, nested, parentManifest);
  }

  function dogfoodStatusArtifactContractStatus(manifestFile, nested) {
    const dir = path.dirname(manifestFile);
    const artifactMissing = artifactPaths(nested)
      .filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const statusCheckValues = Object.values(nested.checks ?? {});
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      status_checks_green: statusCheckValues.length > 0 && statusCheckValues.every((value) => value === true),
      declared_artifacts_exist: artifactMissing.length === 0,
      health_ok: readJsonIfExists(firstPath(dir, artifactValue(nested, "health"), "health.json"))?.ok === true,
      task_sessions_api_exists: fileSize(firstPath(dir, artifactValue(nested, "task_sessions"), "task-sessions.json")) > 2,
      queue_ready_api_exists: fileSize(firstPath(dir, artifactValue(nested, "queue_ready"), "queue-ready.json")) > 2,
      process_list_nonempty: fileSize(firstPath(dir, artifactValue(nested, "processes"), "processes-interesting.txt")) > 20,
      ps_nonempty: fileSize(firstPath(dir, artifactValue(nested, "ps"), "ps.txt")) > 100,
      listener_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "listeners"), "listeners.txt")),
      window_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "windows"), "windows.json")),
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: artifactMissing.length === 0 && failedChecks.length === 0,
      kind: nested.kind,
      manifest: manifestFile,
      checks: { ...checks, declared_artifact_missing_count: artifactMissing.length },
      missing: artifactMissing,
      failed_checks: failedChecks,
    };
  }

  function snapshotEvidenceStatus(item) {
    const dir = typeof item === "string" ? item : item?.path ?? item?.dir;
    if (!dir) {
      return { ok: false, reason: "missing snapshot directory path" };
    }
    const files = {
      health: path.join(dir, "health.json"),
      activity: path.join(dir, "activity.json"),
      queue_ready: path.join(dir, "queue_state_ready.json"),
      task_messages: path.join(dir, "task-messages_limit_50.json"),
      windows: path.join(dir, "windows.json"),
      ps: path.join(dir, "ps.txt"),
      screen: path.join(dir, "screen.png"),
    };
    const health = readJsonIfExists(files.health);
    const checks = {
      directory_exists: fs.existsSync(dir) && fs.statSync(dir).isDirectory(),
      health_ok: health?.ok === true,
      activity_exists: fileSize(files.activity) > 2,
      queue_ready_exists: fileSize(files.queue_ready) > 2,
      task_messages_exists: fileSize(files.task_messages) > 2,
      windows_exists: fileSize(files.windows) > 2,
      process_list_nonempty: fileSize(files.ps) > 100,
      screen_nonempty: !fs.existsSync(files.screen) || fileSize(files.screen) > 10000,
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: failedChecks.length === 0,
      dir,
      checks,
      failed_checks: failedChecks,
    };
  }

  function scenarioArtifactContractStatus(manifestFile, nested, parentManifest) {
    if (!nested || typeof nested !== "object" || !nested.scenario) {
      return { ok: true, skipped: true, reason: "not a lab scenario artifact" };
    }
    const dir = path.dirname(manifestFile);
    const requiredFiles = [
      "manifest.json",
      nested.captures?.before ?? "captures/before/capture-summary.json",
      nested.captures?.after ?? "captures/after/capture-summary.json",
      "captures/after/screen.png",
      "captures/after/windows.json",
      "captures/after/ps.txt",
      "captures/after/processes-interesting.txt",
      "captures/after/queue-ax-tree.txt",
      "api/after/health.json",
      "api/after/task-messages_limit_120.json",
      "api/after/activity_limit_120.json",
      "api/after/queue_state_ready.json",
      "api-state.json",
      "task-messages.json",
      "windows.json",
      "screenshot-after.png",
    ];
    if (Number(parentManifest.capture_video_seconds ?? 0) > 0) {
      requiredFiles.push("captures/after/screen.mov");
      requiredFiles.push("screen.mov");
    }
    const missing = requiredFiles.filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const afterCapture = readJsonIfExists(path.join(dir, nested.captures?.after ?? "captures/after/capture-summary.json"));
    const apiHealth = readJsonIfExists(path.join(dir, "api/after/health.json"));
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      after_screen_nonempty: Number(afterCapture?.screen?.bytes ?? 0) > 10000,
      after_video_present: Number(parentManifest.capture_video_seconds ?? 0) <= 0 || Number(afterCapture?.video?.bytes ?? 0) > 10000,
      api_health_ok: apiHealth?.ok === true,
      api_state_alias_nonempty: fileSize(path.join(dir, "api-state.json")) > 100,
      task_messages_alias_nonempty: fileSize(path.join(dir, "task-messages.json")) > 10,
      windows_alias_nonempty: fileSize(path.join(dir, "windows.json")) > 2,
      screenshot_after_alias_nonempty: fileSize(path.join(dir, "screenshot-after.png")) > 10000,
      screen_recording_alias_present: Number(parentManifest.capture_video_seconds ?? 0) <= 0 || fileSize(path.join(dir, "screen.mov")) > 10000,
      queue_ax_tree_nonempty: fileSize(path.join(dir, "captures/after/queue-ax-tree.txt")) > 100,
      process_list_nonempty: fileSize(path.join(dir, "captures/after/ps.txt")) > 100,
      missing_file_count: missing.length,
    };
    const failedChecks = Object.entries(checks)
      .filter(([key, value]) => key !== "missing_file_count" && value !== true)
      .map(([key]) => key);
    return {
      ok: missing.length === 0 && failedChecks.length === 0,
      scenario: nested.scenario,
      manifest: manifestFile,
      checks,
      missing,
      failed_checks: failedChecks,
    };
  }

  function windowChurnArtifactContractStatus(manifestFile, nested) {
    const dir = path.dirname(manifestFile);
    const artifactMissing = artifactPaths(nested)
      .filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const checkValues = Object.values(nested.checks ?? {});
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      status_checks_green: checkValues.length > 0 && checkValues.every((value) => value === true),
      declared_artifacts_exist: artifactMissing.length === 0,
      samples_directory_exists: fs.existsSync(path.join(dir, artifactValue(nested, "samples") || "samples")),
      enough_samples: nested.checks?.enough_samples === true,
      max_single_window_changes_ok: nested.checks?.max_single_window_changes_ok === true,
      total_bounds_changes_ok: nested.checks?.total_bounds_changes_ok === true,
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: artifactMissing.length === 0 && failedChecks.length === 0,
      kind: nested.kind,
      manifest: manifestFile,
      checks: { ...checks, declared_artifact_missing_count: artifactMissing.length },
      missing: artifactMissing,
      failed_checks: failedChecks,
      totals: nested.totals,
    };
  }

  function faultArtifactContractStatus(manifestFile, nested) {
    const dir = path.dirname(manifestFile);
    const artifactMissing = artifactPaths(nested)
      .filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const captureSummary = firstJson(dir, artifactValue(nested, "capture_summary"), ...captureSummaryFallbacks(nested.scenario));
    const apiStatePath = firstPath(dir, artifactValue(nested, "api_state"), "api-state.json");
    const processPath = firstPath(
      dir,
      artifactValue(nested, "process_list"),
      ...capturePathFallbacks(nested.scenario, "ps.txt"),
      artifactValue(nested, "processes_after_cleanup"),
      artifactValue(nested, "processes_after_proof"),
      artifactValue(nested, "fault_processes_after"),
    );
    const windowPath = firstPath(
      dir,
      artifactValue(nested, "windows_after_fault"),
      artifactValue(nested, "windows_after_restart"),
      artifactValue(nested, "windows_after"),
      artifactValue(nested, "windows_after_cleanup"),
      artifactValue(nested, "windows_after_proof"),
      artifactValue(nested, "windows"),
      ...capturePathFallbacks(nested.scenario, "windows.json"),
    );
    const screenshotPath = firstPath(
      dir,
      artifactValue(nested, "screenshot_after_fault"),
      artifactValue(nested, "screenshot_after_restart"),
      artifactValue(nested, "screenshot_after"),
      artifactValue(nested, "screenshot"),
      ...capturePathFallbacks(nested.scenario, "screen.png"),
    );
    const isScreenDenied = nested.scenario === "screen-capture-denied";
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      assertions_green: assertionsGreen(nested),
      declared_artifacts_exist: artifactMissing.length === 0,
      api_state_exists: fileSize(apiStatePath) > 0,
      process_list_nonempty: fileSize(processPath) > 100,
      window_list_exists: fileSize(windowPath) > 2,
      capture_summary_exists: Boolean(captureSummary),
      screenshot_nonempty: isScreenDenied || fileSize(screenshotPath) > 10000 || Number(captureSummary?.screen?.bytes ?? 0) > 10000,
      screen_denied_zero_byte_with_actionable_error: !isScreenDenied || (
        Number(captureSummary?.screen?.bytes ?? -1) === 0
        && String(captureSummary?.screen?.failure_hint ?? "").length > 20
        && fs.existsSync(firstPath(dir, artifactValue(nested, "screencapture_error"), ...capturePathFallbacks(nested.scenario, "screencapture.err")))
      ),
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: artifactMissing.length === 0 && failedChecks.length === 0,
      scenario: nested.scenario,
      kind: nested.kind,
      manifest: manifestFile,
      checks: { ...checks, declared_artifact_missing_count: artifactMissing.length },
      missing: artifactMissing,
      failed_checks: failedChecks,
    };
  }

  function connectivityArtifactContractStatus(manifestFile, nested) {
    const dir = path.dirname(manifestFile);
    const artifactMissing = artifactPaths(nested)
      .filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      assertions_green: assertionsGreen(nested),
      declared_artifacts_exist: artifactMissing.length === 0,
      api_state_exists: fileSize(firstPath(dir, artifactValue(nested, "api_state"), "api-state.json")) > 0,
      ssh_probe_artifacts_exist: fs.existsSync(firstPath(dir, artifactValue(nested, "ssh_probe_stdout"), "ssh-probe.out"))
        && fs.existsSync(firstPath(dir, artifactValue(nested, "ssh_probe_stderr"), "ssh-probe.err")),
      vnc_probe_artifacts_exist: fs.existsSync(firstPath(dir, artifactValue(nested, "vnc_port_probe_stdout"), "vnc-port-probe.out"))
        && fs.existsSync(firstPath(dir, artifactValue(nested, "vnc_port_probe_stderr"), "vnc-port-probe.err")),
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: artifactMissing.length === 0 && failedChecks.length === 0,
      kind: nested.kind,
      manifest: manifestFile,
      checks: { ...checks, declared_artifact_missing_count: artifactMissing.length },
      missing: artifactMissing,
      failed_checks: failedChecks,
    };
  }

  function orphanArtifactContractStatus(manifestFile, nested) {
    const dir = path.dirname(manifestFile);
    const artifactMissing = artifactPaths(nested)
      .filter((relative) => !fs.existsSync(path.join(dir, relative)));
    const checks = {
      manifest_green: nested.ok === true || nested.passed === true,
      assertions_green: assertionsGreen(nested),
      declared_artifacts_exist: artifactMissing.length === 0,
      process_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "processes"), "processes-interesting.txt")),
      ps_artifact_nonempty: fileSize(firstPath(dir, artifactValue(nested, "ps"), "ps.txt")) > 100,
      listener_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "listeners"), "listeners.txt")),
      window_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "windows"), "windows.json")),
      terminal_window_artifact_exists: fs.existsSync(firstPath(dir, artifactValue(nested, "terminal_windows"), "terminal-windows.txt")),
    };
    const failedChecks = Object.entries(checks)
      .filter(([, value]) => value !== true)
      .map(([key]) => key);
    return {
      ok: artifactMissing.length === 0 && failedChecks.length === 0,
      kind: nested.kind,
      manifest: manifestFile,
      checks: { ...checks, declared_artifact_missing_count: artifactMissing.length },
      missing: artifactMissing,
      failed_checks: failedChecks,
    };
  }

  function artifactValue(nested, key) {
    const value = nested?.artifacts?.[key];
    return typeof value === "string" ? value : undefined;
  }

  function artifactPaths(nested) {
    return Object.values(nested?.artifacts ?? {})
      .filter((value) => typeof value === "string");
  }

  function firstPath(dir, ...candidates) {
    for (const candidate of candidates.flat().filter(Boolean)) {
      const absolute = path.join(dir, candidate);
      if (fs.existsSync(absolute)) return absolute;
    }
    return path.join(dir, candidates.flat().filter(Boolean)[0] ?? "__missing__");
  }

  function firstJson(dir, ...candidates) {
    const found = firstPath(dir, ...candidates);
    return readJsonIfExists(found);
  }

  function captureSummaryFallbacks(scenario) {
    return capturePathFallbacks(scenario, "capture-summary.json");
  }

  function capturePathFallbacks(scenario, file) {
    const dirsByScenario = {
      "codex-app-server-down": ["captures/after-fault"],
      "orchestrator-crash-restart": ["captures/after-restart"],
      "queue-app-accessibility-denied": ["captures/accessibility-denied"],
      "screen-capture-denied": ["captures/screen-denied"],
    };
    const dirs = [...(dirsByScenario[scenario] ?? []), "captures/after", "captures/after-fault", "captures/after-restart", "captures/accessibility-denied", "captures/screen-denied"];
    return [...new Set(dirs)].map((captureDir) => `${captureDir}/${file}`);
  }

  function assertionsGreen(nested) {
    return !Array.isArray(nested.assertions) || nested.assertions.every((assertion) => assertion?.ok === true);
  }

  function readJsonIfExists(file) {
    try {
      if (!fs.existsSync(file)) return undefined;
      return JSON.parse(fs.readFileSync(file, "utf8"));
    } catch {
      return undefined;
    }
  }

  function fileSize(file) {
    try {
      return fs.statSync(file).size;
    } catch {
      return 0;
    }
  }
}
NODE
}

emit_readiness_summary() {
  if [[ -x bin/readiness-summary ]]; then
    node bin/readiness-summary "$manifest"
  fi
}

emit_artifact_audit() {
  if [[ ! -f bin/product-readiness-artifact-audit ]]; then
    return
  fi
  local stdout_path="$artifact_dir/artifact-audit.stdout.log"
  local stderr_path="$artifact_dir/artifact-audit.stderr.log"
  local audit_rc=0
  if node bin/product-readiness-artifact-audit "$manifest" >"$stdout_path" 2>"$stderr_path"; then
    audit_rc=0
  else
    audit_rc=$?
  fi
  local audit_manifest
  audit_manifest="$(awk '/^artifact audit manifest:/ { value=$4 } END { print value }' "$stdout_path")"
  if [[ -n "$audit_manifest" && -f "$audit_manifest" ]]; then
    add_evidence "artifact_audit" "\"$(repo_relative_path "$audit_manifest")\""
    ARTIFACT_AUDIT_RC="$audit_rc" ARTIFACT_AUDIT_MANIFEST="$(repo_relative_path "$audit_manifest")" MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
manifest.artifact_audit = {
  manifest: process.env.ARTIFACT_AUDIT_MANIFEST,
  ok: process.env.ARTIFACT_AUDIT_RC === "0",
  exit_code: Number(process.env.ARTIFACT_AUDIT_RC),
};
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE
  fi
}

append_step() {
  local name="$1"
  local status="$2"
  local stdout_path="$3"
  local stderr_path="$4"
  local started="$5"
  local finished="$6"
  local exit_code="$7"
  local optional="${8:-false}"
  local timed_out="${9:-false}"
  local timeout_seconds="${10:-}"
  STEP_NAME="$name" STEP_STATUS="$status" STDOUT_PATH="$stdout_path" STDERR_PATH="$stderr_path" \
    STEP_STARTED="$started" STEP_FINISHED="$finished" STEP_EXIT_CODE="$exit_code" STEP_OPTIONAL="$optional" \
    STEP_TIMED_OUT="$timed_out" STEP_TIMEOUT_SECONDS="$timeout_seconds" \
    MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const step = {
  name: process.env.STEP_NAME,
  status: process.env.STEP_STATUS,
  started_at: process.env.STEP_STARTED,
  finished_at: process.env.STEP_FINISHED,
  duration_ms: Date.parse(process.env.STEP_FINISHED) - Date.parse(process.env.STEP_STARTED),
  exit_code: Number(process.env.STEP_EXIT_CODE),
  stdout_path: process.env.STDOUT_PATH,
  stderr_path: process.env.STDERR_PATH,
  optional: process.env.STEP_OPTIONAL === "true",
};
if (process.env.STEP_TIMED_OUT === "true") {
  step.timed_out = true;
}
if (process.env.STEP_TIMEOUT_SECONDS) {
  step.timeout_seconds = Number(process.env.STEP_TIMEOUT_SECONDS);
}
manifest.steps.push(step);
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE
}

add_evidence() {
  local key="$1"
  local value_json="$2"
  EVIDENCE_KEY="$key" EVIDENCE_JSON="$value_json" MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
manifest.evidence[process.env.EVIDENCE_KEY] = JSON.parse(process.env.EVIDENCE_JSON);
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE
}

append_run_evidence() {
  local key="$1"
  local source_field="$2"
  local source_value="$3"
  local local_manifest="$4"
  EVIDENCE_KEY="$key" SOURCE_FIELD="$source_field" SOURCE_VALUE="$source_value" LOCAL_MANIFEST="$local_manifest" MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const evidence = manifest.evidence[process.env.EVIDENCE_KEY];
const runs = Array.isArray(evidence) ? evidence : [];
runs.push({
  [process.env.SOURCE_FIELD]: process.env.SOURCE_VALUE,
  local_manifest: process.env.LOCAL_MANIFEST,
});
manifest.evidence[process.env.EVIDENCE_KEY] = runs;
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE
}

add_blocker() {
  local requirement="$1"
  local evidence="$2"
  REQUIREMENT="$requirement" EVIDENCE="$evidence" MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
manifest.blockers.push({
  requirement: process.env.REQUIREMENT,
  evidence: process.env.EVIDENCE,
});
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE
}

run_step_command() {
  local stdout_path="$1"
  local stderr_path="$2"
  local result_path="$3"
  shift 3
  if [[ "$step_timeout_seconds" == "0" ]]; then
    "$@" >"$stdout_path" 2>"$stderr_path"
    local raw_code=$?
    printf '{"timed_out":false,"timeout_seconds":0,"exit_code":%s}\n' "$raw_code" >"$result_path"
    return "$raw_code"
  fi
  PRODUCT_READINESS_TIMEOUT_SECONDS="$step_timeout_seconds" \
    PRODUCT_READINESS_TIMEOUT_STDOUT="$stdout_path" \
    PRODUCT_READINESS_TIMEOUT_STDERR="$stderr_path" \
    PRODUCT_READINESS_TIMEOUT_RESULT="$result_path" \
    node - "$@" <<'NODE'
const fs = require("node:fs");
const { spawn } = require("node:child_process");

const timeoutSeconds = Number(process.env.PRODUCT_READINESS_TIMEOUT_SECONDS ?? "0");
const stdoutPath = process.env.PRODUCT_READINESS_TIMEOUT_STDOUT;
const stderrPath = process.env.PRODUCT_READINESS_TIMEOUT_STDERR;
const resultPath = process.env.PRODUCT_READINESS_TIMEOUT_RESULT;
const [command, ...args] = process.argv.slice(2);

if (!command) {
  fs.writeFileSync(resultPath, JSON.stringify({ timed_out: false, timeout_seconds: timeoutSeconds, exit_code: 2, error: "missing command" }) + "\n");
  process.exit(2);
}
if (!Number.isFinite(timeoutSeconds) || timeoutSeconds < 0) {
  fs.writeFileSync(resultPath, JSON.stringify({ timed_out: false, timeout_seconds: timeoutSeconds, exit_code: 2, error: "invalid timeout" }) + "\n");
  process.exit(2);
}

const stdout = fs.createWriteStream(stdoutPath);
const stderr = fs.createWriteStream(stderrPath);
let timedOut = false;
let killTimer;
const child = spawn(command, args, {
  cwd: process.cwd(),
  env: process.env,
  detached: process.platform !== "win32",
  stdio: ["ignore", "pipe", "pipe"],
});
child.stdout.pipe(stdout, { end: false });
child.stderr.pipe(stderr, { end: false });
function finish(result) {
  stdout.end(() => {
    stderr.end(() => {
      fs.writeFileSync(resultPath, JSON.stringify(result) + "\n");
      process.exit(result.exit_code);
    });
  });
}
const timer = setTimeout(() => {
  timedOut = true;
  stderr.write(`\nproduct-readiness step timed out after ${timeoutSeconds}s\n`);
  try {
    if (process.platform !== "win32") {
      process.kill(-child.pid, "SIGTERM");
    } else {
      child.kill("SIGTERM");
    }
  } catch {}
  killTimer = setTimeout(() => {
    try {
      if (process.platform !== "win32") {
        process.kill(-child.pid, "SIGKILL");
      } else {
        child.kill("SIGKILL");
      }
    } catch {}
  }, 1000);
  killTimer.unref?.();
}, timeoutSeconds * 1000);
timer.unref?.();

child.on("error", (error) => {
  clearTimeout(timer);
  if (killTimer) clearTimeout(killTimer);
  stderr.write(`${error.message}\n`);
  finish({ timed_out: timedOut, timeout_seconds: timeoutSeconds, exit_code: 127, error: error.message });
});

child.on("exit", (code, signal) => {
  clearTimeout(timer);
  if (killTimer) clearTimeout(killTimer);
  const exitCode = timedOut ? 124 : (code ?? 1);
  finish({ timed_out: timedOut, timeout_seconds: timeoutSeconds, exit_code: exitCode, signal });
});
NODE
}

run_step() {
  local name="$1"
  shift
  local safe
  safe="$(printf "%s" "$name" | tr -cs 'A-Za-z0-9._-' '-' | sed 's/^-//; s/-$//')"
  local stdout_path="$artifact_dir/steps/$safe.stdout.log"
  local stderr_path="$artifact_dir/steps/$safe.stderr.log"
  local timeout_result="$artifact_dir/steps/$safe.timeout.json"
  local started
  local finished
  local code
  local timed_out="false"
  started="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "product readiness start: $name"
  set +e
  run_step_command "$stdout_path" "$stderr_path" "$timeout_result" "$@"
  code=$?
  set -e
  finished="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if [[ -f "$timeout_result" ]] && grep -q '"timed_out":true' "$timeout_result"; then
    timed_out="true"
  fi
  if [[ "$code" == "0" ]]; then
    echo "product readiness pass: $name"
    append_step "$name" passed "$stdout_path" "$stderr_path" "$started" "$finished" "$code" false "$timed_out" "$step_timeout_seconds"
  else
    echo "product readiness fail: $name" >&2
    append_step "$name" failed "$stdout_path" "$stderr_path" "$started" "$finished" "$code" false "$timed_out" "$step_timeout_seconds"
    if [[ "$mode" == "lab" && "$name" != "stop lab dogfood stack" ]]; then
      local cleanup_stdout="$artifact_dir/steps/failed-step-lab-cleanup.stdout.log"
      local cleanup_stderr="$artifact_dir/steps/failed-step-lab-cleanup.stderr.log"
      local stop_aerospace=0
      case "$name" in
        *"window churn"*|*"aerospace"*|*"ghostty cleanup"*) stop_aerospace=1 ;;
      esac
      env LAB_DOGFOOD_STOP_AEROSPACE="$stop_aerospace" bin/lab-mac-dogfood stop >"$cleanup_stdout" 2>"$cleanup_stderr" || true
      env LAB_DOGFOOD_STOP_AEROSPACE=0 bin/lab-mac-dogfood cleanup >>"$cleanup_stdout" 2>>"$cleanup_stderr" || true
      add_evidence "failed_step_lab_cleanup" "\"$cleanup_stdout\""
    fi
    local failed_run
    failed_run="$(latest_lab_run_from_log "$stdout_path")"
    if [[ -n "$failed_run" && -d "$failed_run" ]]; then
      copy_local_artifact "$failed_run" "failed-$safe"
      add_evidence "failed_${safe//-/_}" "\"$artifact_dir/failed-$safe/manifest.json\""
      add_blocker "Step failed: $name" "$artifact_dir/failed-$safe/manifest.json"
    else
      local failed_manifest
      failed_manifest="$(latest_manifest_path_from_log "$stdout_path" "manifest:")"
      if [[ -n "$failed_manifest" && -f "$failed_manifest" ]]; then
        add_evidence "failed_${safe//-/_}_manifest" "\"$(repo_relative_path "$failed_manifest")\""
        add_blocker "Step failed: $name" "$(repo_relative_path "$failed_manifest")"
      else
        add_blocker "Step failed: $name" "stdout: $stdout_path; stderr: $stderr_path"
      fi
    fi
    update_manifest
    emit_artifact_audit || true
    update_manifest
    emit_readiness_summary || true
    echo "product readiness manifest: $manifest"
    tail -n 80 "$stdout_path" || true
    tail -n 80 "$stderr_path" >&2 || true
    exit "$code"
  fi
}

sync_remote_artifact() {
  local remote_path="$1"
  local local_name="$2"
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
  local remote_repo="/Users/$lab_user/dev/2026/eventloopOS"
  mkdir -p "$artifact_dir/$local_name"
  rsync -az -e "ssh -i '$lab_key' -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8" \
    "$lab_user@$lab_host:$remote_repo/$remote_path/" "$artifact_dir/$local_name/"
}

source_fingerprint() {
  {
    printf "HEAD "
    git rev-parse HEAD 2>/dev/null || printf "unknown"
    printf "\n"
    for path in package.json pnpm-lock.yaml bin app/macos app/orchestrator app/shared app/native-host app/browser-extension app/test-harness; do
      [[ -e "$path" ]] || continue
      find "$path" -type f \
        ! -path '*/node_modules/*' \
        ! -path '*/.build/*' \
        ! -path '*/dist/*' \
        ! -path '*/build/*' \
        ! -path '*/.next/*' \
        -print0
    done | sort -z | xargs -0 shasum 2>/dev/null || true
  } | shasum | awk '{print $1}'
}

baseline_cache_enabled() {
  case "$baseline_cache" in
    1|true|yes|on) return 0 ;;
    0|false|no|off) return 1 ;;
    auto)
      [[ "$profile" != "release" ]]
      return
      ;;
    *)
      echo "unknown PRODUCT_READINESS_BASELINE_CACHE: $baseline_cache" >&2
      exit 2
      ;;
  esac
}

baseline_cache_lookup() {
  baseline_cache_enabled || return 1
  [[ -f "$baseline_cache_file" ]] || return 1
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local fingerprint="$1"
  BASELINE_CACHE_FILE="$baseline_cache_file" LAB_HOST="$lab_host" LAB_USER="$lab_user" \
    FINGERPRINT="$fingerprint" TTL_SECONDS="$baseline_cache_ttl_seconds" node <<'NODE'
const fs = require("node:fs");
const cacheFile = process.env.BASELINE_CACHE_FILE;
const ttlSeconds = Number(process.env.TTL_SECONDS || "0");
try {
  const cache = JSON.parse(fs.readFileSync(cacheFile, "utf8"));
  const ageSeconds = (Date.now() - Date.parse(cache.cached_at || "")) / 1000;
  const ok =
    cache.ok === true &&
    cache.lab_host === process.env.LAB_HOST &&
    cache.lab_user === process.env.LAB_USER &&
    cache.source_fingerprint === process.env.FINGERPRINT &&
    ttlSeconds > 0 &&
    Number.isFinite(ageSeconds) &&
    ageSeconds >= 0 &&
    ageSeconds <= ttlSeconds &&
    cache.local_artifact_dir &&
    fs.existsSync(cache.local_artifact_dir) &&
    fs.existsSync(`${cache.local_artifact_dir}/manifest.json`);
  if (!ok) process.exit(1);
  console.log(cache.local_artifact_dir);
} catch {
  process.exit(1);
}
NODE
}

write_baseline_cache() {
  local local_artifact_dir="$1"
  local remote_run="$2"
  baseline_cache_enabled || return 0
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local fingerprint="$3"
  mkdir -p "$(dirname "$baseline_cache_file")"
  BASELINE_CACHE_FILE="$baseline_cache_file" LAB_HOST="$lab_host" LAB_USER="$lab_user" \
    FINGERPRINT="$fingerprint" LOCAL_ARTIFACT_DIR="$local_artifact_dir" REMOTE_RUN="$remote_run" node <<'NODE'
const fs = require("node:fs");
const cache = {
  schema_version: 1,
  kind: "eventloopos.product_readiness_baseline_cache",
  ok: true,
  cached_at: new Date().toISOString(),
  lab_host: process.env.LAB_HOST,
  lab_user: process.env.LAB_USER,
  source_fingerprint: process.env.FINGERPRINT,
  local_artifact_dir: process.env.LOCAL_ARTIFACT_DIR,
  remote_run: process.env.REMOTE_RUN,
};
fs.writeFileSync(process.env.BASELINE_CACHE_FILE, `${JSON.stringify(cache, null, 2)}\n`);
NODE
}

copy_local_artifact() {
  local source_path="$1"
  local local_name="$2"
  mkdir -p "$artifact_dir/$local_name"
  rsync -a "$source_path/" "$artifact_dir/$local_name/"
}

latest_lab_run_from_log() {
  local log="$1"
  awk '/^artifacts\/lab-runs\// { value=$1 } END { print value }' "$log"
}

latest_install_run_from_log() {
  local log="$1"
  awk '/^artifacts\/install\// { value=$1 } END { print value }' "$log"
}

latest_manifest_path_from_log() {
  local log="$1"
  local marker="$2"
  awk -v marker="$marker" '$0 ~ marker { value=$NF } END { print value }' "$log"
}

repo_relative_path() {
  local value="$1"
  case "$value" in
    "$repo_root"/*) printf "%s\n" "${value#"$repo_root/"}" ;;
    *) printf "%s\n" "$value" ;;
  esac
}

lab_lock_acquired=0

lab_lock_is_stale() {
  if [[ ! -d "$lab_lock_dir" ]]; then
    return 1
  fi
  LOCK_DIR="$lab_lock_dir" TTL_SECONDS="$lab_lock_ttl_seconds" node <<'NODE'
const fs = require("node:fs");
const lockDir = process.env.LOCK_DIR;
const ttlSeconds = Number(process.env.TTL_SECONDS || "0");
try {
  const metadataPath = `${lockDir}/metadata.json`;
  if (fs.existsSync(metadataPath)) {
    const metadata = JSON.parse(fs.readFileSync(metadataPath, "utf8"));
    const pid = Number(metadata.pid);
    if (Number.isInteger(pid) && pid > 0) {
      try {
        process.kill(pid, 0);
      } catch (error) {
        if (error?.code === "ESRCH") {
          process.exit(0);
        }
      }
    }
  }
  const stat = fs.statSync(lockDir);
  const ageSeconds = (Date.now() - stat.mtimeMs) / 1000;
  process.exit(ttlSeconds > 0 && ageSeconds > ttlSeconds ? 0 : 1);
} catch {
  process.exit(1);
}
NODE
}

write_lab_lock_metadata() {
  local metadata="$artifact_dir/lab-lock.json"
  cat >"$metadata" <<EOF
{
  "run_id": "$run_id",
  "pid": $$,
  "mode": "$mode",
  "profile": "$profile",
  "artifact_dir": "$artifact_dir",
  "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
  cp "$metadata" "$lab_lock_dir/metadata.json"
}

acquire_lab_lock() {
  if [[ "$lab_lock_enabled" != "1" ]]; then
    return
  fi
  mkdir -p "$(dirname "$lab_lock_dir")"
  if mkdir "$lab_lock_dir" 2>/dev/null; then
    lab_lock_acquired=1
    write_lab_lock_metadata
    add_evidence "lab_lock" "\"$artifact_dir/lab-lock.json\""
    return
  fi
  if lab_lock_is_stale; then
    rm -rf "$lab_lock_dir"
    if mkdir "$lab_lock_dir" 2>/dev/null; then
      lab_lock_acquired=1
      write_lab_lock_metadata
      add_evidence "lab_lock" "\"$artifact_dir/lab-lock.json\""
      return
    fi
  fi
  local current_lock="$artifact_dir/current-lab-lock.json"
  if [[ -f "$lab_lock_dir/metadata.json" ]]; then
    cp "$lab_lock_dir/metadata.json" "$current_lock"
  else
    printf '{"error":"lock metadata missing"}\n' >"$current_lock"
  fi
  add_evidence "blocked_lab_lock" "\"$current_lock\""
  add_blocker "Another product-readiness lab proof is already running" "$current_lock"
  update_manifest
  emit_artifact_audit || true
  update_manifest
  emit_readiness_summary || true
  echo "product readiness blocked by lab lock: $current_lock" >&2
  echo "Set PRODUCT_READINESS_LAB_LOCK=0 only for read-only probes." >&2
  exit 1
}

write_remote_lab_lock() {
  if [[ "$mode" != "lab" || "$lab_lock_acquired" != "1" ]]; then
    return
  fi
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
  local remote_repo="/Users/$lab_user/dev/2026/eventloopOS"
  ssh -i "$lab_key" -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=15 -o ServerAliveCountMax=2 \
    "$lab_user@$lab_host" "mkdir -p '$remote_repo/$lab_lock_dir' && cat > '$remote_repo/$lab_lock_dir/metadata.json'" \
    <"$artifact_dir/lab-lock.json" >/dev/null 2>&1 || true
}

remove_remote_lab_lock() {
  if [[ "$mode" != "lab" ]]; then
    return
  fi
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
  local remote_repo="/Users/$lab_user/dev/2026/eventloopOS"
  ssh -i "$lab_key" -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=15 -o ServerAliveCountMax=2 \
    "$lab_user@$lab_host" "rm -rf '$remote_repo/$lab_lock_dir'" >/dev/null 2>&1 || true
}

release_lab_lock() {
  if [[ "$lab_lock_acquired" != "1" ]]; then
    return
  fi
  remove_remote_lab_lock
  local owner=""
  if [[ -f "$lab_lock_dir/metadata.json" ]]; then
    owner="$(RUN_ID="$run_id" LOCK_METADATA="$lab_lock_dir/metadata.json" node <<'NODE' || true
const fs = require("node:fs");
try {
  const metadata = JSON.parse(fs.readFileSync(process.env.LOCK_METADATA, "utf8"));
  if (metadata.run_id === process.env.RUN_ID) console.log("mine");
} catch {}
NODE
)"
  fi
  if [[ "$owner" == "mine" ]]; then
    rm -rf "$lab_lock_dir"
  fi
}

latest_fresh_clone_manifest_from_log() {
  local log="$1"
  awk '/^fresh clone proof manifest:/ { value=$5 } END { print value }' "$log"
}

run_lab_completion_workspace_proof() {
  local lab_host="${LAB_MAC_HOST:-100.71.111.25}"
  local lab_user="${LAB_MAC_USER:-claw}"
  local lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
  ssh -i "$lab_key" -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8 \
    "$lab_user@$lab_host" 'cd /Users/'"$lab_user"'/dev/2026/eventloopOS && export PATH=/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin; run="artifacts/lab-runs/$(date +%Y%m%d-%H%M%S)-codex-completion-workspace-proof"; mkdir -p "$run"; EVENTLOOPOS_CODEX_COMPLETION_WORKSPACE_ARTIFACT_DIR="$PWD/$run" pnpm test:e2e:event-loop:codex-completion-workspace >"$run/proof.out" 2>"$run/proof.err"; code=$?; echo "$run"; exit $code'
}

run_local() {
  run_step "local codex status proof" pnpm codex:status-proof
  local codex_manifest
  codex_manifest="$(latest_manifest_path_from_log "$artifact_dir/steps/local-codex-status-proof.stdout.log" "codex status proof manifest:")"
  if [[ -n "$codex_manifest" ]]; then
    add_evidence "codex_status" "\"$(repo_relative_path "$codex_manifest")\""
  fi

  run_step "local macos install proof" pnpm macos:install-proof
  local install_manifest
  install_manifest="$(latest_manifest_path_from_log "$artifact_dir/steps/local-macos-install-proof.stdout.log" "macOS install proof manifest:")"
  if [[ -n "$install_manifest" ]]; then
    add_evidence "macos_install" "\"$(repo_relative_path "$install_manifest")\""
  fi

  run_step "local queue ui error text proof" bash -lc 'cd app/macos && swift test --filter QueueWindowPresentationTests'
  add_evidence "queue_ui_error_text" "\"$artifact_dir/steps/local-queue-ui-error-text-proof.stdout.log\""
  add_evidence "queue_ui_presentation" "\"$artifact_dir/steps/local-queue-ui-error-text-proof.stdout.log\""

  run_step "local macos permission status" pnpm macos:permission-status
  local permission_manifest
  permission_manifest="$(latest_manifest_path_from_log "$artifact_dir/steps/local-macos-permission-status.stdout.log" "macOS permission status manifest:")"
  if [[ -n "$permission_manifest" ]]; then
    add_evidence "macos_permissions" "\"$(repo_relative_path "$permission_manifest")\""
  fi

  if [[ "$profile" == "quick" ]]; then
    return
  fi

  run_step "local proof live" pnpm proof:live
  local live_manifest
  live_manifest="$(latest_manifest_path_from_log "$artifact_dir/steps/local-proof-live.stdout.log" "proof manifest:")"
  if [[ -z "$live_manifest" && -f artifacts/proof-live-manifest.json ]]; then
    live_manifest="artifacts/proof-live-manifest.json"
  fi
  if [[ -n "$live_manifest" && -f "$live_manifest" ]]; then
    add_evidence "local_live_manifest" "\"$(repo_relative_path "$live_manifest")\""
  else
    add_blocker "Local dogfood proof did not emit a manifest" "$artifact_dir/steps/local-proof-live.stdout.log"
  fi

  if [[ "$profile" == "release" ]]; then
    add_blocker "Release-ready proof requires remote Mac lab evidence" "local mode cannot prove reboot, fresh lab setup, VNC/Tailscale, or lab 3x flake confidence"
  fi
}

run_lab() {
  local queue_runs=()
  local decision_runs=()
  local recovery_runs=()
  local workspace_runs=()
  local codex_app_server_fault_runs=()
  local restart_fault_runs=()
  local duplicate_fault_runs=()
  local postgres_fault_runs=()
  local postgres_migration_mismatch_fault_runs=()
  local aerospace_fault_runs=()
  local aerospace_permission_fault_runs=()
  local ghostty_cleanup_fault_runs=()
  local screen_capture_fault_runs=()
  local queue_app_accessibility_fault_runs=()
  local aerospace_restore_fault_runs=()
  local connectivity_fault_runs=()
  local orphan_run=""
  local stopped_stack_before_orphan="0"

  if [[ "$fast_preflight" == "1" ]]; then
    run_step "lab connectivity status" env LAB_CONNECTIVITY_SSH_TIMEOUT=5 LAB_CONNECTIVITY_VNC_TIMEOUT=5 bin/lab-mac-connectivity-proof status
  else
    run_step "lab connectivity status" bin/lab-mac-connectivity-proof status
  fi
  local connectivity_status_run
  connectivity_status_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-connectivity-status.stdout.log")"
  if [[ -n "$connectivity_status_run" ]]; then
    copy_local_artifact "$connectivity_status_run" "connectivity-status"
    add_evidence "connectivity_status" "\"$artifact_dir/connectivity-status/manifest.json\""
  fi
  if [[ "$profile" == "quick" && "$lab_quick_scope" == "transport" ]]; then
    return
  fi
  run_step "sync lab checkout" bin/lab-mac-sync
  write_remote_lab_lock

  local baseline_fingerprint
  local cached_baseline
  baseline_fingerprint="$(source_fingerprint)"
  cached_baseline="$(baseline_cache_lookup "$baseline_fingerprint" || true)"
  if [[ -n "$cached_baseline" ]]; then
    local cache_stdout="$artifact_dir/steps/lab-install-baseline-cached.stdout.log"
    local cache_stderr="$artifact_dir/steps/lab-install-baseline-cached.stderr.log"
    local cache_started
    local cache_finished
    cache_started="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    mkdir -p "$artifact_dir/baseline"
    rsync -a "$cached_baseline/" "$artifact_dir/baseline/"
    cp "$baseline_cache_file" "$artifact_dir/baseline-cache.json"
    {
      echo "baseline cache hit"
      echo "source_fingerprint=$baseline_fingerprint"
      echo "cached_baseline=$cached_baseline"
      echo "cache_file=$baseline_cache_file"
    } >"$cache_stdout"
    : >"$cache_stderr"
    cache_finished="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    append_step "lab install baseline cached" passed "$cache_stdout" "$cache_stderr" "$cache_started" "$cache_finished" 0
    add_evidence "baseline" "\"$artifact_dir/baseline/manifest.json\""
    add_evidence "baseline_cache" "\"$artifact_dir/baseline-cache.json\""
  else
    run_step "lab install baseline" bin/lab-mac-baseline
    local baseline_run
    baseline_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-install-baseline.stdout.log")"
    if [[ -n "$baseline_run" ]]; then
      sync_remote_artifact "$baseline_run" "baseline"
      add_evidence "baseline" "\"$artifact_dir/baseline/manifest.json\""
      write_baseline_cache "$artifact_dir/baseline" "$baseline_run" "$baseline_fingerprint"
      if [[ -f "$baseline_cache_file" ]]; then
        cp "$baseline_cache_file" "$artifact_dir/baseline-cache.json"
        add_evidence "baseline_cache" "\"$artifact_dir/baseline-cache.json\""
      fi
    fi
  fi
  run_step "lab screen capture permission status" bin/lab-mac-screen-capture-permission status

  if [[ "$profile" == "lab-ready" || "$profile" == "dogfood" || "$profile" == "release" ]]; then
    run_step "start lab dogfood real codex" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood start
    run_step "lab dogfood status before" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood wait-ready
    local before_status
    before_status="$(latest_lab_run_from_log "$artifact_dir/steps/lab-dogfood-status-before.stdout.log")"
    if [[ -n "$before_status" ]]; then
      sync_remote_artifact "$before_status" "dogfood-status-before"
      add_evidence "dogfood_status_before" "\"$artifact_dir/dogfood-status-before/manifest.json\""
    fi
    run_step "lab window churn guard before" bin/lab-mac-window-churn-guard status
    local window_churn_before
    window_churn_before="$(latest_lab_run_from_log "$artifact_dir/steps/lab-window-churn-guard-before.stdout.log")"
    if [[ -n "$window_churn_before" ]]; then
      sync_remote_artifact "$window_churn_before" "window-churn-before"
      add_evidence "window_churn_before" "\"$artifact_dir/window-churn-before/manifest.json\""
    fi
    run_step "lab snapshot before" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood snapshot
    local before_snapshot
    before_snapshot="$(latest_lab_run_from_log "$artifact_dir/steps/lab-snapshot-before.stdout.log")"
    if [[ -n "$before_snapshot" ]]; then
      sync_remote_artifact "$before_snapshot" "snapshot-before"
      add_evidence "snapshot_before" "\"$artifact_dir/snapshot-before\""
    fi
  fi

  if [[ "$profile" == "dogfood" || "$profile" == "release" ]]; then
    for ((i = 1; i <= runs; i += 1)); do
    run_step "lab queue followup run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 LAB_MAC_CAPTURE_VIDEO_SECONDS="$capture_video_seconds" bin/lab-mac-scenario queue-followup
    local queue_run
    queue_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-queue-followup-run-$i.stdout.log")"
    if [[ -n "$queue_run" ]]; then
      queue_runs+=("$queue_run")
      sync_remote_artifact "$queue_run" "queue-followup-$i"
      append_run_evidence "queue_followup_runs" "remote" "$queue_run" "$artifact_dir/queue-followup-$i/manifest.json"
    fi

    if [[ "$profile" != "release" ]]; then
      continue
    fi

    run_step "lab queue decisions run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 LAB_MAC_CAPTURE_VIDEO_SECONDS="$capture_video_seconds" bin/lab-mac-scenario queue-decisions
    local decision_run
    decision_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-queue-decisions-run-$i.stdout.log")"
    if [[ -n "$decision_run" ]]; then
      decision_runs+=("$decision_run")
      sync_remote_artifact "$decision_run" "queue-decisions-$i"
      append_run_evidence "queue_decision_runs" "remote" "$decision_run" "$artifact_dir/queue-decisions-$i/manifest.json"
    fi

    run_step "lab codex recovery run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 LAB_MAC_CAPTURE_VIDEO_SECONDS="$capture_video_seconds" bin/lab-mac-scenario codex-recovery
    local recovery_run
    recovery_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-codex-recovery-run-$i.stdout.log")"
    if [[ -n "$recovery_run" ]]; then
      recovery_runs+=("$recovery_run")
      sync_remote_artifact "$recovery_run" "codex-recovery-$i"
      append_run_evidence "codex_recovery_runs" "remote" "$recovery_run" "$artifact_dir/codex-recovery-$i/manifest.json"
    fi

    run_step "lab codex completion workspace run $i" bin/lab-mac-completion-workspace-proof
    local workspace_run
    workspace_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-codex-completion-workspace-run-$i.stdout.log")"
    if [[ -n "$workspace_run" ]]; then
      workspace_runs+=("$workspace_run")
      sync_remote_artifact "$workspace_run" "completion-workspace-$i"
      append_run_evidence "completion_workspace_runs" "remote" "$workspace_run" "$artifact_dir/completion-workspace-$i/manifest.json"
    fi

    if [[ "$i" -gt "$fault_runs" ]]; then
      continue
    fi

    run_step "lab codex app-server down fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof codex-app-server-down
    local fault_run
    fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-codex-app-server-down-fault-run-$i.stdout.log")"
    if [[ -n "$fault_run" ]]; then
      codex_app_server_fault_runs+=("$fault_run")
      sync_remote_artifact "$fault_run" "fault-codex-app-server-down-$i"
      append_run_evidence "codex_app_server_down_fault_runs" "remote" "$fault_run" "$artifact_dir/fault-codex-app-server-down-$i/manifest.json"
    fi

    run_step "lab orchestrator crash restart fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof orchestrator-crash-restart
    local restart_fault_run
    restart_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-orchestrator-crash-restart-fault-run-$i.stdout.log")"
    if [[ -n "$restart_fault_run" ]]; then
      restart_fault_runs+=("$restart_fault_run")
      sync_remote_artifact "$restart_fault_run" "fault-orchestrator-crash-restart-$i"
      append_run_evidence "orchestrator_crash_restart_fault_runs" "remote" "$restart_fault_run" "$artifact_dir/fault-orchestrator-crash-restart-$i/manifest.json"
    fi

    run_step "lab duplicate idempotency fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof duplicate-idempotency
    local duplicate_fault_run
    duplicate_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-duplicate-idempotency-fault-run-$i.stdout.log")"
    if [[ -n "$duplicate_fault_run" ]]; then
      duplicate_fault_runs+=("$duplicate_fault_run")
      sync_remote_artifact "$duplicate_fault_run" "fault-duplicate-idempotency-$i"
      append_run_evidence "duplicate_idempotency_fault_runs" "remote" "$duplicate_fault_run" "$artifact_dir/fault-duplicate-idempotency-$i/manifest.json"
    fi

    run_step "lab postgres unavailable fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof postgres-unavailable
    local postgres_fault_run
    postgres_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-postgres-unavailable-fault-run-$i.stdout.log")"
    if [[ -n "$postgres_fault_run" ]]; then
      postgres_fault_runs+=("$postgres_fault_run")
      sync_remote_artifact "$postgres_fault_run" "fault-postgres-unavailable-$i"
      append_run_evidence "postgres_unavailable_fault_runs" "remote" "$postgres_fault_run" "$artifact_dir/fault-postgres-unavailable-$i/manifest.json"
    fi

    if [[ "$include_postgres_migration_mismatch" == "1" ]]; then
      run_step "lab postgres migration mismatch fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof postgres-migration-mismatch
      local postgres_migration_mismatch_fault_run
      postgres_migration_mismatch_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-postgres-migration-mismatch-fault-run-$i.stdout.log")"
      if [[ -n "$postgres_migration_mismatch_fault_run" ]]; then
        postgres_migration_mismatch_fault_runs+=("$postgres_migration_mismatch_fault_run")
        sync_remote_artifact "$postgres_migration_mismatch_fault_run" "fault-postgres-migration-mismatch-$i"
        append_run_evidence "postgres_migration_mismatch_fault_runs" "remote" "$postgres_migration_mismatch_fault_run" "$artifact_dir/fault-postgres-migration-mismatch-$i/manifest.json"
      fi
    fi

    run_step "lab aerospace unavailable fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof aerospace-unavailable
    local aerospace_fault_run
    aerospace_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-aerospace-unavailable-fault-run-$i.stdout.log")"
    if [[ -n "$aerospace_fault_run" ]]; then
      aerospace_fault_runs+=("$aerospace_fault_run")
      sync_remote_artifact "$aerospace_fault_run" "fault-aerospace-unavailable-$i"
      append_run_evidence "aerospace_unavailable_fault_runs" "remote" "$aerospace_fault_run" "$artifact_dir/fault-aerospace-unavailable-$i/manifest.json"
    fi

    run_step "lab aerospace permission missing fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof aerospace-permission-missing
    local aerospace_permission_fault_run
    aerospace_permission_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-aerospace-permission-missing-fault-run-$i.stdout.log")"
    if [[ -n "$aerospace_permission_fault_run" ]]; then
      aerospace_permission_fault_runs+=("$aerospace_permission_fault_run")
      sync_remote_artifact "$aerospace_permission_fault_run" "fault-aerospace-permission-missing-$i"
      append_run_evidence "aerospace_permission_missing_fault_runs" "remote" "$aerospace_permission_fault_run" "$artifact_dir/fault-aerospace-permission-missing-$i/manifest.json"
    fi

    run_step "lab ghostty cleanup failure fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof ghostty-cleanup-failure
    local ghostty_cleanup_fault_run
    ghostty_cleanup_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-ghostty-cleanup-failure-fault-run-$i.stdout.log")"
    if [[ -n "$ghostty_cleanup_fault_run" ]]; then
      ghostty_cleanup_fault_runs+=("$ghostty_cleanup_fault_run")
      sync_remote_artifact "$ghostty_cleanup_fault_run" "fault-ghostty-cleanup-failure-$i"
      append_run_evidence "ghostty_cleanup_failure_fault_runs" "remote" "$ghostty_cleanup_fault_run" "$artifact_dir/fault-ghostty-cleanup-failure-$i/manifest.json"
    fi

    run_step "lab screen capture denied fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof screen-capture-denied
    local screen_capture_fault_run
    screen_capture_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-screen-capture-denied-fault-run-$i.stdout.log")"
    if [[ -n "$screen_capture_fault_run" ]]; then
      screen_capture_fault_runs+=("$screen_capture_fault_run")
      sync_remote_artifact "$screen_capture_fault_run" "fault-screen-capture-denied-$i"
      append_run_evidence "screen_capture_denied_fault_runs" "remote" "$screen_capture_fault_run" "$artifact_dir/fault-screen-capture-denied-$i/manifest.json"
    fi

    run_step "lab queue app accessibility denied fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof queue-app-accessibility-denied
    local queue_app_accessibility_fault_run
    queue_app_accessibility_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-queue-app-accessibility-denied-fault-run-$i.stdout.log")"
    if [[ -n "$queue_app_accessibility_fault_run" ]]; then
      queue_app_accessibility_fault_runs+=("$queue_app_accessibility_fault_run")
      sync_remote_artifact "$queue_app_accessibility_fault_run" "fault-queue-app-accessibility-denied-$i"
      append_run_evidence "queue_app_accessibility_denied_fault_runs" "remote" "$queue_app_accessibility_fault_run" "$artifact_dir/fault-queue-app-accessibility-denied-$i/manifest.json"
    fi

    run_step "lab aerospace restore server down fault run $i" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-fault-proof aerospace-restore-server-down
    local aerospace_restore_fault_run
    aerospace_restore_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-aerospace-restore-server-down-fault-run-$i.stdout.log")"
    if [[ -n "$aerospace_restore_fault_run" ]]; then
      aerospace_restore_fault_runs+=("$aerospace_restore_fault_run")
      sync_remote_artifact "$aerospace_restore_fault_run" "fault-aerospace-restore-server-down-$i"
      append_run_evidence "aerospace_restore_server_down_fault_runs" "remote" "$aerospace_restore_fault_run" "$artifact_dir/fault-aerospace-restore-server-down-$i/manifest.json"
    fi

    run_step "lab tailscale vnc disconnected fault run $i" bin/lab-mac-connectivity-proof fault
    local connectivity_fault_run
    connectivity_fault_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-tailscale-vnc-disconnected-fault-run-$i.stdout.log")"
    if [[ -n "$connectivity_fault_run" ]]; then
      connectivity_fault_runs+=("$connectivity_fault_run")
      copy_local_artifact "$connectivity_fault_run" "fault-tailscale-vnc-disconnected-$i"
      append_run_evidence "tailscale_vnc_disconnected_fault_runs" "local" "$connectivity_fault_run" "$artifact_dir/fault-tailscale-vnc-disconnected-$i/manifest.json"
    fi
    done
  fi

  if [[ "$profile" == "dogfood" || "$profile" == "release" ]]; then
    run_step "lab window churn guard after" bin/lab-mac-window-churn-guard status
    local window_churn_after
    window_churn_after="$(latest_lab_run_from_log "$artifact_dir/steps/lab-window-churn-guard-after.stdout.log")"
    if [[ -n "$window_churn_after" ]]; then
      sync_remote_artifact "$window_churn_after" "window-churn-after"
      add_evidence "window_churn_after" "\"$artifact_dir/window-churn-after/manifest.json\""
    fi
    run_step "lab dogfood status after" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood status
    local after_status
    after_status="$(latest_lab_run_from_log "$artifact_dir/steps/lab-dogfood-status-after.stdout.log")"
    if [[ -n "$after_status" ]]; then
      sync_remote_artifact "$after_status" "dogfood-status-after"
      add_evidence "dogfood_status_after" "\"$artifact_dir/dogfood-status-after/manifest.json\""
    fi
    run_step "lab snapshot after" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood snapshot
    local after_snapshot
    after_snapshot="$(latest_lab_run_from_log "$artifact_dir/steps/lab-snapshot-after.stdout.log")"
    if [[ -n "$after_snapshot" ]]; then
      sync_remote_artifact "$after_snapshot" "snapshot-after"
      add_evidence "snapshot_after" "\"$artifact_dir/snapshot-after\""
    fi
    if [[ "$stopped_stack_before_orphan" != "1" ]]; then
      run_step "stop lab dogfood stack" bin/lab-mac-dogfood stop
      stopped_stack_before_orphan="1"
    fi
    run_step "lab cleanup windows" env LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-dogfood cleanup
    run_step "lab no orphan windows processes" bin/lab-mac-orphan-proof
    orphan_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-no-orphan-windows-processes.stdout.log")"
    if [[ -n "$orphan_run" ]]; then
      sync_remote_artifact "$orphan_run" "orphan-proof"
      add_evidence "orphan_proof" "\"$artifact_dir/orphan-proof/manifest.json\""
    fi
  fi

  if [[ "$profile" != "release" ]]; then
    :
  elif [[ "$include_reboot" == "1" ]]; then
    run_step "lab reboot proof" env LAB_MAC_REBOOT=1 LAB_MAC_REBOOT_REQUIRE_SUDO=1 LAB_DOGFOOD_REAL_CODEX=1 LAB_DOGFOOD_POSTGRES=0 bin/lab-mac-reboot-proof
    local reboot_run
    reboot_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-reboot-proof.stdout.log")"
    if [[ -n "$reboot_run" ]]; then
      mkdir -p "$artifact_dir/reboot-proof"
      rsync -a "$reboot_run/" "$artifact_dir/reboot-proof/"
      add_evidence "reboot_proof" "\"$artifact_dir/reboot-proof/manifest.json\""
    fi
  elif [[ "$profile" == "release" ]]; then
    add_blocker "Release-ready reboot recovery requires reboot proof" "PRODUCT_READINESS_REBOOT=0 narrowed this run"
  fi

  if [[ "$profile" != "release" ]]; then
    :
  elif [[ "$include_fresh_clone" == "1" ]]; then
    run_step "lab fresh clone setup proof" bin/lab-mac-fresh-clone-proof
    local fresh_clone_run
    fresh_clone_run="$(latest_lab_run_from_log "$artifact_dir/steps/lab-fresh-clone-setup-proof.stdout.log")"
    if [[ -n "$fresh_clone_run" ]]; then
      sync_remote_artifact "$fresh_clone_run" "fresh-clone-setup"
      add_evidence "fresh_clone_setup" "\"$artifact_dir/fresh-clone-setup/manifest.json\""
    fi
  else
    add_blocker "Release-ready setup requires fresh clone proof" "PRODUCT_READINESS_FRESH_CLONE=0 narrowed this run"
  fi

  if [[ "$profile" != "release" ]]; then
    :
  elif [[ -n "$install_artifact" && -f "$install_artifact" ]]; then
    if INSTALL_ARTIFACT="$install_artifact" node <<'NODE'
const fs = require("node:fs");
const manifest = JSON.parse(fs.readFileSync(process.env.INSTALL_ARTIFACT, "utf8"));
if (manifest.ok === true && (manifest.unsigned_dev_ok === true || (manifest.signed === true && manifest.notarized === true))) {
  process.exit(0);
}
process.exit(1);
NODE
    then
      add_evidence "macos_install" "\"$install_artifact\""
    else
      add_blocker "Release-ready install requires a passing signed/notarized or unsigned-dev app install proof" "$install_artifact failed validation"
    fi
  else
    run_step "lab macos install proof" bin/lab-mac-install-proof
    local install_run
    install_run="$(latest_install_run_from_log "$artifact_dir/steps/lab-macos-install-proof.stdout.log")"
    if [[ -n "$install_run" ]]; then
      sync_remote_artifact "$install_run" "macos-install"
      add_evidence "macos_install" "\"$artifact_dir/macos-install/manifest.json\""
    else
      add_blocker "Release-ready install requires signed/notarized or unsigned-dev app proof" "lab install proof did not print an artifacts/install run path"
    fi
  fi

  QUEUE_RUNS="$(printf "%s\n" "${queue_runs[@]}")" \
  DECISION_RUNS="$(printf "%s\n" "${decision_runs[@]}")" \
  RECOVERY_RUNS="$(printf "%s\n" "${recovery_runs[@]}")" \
  WORKSPACE_RUNS="$(printf "%s\n" "${workspace_runs[@]}")" \
  FAULT_RUNS="$(printf "%s\n" "${codex_app_server_fault_runs[@]}")" \
  RESTART_FAULT_RUNS="$(printf "%s\n" "${restart_fault_runs[@]}")" \
  DUPLICATE_FAULT_RUNS="$(printf "%s\n" "${duplicate_fault_runs[@]}")" \
  POSTGRES_FAULT_RUNS="$(printf "%s\n" "${postgres_fault_runs[@]}")" \
  POSTGRES_MIGRATION_MISMATCH_FAULT_RUNS="$(printf "%s\n" "${postgres_migration_mismatch_fault_runs[@]}")" \
  AEROSPACE_FAULT_RUNS="$(printf "%s\n" "${aerospace_fault_runs[@]}")" \
  AEROSPACE_PERMISSION_FAULT_RUNS="$(printf "%s\n" "${aerospace_permission_fault_runs[@]}")" \
  GHOSTTY_CLEANUP_FAULT_RUNS="$(printf "%s\n" "${ghostty_cleanup_fault_runs[@]}")" \
  SCREEN_CAPTURE_FAULT_RUNS="$(printf "%s\n" "${screen_capture_fault_runs[@]}")" \
  QUEUE_APP_ACCESSIBILITY_FAULT_RUNS="$(printf "%s\n" "${queue_app_accessibility_fault_runs[@]}")" \
  AEROSPACE_RESTORE_FAULT_RUNS="$(printf "%s\n" "${aerospace_restore_fault_runs[@]}")" \
  CONNECTIVITY_FAULT_RUNS="$(printf "%s\n" "${connectivity_fault_runs[@]}")" \
  MANIFEST="$manifest" ARTIFACT_DIR="$artifact_dir" node <<'NODE'
const fs = require("node:fs");
const manifestPath = process.env.MANIFEST;
const artifactDir = process.env.ARTIFACT_DIR;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const split = (value) => value.split(/\n/).map((line) => line.trim()).filter(Boolean);
manifest.evidence.queue_followup_runs = split(process.env.QUEUE_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/queue-followup-${index + 1}/manifest.json`,
}));
manifest.evidence.queue_decision_runs = split(process.env.DECISION_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/queue-decisions-${index + 1}/manifest.json`,
}));
manifest.evidence.codex_recovery_runs = split(process.env.RECOVERY_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/codex-recovery-${index + 1}/manifest.json`,
}));
manifest.evidence.completion_workspace_runs = split(process.env.WORKSPACE_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/completion-workspace-${index + 1}/manifest.json`,
}));
manifest.evidence.codex_app_server_down_fault_runs = split(process.env.FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-codex-app-server-down-${index + 1}/manifest.json`,
}));
manifest.evidence.orchestrator_crash_restart_fault_runs = split(process.env.RESTART_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-orchestrator-crash-restart-${index + 1}/manifest.json`,
}));
manifest.evidence.duplicate_idempotency_fault_runs = split(process.env.DUPLICATE_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-duplicate-idempotency-${index + 1}/manifest.json`,
}));
manifest.evidence.postgres_unavailable_fault_runs = split(process.env.POSTGRES_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-postgres-unavailable-${index + 1}/manifest.json`,
}));
manifest.evidence.postgres_migration_mismatch_fault_runs = split(process.env.POSTGRES_MIGRATION_MISMATCH_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-postgres-migration-mismatch-${index + 1}/manifest.json`,
}));
manifest.evidence.aerospace_unavailable_fault_runs = split(process.env.AEROSPACE_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-aerospace-unavailable-${index + 1}/manifest.json`,
}));
manifest.evidence.aerospace_permission_missing_fault_runs = split(process.env.AEROSPACE_PERMISSION_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-aerospace-permission-missing-${index + 1}/manifest.json`,
}));
manifest.evidence.ghostty_cleanup_failure_fault_runs = split(process.env.GHOSTTY_CLEANUP_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-ghostty-cleanup-failure-${index + 1}/manifest.json`,
}));
manifest.evidence.screen_capture_denied_fault_runs = split(process.env.SCREEN_CAPTURE_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-screen-capture-denied-${index + 1}/manifest.json`,
}));
manifest.evidence.queue_app_accessibility_denied_fault_runs = split(process.env.QUEUE_APP_ACCESSIBILITY_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-queue-app-accessibility-denied-${index + 1}/manifest.json`,
}));
manifest.evidence.aerospace_restore_server_down_fault_runs = split(process.env.AEROSPACE_RESTORE_FAULT_RUNS).map((remote, index) => ({
  remote,
  local_manifest: `${artifactDir}/fault-aerospace-restore-server-down-${index + 1}/manifest.json`,
}));
manifest.evidence.tailscale_vnc_disconnected_fault_runs = split(process.env.CONNECTIVITY_FAULT_RUNS).map((local, index) => ({
  local,
  local_manifest: `${artifactDir}/fault-tailscale-vnc-disconnected-${index + 1}/manifest.json`,
}));
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
NODE

  if [[ "$profile" != "release" ]]; then
    :
  elif [[ "$runs" -lt 3 ]]; then
    add_blocker "Release-ready flake confidence requires at least 3 runs" "current run count: $runs"
  fi
  if [[ "$profile" == "release" && "$include_postgres_migration_mismatch" != "1" ]]; then
    add_blocker "Release-ready Postgres migration mismatch proof is required" "PRODUCT_READINESS_POSTGRES_MIGRATION_MISMATCH=0 narrowed this run"
  fi
  if [[ "$stop_stack" == "1" && "$stopped_stack_before_orphan" != "1" ]]; then
    run_step "stop lab dogfood stack" bin/lab-mac-dogfood stop
  fi
}

init_manifest
trap release_lab_lock EXIT

if [[ "$mode" == "lab" ]]; then
  acquire_lab_lock
fi

case "$mode" in
  lab) run_lab ;;
  local) run_local ;;
esac

update_manifest
emit_artifact_audit || true
update_manifest

jq '{passed, release_ready, release_ready_reasons, requested_runs, requested_fault_runs, required_release_runs, release_required_artifact_counts, release_repeat_artifact_counts, requirement_coverage_passed, requirement_coverage_gaps: [.requirement_coverage_gaps[] | {id, status, requirement, note, evidence}], blockers, evidence, steps: [.steps[] | {name, status, duration_ms}]}' "$manifest"
emit_readiness_summary || true
echo "product readiness manifest: $manifest"
