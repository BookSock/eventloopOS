update_manifest() {
  MANIFEST="$manifest" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const manifestPath = process.env.MANIFEST;
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
manifest.finished_at = new Date().toISOString();
manifest.duration_ms = Date.parse(manifest.finished_at) - Date.parse(manifest.started_at);
const stepsPassed = manifest.steps.every((step) => step.status === "passed" || step.optional === true);
const blockersClear = (manifest.blockers ?? []).length === 0;
manifest.requirement_coverage = buildRequirementCoverage(manifest);
manifest.requirement_coverage_gaps = manifest.requirement_coverage.filter((item) => item.status !== "passed");
manifest.requirement_coverage_passed = manifest.requirement_coverage_gaps.length === 0;
manifest.profile_gate_reasons = buildProfileGateReasons(manifest);
manifest.profile_gate_passed = manifest.profile_gate_reasons.length === 0;
manifest.release_ready_reasons = buildReleaseReadyReasons(manifest, stepsPassed);
manifest.release_ready = manifest.release_ready_reasons.length === 0;
manifest.passed = stepsPassed && blockersClear && manifest.profile_gate_passed && (manifest.profile !== "release" || manifest.release_ready);
fs.writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);

function buildReleaseReadyReasons(manifest, stepsPassed) {
  const reasons = [];
  if (manifest.mode !== "lab") {
    reasons.push({
      requirement: "release readiness requires lab mode",
      evidence: `current mode: ${manifest.mode}`,
    });
  }
  if (manifest.profile !== "release") {
    reasons.push({
      requirement: "release readiness requires release profile",
      evidence: `current profile: ${manifest.profile}`,
    });
  }
  if (!stepsPassed) {
    reasons.push({
      requirement: "all readiness proof steps must pass",
      evidence: `${(manifest.steps ?? []).filter((step) => step.status !== "passed" && step.optional !== true).length} failed steps`,
    });
  }
  if (manifest.requested_runs < manifest.required_release_runs) {
    reasons.push({
      requirement: "critical lab proofs must pass enough repeat runs",
      evidence: `requested_runs=${manifest.requested_runs}; required_release_runs=${manifest.required_release_runs}`,
    });
  }
  if (manifest.profile === "release" && manifest.requested_runs >= manifest.required_release_runs && manifest.release_repeat_artifacts_passed !== true) {
    reasons.push({
      requirement: "critical lab proofs must have required real artifact sets",
      evidence: JSON.stringify({
        required: manifest.release_required_artifact_counts ?? {},
        actual: manifest.release_repeat_artifact_counts ?? {},
      }),
    });
  }
  if (manifest.profile === "release" && manifest.artifact_contract?.status_artifacts_passed === false) {
    reasons.push({
      requirement: "dogfood status artifacts must prove orchestrator/app health",
      evidence: JSON.stringify(manifest.artifact_contract.status_artifacts ?? {}),
    });
  }
  if ((manifest.blockers ?? []).length > 0) {
    reasons.push({
      requirement: "manifest blockers must be empty",
      evidence: `${manifest.blockers.length} blockers`,
    });
  }
  if (!manifest.requirement_coverage_passed) {
    reasons.push({
      requirement: "all real-user readiness requirements must have passing coverage",
      evidence: `${manifest.requirement_coverage_gaps.length} coverage gaps`,
    });
  }
  return reasons;
}

function buildProfileGateReasons(manifest) {
  const reasons = [];
  const contract = manifest.artifact_contract ?? {};
  const evidence = manifest.evidence ?? {};
  const steps = manifest.steps ?? [];
  const okStatus = (key) => (contract.status_artifacts?.[key] ?? []).some((status) => status.ok === true);
  const okSnapshot = (key) => (contract.snapshots?.[key] ?? []).some((status) => status.ok === true);
  const okScenarioCount = (key) => (contract.scenario_artifacts?.[key] ?? []).filter((status) => status.ok === true).length;
  const okSingle = (key) => (contract.single_artifacts?.[key] ?? []).some((status) => status.ok === true);
  const evidenceHas = (key) => evidence[key] !== undefined && evidence[key] !== null && evidence[key] !== "";
  const stepPassed = (needle) => steps.some((step) => step.name?.toLowerCase().includes(needle.toLowerCase()) && step.status === "passed");
  const localManifestGreen = (key) => {
    const file = evidence[key];
    if (typeof file !== "string") return false;
    try {
      if (!fs.existsSync(file)) return false;
      const nested = JSON.parse(fs.readFileSync(file, "utf8"));
      return nested.ok === true || nested.passed === true;
    } catch {
      return false;
    }
  };
  const requireReason = (condition, requirement, evidence) => {
    if (!condition) reasons.push({ requirement, evidence });
  };
  if (manifest.mode === "local" && manifest.profile === "dogfood") {
    requireReason(localManifestGreen("local_live_manifest"), "local dogfood requires a green proof:live manifest", "local_live_manifest");
    requireReason(evidenceHas("queue_ui_presentation") && stepPassed("local queue ui error text proof"), "local dogfood requires green Queue UI presentation proof", "queue_ui_presentation");
    return reasons;
  }
  if (manifest.mode !== "lab") {
    return reasons;
  }
  if (manifest.profile === "lab-ready") {
    requireReason(okStatus("dogfood_status_before"), "lab-ready requires a green dogfood status artifact", "dogfood_status_before");
    requireReason(okSnapshot("snapshot_before"), "lab-ready requires a green desktop/API snapshot", "snapshot_before");
    requireReason(okSingle("window_churn_before"), "lab-ready requires a green desktop churn guard before snapshot", "window_churn_before");
  }
  if (manifest.profile === "dogfood") {
    const requestedRuns = Number(manifest.requested_runs ?? 1);
    requireReason(okStatus("dogfood_status_before"), "dogfood requires a green before dogfood status artifact", "dogfood_status_before");
    requireReason(okStatus("dogfood_status_after"), "dogfood requires a green after dogfood status artifact", "dogfood_status_after");
    requireReason(okSnapshot("snapshot_before"), "dogfood requires a green before desktop/API snapshot", "snapshot_before");
    requireReason(okSnapshot("snapshot_after"), "dogfood requires a green after desktop/API snapshot", "snapshot_after");
    requireReason(okSingle("window_churn_before"), "dogfood requires a green before desktop churn guard", "window_churn_before");
    requireReason(okSingle("window_churn_after"), "dogfood requires a green after desktop churn guard", "window_churn_after");
    requireReason(okScenarioCount("queue_followup_runs") >= requestedRuns, "dogfood requires green real Codex queue-followup artifacts", `queue_followup_runs ${okScenarioCount("queue_followup_runs")}/${requestedRuns}`);
    requireReason(okSingle("orphan_proof"), "dogfood requires green no-orphan cleanup proof", "orphan_proof");
  }
  return reasons;
}

function buildRequirementCoverage(manifest) {
  const evidence = manifest.evidence ?? {};
  const steps = manifest.steps ?? [];
  const blockers = manifest.blockers ?? [];
  const evidenceHas = (key) => {
    const value = evidence[key];
    if (Array.isArray(value)) return value.length > 0;
    return value !== undefined && value !== null && value !== "";
  };
  const evidenceCount = (key) => Array.isArray(evidence[key]) ? evidence[key].length : evidenceHas(key) ? 1 : 0;
  const evidenceAny = (...keys) => keys.some(evidenceHas);
  const evidenceItems = (key) => {
    const value = evidence[key];
    if (Array.isArray(value)) return value;
    return evidenceHas(key) ? [value] : [];
  };
  const evidenceManifestPath = (item) => typeof item === "string"
    ? item
    : item?.local_manifest ?? item?.manifest;
  const readEvidenceManifest = (item) => {
    const file = evidenceManifestPath(item);
    if (!file) return undefined;
    try {
      if (!fs.existsSync(file)) return undefined;
      return JSON.parse(fs.readFileSync(file, "utf8"));
    } catch {
      return undefined;
    }
  };
  const evidenceManifests = (key) => evidenceItems(key).map(readEvidenceManifest).filter(Boolean);
  const manifestGreen = (nested) => nested?.ok === true || nested?.passed === true;
  const evidenceGreen = (key, predicate = manifestGreen) => evidenceManifests(key).some(predicate);
  const snapshotEvidenceStatuses = Object.fromEntries(
    ["snapshot_before", "snapshot_after"].map((key) => [key, evidenceItems(key).map(snapshotEvidenceStatus)])
  );
  const snapshotEvidenceGreen = (...keys) => keys.some((key) =>
    (snapshotEvidenceStatuses[key] ?? []).some((status) => status.ok === true)
  );
  const baselineStepGreen = (...ids) => evidenceManifests("baseline").some((nested) => {
    if (!manifestGreen(nested)) return false;
    const steps = Array.isArray(nested.steps) ? nested.steps : [];
    return ids.every((id) => steps.some((step) => step.id === id && step.ok === true));
  });
  const installEvidenceGreen = evidenceGreen("macos_install", (nested) =>
    manifestGreen(nested) && (nested.unsigned_dev_ok === true || nested.signed === true || nested.notarized === true)
  );
  const codexEvidenceGreen = evidenceGreen("codex_status");
  const macosPermissionsEvidenceGreen = evidenceGreen("macos_permissions");
  const dogfoodStatusEvidenceGreen = evidenceGreen("dogfood_status_before", (nested) =>
    manifestGreen(nested)
      && nested?.checks?.health_ok === true
      && nested?.checks?.task_sessions_api_ok === true
      && nested?.checks?.queue_api_ok === true
      && nested?.checks?.dogfood_process_visible === true
      && nested?.checks?.listener_4480_visible === true
      && nested?.checks?.queue_app_process_visible === true
  );
  const installBaselineGreen = baselineStepGreen("macos_build", "macos_launch");
  const codexBaselineGreen = baselineStepGreen("codex");
  const permissionsBaselineGreen = baselineStepGreen("macos_permissions");
  const stepPassed = (needle) => steps.some((step) => step.name.includes(needle) && step.status === "passed");
  const stepFailed = (needle) => steps.some((step) => step.name.includes(needle) && step.status === "failed");
  const localLiveEvidenceGreen = evidenceGreen("local_live_manifest");
  const queueUiPresentationEvidenceGreen = evidenceHas("queue_ui_presentation") && stepPassed("local queue ui error text proof");
  const queueUiErrorTextEvidenceGreen = evidenceHas("queue_ui_error_text") && stepPassed("local queue ui error text proof");
  const blockerText = blockers.map((blocker) => `${blocker.requirement ?? ""} ${blocker.evidence ?? ""}`).join("\n").toLowerCase();
  const blockedBy = (...needles) => needles.some((needle) => blockerText.includes(needle.toLowerCase()) || stepFailed(needle));
  const releaseOnly = manifest.profile === "release";
  const dogfoodOrRelease = manifest.profile === "dogfood" || releaseOnly;
  const labReadyOrDogfoodOrRelease = manifest.profile === "lab-ready" || dogfoodOrRelease;
  const labMode = manifest.mode === "lab";
  const releaseRepeatEvidenceKeys = [
    "queue_followup_runs",
    "queue_decision_runs",
    "codex_recovery_runs",
    "completion_workspace_runs",
    "codex_app_server_down_fault_runs",
    "orchestrator_crash_restart_fault_runs",
    "duplicate_idempotency_fault_runs",
    "postgres_unavailable_fault_runs",
    "postgres_migration_mismatch_fault_runs",
    "aerospace_unavailable_fault_runs",
    "aerospace_permission_missing_fault_runs",
    "ghostty_cleanup_failure_fault_runs",
    "screen_capture_denied_fault_runs",
    "queue_app_accessibility_denied_fault_runs",
    "aerospace_restore_server_down_fault_runs",
    "tailscale_vnc_disconnected_fault_runs",
  ];
  const releaseEvidenceStatus = (item) => {
    const manifestFile = typeof item === "string"
      ? item
      : item?.local_manifest ?? item?.manifest;
    if (!manifestFile) {
      return { ok: false, reason: "missing local_manifest" };
    }
    try {
      if (!fs.existsSync(manifestFile)) {
        return { ok: false, manifest: manifestFile, reason: "manifest file missing" };
      }
      const nested = JSON.parse(fs.readFileSync(manifestFile, "utf8"));
      const artifactContract = artifactContractStatus(manifestFile, nested, manifest);
      const ok = (nested.ok === true || nested.passed === true) && artifactContract.ok;
      return {
        ok,
        manifest: manifestFile,
        kind: nested.kind,
        artifact_contract: artifactContract,
        reason: ok ? undefined : (nested.ok === true || nested.passed === true) ? "nested artifact contract not green" : "nested manifest not green",
      };
    } catch (error) {
      return { ok: false, manifest: manifestFile, reason: String(error?.message ?? error) };
    }
  };
  const scenarioEvidenceKeys = [
    "queue_followup_runs",
    "queue_decision_runs",
    "codex_recovery_runs",
  ];
  const statusEvidenceKeys = [
    "dogfood_status_before",
    "dogfood_status_after",
  ];
  const faultEvidenceKeys = [
    "completion_workspace_runs",
    "codex_app_server_down_fault_runs",
    "orchestrator_crash_restart_fault_runs",
    "duplicate_idempotency_fault_runs",
    "postgres_unavailable_fault_runs",
    "postgres_migration_mismatch_fault_runs",
    "aerospace_unavailable_fault_runs",
    "aerospace_permission_missing_fault_runs",
    "ghostty_cleanup_failure_fault_runs",
    "screen_capture_denied_fault_runs",
    "queue_app_accessibility_denied_fault_runs",
    "aerospace_restore_server_down_fault_runs",
    "tailscale_vnc_disconnected_fault_runs",
  ];
  const faultRepeatEvidenceKeys = faultEvidenceKeys.filter((key) => key !== "completion_workspace_runs");
  const singleArtifactEvidenceKeys = [
    "window_churn_before",
    "window_churn_after",
    "orphan_proof",
  ];
  const releaseEvidenceStatuses = Object.fromEntries(
    releaseRepeatEvidenceKeys.map((key) => [
      key,
      (Array.isArray(evidence[key]) ? evidence[key] : evidenceHas(key) ? [evidence[key]] : []).map(releaseEvidenceStatus),
    ])
  );
  const scenarioArtifactStatuses = Object.fromEntries(
    scenarioEvidenceKeys.map((key) => [key, releaseEvidenceStatuses[key] ?? []])
  );
  const statusArtifactStatuses = Object.fromEntries(
    statusEvidenceKeys.map((key) => [
      key,
      (Array.isArray(evidence[key]) ? evidence[key] : evidenceHas(key) ? [evidence[key]] : []).map(releaseEvidenceStatus),
    ])
  );
  const faultArtifactStatuses = Object.fromEntries(
    faultEvidenceKeys.map((key) => [key, releaseEvidenceStatuses[key] ?? []])
  );
  const singleArtifactStatuses = Object.fromEntries(
    singleArtifactEvidenceKeys.map((key) => [
      key,
      (Array.isArray(evidence[key]) ? evidence[key] : evidenceHas(key) ? [evidence[key]] : []).map(releaseEvidenceStatus),
    ])
  );
  const scenarioArtifactStatusCount = Object.values(scenarioArtifactStatuses).flat().length;
  const scenarioArtifactContractPassed = scenarioArtifactStatusCount > 0
    && Object.values(scenarioArtifactStatuses).flat().every((status) => status.ok === true);
  const statusArtifactStatusCount = Object.values(statusArtifactStatuses).flat().length;
  const statusArtifactContractPassed = statusArtifactStatusCount > 0
    && Object.values(statusArtifactStatuses).flat().every((status) => status.ok === true);
  const singleArtifactStatusCount = Object.values(singleArtifactStatuses).flat().length;
  const singleArtifactContractPassed = singleArtifactStatusCount > 0
    && Object.values(singleArtifactStatuses).flat().every((status) => status.ok === true);
  const requiredArtifactStatuses = Object.values(releaseEvidenceStatuses).flat();
  const requiredArtifactStatusCount = requiredArtifactStatuses.length;
  const requiredArtifactContractPassed = requiredArtifactStatusCount > 0
    && requiredArtifactStatuses.every((status) => status.ok === true);
  manifest.artifact_contract = {
    snapshots: snapshotEvidenceStatuses,
    scenario_artifacts_passed: scenarioArtifactContractPassed,
    scenario_artifact_status_count: scenarioArtifactStatusCount,
    scenario_artifacts: scenarioArtifactStatuses,
    status_artifacts_passed: statusArtifactContractPassed,
    status_artifact_status_count: statusArtifactStatusCount,
    status_artifacts: statusArtifactStatuses,
    required_artifacts_passed: requiredArtifactContractPassed,
    required_artifact_status_count: requiredArtifactStatusCount,
    fault_artifacts: faultArtifactStatuses,
    single_artifacts_passed: singleArtifactContractPassed,
    single_artifact_status_count: singleArtifactStatusCount,
    single_artifacts: singleArtifactStatuses,
  };
  const releaseRepeatCounts = Object.fromEntries(
    releaseRepeatEvidenceKeys.map((key) => [
      key,
      releaseEvidenceStatuses[key].filter((status) => status.ok).length,
    ])
  );
  const releaseRequiredArtifactCounts = Object.fromEntries(
    releaseRepeatEvidenceKeys.map((key) => [
      key,
      faultRepeatEvidenceKeys.includes(key)
        ? Number(manifest.requested_fault_runs ?? manifest.requested_runs ?? 1)
        : Number(manifest.requested_runs ?? 1),
    ])
  );
  const releaseRepeatFailures = Object.fromEntries(
    Object.entries(releaseEvidenceStatuses)
      .map(([key, statuses]) => [key, statuses.filter((status) => !status.ok)])
      .filter(([, failures]) => failures.length > 0)
  );
  const artifactEvidenceGreen = (...keys) => keys.some((key) =>
    (releaseEvidenceStatuses[key] ?? []).some((status) => status.ok === true)
  );
  const releaseRepeatEvidencePassed = releaseRepeatEvidenceKeys.every(
    (key) => releaseRepeatCounts[key] >= releaseRequiredArtifactCounts[key]
  );
  manifest.release_required_artifact_counts = releaseRequiredArtifactCounts;
  manifest.release_repeat_artifact_counts = releaseRepeatCounts;
  manifest.release_repeat_artifact_failures = releaseRepeatFailures;
  manifest.release_repeat_artifacts_passed = releaseOnly && releaseRepeatEvidencePassed;
  const item = (id, requirement, status, evidenceKeys = [], note = undefined) => ({
    id,
    requirement,
    status,
    evidence: evidenceKeys.filter(evidenceHas),
    note,
  });
  const statusFor = ({ passed, blocked, pending, notRunNote }) => {
    if (passed) return "passed";
    if (blocked) return "blocked";
    if (pending) return "pending";
    return notRunNote ? "not_run" : "missing";
  };
