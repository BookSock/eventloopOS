  const dir = writeDir(name);
  fs.mkdirSync(path.join(dir, "samples"), { recursive: true });
  fs.writeFileSync(path.join(dir, "manifest.json"), `${JSON.stringify({
    kind: "eventloopos.lab_window_churn_guard",
    ok,
    passed: ok,
    checks: {
      enough_samples: true,
      aerospace_samples_parse: true,
      bounds_samples_parse: true,
      max_single_window_changes_ok: ok,
      total_bounds_changes_ok: ok,
    },
    failed_checks: ok ? [] : ["max_single_window_changes_ok"],
    totals: {
      aerospace_changes: ok ? 0 : 20,
      bounds_changes: ok ? 0 : 20,
      max_single_window_changes: ok ? 0 : 10,
    },
    artifacts: {
      samples: "samples/",
    },
  }, null, 2)}\n`);
  fs.writeFileSync(path.join(dir, "samples", "sample-1.aerospace.json"), "[]\n");
  fs.writeFileSync(path.join(dir, "samples", "sample-1.bounds.json"), "[]\n");
