#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/product-readiness-proof [lab|local] [quick|lab-ready|dogfood|release]

Run a product-readiness gate and write one pass/fail manifest with links to the
underlying proof artifacts.

Modes:
  lab    Run against the remote Mac lab. This is the default and uses real Codex.
  local  Run the strongest local live proof available on this Mac.

Environment for lab mode:
  LAB_MAC_HOST              default: 100.71.111.25
  LAB_MAC_USER              default: claw
  LAB_MAC_KEY               default: ~/.ssh/eventloop_lab_mac
  LAB_DOGFOOD_URL           default: http://127.0.0.1:4480
  PRODUCT_READINESS_PROFILE default: release; one of quick, lab-ready, dogfood, release
  PRODUCT_READINESS_RUNS    default: 3 for lab release, otherwise 1
  PRODUCT_READINESS_FAULT_RUNS
                            default: PRODUCT_READINESS_RUNS; release fault
                            matrix repeat count. Set to 1 for fast release
                            iteration while keeping 3x happy-path runs.
  PRODUCT_READINESS_REBOOT  default: 1 for lab release, otherwise 0
  PRODUCT_READINESS_FRESH_CLONE
                            default: 1 for lab release, otherwise 0
  PRODUCT_READINESS_POSTGRES_MIGRATION_MISMATCH
                            default: 1 for lab release, otherwise 0
  PRODUCT_READINESS_FAST_PREFLIGHT
                            default: 1; use shorter SSH/VNC timeouts for first lab transport gate
  PRODUCT_READINESS_LAB_QUICK_SCOPE
                            default: setup; set to transport to run only SSH/VNC
                            reachability. Valid only with quick profile.
  PRODUCT_READINESS_LAB_LOCK default: 1; prevent concurrent lab GUI/process mutations
  PRODUCT_READINESS_LOCK_TTL_SECONDS
                            default: 7200; remove stale local lab lock after this age
  PRODUCT_READINESS_BASELINE_CACHE
                            default: auto; auto enables cache for quick/dogfood and disables for release
  PRODUCT_READINESS_BASELINE_CACHE_TTL_SECONDS
                            default: 86400; reuse green lab baseline within this age when source/lab match
  PRODUCT_READINESS_INSTALL_ARTIFACT
                            path to macOS install proof manifest
  PRODUCT_READINESS_SIGNING_ARTIFACT
                            legacy alias for PRODUCT_READINESS_INSTALL_ARTIFACT
  PRODUCT_READINESS_CAPTURE_VIDEO_SECONDS
                            default: 0 for quick/lab-ready, 3 for dogfood/release
  PRODUCT_READINESS_STOP    default: 0; set to 1 to stop dogfood stack at end;
                            dogfood/release always stop before no-orphan proof
  PRODUCT_READINESS_STEP_TIMEOUT_SECONDS
                            default: 600 quick, 900 lab-ready, 1800 dogfood, 3600 release;
                            set 0 to disable per-step timeout
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

mode="${1:-lab}"
profile_arg="${2:-}"
case "$mode" in
  --self-test)
    PRODUCT_READINESS_PROOF="$repo_root/bin/product-readiness-proof" node <<'NODE'
const assert = require("node:assert/strict");
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const vm = require("node:vm");

const scriptPath = process.env.PRODUCT_READINESS_PROOF;
const source = fs.readFileSync(scriptPath, "utf8");
const match = source.match(/update_manifest\(\) {\n\s*MANIFEST="\$manifest" node <<'NODE'\n([\s\S]*?)\nNODE\n}/);
assert(match, "could not extract update_manifest node body");
const updateManifestBody = match[1];
const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-product-readiness-self-test-"));

try {
  const redBaseline = writeJson("red-baseline.json", {
    kind: "eventloopos.lab_mac_baseline",
    ok: false,
    steps: [
      { id: "macos_build", ok: true },
      { id: "macos_launch", ok: true },
      { id: "codex", ok: true },
      { id: "macos_permissions", ok: true },
    ],
  });
  const greenBaseline = writeJson("green-baseline.json", {
    kind: "eventloopos.lab_mac_baseline",
    ok: true,
    steps: [
      { id: "macos_build", ok: true },
      { id: "macos_launch", ok: true },
      { id: "codex", ok: true },
      { id: "macos_permissions", ok: true },
    ],
  });
  const redInstall = writeJson("red-install.json", {
    kind: "eventloopos.macos_install_proof",
    ok: false,
    unsigned_dev_ok: true,
  });
  const greenInstall = writeJson("green-install.json", {
    kind: "eventloopos.macos_install_proof",
    ok: true,
    unsigned_dev_ok: true,
  });
  const greenCodex = writeJson("green-codex.json", {
    kind: "eventloopos.codex_status_proof",
    ok: true,
  });
  const greenPermissions = writeJson("green-permissions.json", {
    kind: "eventloopos.macos_permission_status",
    ok: true,
  });
  const redDogfoodStatus = writeDogfoodStatusFixture("red-dogfood-status", { ok: false });
  const greenDogfoodStatus = writeDogfoodStatusFixture("green-dogfood-status", { ok: true });
  const missingChecksDogfoodStatus = writeDogfoodStatusFixture("missing-checks-dogfood-status", { ok: true, includeChecks: false });
  const redScenario = writeJson("red-scenario.json", {
    kind: "eventloopos.lab_scenario",
    scenario: "queue-followup",
    ok: true,
  });
  const greenQueueFollowup = writeScenarioFixture("green-queue-followup", "queue-followup");
  const greenQueueFollowupWithVideo = writeScenarioFixture("green-queue-followup-with-video", "queue-followup", { includeVideo: true });
  const greenFault = writeFaultFixture("green-fault", "codex-app-server-down");
  const redFault = writeJson("red-fault.json", {
    kind: "eventloopos.lab_fault_proof",
    scenario: "codex-app-server-down",
    ok: true,
    assertions: [{ name: "actionable_failure", ok: true }],
    artifacts: {},
  });
  const redLive = writeJson("red-live.json", {
    kind: "eventloopos.agent_proof",
    passed: false,
  });
  const greenLive = writeJson("green-live.json", {
    kind: "eventloopos.agent_proof",
    passed: true,
  });
  const queueUiLog = writeJson("queue-ui.log", {
    note: "path exists but product coverage should require passed step",
  });
  const emptySnapshot = writeDir("empty-snapshot");
  const greenSnapshot = writeSnapshotDir("green-snapshot");
  const greenSnapshotAfter = writeSnapshotDir("green-snapshot-after");
  const greenOrphan = writeOrphanFixture("green-orphan");
  const greenWindowChurn = writeWindowChurnFixture("green-window-churn", { ok: true });

  const redProduct = updateProduct({
    evidence: {
      baseline: redBaseline,
      macos_install: redInstall,
    },
  });
  assert.notEqual(coverage(redProduct, "install_macos_app").status, "passed");
  assert.notEqual(coverage(redProduct, "codex_login_status").status, "passed");
  assert.notEqual(coverage(redProduct, "first_run_permission_flow").status, "passed");

  const greenProduct = updateProduct({
    evidence: {
      baseline: greenBaseline,
      macos_install: greenInstall,
      codex_status: greenCodex,
      macos_permissions: greenPermissions,
    },
  });
  assert.equal(coverage(greenProduct, "install_macos_app").status, "passed");
  assert.equal(coverage(greenProduct, "codex_login_status").status, "passed");
  assert.equal(coverage(greenProduct, "first_run_permission_flow").status, "passed");

  const redNestedProduct = updateProduct({
    profile: "release",
    requested_runs: 3,
    evidence: {
      queue_followup_runs: [{ local_manifest: redScenario }],
      codex_app_server_down_fault_runs: [{ local_manifest: redFault }],
    },
  });
  assert.notEqual(coverage(redNestedProduct, "real_codex_task_start_bind").status, "passed");
  assert.notEqual(coverage(redNestedProduct, "queue_review_items").status, "passed");
  assert.notEqual(coverage(redNestedProduct, "fault_codex_app_server_down").status, "passed");
  assert.equal(redNestedProduct.artifact_contract.scenario_artifacts.queue_followup_runs[0].ok, false);
  assert.equal(redNestedProduct.artifact_contract.fault_artifacts.codex_app_server_down_fault_runs[0].ok, false);

  const redSnapshotProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      snapshot_after: emptySnapshot,
    },
  });
  assert.notEqual(coverage(redSnapshotProduct, "active_tasks_menu_window").status, "passed");
  assert.equal(redSnapshotProduct.artifact_contract.snapshots.snapshot_after[0].ok, false);

  const greenSnapshotProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      snapshot_after: greenSnapshot,
    },
  });
  assert.equal(coverage(greenSnapshotProduct, "active_tasks_menu_window").status, "passed");
  assert.equal(greenSnapshotProduct.artifact_contract.snapshots.snapshot_after[0].ok, true);

  const labReadyProduct = updateProduct({
    profile: "lab-ready",
    evidence: {
      dogfood_status_before: greenDogfoodStatus,
      snapshot_before: greenSnapshot,
      window_churn_before: greenWindowChurn,
    },
  });
  assert.equal(coverage(labReadyProduct, "connect_orchestrator").status, "passed");
  assert.equal(coverage(labReadyProduct, "active_tasks_menu_window").status, "passed");
  assert.notEqual(coverage(labReadyProduct, "real_codex_task_start_bind").status, "passed");
  assert.equal(labReadyProduct.profile_gate_passed, true);
  assert.equal(labReadyProduct.passed, true);

  const labReadyMissingStatusProduct = updateProduct({
    profile: "lab-ready",
    evidence: {
      snapshot_before: greenSnapshot,
    },
  });
  assert.equal(labReadyMissingStatusProduct.profile_gate_passed, false);
  assert.equal(labReadyMissingStatusProduct.passed, false);
  assert.equal(
    labReadyMissingStatusProduct.profile_gate_reasons.some((reason) => reason.requirement.includes("dogfood status")),
    true,
  );

  const labReadyMissingSnapshotProduct = updateProduct({
    profile: "lab-ready",
    evidence: {
      dogfood_status_before: greenDogfoodStatus,
    },
  });
  assert.equal(labReadyMissingSnapshotProduct.profile_gate_passed, false);
  assert.equal(labReadyMissingSnapshotProduct.passed, false);
  assert.equal(
    labReadyMissingSnapshotProduct.profile_gate_reasons.some((reason) => reason.requirement.includes("snapshot")),
    true,
  );

  const redDogfoodStatusProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      dogfood_status_before: redDogfoodStatus,
    },
  });
  assert.notEqual(coverage(redDogfoodStatusProduct, "connect_orchestrator").status, "passed");
  assert.equal(redDogfoodStatusProduct.artifact_contract.status_artifacts.dogfood_status_before[0].ok, false);

  const greenDogfoodStatusProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      dogfood_status_before: greenDogfoodStatus,
    },
  });
  assert.equal(coverage(greenDogfoodStatusProduct, "connect_orchestrator").status, "passed");
  assert.equal(greenDogfoodStatusProduct.artifact_contract.status_artifacts.dogfood_status_before[0].ok, true);
  assert.equal(greenDogfoodStatusProduct.profile_gate_passed, false);
  assert.equal(greenDogfoodStatusProduct.passed, false);

  const greenDogfoodProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      dogfood_status_before: greenDogfoodStatus,
      dogfood_status_after: greenDogfoodStatus,
      snapshot_before: greenSnapshot,
      snapshot_after: greenSnapshotAfter,
      queue_followup_runs: [{ local_manifest: greenQueueFollowup }],
      window_churn_before: greenWindowChurn,
      window_churn_after: greenWindowChurn,
      orphan_proof: greenOrphan,
    },
  });
  assert.equal(greenDogfoodProduct.profile_gate_passed, true);
  assert.equal(greenDogfoodProduct.passed, true);
  assert.equal(coverage(greenDogfoodProduct, "real_codex_task_start_bind").status, "passed");
  assert.equal(coverage(greenDogfoodProduct, "queue_review_items").status, "passed");
  assert.equal(coverage(greenDogfoodProduct, "no_orphan_windows_processes").status, "passed");

  const partialVideoDogfoodProduct = updateProduct({
    profile: "dogfood",
    requested_runs: 3,
    capture_video_seconds: 3,
    evidence: {
      queue_followup_runs: [{ local_manifest: greenQueueFollowupWithVideo }],
    },
  });
  assert.notEqual(coverage(partialVideoDogfoodProduct, "queue_ui_video_artifact").status, "passed");

  const completeVideoDogfoodProduct = updateProduct({
    profile: "dogfood",
    requested_runs: 1,
    capture_video_seconds: 3,
    evidence: {
      queue_followup_runs: [{ local_manifest: greenQueueFollowupWithVideo }],
    },
  });
  assert.equal(coverage(completeVideoDogfoodProduct, "queue_ui_video_artifact").status, "passed");

  const threeScenarioRuns = [
    { local_manifest: greenQueueFollowup },
    { local_manifest: greenQueueFollowup },
    { local_manifest: greenQueueFollowup },
  ];
  const threeFaultStyleRuns = [
    { local_manifest: greenFault },
    { local_manifest: greenFault },
    { local_manifest: greenFault },
  ];
  const oneFaultRun = [{ local_manifest: greenFault }];
  const fastFaultMatrixReleaseProduct = updateProduct({
    profile: "release",
    requested_runs: 3,
    requested_fault_runs: 1,
    evidence: {
      queue_followup_runs: threeScenarioRuns,
      queue_decision_runs: threeScenarioRuns,
      codex_recovery_runs: threeScenarioRuns,
      completion_workspace_runs: threeFaultStyleRuns,
      codex_app_server_down_fault_runs: oneFaultRun,
      orchestrator_crash_restart_fault_runs: oneFaultRun,
      duplicate_idempotency_fault_runs: oneFaultRun,
      postgres_unavailable_fault_runs: oneFaultRun,
      postgres_migration_mismatch_fault_runs: oneFaultRun,
      aerospace_unavailable_fault_runs: oneFaultRun,
      aerospace_permission_missing_fault_runs: oneFaultRun,
      ghostty_cleanup_failure_fault_runs: oneFaultRun,
      screen_capture_denied_fault_runs: oneFaultRun,
      queue_app_accessibility_denied_fault_runs: oneFaultRun,
      aerospace_restore_server_down_fault_runs: oneFaultRun,
      tailscale_vnc_disconnected_fault_runs: oneFaultRun,
    },
  });
  assert.equal(fastFaultMatrixReleaseProduct.release_required_artifact_counts.queue_followup_runs, 3);
  assert.equal(fastFaultMatrixReleaseProduct.release_required_artifact_counts.completion_workspace_runs, 3);
  assert.equal(fastFaultMatrixReleaseProduct.release_required_artifact_counts.codex_app_server_down_fault_runs, 1);
  assert.equal(fastFaultMatrixReleaseProduct.release_repeat_artifacts_passed, true);
  assert.equal(coverage(fastFaultMatrixReleaseProduct, "flake_confidence_3x").status, "passed");

  const failedRebootAfterGreenEvidenceProduct = updateProduct({
    profile: "release",
    requested_runs: 1,
    requested_fault_runs: 1,
    blockers: [{ requirement: "Step failed: lab reboot proof", evidence: "reboot-proof/manifest.json" }],
    steps: [{ name: "lab reboot proof", status: "failed", exit_code: 1 }],
    evidence: {
      queue_followup_runs: [{ local_manifest: greenQueueFollowupWithVideo }],
      queue_decision_runs: [{ local_manifest: greenQueueFollowup }],
      codex_recovery_runs: [{ local_manifest: greenQueueFollowup }],
      completion_workspace_runs: [{ local_manifest: greenFault }],
      codex_app_server_down_fault_runs: oneFaultRun,
      orchestrator_crash_restart_fault_runs: oneFaultRun,
      duplicate_idempotency_fault_runs: oneFaultRun,
      postgres_unavailable_fault_runs: oneFaultRun,
      postgres_migration_mismatch_fault_runs: oneFaultRun,
      aerospace_unavailable_fault_runs: oneFaultRun,
      aerospace_permission_missing_fault_runs: oneFaultRun,
      ghostty_cleanup_failure_fault_runs: oneFaultRun,
      screen_capture_denied_fault_runs: oneFaultRun,
      queue_app_accessibility_denied_fault_runs: oneFaultRun,
      aerospace_restore_server_down_fault_runs: oneFaultRun,
      tailscale_vnc_disconnected_fault_runs: oneFaultRun,
    },
  });
  assert.equal(failedRebootAfterGreenEvidenceProduct.passed, false);
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "real_codex_task_start_bind").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "approve_defer_ignore_followups").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "resume_after_interruption_restart").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "workspace_save_restore").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "fault_codex_app_server_down").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "fault_stale_codex_thread").status, "passed");
  assert.equal(coverage(failedRebootAfterGreenEvidenceProduct, "reboot_relaunch_remote").status, "blocked");

  const missingChecksDogfoodStatusProduct = updateProduct({
    profile: "dogfood",
    evidence: {
      dogfood_status_before: missingChecksDogfoodStatus,
    },
  });
  assert.notEqual(coverage(missingChecksDogfoodStatusProduct, "connect_orchestrator").status, "passed");
  assert.equal(missingChecksDogfoodStatusProduct.artifact_contract.status_artifacts.dogfood_status_before[0].ok, false);
  assert.equal(
    missingChecksDogfoodStatusProduct.artifact_contract.status_artifacts.dogfood_status_before[0].artifact_contract.failed_checks.includes("status_checks_green"),
    true,
  );

  const redReleaseDogfoodStatusProduct = updateProduct({
    profile: "release",
    requested_runs: 3,
    evidence: {
      dogfood_status_before: redDogfoodStatus,
    },
  });
  assert.equal(
    redReleaseDogfoodStatusProduct.release_ready_reasons.some((reason) => reason.requirement.includes("dogfood status artifacts")),
    true,
  );

  const redLocalEvidenceProduct = updateProduct({
    mode: "local",
    profile: "dogfood",
    evidence: {
      local_live_manifest: redLive,
      queue_ui_error_text: queueUiLog,
      queue_ui_presentation: queueUiLog,
    },
  });
  assert.notEqual(coverage(redLocalEvidenceProduct, "connect_orchestrator").status, "passed");
  assert.notEqual(coverage(redLocalEvidenceProduct, "status_history_explainability").status, "passed");
  assert.notEqual(coverage(redLocalEvidenceProduct, "user_facing_dependency_error_text").status, "passed");
  assert.equal(redLocalEvidenceProduct.profile_gate_passed, false);
  assert.equal(redLocalEvidenceProduct.passed, false);

  const greenLocalEvidenceProduct = updateProduct({
    mode: "local",
    profile: "dogfood",
    steps: [{ name: "local queue ui error text proof", status: "passed" }],
    evidence: {
      local_live_manifest: greenLive,
      queue_ui_error_text: queueUiLog,
      queue_ui_presentation: queueUiLog,
    },
  });
  assert.equal(coverage(greenLocalEvidenceProduct, "connect_orchestrator").status, "passed");
  assert.equal(coverage(greenLocalEvidenceProduct, "status_history_explainability").status, "passed");
  assert.equal(coverage(greenLocalEvidenceProduct, "user_facing_dependency_error_text").status, "passed");
  assert.equal(greenLocalEvidenceProduct.profile_gate_passed, true);
  assert.equal(greenLocalEvidenceProduct.passed, true);
  console.log("product-readiness-proof self-test passed");
} finally {
  fs.rmSync(tempDir, { recursive: true, force: true });
}

function writeJson(name, value) {
  const file = path.join(tempDir, name);
  fs.writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
  return file;
}

function writeDir(name) {
  const dir = path.join(tempDir, name);
  fs.mkdirSync(dir, { recursive: true });
  return dir;
}

function writeSnapshotDir(name) {
  const dir = writeDir(name);
  fs.writeFileSync(path.join(dir, "health.json"), JSON.stringify({ ok: true }) + "\n");
  fs.writeFileSync(path.join(dir, "activity.json"), JSON.stringify({ events: [] }) + "\n");
  fs.writeFileSync(path.join(dir, "queue_state_ready.json"), JSON.stringify([]) + "\n");
  fs.writeFileSync(path.join(dir, "task-messages_limit_50.json"), JSON.stringify([]) + "\n");
  fs.writeFileSync(path.join(dir, "windows.json"), JSON.stringify([{ app: "EventLoopQueueApp" }]) + "\n");
  fs.writeFileSync(path.join(dir, "ps.txt"), `${"123 1 /bin/zsh pnpm run dev:dogfood\n".repeat(4)}`);
  fs.writeFileSync(path.join(dir, "screen.png"), Buffer.alloc(12000, 1));
  return dir;
}

function writeDogfoodStatusFixture(name, { ok, includeChecks = true }) {
  const dir = writeDir(name);
  const checks = {
    health_ok: true,
    task_sessions_api_ok: true,
    queue_api_ok: true,
    dogfood_process_visible: ok,
    listener_4480_visible: true,
    queue_app_process_visible: true,
    windows_artifact_exists: true,
    ps_nonempty: true,
  };
  fs.writeFileSync(path.join(dir, "manifest.json"), `${JSON.stringify({
    kind: "eventloopos.lab_dogfood_status",
    ok,
    passed: ok,
    ...(includeChecks ? { checks } : {}),
    artifacts: {
      health: "health.json",
      task_sessions: "task-sessions.json",
      queue_ready: "queue-ready.json",
      processes: "processes-interesting.txt",
      ps: "ps.txt",
      listeners: "listeners.txt",
      windows: "windows.json",
    },
  }, null, 2)}\n`);
  fs.writeFileSync(path.join(dir, "health.json"), JSON.stringify({ ok: true }) + "\n");
  fs.writeFileSync(path.join(dir, "task-sessions.json"), JSON.stringify({ sessions: [] }) + "\n");
  fs.writeFileSync(path.join(dir, "queue-ready.json"), JSON.stringify({ items: [] }) + "\n");
  fs.writeFileSync(path.join(dir, "processes-interesting.txt"), `${"123 node dist/src/index.js\n".repeat(4)}`);
  fs.writeFileSync(path.join(dir, "ps.txt"), `${"123 1 node dist/src/index.js\n".repeat(8)}`);
  fs.writeFileSync(path.join(dir, "listeners.txt"), `${"node TCP *:4480 (LISTEN)\n".repeat(4)}`);
  fs.writeFileSync(path.join(dir, "windows.json"), JSON.stringify([]) + "\n");
  return path.join(dir, "manifest.json");
}

function writeScenarioFixture(name, scenario, { includeVideo = false } = {}) {
  const dir = writeDir(name);
  fs.mkdirSync(path.join(dir, "captures", "before"), { recursive: true });
  fs.mkdirSync(path.join(dir, "captures", "after"), { recursive: true });
  fs.mkdirSync(path.join(dir, "api", "after"), { recursive: true });
  fs.writeFileSync(path.join(dir, "manifest.json"), `${JSON.stringify({
    kind: "eventloopos.lab_scenario",
    scenario,
    ok: true,
    passed: true,
    captures: {
      before: "captures/before/capture-summary.json",
      after: "captures/after/capture-summary.json",
    },
  }, null, 2)}\n`);
  fs.writeFileSync(path.join(dir, "captures", "before", "capture-summary.json"), JSON.stringify({ ok: true }) + "\n");
  fs.writeFileSync(path.join(dir, "captures", "after", "capture-summary.json"), JSON.stringify({
    screen: { bytes: 12000 },
    ...(includeVideo ? { video: { bytes: 12000 } } : {}),
  }) + "\n");
  fs.writeFileSync(path.join(dir, "captures", "after", "screen.png"), Buffer.alloc(12000, 1));
  fs.writeFileSync(path.join(dir, "captures", "after", "windows.json"), JSON.stringify([{ app: "eventloopOS Queue" }]) + "\n");
  fs.writeFileSync(path.join(dir, "captures", "after", "ps.txt"), `${"123 1 node dist/src/index.js\n".repeat(8)}`);
  fs.writeFileSync(path.join(dir, "captures", "after", "processes-interesting.txt"), "EventLoopQueueApp\nnode dist/src/index.js\n");
  fs.writeFileSync(path.join(dir, "captures", "after", "queue-ax-tree.txt"), `${"AXWindow eventloopOS Queue AXButton Approve Defer Ignore\n".repeat(4)}`);
  fs.writeFileSync(path.join(dir, "api", "after", "health.json"), JSON.stringify({ ok: true }) + "\n");
  fs.writeFileSync(path.join(dir, "api", "after", "task-messages_limit_120.json"), JSON.stringify([{ role: "assistant", content: "done" }]) + "\n");
  fs.writeFileSync(path.join(dir, "api", "after", "activity_limit_120.json"), JSON.stringify([{ type: "queue.updated" }]) + "\n");
  fs.writeFileSync(path.join(dir, "api", "after", "queue_state_ready.json"), JSON.stringify([{ id: "followup-1" }]) + "\n");
  fs.writeFileSync(path.join(dir, "api-state.json"), `${JSON.stringify({ health: { ok: true }, queue: [{ id: "followup-1" }] })}\n${" ".repeat(120)}`);
  fs.writeFileSync(path.join(dir, "task-messages.json"), JSON.stringify([{ role: "assistant", content: "done" }]) + "\n");
  fs.writeFileSync(path.join(dir, "windows.json"), JSON.stringify([{ app: "eventloopOS Queue" }]) + "\n");
  fs.writeFileSync(path.join(dir, "screenshot-after.png"), Buffer.alloc(12000, 1));
  if (includeVideo) {
    fs.writeFileSync(path.join(dir, "captures", "after", "screen.mov"), Buffer.alloc(12000, 1));
    fs.writeFileSync(path.join(dir, "screen.mov"), Buffer.alloc(12000, 1));
  }
  return path.join(dir, "manifest.json");
}

function writeFaultFixture(name, scenario) {
  const dir = writeDir(name);
  fs.writeFileSync(path.join(dir, "manifest.json"), `${JSON.stringify({
    kind: "eventloopos.lab_fault_proof",
    scenario,
    ok: true,
    passed: true,
    assertions: [{ name: "actionable_failure", ok: true }],
    artifacts: {
      api_state: "api-state.json",
      process_list: "ps.txt",
      windows_after: "windows.json",
      capture_summary: "capture-summary.json",
      screenshot_after: "screen.png",
    },
  }, null, 2)}\n`);
  fs.writeFileSync(path.join(dir, "api-state.json"), JSON.stringify({ health: { ok: true } }) + "\n");
  fs.writeFileSync(path.join(dir, "ps.txt"), `${"123 1 node dist/src/index.js\n".repeat(8)}`);
  fs.writeFileSync(path.join(dir, "windows.json"), JSON.stringify([{ app: "eventloopOS Queue" }]) + "\n");
  fs.writeFileSync(path.join(dir, "capture-summary.json"), JSON.stringify({ screen: { bytes: 12000 } }) + "\n");
  fs.writeFileSync(path.join(dir, "screen.png"), Buffer.alloc(12000, 1));
  return path.join(dir, "manifest.json");
}

function writeOrphanFixture(name) {
  const dir = writeDir(name);
  fs.writeFileSync(path.join(dir, "manifest.json"), `${JSON.stringify({
    kind: "eventloopos.lab_orphan_proof",
    ok: true,
    passed: true,
    assertions: [{ name: "no_orphans", ok: true }],
    artifacts: {
      processes: "processes-interesting.txt",
      ps: "ps.txt",
      listeners: "listeners.txt",
      windows: "windows.json",
      terminal_windows: "terminal-windows.txt",
    },
  }, null, 2)}\n`);
  fs.writeFileSync(path.join(dir, "processes-interesting.txt"), "no orphan eventloopOS windows\n");
  fs.writeFileSync(path.join(dir, "ps.txt"), `${"123 1 /bin/zsh clean\n".repeat(8)}`);
  fs.writeFileSync(path.join(dir, "listeners.txt"), "");
  fs.writeFileSync(path.join(dir, "windows.json"), JSON.stringify([]) + "\n");
  fs.writeFileSync(path.join(dir, "terminal-windows.txt"), "0\n");
  return path.join(dir, "manifest.json");
}

