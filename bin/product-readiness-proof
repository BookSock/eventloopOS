  schema_version: 1,
  kind: "eventloopos.product_readiness_proof",
  mode: process.env.MODE,
  profile: process.env.PROFILE,
  lab_quick_scope: process.env.LAB_QUICK_SCOPE,
  run_id: process.env.RUN_ID,
  started_at: process.env.STARTED_AT,
  finished_at: undefined,
  duration_ms: undefined,
  artifact_dir: process.env.ARTIFACT_DIR,
  requested_runs: Number(process.env.RUNS),
  requested_fault_runs: Number(process.env.FAULT_RUNS),
  required_release_runs: 3,
  capture_video_seconds: Number(process.env.CAPTURE_VIDEO_SECONDS ?? 0),
  release_options: {
    reboot: flag(process.env.INCLUDE_REBOOT),
    fresh_clone: flag(process.env.INCLUDE_FRESH_CLONE),
    postgres_migration_mismatch: flag(process.env.INCLUDE_POSTGRES_MIGRATION_MISMATCH),
    fast_preflight: flag(process.env.FAST_PREFLIGHT),
    baseline_cache: process.env.BASELINE_CACHE,
