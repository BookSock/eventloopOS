  MODE="$mode" PROFILE="$profile" LAB_QUICK_SCOPE="$lab_quick_scope" RUN_ID="$run_id" STARTED_AT="$started_at" ARTIFACT_DIR="$artifact_dir" RUNS="$runs" FAULT_RUNS="$fault_runs" CAPTURE_VIDEO_SECONDS="$capture_video_seconds" STEP_TIMEOUT_SECONDS="$step_timeout_seconds" INCLUDE_REBOOT="$include_reboot" INCLUDE_FRESH_CLONE="$include_fresh_clone" INCLUDE_POSTGRES_MIGRATION_MISMATCH="$include_postgres_migration_mismatch" FAST_PREFLIGHT="$fast_preflight" BASELINE_CACHE="$baseline_cache" LAB_LOCK_ENABLED="$lab_lock_enabled" STOP_STACK="$stop_stack" node <<'NODE' >"$manifest"
const flag = (value) => value === "1" || value === "true";
