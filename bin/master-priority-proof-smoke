#!/usr/bin/env node
import { createServer } from "node:net";
import { mkdirSync, writeFileSync } from "node:fs";
import { dirname, resolve } from "node:path";
import { spawn } from "node:child_process";

const startedAt = new Date();
const runId = `${startedAt.toISOString().replace(/[:.]/g, "-")}-${process.pid}`;
const repoRoot = process.cwd();
const artifactDir = resolve(repoRoot, process.env.EVENTLOOPOS_MASTER_PRIORITY_ARTIFACT_DIR ?? `artifacts/master-priority/${runId}`);
const manifestPath = resolve(artifactDir, "manifest.json");
const manifest = {
  schema_version: 1,
  kind: "eventloopos.master_priority_proof",
  run_id: runId,
  started_at: startedAt.toISOString(),
  finished_at: undefined,
  duration_ms: undefined,
  artifact_dir: artifactDir,
  orchestrator_url: undefined,
  steps: [],
  passed: false,
};

let server;
let port;

mkdirSync(dirname(manifestPath), { recursive: true });
writeManifest();

try {
  port = await freePort();
  manifest.orchestrator_url = `http://127.0.0.1:${port}`;
  writeManifest();

  await step("build orchestrator", async () => {
    await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "build"]);
  });

  server = startOrchestrator(port);

  await step("wait for orchestrator", async () => {
    await waitForHealth(manifest.orchestrator_url);
  });

  await step("clear seed queue", async () => {
    const queue = await getJson("/queue?state=ready");
    for (const item of queue.items ?? []) {
      await postJson(`/queue/${encodeURIComponent(item.id)}/done`, {
        action: "done",
        actor_id: "master_priority_proof",
      }, { "Idempotency-Key": `master-priority-done-${item.id}` });
    }
    return {
      cleared: (queue.items ?? []).length,
    };
  });

  await step("add low priority background item", async () => {
    const now = new Date().toISOString();
    const event = {
      id: "evt_master_priority_low",
      source: "local",
      source_id: "local:master-priority-low",
      idempotency_key: "local:master-priority-low",
      occurred_at: now,
      received_at: now,
      type: "local.note",
      title: "Low priority reading note",
      summary: "Read this when nothing higher priority exists.",
      raw_ref: {
        id: "raw_master_priority_low",
        uri: "local://master-priority-low",
        media_type: "text/plain",
      },
      links: [],
      resources: [],
    };
    const body = await postJson("/events", { event }, { "Idempotency-Key": event.idempotency_key });
    assert(body.queue_item?.priority_score === 500, `unexpected low item priority: ${JSON.stringify(body.queue_item)}`);
    return {
      queue_item_id: body.queue_item.id,
      priority_score: body.queue_item.priority_score,
    };
  });

  await step("master command creates higher priority task-hinted item", async () => {
    const body = await postJson("/voice/commands", {
      transcript: "Blog task now highest priority. Work this before reading queue.",
      task_hint: "blog feedback",
      idempotency_key: "master-priority-voice",
      source_id: "master-priority-voice",
    }, { "Idempotency-Key": "master-priority-voice" });
    assert(body.queue_item?.priority_score === 700, `unexpected master item priority: ${JSON.stringify(body.queue_item)}`);
    return {
      queue_item_id: body.queue_item.id,
      task_id: body.queue_item.task_id,
      priority_score: body.queue_item.priority_score,
    };
  });

  await step("queue is reordered by priority", async () => {
    const queue = await getJson("/queue?state=ready");
    const items = (queue.items ?? []).map((item) => ({
      id: item.id,
      task_id: item.task_id,
      priority_score: item.priority_score,
      reasons: item.priority_reasons,
      title: item.review_packet?.title,
    }));
    assert(items.length === 2, `expected 2 ready items, got ${JSON.stringify(items)}`);
    assert(items[0].id === "qit_evt_voice_master_priority_voice", `master priority item not first: ${JSON.stringify(items)}`);
    assert(items[0].priority_score > items[1].priority_score, `queue not sorted by score: ${JSON.stringify(items)}`);
    return {
      items,
    };
  });

  manifest.passed = true;
} catch (error) {
  manifest.error = error instanceof Error ? error.stack ?? error.message : String(error);
  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
  process.exitCode = 1;
} finally {
  await stopOrchestrator();
  manifest.finished_at = new Date().toISOString();
  manifest.duration_ms = Date.parse(manifest.finished_at) - Date.parse(manifest.started_at);
  writeManifest();
  console.log(`master priority proof manifest: ${manifestPath}`);
}

function startOrchestrator(listenPort) {
  const child = spawn("node", ["app/orchestrator/dist/src/index.js"], {
    cwd: repoRoot,
    env: {
      ...process.env,
      ORCHESTRATOR_HOST: "127.0.0.1",
      ORCHESTRATOR_PORT: String(listenPort),
      ORCHESTRATOR_TASK_SESSIONS: "off",
      ORCHESTRATOR_MCP_SOURCES: "off",
      ORCHESTRATOR_WORKSPACE: "off",
    },
    stdio: ["ignore", "pipe", "pipe"],
  });
  child.stdout.pipe(process.stdout);
  child.stderr.pipe(process.stderr);
  return child;
}

async function step(name, run) {
  const record = {
    name,
    status: "running",
    started_at: new Date().toISOString(),
    finished_at: undefined,
    duration_ms: undefined,
    details: undefined,
    error: undefined,
  };
  manifest.steps.push(record);
  writeManifest();
  console.log(`master priority proof start: ${name}`);
  try {
    const details = await run();
    record.status = "passed";
    record.details = details;
    return details;
  } catch (error) {
    record.status = "failed";
    record.error = error instanceof Error ? error.message : String(error);
    throw error;
  } finally {
    record.finished_at = new Date().toISOString();
    record.duration_ms = Date.parse(record.finished_at) - Date.parse(record.started_at);
    writeManifest();
    console.log(`master priority proof ${record.status}: ${name}`);
  }
}

async function waitForHealth(url) {
  const deadline = Date.now() + 20_000;
  while (Date.now() < deadline) {
    try {
      const response = await fetch(new URL("/health", url));
      if (response.ok) return;
    } catch {
      // Server not ready yet.
    }
    await sleep(250);
  }
  throw new Error(`timed out waiting for orchestrator health at ${url}/health`);
}

async function getJson(path) {
  const response = await fetch(new URL(path, manifest.orchestrator_url));
  return await readJsonResponse(response, "GET", path);
}

async function postJson(path, body, headers = {}) {
  const response = await fetch(new URL(path, manifest.orchestrator_url), {
    method: "POST",
    headers: {
      "content-type": "application/json",
      ...headers,
    },
    body: JSON.stringify(body),
  });
  return await readJsonResponse(response, "POST", path);
}

async function readJsonResponse(response, method, path) {
  const text = await response.text();
  const body = text ? JSON.parse(text) : {};
  if (!response.ok) {
    throw new Error(`${method} ${path} failed ${response.status}: ${JSON.stringify(body)}`);
  }
  return body;
}

async function spawnChecked(command, args, env = process.env) {
  return await new Promise((resolveSpawn, rejectSpawn) => {
    const child = spawn(command, args, {
      cwd: repoRoot,
      env,
      stdio: "inherit",
    });
    child.on("error", rejectSpawn);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolveSpawn();
      } else {
        rejectSpawn(new Error(`${command} ${args.join(" ")} exited with ${signal ?? code}`));
      }
    });
  });
}

async function stopOrchestrator() {
  if (!server || server.killed || server.exitCode !== null) return;
  server.kill("SIGTERM");
  await new Promise((resolve) => server.once("exit", resolve));
  server = undefined;
}

async function freePort() {
  return await new Promise((resolve, reject) => {
    const socket = createServer();
    socket.once("error", reject);
    socket.listen(0, "127.0.0.1", () => {
      const address = socket.address();
      socket.close(() => {
        if (address && typeof address === "object") {
          resolve(address.port);
        } else {
          reject(new Error("failed to allocate free port"));
        }
      });
    });
  });
}

function writeManifest() {
  writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
}

function assert(condition, message) {
  if (!condition) throw new Error(message);
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}
