#!/bin/zsh
set -euo pipefail

: "${EVENTLOOPOS_CODEX_APP_SERVER_URL:?missing EVENTLOOPOS_CODEX_APP_SERVER_URL}"
: "${EVENTLOOPOS_THREAD_ID:?missing EVENTLOOPOS_THREAD_ID}"
: "${EVENTLOOPOS_CODEX_WORKDIR:?missing EVENTLOOPOS_CODEX_WORKDIR}"

export CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
if [[ ! -d "$CODEX_HOME" ]]; then
  echo "CODEX_HOME does not exist: $CODEX_HOME" >&2
  exit 1
fi
cd "$EVENTLOOPOS_CODEX_WORKDIR"

if [[ -n "${EVENTLOOPOS_GHOSTTY_TITLE:-}" ]]; then
  printf '\033]0;%s\007' "$EVENTLOOPOS_GHOSTTY_TITLE"
fi

exec codex --remote "$EVENTLOOPOS_CODEX_APP_SERVER_URL" --no-alt-screen resume "$EVENTLOOPOS_THREAD_ID"
