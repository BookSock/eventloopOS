#!/usr/bin/env node
import http from "node:http";
import fs from "node:fs";
import path from "node:path";
import { performance } from "node:perf_hooks";

const args = process.argv.slice(2);
const DEFAULT_BUDGETS_MS = {
  health: 500,
  queue: 800,
  workspace_capture: 5_000,
  workspace_capture_no_frames: 800,
  workspace_restore_plan: 2_000,
  workspace_restore_plan_uncached: 2_000,
  workspace_restore_execute: 5_000,
};

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/workspace-latency-proof [--url URL] [--runs N] [--execute] [--manifest PATH]

Measures eventloopOS workspace responsiveness against local budget defaults.

Environment:
  EVENTLOOPOS_ORCHESTRATOR_URL      default: http://127.0.0.1:4377
  EVENTLOOPOS_WORKSPACE_LATENCY_RUNS default: 5
  EVENTLOOPOS_WORKSPACE_LATENCY_EXECUTE default: 0
`);
  process.exit(0);
}

if (args.includes("--budgets-json")) {
  console.log(JSON.stringify({
    kind: "eventloopos.workspace_latency_budgets",
    budgets_ms: DEFAULT_BUDGETS_MS,
  }, null, 2));
  process.exit(0);
}

if (args.includes("--self-test")) {
  await runSelfTest();
  process.exit(0);
}

const url = readArg("--url") ?? process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? "http://127.0.0.1:4377";
const runs = positiveInteger(readArg("--runs") ?? process.env.EVENTLOOPOS_WORKSPACE_LATENCY_RUNS, 5);
const executeRestore = args.includes("--execute") || process.env.EVENTLOOPOS_WORKSPACE_LATENCY_EXECUTE === "1";
const runId = new Date().toISOString().replace(/[-:]/g, "").replace(/\.\d+Z$/, "Z");
const manifestPath = readArg("--manifest")
  ?? path.join("artifacts", "workspace-latency", runId, "manifest.json");

const manifest = await measureWorkspaceLatency({ baseUrl: url, runs, executeRestore });
writeJson(manifestPath, manifest);
console.log(`workspace latency manifest: ${manifestPath}`);
console.log(JSON.stringify({
  ok: manifest.ok,
  runs: manifest.runs,
  failed_budgets: manifest.failed_budgets,
  summary: manifest.summary,
}, null, 2));
process.exit(manifest.ok ? 0 : 1);

async function measureWorkspaceLatency({ baseUrl, runs, executeRestore }) {
  const startedAt = new Date().toISOString();
  const budgetsMs = { ...DEFAULT_BUDGETS_MS };
  const samples = [];

  for (let index = 0; index < runs; index += 1) {
    const sample = { run: index + 1, ok: true, timings_ms: {}, errors: [] };
    try {
      await timed(sample, "health", () => requestJson(baseUrl, "/health"));
      await timed(sample, "queue", () => requestJson(baseUrl, "/queue"));
      const fastCapture = await timed(sample, "workspace_capture_no_frames", () => requestJson(baseUrl, "/workspace/capture", {
        method: "POST",
        body: { capture_frames: false },
      }));
      if (!fastCapture.snapshot || !Array.isArray(fastCapture.snapshot.windows)) {
        throw new Error("workspace no-frame capture response missing snapshot.windows");
      }
      const capture = await timed(sample, "workspace_capture", () => requestJson(baseUrl, "/workspace/capture", {
        method: "POST",
        body: {
          frame_window_ids: activeFrameWindowIds(fastCapture.snapshot),
          focus_frame_workspaces: true,
          restore_frame_capture_focus: true,
        },
      }));
      const snapshot = capture.snapshot;
      if (!snapshot || !Array.isArray(snapshot.windows)) {
        throw new Error("workspace capture response missing snapshot.windows");
      }
      await timed(sample, "workspace_restore_plan", () => requestJson(baseUrl, "/workspace/restore-plan", {
        method: "POST",
        body: {
          snapshot,
          current_windows: snapshot.windows,
        },
      }));
      await timed(sample, "workspace_restore_plan_uncached", () => requestJson(baseUrl, "/workspace/restore-plan", {
        method: "POST",
        body: { snapshot },
      }));
      if (executeRestore) {
        await timed(sample, "workspace_restore_execute", () => requestJson(baseUrl, "/workspace/restore", {
          method: "POST",
          headers: {
            "Idempotency-Key": `workspace-latency-${Date.now()}-${index}`,
          },
          body: {
            confirm_execute: true,
            snapshot,
            current_windows: snapshot.windows,
          },
        }));
      }
    } catch (error) {
      sample.ok = false;
      sample.errors.push(error instanceof Error ? error.message : String(error));
    }
    samples.push(sample);
  }

  const summary = summarize(samples);
  const failedBudgets = [];
  for (const [name, budget] of Object.entries(budgetsMs)) {
    if (!executeRestore && name === "workspace_restore_execute") continue;
    const p95 = summary[name]?.p95_ms;
    if (typeof p95 === "number" && p95 > budget) {
      failedBudgets.push({ name, p95_ms: p95, budget_ms: budget });
    }
  }

  const finishedAt = new Date().toISOString();
  return {
    ok: samples.every((sample) => sample.ok) && failedBudgets.length === 0,
    kind: "eventloopos.workspace_latency_proof",
    started_at: startedAt,
    finished_at: finishedAt,
    orchestrator_url: baseUrl,
    runs,
    execute_restore: executeRestore,
    budgets_ms: budgetsMs,
    failed_budgets: failedBudgets,
    summary,
    samples,
  };
}

async function timed(sample, name, fn) {
  const start = performance.now();
  try {
    const value = await fn();
    sample.timings_ms[name] = roundMs(performance.now() - start);
    return value;
  } catch (error) {
    sample.timings_ms[name] = roundMs(performance.now() - start);
    throw error;
  }
}

async function requestJson(baseUrl, route, options = {}) {
  const headers = {
    ...(options.headers ?? {}),
  };
  let body;
  if (options.body !== undefined) {
    headers["content-type"] = "application/json";
    body = JSON.stringify(options.body);
  }
  const response = await fetch(new URL(route, baseUrl), {
    method: options.method ?? "GET",
    headers,
    body,
  });
  const text = await response.text();
  let parsed;
  try {
    parsed = text ? JSON.parse(text) : {};
  } catch {
    parsed = { raw: text };
  }
  if (!response.ok) {
    throw new Error(`${route} HTTP ${response.status}: ${JSON.stringify(parsed)}`);
  }
  return parsed;
}

function summarize(samples) {
  const names = new Set(samples.flatMap((sample) => Object.keys(sample.timings_ms)));
  const result = {};
  for (const name of names) {
    const values = samples
      .map((sample) => sample.timings_ms[name])
      .filter((value) => typeof value === "number" && Number.isFinite(value))
      .sort((left, right) => left - right);
    if (values.length === 0) continue;
    result[name] = {
      count: values.length,
      min_ms: roundMs(values[0]),
      median_ms: percentile(values, 0.5),
      p95_ms: percentile(values, 0.95),
      max_ms: roundMs(values[values.length - 1]),
    };
  }
  return result;
}

function activeFrameWindowIds(snapshot) {
  const windows = Array.isArray(snapshot?.windows) ? snapshot.windows : [];
  const activeWorkspace = typeof snapshot?.activeWorkspace === "string" && snapshot.activeWorkspace
    ? snapshot.activeWorkspace
    : undefined;
  const activeWindowIds = windows
    .filter((window) => activeWorkspace && window.workspace === activeWorkspace)
    .map((window) => window.id)
    .filter(isPositiveInteger);
  if (activeWindowIds.length > 0) return activeWindowIds;
  if (isPositiveInteger(snapshot?.focusedWindowId)) return [snapshot.focusedWindowId];
  return windows.map((window) => window.id).filter(isPositiveInteger);
}

function isPositiveInteger(value) {
  return Number.isInteger(value) && value > 0;
}

function percentile(values, p) {
  if (values.length === 0) return undefined;
  const index = Math.min(values.length - 1, Math.ceil(values.length * p) - 1);
  return roundMs(values[index]);
}

function roundMs(value) {
  return Math.round(value * 10) / 10;
}

function readArg(name) {
  const index = args.indexOf(name);
  if (index < 0) return undefined;
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    throw new Error(`${name} requires a value`);
  }
  return value;
}

function positiveInteger(value, fallback) {
  if (value === undefined || value === "") return fallback;
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed <= 0) {
    throw new Error(`expected positive integer, got ${value}`);
  }
  return parsed;
}

function writeJson(filePath, value) {
  fs.mkdirSync(path.dirname(filePath), { recursive: true });
  fs.writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`);
}

async function runSelfTest() {
  const server = http.createServer(async (request, response) => {
    const send = (status, body) => {
      response.writeHead(status, { "content-type": "application/json" });
      response.end(JSON.stringify(body));
    };

    if (request.method === "GET" && request.url === "/health") {
      send(200, { ok: true });
      return;
    }
    if (request.method === "GET" && request.url === "/queue") {
      send(200, { ok: true, items: [] });
      return;
    }
    if (request.method === "POST" && request.url === "/workspace/capture") {
      send(200, {
        ok: true,
        snapshot: {
          backend: "aerospace",
          activeWorkspace: "test",
          focusedWindowId: 1,
          windows: [
            {
              id: 1,
              app: "TextEdit",
              title: "Self Test",
              workspace: "test",
              layout: "floating",
              frame: { x: 10, y: 20, width: 300, height: 200 },
            },
          ],
        },
      });
      return;
    }
    if (request.method === "POST" && request.url === "/workspace/restore-plan") {
      send(200, {
        ok: true,
        plan: { commands: [], skipped: [] },
        execute_supported: true,
      });
      return;
    }
    if (request.method === "POST" && request.url === "/workspace/restore") {
      send(200, {
        ok: true,
        plan: { commands: [], skipped: [] },
        receipt: { commands: [], skipped: [] },
        execute_supported: true,
      });
      return;
    }
    send(404, { ok: false, error: "not_found" });
  });

  await new Promise((resolve) => server.listen(0, "127.0.0.1", resolve));
  try {
    const address = server.address();
    const port = typeof address === "object" && address ? address.port : 0;
    const manifest = await measureWorkspaceLatency({
      baseUrl: `http://127.0.0.1:${port}`,
      runs: 2,
      executeRestore: true,
    });
    if (!manifest.ok) throw new Error(`self-test manifest not ok: ${JSON.stringify(manifest)}`);
    if (manifest.samples.length !== 2) throw new Error("self-test did not run twice");
    if (!manifest.summary.workspace_restore_execute) throw new Error("self-test missing execute summary");
    console.log("workspace-latency-proof self-test passed");
  } finally {
    await new Promise((resolve) => server.close(resolve));
  }
}
