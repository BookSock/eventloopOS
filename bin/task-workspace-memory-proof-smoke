#!/usr/bin/env node
import { createServer } from "node:net";
import { mkdtempSync, mkdirSync, rmSync, writeFileSync } from "node:fs";
import { tmpdir } from "node:os";
import { dirname, join, resolve } from "node:path";
import { execFile, spawn } from "node:child_process";

const startedAt = new Date();
const runId = `${startedAt.toISOString().replace(/[:.]/g, "-")}-${process.pid}`;
const repoRoot = process.cwd();
const artifactDir = resolve(repoRoot, process.env.EVENTLOOPOS_TASK_WORKSPACE_MEMORY_ARTIFACT_DIR ?? `artifacts/task-workspace-memory/${runId}`);
const manifestPath = resolve(artifactDir, "manifest.json");
const smokeTitles = [
  `eventloopOS-task-memory-alpha-${runId}.txt`,
  `eventloopOS-task-memory-beta-${runId}.txt`,
];
const manifest = {
  schema_version: 1,
  kind: "eventloopos.task_workspace_memory_proof",
  run_id: runId,
  started_at: startedAt.toISOString(),
  finished_at: undefined,
  duration_ms: undefined,
  artifact_dir: artifactDir,
  orchestrator_url: undefined,
  task_windows: [],
  steps: [],
  passed: false,
};

let server;
let smokeDir;

mkdirSync(dirname(manifestPath), { recursive: true });
writeManifest();

try {
  const port = await freePort();
  manifest.orchestrator_url = `http://127.0.0.1:${port}`;
  writeManifest();

  await step("build orchestrator", async () => {
    await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "build"]);
  });

  server = startOrchestrator(port);
  await step("wait for orchestrator", async () => {
    await waitForHealth(manifest.orchestrator_url);
  });

  const before = await step("capture baseline windows", async () => {
    const windows = await listAerospaceWindows();
    return { count: windows.length, windows };
  });
  const baselineById = new Map(before.windows.map((window) => [window.id, window]));

  const taskWindows = await step("launch sacrificial task windows", async () => {
    smokeDir = mkdtempSync(join(tmpdir(), "eventloopos-task-memory-"));
    for (const title of smokeTitles) {
      const path = join(smokeDir, title);
      writeFileSync(path, `${title}\n`, "utf8");
      await execFilePromise("open", ["-a", "TextEdit", path], { timeoutMs: 5_000 });
    }
    const launched = await waitForSmokeWindows(smokeTitles, new Set(before.windows.map((window) => window.id)));
    manifest.task_windows = launched;
    writeManifest();
    return launched;
  });

  const alpha = taskWindows.find((window) => window.title.includes("alpha"));
  const beta = taskWindows.find((window) => window.title.includes("beta"));
  assert(alpha && beta, `missing smoke windows: ${JSON.stringify(taskWindows)}`);
  const allowedIds = new Set([alpha.id, beta.id]);
  const taskA = { hint: "task workspace memory proof a", expectedId: "task_task_workspace_memory_proof_a" };
  const taskB = { hint: "task workspace memory proof b", expectedId: "task_task_workspace_memory_proof_b" };
  const workspaceA1 = `evt-mem-a1-${process.pid}`;
  const workspaceA2 = `evt-mem-a2-${process.pid}`;
  const workspaceB1 = `evt-mem-b1-${process.pid}`;
  const workspaceB2 = `evt-mem-b2-${process.pid}`;
  const taskASnapshot = {
    backend: "aerospace",
    activeWorkspace: workspaceA1,
    focusedWindowId: alpha.id,
    windows: [
      { ...alpha, workspace: workspaceA1 },
      { ...beta, workspace: workspaceA2 },
    ],
  };
  const taskBSnapshot = {
    backend: "aerospace",
    activeWorkspace: workspaceB1,
    focusedWindowId: beta.id,
    windows: [
      { ...alpha, workspace: workspaceB2 },
      { ...beta, workspace: workspaceB1 },
    ],
  };

  const firstA = await step("create task A first paper", async () => {
    const body = await postJson("/events", manualEvent({
      id: "evt_task_workspace_memory_a_first",
      idempotencyKey: `idem-task-workspace-memory-a-first-${runId}`,
      taskHint: taskA.hint,
      title: "Task A first paper",
      summary: "Save task A workspace snapshot when this paper is done.",
    }));
    assert(body.queue_item?.id, `task A first event missing queue item: ${JSON.stringify(body)}`);
    assert(body.queue_item.task_id === taskA.expectedId, `task A id mismatch: ${JSON.stringify(body.queue_item)}`);
    return { queue_item_id: body.queue_item.id, task_id: body.queue_item.task_id };
  });

  await step("mark task A done with A layout", async () => {
    const body = await postJson(`/queue/${encodeURIComponent(firstA.queue_item_id)}/done`, {
      action: "done",
      actor_id: "task_workspace_memory_proof",
      workspace_snapshot: taskASnapshot,
    });
    assert(body.ok === true, `task A done failed: ${JSON.stringify(body)}`);
    return {
      task_id: firstA.task_id,
      queue_item_id: firstA.queue_item_id,
      saved_window_ids: taskASnapshot.windows.map((window) => window.id),
      focused_window_id: taskASnapshot.focusedWindowId,
      saved_layout: windowWorkspaceMap(taskASnapshot.windows),
    };
  });

  const firstB = await step("create task B first paper", async () => {
    const body = await postJson("/events", manualEvent({
      id: "evt_task_workspace_memory_b_first",
      idempotencyKey: `idem-task-workspace-memory-b-first-${runId}`,
      taskHint: taskB.hint,
      title: "Task B first paper",
      summary: "Save task B workspace snapshot when this paper is done.",
    }));
    assert(body.queue_item?.id, `task B first event missing queue item: ${JSON.stringify(body)}`);
    assert(body.queue_item.task_id === taskB.expectedId, `task B id mismatch: ${JSON.stringify(body.queue_item)}`);
    return { queue_item_id: body.queue_item.id, task_id: body.queue_item.task_id };
  });

  await step("mark task B done with B layout", async () => {
    const body = await postJson(`/queue/${encodeURIComponent(firstB.queue_item_id)}/done`, {
      action: "done",
      actor_id: "task_workspace_memory_proof",
      workspace_snapshot: taskBSnapshot,
    });
    assert(body.ok === true, `task B done failed: ${JSON.stringify(body)}`);
    return {
      task_id: firstB.task_id,
      queue_item_id: firstB.queue_item_id,
      saved_window_ids: taskBSnapshot.windows.map((window) => window.id),
      focused_window_id: taskBSnapshot.focusedWindowId,
      saved_layout: windowWorkspaceMap(taskBSnapshot.windows),
    };
  });

  await step("create task A second paper with inherited A workspace", async () => {
    const body = await postJson("/events", manualEvent({
      id: "evt_task_workspace_memory_a_second",
      idempotencyKey: `idem-task-workspace-memory-a-second-${runId}`,
      taskHint: taskA.hint,
      title: "Task A second paper",
      summary: "Should inherit task A saved workspace.",
    }));
    const workspaceContext = findWorkspaceContext(body.queue_item);
    assertWorkspaceSnapshotMatches(workspaceContext.snapshot, taskASnapshot, "task A inherited snapshot");
    return {
      queue_item_id: body.queue_item.id,
      task_id: body.queue_item.task_id,
      workspace_context_id: workspaceContext.id,
      inherited_layout: windowWorkspaceMap(workspaceContext.snapshot.windows),
    };
  });

  await step("create task B second paper with inherited B workspace", async () => {
    const body = await postJson("/events", manualEvent({
      id: "evt_task_workspace_memory_b_second",
      idempotencyKey: `idem-task-workspace-memory-b-second-${runId}`,
      taskHint: taskB.hint,
      title: "Task B second paper",
      summary: "Should inherit task B saved workspace.",
    }));
    const workspaceContext = findWorkspaceContext(body.queue_item);
    assertWorkspaceSnapshotMatches(workspaceContext.snapshot, taskBSnapshot, "task B inherited snapshot");
    return {
      queue_item_id: body.queue_item.id,
      task_id: body.queue_item.task_id,
      workspace_context_id: workspaceContext.id,
      inherited_layout: windowWorkspaceMap(workspaceContext.snapshot.windows),
    };
  });

  const pulledA = await step("pull task A again and restore A layout", async () => {
    const leased = await leaseNext();
    assert(leased.item?.task_id === taskA.expectedId, `expected task A pull, got ${JSON.stringify(leased.item)}`);
    const workspaceContext = findWorkspaceContext(leased.item);
    assertWorkspaceSnapshotMatches(workspaceContext.snapshot, taskASnapshot, "task A pulled snapshot");
    const restore = await restoreSnapshot(workspaceContext.snapshot, [alpha.id, beta.id], allowedIds, baselineById, `task-workspace-memory-restore-a-${runId}`);
    await assertCurrentWorkspaces([
      [alpha.id, workspaceA1],
      [beta.id, workspaceA2],
    ]);

    const currentTaskWindows = await currentVersions([alpha.id, beta.id]);
    await postJson(`/queue/${encodeURIComponent(leased.item.id)}/done`, {
      action: "done",
      actor_id: "task_workspace_memory_proof",
      workspace_snapshot: {
        backend: "aerospace",
        activeWorkspace: workspaceA1,
        focusedWindowId: alpha.id,
        windows: currentTaskWindows,
      },
    });

    return {
      queue_item_id: leased.item.id,
      task_id: leased.item.task_id,
      restored_window_ids: restore.movedWindowIds,
      restore_commands: restore.commands,
      expected_layout: { [alpha.id]: workspaceA1, [beta.id]: workspaceA2 },
      non_test_changed_windows: restore.nonTestChangedWindows,
    };
  });

  await step("pull task B again and restore B layout", async () => {
    const leased = await leaseNext();
    assert(leased.item?.task_id === taskB.expectedId, `expected task B pull after ${pulledA.queue_item_id}, got ${JSON.stringify(leased.item)}`);
    const workspaceContext = findWorkspaceContext(leased.item);
    assertWorkspaceSnapshotMatches(workspaceContext.snapshot, taskBSnapshot, "task B pulled snapshot");
    const restore = await restoreSnapshot(workspaceContext.snapshot, [alpha.id, beta.id], allowedIds, baselineById, `task-workspace-memory-restore-b-${runId}`);
    await assertCurrentWorkspaces([
      [alpha.id, workspaceB2],
      [beta.id, workspaceB1],
    ]);
    return {
      queue_item_id: leased.item.id,
      task_id: leased.item.task_id,
      restored_window_ids: restore.movedWindowIds,
      restore_commands: restore.commands,
      expected_layout: { [alpha.id]: workspaceB2, [beta.id]: workspaceB1 },
      non_test_changed_windows: restore.nonTestChangedWindows,
    };
  });

  await step("restore sacrificial windows to original workspaces", async () => {
    const currentTaskWindows = await currentVersions([alpha.id, beta.id]);
    const body = await postJson("/workspace/restore", {
      confirm_execute: true,
      snapshot: {
        backend: "aerospace",
        windows: [alpha, beta],
      },
      current_windows: currentTaskWindows,
    }, { "Idempotency-Key": `task-workspace-memory-cleanup-${runId}` });
    assert(body.ok === true, `cleanup restore failed: ${JSON.stringify(body)}`);
    assertOnlyTestWindowsInPlan(body.plan, allowedIds);
    const current = await listAerospaceWindows();
    await assertWindowWorkspace(alpha.id, alpha.workspace, current);
    await assertWindowWorkspace(beta.id, beta.workspace, current);
    const nonTestChangedWindows = changedBaselineWindows(baselineById, current, allowedIds);
    assert(nonTestChangedWindows.length === 0, `non-test windows changed workspace: ${JSON.stringify(nonTestChangedWindows)}`);
    return {
      command_count: body.plan.commands.length,
      restore_commands: body.plan.commands,
      restored_to_original: { [alpha.id]: alpha.workspace, [beta.id]: beta.workspace },
      non_test_changed_windows: nonTestChangedWindows,
    };
  });

  manifest.passed = true;
} catch (error) {
  manifest.error = error instanceof Error ? error.stack ?? error.message : String(error);
  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
  process.exitCode = 1;
} finally {
  await cleanupSmokeWindows();
  await stopOrchestrator();
  manifest.finished_at = new Date().toISOString();
  manifest.duration_ms = Date.parse(manifest.finished_at) - Date.parse(manifest.started_at);
  writeManifest();
  console.log(`task workspace memory proof manifest: ${manifestPath}`);
}

function manualEvent({ id, idempotencyKey, taskHint, title, summary }) {
  return {
    id,
    source: "manual",
    source_id: `manual:${id}`,
    idempotency_key: idempotencyKey,
    occurred_at: new Date().toISOString(),
    received_at: new Date().toISOString(),
    actor: { id: "user_proof", type: "human" },
    task_hint: taskHint,
    type: "manual.review_requested",
    title,
    summary,
    raw_ref: { id: `raw_${id}`, uri: `manual://${id}` },
    links: [],
    resources: [],
  };
}

function startOrchestrator(listenPort) {
  const child = spawn("node", ["app/orchestrator/dist/src/index.js"], {
    cwd: repoRoot,
    env: {
      ...process.env,
      ORCHESTRATOR_HOST: "127.0.0.1",
      ORCHESTRATOR_PORT: String(listenPort),
      ORCHESTRATOR_SEED_FIXTURE: "app/orchestrator/fixtures/empty-review-packets.json",
      ORCHESTRATOR_TASK_SESSIONS: "off",
      ORCHESTRATOR_MCP_SOURCES: "off",
      ORCHESTRATOR_WORKSPACE: "aerospace",
      ORCHESTRATOR_WORKSPACE_EXECUTE: "enabled",
    },
    stdio: ["ignore", "pipe", "pipe"],
  });
  child.stdout.pipe(process.stdout);
  child.stderr.pipe(process.stderr);
  return child;
}

async function leaseNext() {
  const body = await postJson("/queue/lease-next", {
    lease_owner: "task_workspace_memory_proof",
    lease_ms: 60_000,
  });
  assert(body.item, `lease-next returned no item: ${JSON.stringify(body)}`);
  return body;
}

async function restoreSnapshot(snapshot, targetIds, allowedIds, baselineById, idempotencyKey) {
  const currentTaskWindows = await currentVersions(targetIds);
  const body = await postJson("/workspace/restore", {
    confirm_execute: true,
    snapshot,
    current_windows: currentTaskWindows,
  }, { "Idempotency-Key": idempotencyKey });
  assert(body.ok === true, `restore failed: ${JSON.stringify(body)}`);
  assertOnlyTestWindowsInPlan(body.plan, allowedIds);
  const current = await listAerospaceWindows();
  const nonTestChangedWindows = changedBaselineWindows(baselineById, current, allowedIds);
  assert(nonTestChangedWindows.length === 0, `non-test windows changed workspace: ${JSON.stringify(nonTestChangedWindows)}`);
  return {
    commands: body.plan.commands,
    movedWindowIds: movedWindowIdsFromPlan(body.plan),
    nonTestChangedWindows,
  };
}

async function step(name, run) {
  const record = {
    name,
    status: "running",
    started_at: new Date().toISOString(),
    finished_at: undefined,
    duration_ms: undefined,
    details: undefined,
    error: undefined,
  };
  manifest.steps.push(record);
  writeManifest();
  console.log(`task workspace memory proof start: ${name}`);
  try {
    const details = await run();
    record.status = "passed";
    record.details = details;
    return details;
  } catch (error) {
    record.status = "failed";
    record.error = error instanceof Error ? error.message : String(error);
    throw error;
  } finally {
    record.finished_at = new Date().toISOString();
    record.duration_ms = Date.parse(record.finished_at) - Date.parse(record.started_at);
    writeManifest();
    console.log(`task workspace memory proof ${record.status}: ${name}`);
  }
}

async function waitForSmokeWindows(titles, excludedIds) {
  const deadline = Date.now() + 15_000;
  let last = [];
  while (Date.now() < deadline) {
    const windows = await listAerospaceWindows();
    last = windows;
    const found = titles.map((title) => windows.find((window) => !excludedIds.has(window.id) && window.title.includes(title)));
    if (found.every(Boolean)) return found;
    await sleep(250);
  }
  throw new Error(`timed out waiting for task memory windows ${titles.join(", ")}; last=${JSON.stringify(last)}`);
}

async function currentVersions(ids) {
  const windows = await listAerospaceWindows();
  return ids.map((id) => {
    const window = windows.find((candidate) => candidate.id === id);
    assert(window, `window ${id} missing`);
    return window;
  });
}

function findWorkspaceContext(queueItem) {
  const contexts = queueItem?.review_packet?.context ?? [];
  const workspaceContext = contexts.find((context) => context?.kind === "workspace_snapshot" && context?.source === "task_workspace_memory");
  assert(workspaceContext?.snapshot, `queue item missing task workspace memory context: ${JSON.stringify(queueItem)}`);
  return workspaceContext;
}

function assertWorkspaceSnapshotMatches(actual, expected, label) {
  assert(actual?.focusedWindowId === expected.focusedWindowId, `${label} focused window mismatch: ${JSON.stringify(actual)}`);
  assert(actual?.activeWorkspace === expected.activeWorkspace, `${label} active workspace mismatch: ${JSON.stringify(actual)}`);
  const actualMap = windowWorkspaceMap(actual.windows ?? []);
  const expectedMap = windowWorkspaceMap(expected.windows);
  assert(JSON.stringify(actualMap) === JSON.stringify(expectedMap), `${label} layout mismatch: actual=${JSON.stringify(actualMap)} expected=${JSON.stringify(expectedMap)}`);
}

function windowWorkspaceMap(windows) {
  return Object.fromEntries(windows.map((window) => [String(window.id), window.workspace]));
}

function movedWindowIdsFromPlan(plan) {
  const ids = [];
  for (const command of Array.isArray(plan?.commands) ? plan.commands : []) {
    const args = Array.isArray(command.args) ? command.args : [];
    if (args[0] === "move-node-to-workspace") ids.push(Number(args[2]));
  }
  return ids;
}

function assertOnlyTestWindowsInPlan(plan, allowedIds) {
  const commands = Array.isArray(plan?.commands) ? plan.commands : [];
  for (const command of commands) {
    const args = Array.isArray(command.args) ? command.args : [];
    if (args[0] === "workspace") {
      assert(args.length === 2, `unexpected workspace command ${JSON.stringify(command)}`);
      continue;
    }
    if (args[0] === "focus") {
      const focusedWindowId = Number(args[2]);
      assert(args[1] === "--window-id", `focus command missing --window-id ${JSON.stringify(command)}`);
      assert(allowedIds.has(focusedWindowId), `restore plan tried to focus non-test window ${focusedWindowId}`);
      continue;
    }
    const windowId = Number(args[2]);
    assert(args[0] === "move-node-to-workspace", `unexpected restore command ${JSON.stringify(command)}`);
    assert(args[1] === "--window-id", `restore command missing --window-id ${JSON.stringify(command)}`);
    assert(allowedIds.has(windowId), `restore plan tried to move non-test window ${windowId}`);
  }
}

async function assertCurrentWorkspaces(expectedEntries) {
  const current = await listAerospaceWindows();
  for (const [windowId, workspace] of expectedEntries) {
    await assertWindowWorkspace(windowId, workspace, current);
  }
}

async function assertWindowWorkspace(windowId, workspace, windows) {
  const window = windows.find((candidate) => candidate.id === windowId);
  assert(window, `window ${windowId} missing`);
  assert(window.workspace === workspace, `window ${windowId} workspace ${window.workspace}, expected ${workspace}`);
}

function changedBaselineWindows(baselineById, current, allowedIds) {
  const currentById = new Map(current.map((window) => [window.id, window]));
  const changed = [];
  for (const [id, before] of baselineById) {
    if (allowedIds.has(id)) continue;
    const after = currentById.get(id);
    if (after && after.workspace !== before.workspace) {
      changed.push({ id, app: before.app, title: before.title, before: before.workspace, after: after.workspace });
    }
  }
  return changed;
}

async function listAerospaceWindows() {
  const { stdout } = await execFilePromise("aerospace", [
    "list-windows",
    "--all",
    "--format",
    "%{window-id}|%{app-name}|%{window-title}|%{workspace}",
  ], { timeoutMs: 10_000 });
  return stdout.split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => {
      const parts = line.split("|");
      const id = Number(parts.shift());
      const app = parts.shift() ?? "";
      const workspace = parts.pop() ?? "";
      const title = parts.join("|");
      assert(Number.isInteger(id), `invalid AeroSpace window id line: ${line}`);
      return { id, app, title, workspace };
    });
}

async function waitForHealth(url) {
  const deadline = Date.now() + 20_000;
  while (Date.now() < deadline) {
    try {
      const response = await fetch(new URL("/health", url));
      if (response.ok) return;
    } catch {
      // Server not ready yet.
    }
    await sleep(250);
  }
  throw new Error(`timed out waiting for orchestrator health at ${url}/health`);
}

async function postJson(path, body, headers = {}) {
  const response = await fetch(new URL(path, manifest.orchestrator_url), {
    method: "POST",
    headers: {
      "content-type": "application/json",
      ...headers,
    },
    body: JSON.stringify(body),
  });
  const text = await response.text();
  const parsed = text ? JSON.parse(text) : {};
  if (!response.ok) {
    throw new Error(`POST ${path} failed ${response.status}: ${JSON.stringify(parsed)}`);
  }
  return parsed;
}

async function cleanupSmokeWindows() {
  for (const window of manifest.task_windows) {
    if (!Number.isInteger(window?.id)) continue;
    try {
      await execFilePromise("aerospace", ["close", "--window-id", String(window.id)], { timeoutMs: 5_000 });
    } catch {
      // Already closed or AeroSpace cannot see it anymore.
    }
  }
  for (const title of smokeTitles) {
    try {
      await execFilePromise("osascript", [
        "-e",
        `tell application "TextEdit" to close (documents whose name is "${escapeAppleScriptString(title)}") saving no`,
      ], { timeoutMs: 5_000 });
    } catch {
      // Already closed.
    }
    try {
      await execFilePromise("osascript", [
        "-e",
        `tell application "System Events"
  if exists process "TextEdit" then
    tell process "TextEdit"
      repeat with candidateWindow in windows
        try
          if (name of candidateWindow as string) contains "${escapeAppleScriptString(title)}" then perform action "AXClose" of candidateWindow
        end try
      end repeat
    end tell
  end if
end tell`,
      ], { timeoutMs: 5_000 });
    } catch {
      // Already closed or accessibility unavailable.
    }
  }
  if (smokeDir) {
    rmSync(smokeDir, { recursive: true, force: true });
  }
}

async function stopOrchestrator() {
  if (!server || server.killed || server.exitCode !== null) return;
  server.kill("SIGTERM");
  await new Promise((resolve) => server.once("exit", resolve));
  server = undefined;
}

async function spawnChecked(command, args, env = process.env) {
  return await new Promise((resolveSpawn, rejectSpawn) => {
    const child = spawn(command, args, {
      cwd: repoRoot,
      env,
      stdio: "inherit",
    });
    child.on("error", rejectSpawn);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolveSpawn();
      } else {
        rejectSpawn(new Error(`${command} ${args.join(" ")} exited with ${signal ?? code}`));
      }
    });
  });
}

async function execFilePromise(command, args, options = {}) {
  return await new Promise((resolveExec, rejectExec) => {
    execFile(command, args, {
      cwd: repoRoot,
      encoding: "utf8",
      timeout: options.timeoutMs ?? 10_000,
      maxBuffer: 1024 * 1024,
    }, (error, stdout, stderr) => {
      if (error) {
        rejectExec(error);
        return;
      }
      resolveExec({ stdout, stderr });
    });
  });
}

async function freePort() {
  return await new Promise((resolve, reject) => {
    const socket = createServer();
    socket.once("error", reject);
    socket.listen(0, "127.0.0.1", () => {
      const address = socket.address();
      socket.close(() => {
        if (address && typeof address === "object") {
          resolve(address.port);
        } else {
          reject(new Error("failed to allocate free port"));
        }
      });
    });
  });
}

function writeManifest() {
  writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
}

function escapeAppleScriptString(value) {
  return value.replaceAll("\\", "\\\\").replaceAll('"', '\\"');
}

function assert(condition, message) {
  if (!condition) throw new Error(message);
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}
