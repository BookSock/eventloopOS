#!/usr/bin/env node
import { spawn } from "node:child_process";
import { existsSync } from "node:fs";
import { createServer } from "node:net";

const profile = sanitizeProfile(process.env.EVENTLOOPOS_DOGFOOD_PROFILE ?? "default");
const orchestratorUrl = process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? defaultOrchestratorUrl(profile);
const orchestratorEndpoint = parseHttpEndpoint(orchestratorUrl);
const postgresPort = process.env.EVENTLOOPOS_POSTGRES_PORT ?? defaultPostgresPort(profile);
const postgresContainer = process.env.EVENTLOOPOS_POSTGRES_CONTAINER ?? defaultPostgresContainer(profile);
const usePostgres = process.env.EVENTLOOPOS_DOGFOOD_POSTGRES !== "0";
const providedDatabaseUrl = process.env.DATABASE_URL;
const launchQueueApp = process.env.EVENTLOOPOS_DOGFOOD_QUEUE_APP !== "0";
const smokeMs = parseOptionalPositiveInteger(process.env.EVENTLOOPOS_DOGFOOD_SMOKE_MS);
const emptySeedFixture = "fixtures/empty-review-packets.json";
const children = [];
let startedPostgres = false;
let cleaningUp = false;

for (const signal of ["SIGINT", "SIGTERM"]) {
  process.once(signal, async () => {
    await cleanup();
    process.exit(0);
  });
}

try {
  await requireAerospace();
  const databaseUrl = usePostgres ? await resolveDatabaseUrl() : undefined;
  await runChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "build"]);
  const taskSessionModes = process.env.ORCHESTRATOR_TASK_SESSIONS ?? "codex_app_server";
  const codexAppServerUrl = await maybeStartSharedCodexAppServer(taskSessionModes);

  const orchestrator = spawnChild("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "start"], {
    DATABASE_URL: databaseUrl,
    EVENTLOOPOS_DOGFOOD_PROFILE: profile,
    EVENTLOOPOS_IN_MEMORY_STORE_FILE: usePostgres
      ? undefined
      : process.env.EVENTLOOPOS_IN_MEMORY_STORE_FILE ?? defaultInMemoryStorePath(profile),
    ORCHESTRATOR_HOST: process.env.ORCHESTRATOR_HOST ?? orchestratorEndpoint.host,
    ORCHESTRATOR_PORT: process.env.ORCHESTRATOR_PORT ?? String(orchestratorEndpoint.port),
    ORCHESTRATOR_TASK_SESSIONS: taskSessionModes,
    ORCHESTRATOR_CODEX_APP_SERVER_URL: process.env.ORCHESTRATOR_CODEX_APP_SERVER_URL ?? codexAppServerUrl,
    ORCHESTRATOR_CODEX_TASK_MAP_PATH: process.env.ORCHESTRATOR_CODEX_TASK_MAP_PATH ?? defaultCodexTaskMapPath(profile),
    ORCHESTRATOR_MCP_SOURCES: process.env.ORCHESTRATOR_MCP_SOURCES ?? defaultMcpSourcesMode(),
    ORCHESTRATOR_MCP_SOURCES_PATH: process.env.ORCHESTRATOR_MCP_SOURCES_PATH ?? defaultMcpSourcesPath(),
    ORCHESTRATOR_SEED_FIXTURE: process.env.ORCHESTRATOR_SEED_FIXTURE ?? (usePostgres ? undefined : emptySeedFixture),
    ORCHESTRATOR_WORKSPACE: process.env.ORCHESTRATOR_WORKSPACE ?? "aerospace",
    ORCHESTRATOR_WORKSPACE_EXECUTE: process.env.ORCHESTRATOR_WORKSPACE_EXECUTE ?? "disabled",
    EVENTLOOPOS_POSTGRES_MIGRATIONS_DIR: process.env.EVENTLOOPOS_POSTGRES_MIGRATIONS_DIR,
  });
  await waitForHealth(orchestratorUrl, 15_000);

  maybeStartPollLoop();

  const app = launchQueueApp
    ? spawnChild("pnpm", ["run", "run:queue-app"], {
      EVENTLOOPOS_ORCHESTRATOR_URL: orchestratorUrl,
      EVENTLOOPOS_QUEUE_APP_RUN_SMOKE_MS: smokeMs === undefined ? undefined : String(smokeMs),
      EVENTLOOPOS_QUEUE_APP_HARNESS_WINDOW: process.env.EVENTLOOPOS_QUEUE_APP_HARNESS_WINDOW,
    })
    : undefined;

  process.stdout.write(`eventloopOS dogfood stack ready at ${orchestratorUrl}\n`);
  process.stdout.write(`Dogfood profile: ${profile}\n`);
  if (usePostgres && providedDatabaseUrl) {
    process.stdout.write("Database: supplied DATABASE_URL\n");
  } else if (usePostgres) {
    process.stdout.write(`Dev Postgres: ${postgresContainer} on 127.0.0.1:${postgresPort}\n`);
  }
  if (codexAppServerUrl) {
    process.stdout.write(`Shared Codex app-server: ${codexAppServerUrl}\n`);
    process.stdout.write("Open visible Codex threads with: codex --remote <url> resume <thread-id>\n");
  }
  if (launchQueueApp) {
    process.stdout.write("Queue app is running. Ctrl-C here stops app, orchestrator, poll loop, and dev Postgres.\n");
  } else {
    process.stdout.write("Queue app disabled for this stack. Ctrl-C here stops orchestrator, poll loop, and dev Postgres.\n");
  }
  // `open -W` can return even while the LSUIElement Queue app remains alive, so
  // the orchestrator is the durable lifecycle owner for dogfood mode.
  const appCode = await waitForExit(orchestrator);
  await cleanup();
  process.exitCode = appCode ?? 0;
} catch (error) {
  process.stderr.write(`${error instanceof Error ? error.message : String(error)}\n`);
  await cleanup();
  process.exitCode = 1;
}

async function requireAerospace() {
  if (process.env.EVENTLOOPOS_DOGFOOD_REQUIRE_AEROSPACE === "0") {
    return;
  }

  try {
    await runChecked("aerospace", ["--version"], { echo: false });
    await runChecked("aerospace", ["list-workspaces", "--focused"], { echo: false });
  } catch (error) {
    throw new Error([
      "AeroSpace is required for eventloopOS dogfood.",
      "Install it with: brew install --cask nikitabobko/tap/aerospace",
      "Then launch AeroSpace, grant Accessibility access if prompted, and rerun pnpm run dev:dogfood.",
      `AeroSpace readiness check failed: ${error instanceof Error ? error.message : String(error)}`,
      "Set EVENTLOOPOS_DOGFOOD_REQUIRE_AEROSPACE=0 only for queue/router hacking without workspace restore.",
    ].join("\n"));
  }
}

async function startPostgres() {
  const result = await runChecked("pnpm", ["run", "dev:postgres:up"], { env: postgresEnv() });
  startedPostgres = true;
  const url = result.stdout.trim().split(/\r?\n/).at(-1);
  if (!url?.startsWith("postgres://")) {
    throw new Error(`dev Postgres did not return a postgres URL: ${result.stdout}`);
  }
  return url;
}

async function resolveDatabaseUrl() {
  if (providedDatabaseUrl) {
    return providedDatabaseUrl;
  }
  return await startPostgres();
}

function maybeStartPollLoop() {
  if (process.env.EVENTLOOPOS_DOGFOOD_MCP_POLL !== "1") {
    return undefined;
  }
  return spawnChild("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "poll:mcp:loop"], {
    EVENTLOOPOS_ORCHESTRATOR_URL: orchestratorUrl,
    EVENTLOOPOS_MCP_POLL_INTERVAL_MS: process.env.EVENTLOOPOS_MCP_POLL_INTERVAL_MS ?? "30000",
    EVENTLOOPOS_MCP_SOURCE_IDS: process.env.EVENTLOOPOS_MCP_SOURCE_IDS,
  });
}

function defaultMcpSourcesMode() {
  return existsSync("config/mcp-sources.json") ? "config" : "off";
}

function defaultMcpSourcesPath() {
  return existsSync("config/mcp-sources.json") ? "config/mcp-sources.json" : undefined;
}

async function maybeStartSharedCodexAppServer(taskSessionModes) {
  if (process.env.ORCHESTRATOR_CODEX_APP_SERVER_URL) {
    return undefined;
  }
  if (process.env.EVENTLOOPOS_DOGFOOD_SHARED_CODEX_APP_SERVER === "0") {
    return undefined;
  }
  if (!taskSessionModes.split(",").map((mode) => mode.trim()).includes("codex_app_server")) {
    return undefined;
  }

  const port = await freePort();
  const url = `ws://127.0.0.1:${port}`;
  spawnChild("codex", ["app-server", "--listen", url]);
  await waitForCodexAppServerReady(port, 15_000);
  return url;
}

async function waitForCodexAppServerReady(port, timeoutMs) {
  const deadline = Date.now() + timeoutMs;
  const readyUrl = `http://127.0.0.1:${port}/readyz`;
  while (Date.now() < deadline) {
    try {
      const response = await fetch(readyUrl);
      if (response.ok) return;
    } catch {
      // keep waiting
    }
    await sleep(100);
  }
  throw new Error(`shared Codex app-server did not become ready at ${readyUrl}`);
}

async function freePort() {
  return await new Promise((resolve, reject) => {
    const socket = createServer();
    socket.once("error", reject);
    socket.listen(0, "127.0.0.1", () => {
      const address = socket.address();
      socket.close(() => {
        if (address && typeof address === "object") {
          resolve(address.port);
        } else {
          reject(new Error("failed to allocate free port"));
        }
      });
    });
  });
}

async function waitForHealth(baseUrl, timeoutMs) {
  const deadline = Date.now() + timeoutMs;
  const healthUrl = new URL("/health", baseUrl);
  while (Date.now() < deadline) {
    try {
      const response = await fetch(healthUrl);
      if (response.ok) return;
    } catch {
      // keep waiting
    }
    await sleep(100);
  }
  throw new Error(`orchestrator did not become healthy at ${healthUrl}`);
}

function spawnChild(command, args, env = {}) {
  const child = spawn(command, args, {
    cwd: process.cwd(),
    env: removeUndefined({ ...process.env, ...env }),
    stdio: "inherit",
  });
  children.push(child);
  child.on("error", (error) => {
    process.stderr.write(`${command} ${args.join(" ")} failed: ${error.message}\n`);
  });
  return child;
}

async function runChecked(command, args, options = {}) {
  return await new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      cwd: process.cwd(),
      env: removeUndefined({ ...process.env, ...options.env }),
      stdio: ["ignore", "pipe", "pipe"],
    });
    let stdout = "";
    let stderr = "";
    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString();
      if (options.echo !== false) {
        process.stdout.write(chunk);
      }
    });
    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
      if (options.echo !== false) {
        process.stderr.write(chunk);
      }
    });
    child.on("error", reject);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolve({ stdout, stderr });
        return;
      }
      reject(new Error(`${command} ${args.join(" ")} exited with ${signal ?? code}`));
    });
  });
}

async function waitForExit(child) {
  return await new Promise((resolve) => {
    child.on("exit", (code) => resolve(code));
  });
}

async function cleanup() {
  if (cleaningUp) return;
  cleaningUp = true;
  for (const child of children.toReversed()) {
    if (child.exitCode === null) {
      child.kill("SIGTERM");
    }
  }
  await Promise.all(children.map((child) => child.exitCode === null ? waitForExit(child) : undefined));
  if (startedPostgres) {
    await runChecked("pnpm", ["run", "dev:postgres:down"], { env: postgresEnv() }).catch((error) => {
      process.stderr.write(`${error instanceof Error ? error.message : String(error)}\n`);
    });
    startedPostgres = false;
  }
  cleaningUp = false;
}

function removeUndefined(input) {
  return Object.fromEntries(Object.entries(input).filter(([, value]) => value !== undefined));
}

function postgresEnv() {
  return {
    EVENTLOOPOS_POSTGRES_CONTAINER: postgresContainer,
    EVENTLOOPOS_POSTGRES_PORT: postgresPort,
  };
}

function defaultOrchestratorUrl(selectedProfile) {
  return `http://127.0.0.1:${defaultOrchestratorPort(selectedProfile)}`;
}

function defaultOrchestratorPort(selectedProfile) {
  if (selectedProfile === "default") return 4377;
  return 4377 + (hashString(selectedProfile) % 1000);
}

function defaultPostgresPort(selectedProfile) {
  if (selectedProfile === "default") return "55432";
  return String(55432 + (hashString(selectedProfile) % 1000));
}

function defaultPostgresContainer(selectedProfile) {
  if (selectedProfile === "default") return "eventloopos-postgres";
  return `eventloopos-postgres-${selectedProfile}`;
}

function defaultInMemoryStorePath(selectedProfile) {
  return `.eventloopos/${selectedProfile}/gateway-store.json`;
}

function defaultCodexTaskMapPath(selectedProfile) {
  if (selectedProfile === "default") return "config/codex-task-map.json";
  return `var/codex-task-map.${selectedProfile}.json`;
}

function parseHttpEndpoint(value) {
  const url = new URL(value);
  if (url.protocol !== "http:" && url.protocol !== "https:") {
    throw new Error(`EVENTLOOPOS_ORCHESTRATOR_URL must be http(s): ${value}`);
  }
  const port = Number(url.port || (url.protocol === "https:" ? 443 : 80));
  if (!Number.isInteger(port) || port < 1 || port > 65535) {
    throw new Error(`invalid orchestrator port in ${value}`);
  }
  return { host: url.hostname, port };
}

function sanitizeProfile(value) {
  const sanitized = value.trim().toLowerCase().replace(/[^a-z0-9_.-]+/g, "-").replace(/^-+|-+$/g, "");
  return sanitized || "default";
}

function hashString(value) {
  let hash = 0;
  for (const char of value) {
    hash = ((hash * 31) + char.charCodeAt(0)) >>> 0;
  }
  return hash;
}

async function sleep(ms) {
  await new Promise((resolve) => setTimeout(resolve, ms));
}

function parseOptionalPositiveInteger(value) {
  if (!value) return undefined;
  const parsed = Number(value);
  return Number.isInteger(parsed) && parsed > 0 ? parsed : undefined;
}
