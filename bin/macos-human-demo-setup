        source_id: `human-demo:ambient-probe:${slug}:${stamp}`,
        idempotency_key: `human-demo:ambient-probe:${slug}:${stamp}`,
        occurred_at: now,
        received_at: now,
        actor: { id: "human_demo_setup", type: "system" },
        task_hint: slug.replaceAll("_", " "),
        type: "manual.review_requested",
        title: "Ambient Autosave Probe",
        summary: "Hidden probe used by setup to verify ambient autosave appears in future paper workspace context.",
        raw_ref: {
          id: `raw_human_demo_ambient_probe_${slug}_${stamp}`,
          uri: `eventloopos-demo://ambient-probe/${slug}/${stamp}`,
          media_type: "text/plain",
        },
        links: [],
        resources: [{
          id: `ctx_human_demo_ambient_probe_${slug}_${stamp}`,
