          title: "Ambient autosave probe",
          source: "human_demo_probe",
          captured_at: now,
          restore_confidence: "low",
          details: {
            task_id: paper.taskId,
            workspace: paper.workspace,
          },
        }],
      },
    }),
  });
  const body = await response.json();
  if (!response.ok) throw new Error(`ambient probe ${paper.taskId} HTTP ${response.status}: ${JSON.stringify(body)}`);
  return body;
}

