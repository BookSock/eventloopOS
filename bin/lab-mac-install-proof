#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/lab-mac-install-proof

Run the macOS app install proof on the remote Mac lab and print the remote
artifact directory path for product-readiness collection.

Environment:
  LAB_MAC_HOST           default: 100.71.111.25
  LAB_MAC_USER           default: claw
  LAB_MAC_KEY            default: ~/.ssh/eventloop_lab_mac
  LAB_MAC_EVENTLOOP_PATH default: ~/dev/2026/eventloopOS
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  "")
    ;;
  *)
    echo "unknown argument: $1" >&2
    usage >&2
    exit 2
    ;;
esac

lab_host="${LAB_MAC_HOST:-100.71.111.25}"
lab_user="${LAB_MAC_USER:-claw}"
lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
eventloop_path="${LAB_MAC_EVENTLOOP_PATH:-~/dev/2026/eventloopOS}"
remote="${lab_user}@${lab_host}"

ssh -i "$lab_key" -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8 "$remote" \
  "bash -s -- '$eventloop_path'" <<'REMOTE'
set -euo pipefail

eventloop_path="$1"
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

case "$eventloop_path" in
  "~"/*) repo="$HOME/${eventloop_path#"~/"}" ;;
  "~") repo="$HOME" ;;
  *) repo="$eventloop_path" ;;
esac

cd "$repo"
output="$(pnpm macos:install-proof)"
printf "%s\n" "$output"
manifest="$(printf "%s\n" "$output" | awk '/macOS install proof manifest:/ { value=$5 } END { print value }')"
if [[ -n "$manifest" ]]; then
  run_dir="${manifest%/manifest.json}"
  case "$run_dir" in
    "$repo"/*) printf "%s\n" "${run_dir#"$repo/"}" ;;
    *) printf "%s\n" "$run_dir" ;;
  esac
fi
REMOTE
