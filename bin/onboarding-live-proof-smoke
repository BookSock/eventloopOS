#!/usr/bin/env node
import { spawn } from "node:child_process";
import { mkdirSync, writeFileSync } from "node:fs";
import { dirname, resolve } from "node:path";
import { createServer } from "node:net";

const startedAt = new Date();
const runId = `${startedAt.toISOString().replace(/[:.]/g, "-")}-${process.pid}`;
const repoRoot = process.cwd();
const artifactDir = resolve(repoRoot, process.env.EVENTLOOPOS_ONBOARDING_LIVE_ARTIFACT_DIR ?? `artifacts/onboarding-live/${runId}`);
const manifestPath = resolve(artifactDir, "manifest.json");
const manifest = {
  schema_version: 1,
  kind: "eventloopos.onboarding_live_proof",
  run_id: runId,
  started_at: startedAt.toISOString(),
  finished_at: undefined,
  duration_ms: undefined,
  artifact_dir: artifactDir,
  orchestrator_url: undefined,
  summary: undefined,
  proposals: [],
  approved_task: undefined,
  task_session_count: undefined,
  steps: [],
  passed: false,
};

let server;
let port;

mkdirSync(dirname(manifestPath), { recursive: true });
writeManifest();

try {
  port = await freePort();
  manifest.orchestrator_url = `http://127.0.0.1:${port}`;
  writeManifest();

  await step("build orchestrator", async () => {
    await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "run", "build"]);
  });

  server = startOrchestrator(port);

  await step("wait for orchestrator", async () => {
    await waitForHealth(manifest.orchestrator_url);
  });

  const scan = await step("scan current Mac context", async () => {
    const body = await getJson("/onboarding/scan");
    assert(body.ok === true, `onboarding scan failed: ${JSON.stringify(redactScan(body))}`);
    assert(body.summary?.window_count > 0, `expected live windows, got ${JSON.stringify(body.summary)}`);
    assert(body.summary?.proposal_count > 0, `expected task proposals, got ${JSON.stringify(body.summary)}`);
    const redacted = redactScan(body);
    manifest.summary = redacted.summary;
    manifest.proposals = redacted.proposals;
    manifest.task_session_count = redacted.task_session_count;
    writeManifest();
    return body;
  });

  await step("verify Codex task runtime is visible", async () => {
    const sessions = await getJson("/task-sessions");
    const count = Array.isArray(sessions.sessions) ? sessions.sessions.length : 0;
    const providers = Array.from(new Set((sessions.sessions ?? []).map((session) => session.provider).filter(Boolean))).sort();
    assert(scan.summary.task_session_count === count, `onboarding session count ${scan.summary.task_session_count} did not match /task-sessions ${count}`);
    assert(providers.includes("codex"), `expected Codex provider in task sessions, got ${providers.join(",") || "none"}`);
    return {
      count,
      providers,
      sample: (sessions.sessions ?? []).slice(0, 3).map((session) => ({
        id: session.id,
        provider: session.provider,
        task_id: session.task_id,
        status: session.status,
      })),
    };
  });

  const approval = await step("approve proposed task workspace", async () => {
    const proposal = firstProposalWithWindows(scan);
    const windowIds = proposal.windows.slice(0, 4).map((window) => window.id);
    const response = await postJson("/onboarding/approvals", {
      proposal_id: proposal.id,
      window_ids: windowIds,
      task_session_ids: [],
      queue_paper: true,
      actor_id: "onboarding_live_proof",
    });
    assert(response.ok === true, `onboarding approval failed: ${JSON.stringify(response)}`);
    assert(response.task_id === proposal.task_id, `approved task mismatch: ${response.task_id} !== ${proposal.task_id}`);
    assert(response.proposal_id === proposal.id, `approved proposal mismatch: ${response.proposal_id} !== ${proposal.id}`);
    const savedWindowIds = (response.workspace_snapshot?.snapshot?.windows ?? []).map((window) => window.id).sort(numberSort);
    assert(JSON.stringify(savedWindowIds) === JSON.stringify([...windowIds].sort(numberSort)), `approved window ids not saved: ${JSON.stringify(savedWindowIds)} !== ${JSON.stringify(windowIds)}`);
    assert(response.queue_item, `expected onboarding approval to queue first paper, got ${JSON.stringify(response)}`);
    assert(response.queue_item.task_id === proposal.task_id, `queued onboarding paper task mismatch: ${response.queue_item.task_id} !== ${proposal.task_id}`);
    const queuedContexts = response.queue_item.review_packet?.context ?? [];
    const queuedWorkspaceContext = queuedContexts.find((context) => context.kind === "workspace_snapshot" && context.source === "task_workspace_memory");
    assert(queuedWorkspaceContext, `expected queued onboarding paper to include task workspace memory, got ${JSON.stringify(queuedContexts)}`);
    const queuedWindowIds = (queuedWorkspaceContext.snapshot?.windows ?? []).map((window) => window.id).sort(numberSort);
    assert(JSON.stringify(queuedWindowIds) === JSON.stringify([...windowIds].sort(numberSort)), `queued onboarding paper did not inherit approved desk: ${JSON.stringify(queuedWindowIds)} !== ${JSON.stringify(windowIds)}`);
    manifest.approved_task = {
      task_id: proposal.task_id,
      title: proposal.title,
      window_ids: windowIds,
      window_count: windowIds.length,
      queued_paper_id: response.queue_item.id,
    };
    writeManifest();
    return manifest.approved_task;
  });

  const browserContext = await step("attach browser tab context to approved task", async () => {
    const now = new Date().toISOString();
    const firstWindowId = approval.window_ids[0];
    const resource = {
      id: `browser_tab:onboarding_live:${stableId(runId)}`,
      kind: "browser_tab",
      title: `Onboarding live tab for ${approval.task_id}`,
      url: `https://example.test/eventloopos/onboarding-live/${encodeURIComponent(runId)}`,
      source: "chrome-extension",
      captured_at: now,
      restore_confidence: "high",
      window_id: firstWindowId == null ? undefined : String(firstWindowId),
      tab_id: `onboarding-live-${stableId(runId)}`,
    };
    const response = await postJson("/events", {
      event: {
        id: `evt_onboarding_live_browser_${stableId(runId)}`,
        source: "browser",
        source_id: `browser:onboarding-live:${runId}`,
        idempotency_key: `browser:onboarding-live:${runId}`,
        occurred_at: now,
        received_at: now,
        actor: {
          id: "onboarding_live_proof",
          type: "system",
        },
        task_hint: approval.task_id.replace(/^task_/, "").replaceAll("_", " "),
        type: "browser.context_captured",
        title: resource.title,
        summary: "Synthetic browser tab context for onboarding live proof.",
        raw_ref: {
          id: `raw_onboarding_live_browser_${stableId(runId)}`,
          uri: resource.url,
          media_type: "application/json",
        },
        links: [],
        resources: [resource],
      },
    });
    assert(response.ok === true, `browser context route failed: ${JSON.stringify(response)}`);
    assert(response.route_decision?.action === "attach_to_task", `browser context should attach to task, got ${JSON.stringify(response.route_decision)}`);
    assert(response.route_decision?.target_task_id === approval.task_id, `browser context target mismatch: ${response.route_decision?.target_task_id} !== ${approval.task_id}`);
    return resource;
  });

  await step("prove future paper inherits approved task desk", async () => {
    const now = new Date().toISOString();
    const event = {
      id: `evt_onboarding_live_${stableId(runId)}`,
      source: "manual",
      source_id: `manual:onboarding-live:${runId}`,
      idempotency_key: `manual:onboarding-live:${runId}`,
      occurred_at: now,
      received_at: now,
      actor: {
        id: "onboarding_live_proof",
        type: "system",
      },
      task_hint: approval.task_id.replace(/^task_/, "").replaceAll("_", " "),
      type: "manual.review_requested",
      title: `Onboarding live followup for ${approval.task_id}`,
      summary: "Proof event should become queue paper with approved task workspace memory.",
      raw_ref: {
        id: `raw_onboarding_live_${stableId(runId)}`,
        uri: `manual://onboarding-live/${encodeURIComponent(runId)}`,
        media_type: "application/json",
      },
      links: [],
      resources: [],
    };
    const response = await postJson("/events", { event });
    assert(response.ok === true, `event route failed: ${JSON.stringify(response)}`);
    assert(response.queue_item, `expected queue item for manual review event, got ${JSON.stringify(response)}`);
    const contexts = response.queue_item?.review_packet?.context ?? [];
    const workspaceContext = contexts.find((context) => context.kind === "workspace_snapshot" && context.source === "task_workspace_memory");
    assert(workspaceContext, `expected task workspace memory context, got ${JSON.stringify(contexts)}`);
    const inheritedWindowIds = (workspaceContext.snapshot?.windows ?? []).map((window) => window.id).sort(numberSort);
    assert(JSON.stringify(inheritedWindowIds) === JSON.stringify([...approval.window_ids].sort(numberSort)), `future paper did not inherit approved desk: ${JSON.stringify(inheritedWindowIds)} !== ${JSON.stringify(approval.window_ids)}`);
    const tabContext = contexts.find((context) => context.kind === "browser_tab" && context.id === browserContext.id);
    assert(tabContext, `expected future paper to inherit task browser tab ${browserContext.id}, got ${JSON.stringify(contexts)}`);
    assert(tabContext.url === browserContext.url, `inherited tab URL mismatch: ${tabContext.url} !== ${browserContext.url}`);
    return {
      queue_item_id: response.queue_item.id,
      review_packet_id: response.review_packet?.id ?? response.queue_item.review_packet_id,
      task_id: response.queue_item.task_id,
      inherited_window_ids: inheritedWindowIds,
      inherited_browser_tab_id: tabContext.id,
    };
  });

  manifest.passed = true;
} catch (error) {
  manifest.error = error instanceof Error ? error.stack ?? error.message : String(error);
  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
  process.exitCode = 1;
} finally {
  await stopOrchestrator();
  manifest.finished_at = new Date().toISOString();
  manifest.duration_ms = Date.parse(manifest.finished_at) - Date.parse(manifest.started_at);
  writeManifest();
  console.log(`onboarding live proof manifest: ${manifestPath}`);
}

function startOrchestrator(listenPort) {
  const child = spawn("node", ["app/orchestrator/dist/src/index.js"], {
    cwd: repoRoot,
    env: {
      ...process.env,
      ORCHESTRATOR_HOST: "127.0.0.1",
      ORCHESTRATOR_PORT: String(listenPort),
      ORCHESTRATOR_SEED_FIXTURE: "app/orchestrator/fixtures/empty-review-packets.json",
      ORCHESTRATOR_TASK_SESSIONS: "codex_app_server",
      ORCHESTRATOR_MCP_SOURCES: "off",
      ORCHESTRATOR_WORKSPACE: "aerospace",
      ORCHESTRATOR_WORKSPACE_EXECUTE: "disabled",
    },
    stdio: ["ignore", "pipe", "pipe"],
  });
  child.stdout.pipe(process.stdout);
  child.stderr.pipe(process.stderr);
  return child;
}

async function step(name, run) {
  const record = {
    name,
    status: "running",
    started_at: new Date().toISOString(),
    finished_at: undefined,
    duration_ms: undefined,
    details: undefined,
    error: undefined,
  };
  manifest.steps.push(record);
  writeManifest();
  console.log(`onboarding live proof start: ${name}`);
  try {
    const details = await run();
    record.status = "passed";
    record.details = details;
    return details;
  } catch (error) {
    record.status = "failed";
    record.error = error instanceof Error ? error.message : String(error);
    throw error;
  } finally {
    record.finished_at = new Date().toISOString();
    record.duration_ms = Date.parse(record.finished_at) - Date.parse(record.started_at);
    writeManifest();
    console.log(`onboarding live proof ${record.status}: ${name}`);
  }
}

function firstProposalWithWindows(scan) {
  const proposal = (scan.proposals ?? []).find((candidate) => Array.isArray(candidate.windows) && candidate.windows.length > 0);
  assert(proposal, `expected at least one onboarding proposal with windows, got ${JSON.stringify(redactScan(scan))}`);
  return proposal;
}

function redactScan(body) {
  const proposals = (body.proposals ?? []).map((proposal) => ({
    id: proposal.id,
    task_id: proposal.task_id,
    title: proposal.title,
    confidence: proposal.confidence,
    reason: proposal.reason,
    window_count: Array.isArray(proposal.windows) ? proposal.windows.length : 0,
    browser_context_count: Array.isArray(proposal.browser_contexts) ? proposal.browser_contexts.length : 0,
    task_session_count: Array.isArray(proposal.task_sessions) ? proposal.task_sessions.length : 0,
  }));
  return {
    ok: body.ok,
    captured_at: body.captured_at,
    summary: body.summary,
    task_session_count: body.summary?.task_session_count ?? 0,
    proposals,
    ungrouped_window_count: Array.isArray(body.ungrouped_windows) ? body.ungrouped_windows.length : undefined,
    warnings: body.warnings ?? [],
  };
}

async function waitForHealth(url) {
  const deadline = Date.now() + 20_000;
  while (Date.now() < deadline) {
    try {
      const response = await fetch(new URL("/health", url));
      if (response.ok) return;
    } catch {
      // Server not ready yet.
    }
    await sleep(250);
  }
  throw new Error(`timed out waiting for orchestrator health at ${url}/health`);
}

async function getJson(path) {
  const response = await fetch(new URL(path, manifest.orchestrator_url));
  const text = await response.text();
  const body = text ? JSON.parse(text) : {};
  if (!response.ok) {
    throw new Error(`GET ${path} failed ${response.status}: ${JSON.stringify(body)}`);
  }
  return body;
}

async function postJson(path, payload) {
  const response = await fetch(new URL(path, manifest.orchestrator_url), {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: JSON.stringify(payload),
  });
  const text = await response.text();
  const body = text ? JSON.parse(text) : {};
  if (!response.ok) {
    throw new Error(`POST ${path} failed ${response.status}: ${JSON.stringify(body)}`);
  }
  return body;
}

function stableId(input) {
  return String(input).toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "") || "unknown";
}

function numberSort(left, right) {
  return left - right;
}

async function spawnChecked(command, args, env = process.env) {
  return await new Promise((resolveSpawn, rejectSpawn) => {
    const child = spawn(command, args, {
      cwd: repoRoot,
      env,
      stdio: "inherit",
    });
    child.on("error", rejectSpawn);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolveSpawn();
      } else {
        rejectSpawn(new Error(`${command} ${args.join(" ")} exited with ${signal ?? code}`));
      }
    });
  });
}

async function stopOrchestrator() {
  if (!server || server.killed || server.exitCode !== null) return;
  server.kill("SIGTERM");
  await new Promise((resolve) => server.once("exit", resolve));
  server = undefined;
}

async function freePort() {
  return await new Promise((resolve, reject) => {
    const socket = createServer();
    socket.once("error", reject);
    socket.listen(0, "127.0.0.1", () => {
      const address = socket.address();
      socket.close(() => {
        if (address && typeof address === "object") {
          resolve(address.port);
        } else {
          reject(new Error("failed to allocate free port"));
        }
      });
    });
  });
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function assert(condition, message) {
  if (!condition) throw new Error(message);
}

function writeManifest() {
  writeFileSync(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`);
}
