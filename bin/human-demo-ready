}

function runScreenshotStep(localOutputPath, envOverride) {
  if (screenshotTarget === "local") {
    return runLocalScreenSharingCapture(localOutputPath, envOverride);
  }
  if (screenshotTarget === "lab") {
    return runLabDesktopCapture(envOverride, "requested");
  }

  const local = runLocalScreenSharingCapture(localOutputPath, envOverride);
  if (local.ok) return local;

  const lab = runLabDesktopCapture(envOverride, "local_screen_sharing_unavailable");
  return {
    ...lab,
    fallback_reason: lab.ok
      ? "local_screen_sharing_unavailable"
      : "local_screen_sharing_and_lab_capture_failed",
    local_attempt: local,
  };
}

function runLocalScreenSharingCapture(localOutputPath, envOverride) {
  const step = runStep("local screen sharing capture", "bin/local-screen-sharing-capture", [localOutputPath], envOverride);
  const image = imageArtifactSummary(localOutputPath);
  return {
    ok: step.status === 0 && image.ok === true,
    capture_mode: "local_screen_sharing_window",
    target: "local",
    output: localOutputPath,
    exit_code: step.status,
    image,
    stdout_path: step.stdout_path,
    stderr_path: step.stderr_path,
  };
}

function runLabDesktopCapture(envOverride, fallbackReason) {
  const label = "human-demo-ready";
  const captureEnv = {
    ...envOverride,
    LAB_MAC_CAPTURE_WORKSPACE: screenshotStage?.result?.workspace ?? envOverride.LAB_MAC_CAPTURE_WORKSPACE ?? "",
  };
  const step = runStep("lab desktop capture", "bin/lab-mac-desktop-capture", [runDir, label], captureEnv);
  const remoteCapturePath = lastNonEmptyLine(step.stdout);
  const localCaptureDir = remoteCapturePath && !remoteCapturePath.startsWith("/")
    ? remoteCapturePath
    : path.join(runDir, "captures", label);
  const sync = remoteCapturePath
    ? syncLabCapture(remoteCapturePath, localCaptureDir, captureEnv)
    : { ok: false, reason: "missing_remote_capture_path" };
  const output = path.join(localCaptureDir, "screen.png");
  const image = imageArtifactSummary(output);
  const summary = readJsonIfPresent(path.join(localCaptureDir, "capture-summary.json"));
  return {
    ok: step.status === 0 && sync.ok === true && image.ok === true,
    capture_mode: "lab_desktop",
    target: "lab",
    fallback_reason: fallbackReason,
    output,
    exit_code: step.status,
    remote_capture_path: remoteCapturePath,
    image,
    lab_capture_summary: summary ? {
      screen: summary.screen,
      queue_app: summary.queue_app,
      gui_fallback: summary.gui_fallback,
    } : undefined,
    stdout_path: step.stdout_path,
    stderr_path: step.stderr_path,
    sync,
  };
}

function syncLabCapture(remoteCapturePath, localCaptureDir, envOverride) {
  mkdirSync(path.resolve(repoRoot, localCaptureDir), { recursive: true });
  const labHost = envOverride.LAB_MAC_HOST ?? "100.71.111.25";
  const labUser = envOverride.LAB_MAC_USER ?? "claw";
  const labKey = envOverride.LAB_MAC_KEY ?? path.join(osHome(), ".ssh", "eventloop_lab_mac");
  const remoteRepo = remoteRepoFromEnv(envOverride);
  const remote = `${labUser}@${labHost}`;
  const sshCommand = [
    "ssh",
    "-i",
    labKey,
    "-o",
    "BatchMode=yes",
    "-o",
    "ConnectTimeout=20",
    "-o",
    "ServerAliveInterval=15",
    "-o",
    "ServerAliveCountMax=8",
  ].join(" ");
  const result = spawnSync("rsync", [
    "-az",
    "-e",
    sshCommand,
    `${remote}:${remoteRepo}/${remoteCapturePath.replace(/\/$/, "")}/`,
    `${path.resolve(repoRoot, localCaptureDir)}/`,
  ], {
    cwd: repoRoot,
    env: envOverride,
    encoding: "utf8",
    shell: false,
  });
  const stdoutPath = path.join(runDir, "steps", "lab-desktop-capture-sync.stdout");
  const stderrPath = path.join(runDir, "steps", "lab-desktop-capture-sync.stderr");
  writeFileSync(path.join(repoRoot, stdoutPath), result.stdout ?? "", "utf8");
  writeFileSync(path.join(repoRoot, stderrPath), result.stderr ?? "", "utf8");
  steps.push({
    name: "lab desktop capture sync",
    command: ["rsync", "-az", "-e", sshCommand, `${remote}:${remoteRepo}/${remoteCapturePath}/`, `${localCaptureDir}/`],
    status: result.status ?? 1,
    signal: result.signal,
    stdout_path: stdoutPath,
    stderr_path: stderrPath,
  });
  return {
    ok: result.status === 0,
    exit_code: result.status ?? 1,
    local_capture_dir: localCaptureDir,
    stdout_path: stdoutPath,
    stderr_path: stderrPath,
  };
}

function normalizeScreenshotTarget(raw) {
  const value = String(raw ?? "").trim().toLowerCase();
  if (["auto", "local", "lab"].includes(value)) return value;
  console.error(`Invalid EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET: ${String(raw)}`);
  process.exit(2);
}

function remoteRepoFromEnv(envOverride) {
  const labUser = envOverride.LAB_MAC_USER ?? "claw";
  const eventloopPath = envOverride.LAB_MAC_EVENTLOOP_PATH ?? "~/dev/2026/eventloopOS";
  if (eventloopPath === "~") return `/Users/${labUser}`;
  if (eventloopPath.startsWith("~/")) return `/Users/${labUser}/${eventloopPath.slice(2)}`;
  return eventloopPath;
}

function osHome() {
  return process.env.HOME ?? "/tmp";
}

function lastNonEmptyLine(value) {
  const lines = String(value ?? "").split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
  return lines.at(-1) ?? "";
}

function extractJsonObject(value) {
  if (!value.trim()) return undefined;
  const starts = [];
  for (let index = value.indexOf("{"); index !== -1; index = value.indexOf("{", index + 1)) {
    starts.push(index);
  }
  for (const start of starts) {
    const candidate = value.slice(start).trim();
    try {
      return JSON.parse(candidate);
    } catch {
      // Try next JSON-looking segment.
    }
  }
  return undefined;
}

function readJsonIfPresent(relativePath) {
  try {
    return JSON.parse(readFileSync(path.resolve(repoRoot, relativePath), "utf8"));
  } catch {
    return undefined;
  }
}

function imageArtifactSummary(relativePath) {
  if (!relativePath) {
    return {
      ok: false,
      path: "",
      reason: "missing",
    };
  }
  const absolutePath = path.resolve(repoRoot, relativePath);
  if (!existsSync(absolutePath)) {
    return {
      ok: false,
      path: relativePath,
      reason: "missing",
    };
  }
  const bytes = statSync(absolutePath).size;
  if (bytes <= 0) {
    return {
      ok: false,
      path: relativePath,
      bytes,
      reason: "empty",
    };
  }
  try {
    const buffer = readFileSync(absolutePath);
    const parsed = parseImageDimensions(buffer);
    const ok = parsed.width > 0 && parsed.height > 0;
    return {
      ok,
      path: relativePath,
      bytes,
      format: parsed.format,
      width: parsed.width,
      height: parsed.height,
      dimensions: `${parsed.width}x${parsed.height}`,
      reason: ok ? "ok" : "invalid_dimensions",
    };
  } catch (error) {
    return {
      ok: false,
      path: relativePath,
      bytes,
      reason: error instanceof Error ? error.message : String(error),
    };
  }
}

function parseImageDimensions(buffer) {
  if (buffer.length >= 24
    && buffer[0] === 0x89
    && buffer[1] === 0x50
    && buffer[2] === 0x4e
    && buffer[3] === 0x47
    && buffer[4] === 0x0d
    && buffer[5] === 0x0a
    && buffer[6] === 0x1a
    && buffer[7] === 0x0a) {
    return {
      format: "png",
      width: buffer.readUInt32BE(16),
      height: buffer.readUInt32BE(20),
    };
  }
  if (buffer.length >= 4 && buffer[0] === 0xff && buffer[1] === 0xd8) {
    for (let offset = 2; offset + 8 < buffer.length;) {
      if (buffer[offset] !== 0xff) {
        offset += 1;
        continue;
      }
      const marker = buffer[offset + 1];
      if (marker === 0xd9 || marker === 0xda) break;
      const segmentLength = buffer.readUInt16BE(offset + 2);
      if (segmentLength < 2) throw new Error("invalid_jpeg_segment");
      if (isJpegStartOfFrame(marker)) {
        return {
          format: "jpeg",
          width: buffer.readUInt16BE(offset + 7),
          height: buffer.readUInt16BE(offset + 5),
        };
      }
      offset += 2 + segmentLength;
    }
  }
  throw new Error("unsupported_image_format");
}

function isJpegStartOfFrame(marker) {
  return (marker >= 0xc0 && marker <= 0xc3)
    || (marker >= 0xc5 && marker <= 0xc7)
    || (marker >= 0xc9 && marker <= 0xcb)
    || (marker >= 0xcd && marker <= 0xcf);
}

function renderReadyMarkdown(manifest) {
  const latest = manifest.latest_human_demo;
  const screenshot = manifest.screen_sharing_capture;
  const queueLatency = manifest.queue_latency;
  const workspaceLatency = manifest.workspace_latency;
  const hotkey = manifest.hotkey_feedback_latency;
  const freshness = latest?.freshness;
  return `# eventloopOS Human Demo Ready

- Ready: ${manifest.ok ? "yes" : "no"}
- Profile: ${manifest.profile}
- URL: ${manifest.url}
- Latest proof: ${latest?.manifest_path ?? ""}
- Latest proof screenshot: ${latest?.screenshot_path ?? ""}
- Suggested result file: ${latest?.suggested_result_path ?? ""}
- Latest proof freshness: ${freshness ? `${freshness.ok ? "ok" : "stale"} age=${freshness.age_hours ?? ""}h max=${freshness.max_age_hours}h${freshness.allowed_stale ? " allowed" : ""}` : ""}
- Opened-window autosave proof: ${latest?.new_window_autosave_ok === true ? "ok" : "missing"}
- Foreign-window containment proof: ${latest?.foreign_window_containment_ok === true ? "ok" : "missing"}
- Agent-spawn containment proof: ${latest?.agent_spawn_window_containment_ok === true ? "ok" : "missing"}
- Fresh screenshot capture: ${screenshot?.output ?? "skipped"}${screenshot?.capture_mode ? ` mode=${screenshot.capture_mode}` : ""}${screenshot?.image?.dimensions ? ` (${screenshot.image.dimensions}, ${screenshot.image.bytes} bytes)` : ""}
- Queue briefing strip: ${manifest.checks?.queue_briefing_strip_visible === true ? "visible" : "missing"}
- Desktop paper reminder HUD: ${manifest.checks?.paper_reminder_hud_visible === true ? "visible" : "missing"}
- Queue latency: ${queueLatency?.manifest_path ?? "skipped"}${manifest.queue_latency_required ? " (required)" : ""}
- Workspace latency: ${workspaceLatency?.manifest_path ?? "skipped"}${manifest.workspace_latency_required ? " (required)" : ""}
- Hotkey feedback latency: ${hotkey?.manifest_path ?? "skipped"}${manifest.hotkey_latency_required ? " (required)" : ""}
- Failed checks: ${manifest.failed_checks.length === 0 ? "none" : manifest.failed_checks.join(", ")}

Next: use \`docs/human-demo-walkthrough.md\`, then run \`bin/human-demo-result-template --write\` and fill the generated result after Jason finishes hands-on pass.
`;
}

function utcStamp() {
  return new Date().toISOString().replace(/[-:]/g, "").replace(/\.\d{3}Z$/, "Z");
}

function demoProofFreshness(generatedAt, nowIso, maxAgeHours, allowStale) {
  const generatedMs = Date.parse(String(generatedAt ?? ""));
  const nowMs = Date.parse(nowIso);
  if (!Number.isFinite(generatedMs) || !Number.isFinite(nowMs)) {
    return {
      ok: allowStale,
      generated_at: generatedAt ?? null,
      age_ms: null,
      age_hours: null,
      max_age_hours: maxAgeHours,
      allowed_stale: allowStale,
      reason: "missing_or_invalid_generated_at",
    };
  }
  const ageMs = Math.max(0, nowMs - generatedMs);
  const maxAgeMs = maxAgeHours * 60 * 60 * 1000;
  const fresh = ageMs <= maxAgeMs;
  return {
    ok: fresh || allowStale,
    generated_at: generatedAt,
    age_ms: ageMs,
    age_hours: Number((ageMs / 60 / 60 / 1000).toFixed(3)),
    max_age_hours: maxAgeHours,
    allowed_stale: allowStale && !fresh,
    reason: fresh ? "fresh" : "stale",
  };
}

function runSelfTest() {
  const noisyJson = `prefix\n{\"ok\":true,\"queue_count\":2,\"ambient_autosave_ok\":true,\"new_window_autosave_ok\":true,\"foreign_window_containment_ok\":true,\"agent_spawn_window_containment_ok\":true}`;
  assert.deepEqual(extractJsonObject(noisyJson), {
    ok: true,
    queue_count: 2,
    ambient_autosave_ok: true,
    new_window_autosave_ok: true,
    foreign_window_containment_ok: true,
    agent_spawn_window_containment_ok: true,
  });
  assert.equal(extractJsonObject("no json"), undefined);
  assert.deepEqual(demoProofFreshness("2026-06-03T10:00:00.000Z", "2026-06-03T20:00:00.000Z", 24, false), {
    ok: true,
    generated_at: "2026-06-03T10:00:00.000Z",
    age_ms: 36000000,
    age_hours: 10,
    max_age_hours: 24,
    allowed_stale: false,
    reason: "fresh",
  });
  assert.equal(demoProofFreshness("2026-06-03T10:00:00.000Z", "2026-06-04T20:00:00.000Z", 24, false).ok, false);
  assert.equal(demoProofFreshness("bad", "2026-06-04T20:00:00.000Z", 24, true).ok, true);
  const readyMarkdown = renderReadyMarkdown({
    ok: true,
    profile: "lab-human-demo",
    url: "http://127.0.0.1:4480",
    checks: { queue_briefing_strip_visible: true, paper_reminder_hud_visible: true },
    failed_checks: [],
    queue_latency_required: true,
    workspace_latency_required: true,
    hotkey_latency_required: false,
    latest_human_demo: {
      manifest_path: "artifacts/lab-runs/demo/manifest.json",
      screenshot_path: "artifacts/lab-runs/demo/screen-sharing.png",
      suggested_result_path: "artifacts/human-demo-results/demo-human-demo-result.md",
      new_window_autosave_ok: true,
      foreign_window_containment_ok: true,
      agent_spawn_window_containment_ok: true,
      freshness: { ok: true, age_hours: 1, max_age_hours: 24 },
    },
    screen_sharing_capture: { output: "artifacts/lab-runs/ready/screen-sharing.png" },
    queue_latency: { manifest_path: "artifacts/lab-runs/ready/queue-latency.json" },
    workspace_latency: { manifest_path: "artifacts/lab-runs/ready/workspace-latency.json" },
    hotkey_feedback_latency: { skipped: true },
  });
  assert.ok(readyMarkdown.includes("Suggested result file: artifacts/human-demo-results/demo-human-demo-result.md"));
  assert.deepEqual(hotkeyLatencyArgs(), ["--hotkey", "ctrl-option-r", "--expect", "Restoring paper:"]);
  process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_CHORD = "ctrl-option-h";
  assert.deepEqual(hotkeyLatencyArgs(), ["--hotkey", "ctrl-option-h"]);
  process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_EXPECT = "No paper selected.";
  assert.deepEqual(hotkeyLatencyArgs(), ["--hotkey", "ctrl-option-h", "--expect", "No paper selected."]);
  delete process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_CHORD;
  delete process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_EXPECT;
  assert.ok(labDemoScreenshotStageScript().includes("task_demo_customer"));
  assert.ok(labDemoScreenshotStageScript().includes("latestDemoProofSnapshot"));
  assert.ok(labDemoScreenshotStageScript().includes("raiseDemoApps"));
  assert.ok(labDemoScreenshotStageScript().includes("queueBriefingStripStatus"));
  assert.ok(labDemoScreenshotStageScript().includes("paperReminderHudStatus"));
  assert.ok(labDemoScreenshotStageScript().includes("eventloopOS Paper Reminder"));
  assert.ok(labDemoScreenshotStageScript().includes("matchingBriefingLine"));
  assert.ok(labDemoScreenshotStageScript().includes("queue-paper-briefing-strip"));
  assert.ok(labDemoScreenshotStageScript().includes("queue-paper-briefing-title"));
  assert.ok(labDemoScreenshotStageScript().includes("queue-paper-briefing-decision"));
  assert.ok(labDemoScreenshotStageScript().includes("queue-paper-briefing-context"));
  assert.ok(labDemoScreenshotStageScript().includes("/workspace/restore"));
  assert.ok(labDemoScreenshotStageScript().includes("present:parts:"));
  assert.ok(labDemoScreenshotStageScript().includes("briefing missing expected parts"));
  assert.ok(labDemoScreenshotStageScript().includes("priority ? \"P\" + priority : \"\""));
  assert.equal(remoteRepoFromEnv({ LAB_MAC_USER: "claw" }), "/Users/claw/dev/2026/eventloopOS");
  assert.equal(remoteRepoFromEnv({ LAB_MAC_USER: "demo", LAB_MAC_EVENTLOOP_PATH: "~/src/eventloopOS" }), "/Users/demo/src/eventloopOS");
  assert.equal(remoteRepoFromEnv({ LAB_MAC_EVENTLOOP_PATH: "/tmp/repo" }), "/tmp/repo");
  assert.equal(lastNonEmptyLine("one\n\ntwo\n"), "two");
  const png = Buffer.from([
    0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a,
    0x00, 0x00, 0x00, 0x0d, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x07, 0x80,
    0x00, 0x00, 0x04, 0x38,
  ]);
  assert.deepEqual(parseImageDimensions(png), { format: "png", width: 1920, height: 1080 });
  const jpeg = Buffer.from([
    0xff, 0xd8,
    0xff, 0xe0, 0x00, 0x04, 0x00, 0x00,
    0xff, 0xc0, 0x00, 0x0b, 0x08,
    0x02, 0xd0,
    0x05, 0x00,
    0x03, 0x01, 0x11, 0x00,
  ]);
  assert.deepEqual(parseImageDimensions(jpeg), { format: "jpeg", width: 1280, height: 720 });
  const markdown = renderReadyMarkdown({
    ok: true,
    profile: "lab-human-demo",
    url: "http://127.0.0.1:4480",
    checks: { queue_briefing_strip_visible: true, paper_reminder_hud_visible: true },
    failed_checks: [],
    latest_human_demo: {
      manifest_path: "artifacts/lab-runs/demo/manifest.json",
      screenshot_path: "artifacts/lab-runs/demo/screen-sharing.png",
      new_window_autosave_ok: true,
      foreign_window_containment_ok: true,
      agent_spawn_window_containment_ok: true,
      freshness: { ok: true, age_hours: 1.25, max_age_hours: 24, allowed_stale: false },
    },
    screen_sharing_capture: {
      output: "artifacts/lab-runs/ready/screen-sharing.png",
      capture_mode: "local_screen_sharing_window",
      image: { dimensions: "1280x720", bytes: 2048 },
    },
    queue_latency: { manifest_path: "artifacts/lab-runs/ready/queue-latency.json" },
    queue_latency_required: true,
    workspace_latency: { manifest_path: "artifacts/lab-runs/ready/workspace-latency.json" },
    workspace_latency_required: true,
    hotkey_feedback_latency: { skipped: true },
  });
  assert.match(markdown, /Ready: yes/);
  assert.match(markdown, /artifacts\/lab-runs\/demo\/manifest\.json/);
  assert.match(markdown, /Latest proof freshness: ok age=1.25h max=24h/);
  assert.match(markdown, /Fresh screenshot capture: artifacts\/lab-runs\/ready\/screen-sharing\.png mode=local_screen_sharing_window \(1280x720, 2048 bytes\)/);
  assert.match(markdown, /Opened-window autosave proof: ok/);
  assert.match(markdown, /Foreign-window containment proof: ok/);
  assert.match(markdown, /Agent-spawn containment proof: ok/);
  assert.match(markdown, /Queue briefing strip: visible/);
  assert.match(markdown, /Desktop paper reminder HUD: visible/);
  assert.match(markdown, /Hotkey feedback latency: skipped/);
  assert.match(markdown, /Queue latency: artifacts\/lab-runs\/ready\/queue-latency\.json/);
  assert.match(markdown, /Workspace latency: artifacts\/lab-runs\/ready\/workspace-latency\.json/);
}
