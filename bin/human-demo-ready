#!/usr/bin/env node
import assert from "node:assert/strict";
import { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from "node:fs";
import { spawnSync } from "node:child_process";
import path from "node:path";
import process from "node:process";

const repoRoot = path.resolve(import.meta.dirname, "..");
process.chdir(repoRoot);

const args = process.argv.slice(2);
const skipScreenshot = args.includes("--skip-screenshot");
const allowStaleDemoProof = args.includes("--allow-stale-demo-proof") || process.env.EVENTLOOPOS_HUMAN_DEMO_ALLOW_STALE_PROOF === "1";
const demoProofMaxAgeHours = numberOption("--demo-proof-max-age-hours", process.env.EVENTLOOPOS_HUMAN_DEMO_PROOF_MAX_AGE_HOURS ?? "24");
const skipQueueLatency = args.includes("--skip-queue-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY === "0";
const queueLatencyEnabled = !skipQueueLatency;
const skipWorkspaceLatency = args.includes("--skip-workspace-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY === "0";
const workspaceLatencyEnabled = !skipWorkspaceLatency;
const skipHotkeyLatency = args.includes("--skip-hotkey-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY === "0";
const hotkeyLatencyRequested = args.includes("--hotkey-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY === "1";
const hotkeyLatencyEnabled = !skipHotkeyLatency && (hotkeyLatencyRequested || process.platform === "darwin");
const jsonOnly = args.includes("--json");

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/human-demo-ready [--skip-screenshot] [--skip-queue-latency] [--skip-workspace-latency] [--skip-hotkey-latency] [--hotkey-latency] [--demo-proof-max-age-hours n] [--allow-stale-demo-proof] [--json]

Check current Mac Studio human-demo readiness without resetting demo state.
Includes read-only queue/master and workspace capture/restore-plan latency gates
by default. On macOS, also includes a live queue-app hotkey feedback p95 gate by default.
Use skip flags only while bootstrapping remote host/Accessibility permission.

Environment:
  LAB_DOGFOOD_PROFILE  default: lab-human-demo
  LAB_DOGFOOD_URL      default: http://127.0.0.1:4480
  SCREEN_SHARING_TITLE default: Zeus
  EVENTLOOPOS_HUMAN_DEMO_PROOF_MAX_AGE_HOURS default: 24
  EVENTLOOPOS_HUMAN_DEMO_ALLOW_STALE_PROOF=1 skips demo proof freshness gate
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY=1 keeps queue latency on
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY=0 skips queue latency
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_TARGET=local runs queue latency on this Mac instead of the lab Mac
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_RUNS default: 3
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY=1 keeps workspace latency on
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY=0 skips workspace latency
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_TARGET=local runs workspace latency on this Mac instead of the lab Mac
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_RUNS default: 2
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY=1 forces hotkey latency on
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY=0 skips hotkey latency
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_TARGET=local runs latency on this Mac instead of the lab Mac
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  console.log("human-demo-ready self-test passed");
  process.exit(0);
}

const runDir = path.join("artifacts", "lab-runs", `${utcStamp()}-human-demo-ready`);
mkdirSync(path.join(repoRoot, runDir, "steps"), { recursive: true });

const startedAt = new Date().toISOString();
const env = {
  ...process.env,
  LAB_DOGFOOD_PROFILE: process.env.LAB_DOGFOOD_PROFILE ?? "lab-human-demo",
  LAB_DOGFOOD_URL: process.env.LAB_DOGFOOD_URL ?? "http://127.0.0.1:4480",
  SCREEN_SHARING_TITLE: process.env.SCREEN_SHARING_TITLE ?? "Zeus",
};

const steps = [];
const dogfood = runStep("dogfood status", "bin/lab-mac-dogfood", ["status"], env);
const dogfoodManifest = extractJsonObject(dogfood.stdout);
const template = runStep("human demo result template", "node", ["bin/human-demo-result-template", "--json"], env);
const templateJson = extractJsonObject(template.stdout);
const latestHumanDemoFreshness = demoProofFreshness(templateJson?.generated_at, startedAt, demoProofMaxAgeHours, allowStaleDemoProof);

let screenshot;
if (!skipScreenshot) {
  screenshot = runStep("screen sharing capture", "bin/local-screen-sharing-capture", [path.join(runDir, "screen-sharing.png")], env);
}
const screenshotImage = skipScreenshot ? undefined : imageArtifactSummary(path.join(runDir, "screen-sharing.png"));
const hotkeyLatencyManifestPath = path.join(runDir, "hotkey-latency.json");
const queueLatencyManifestPath = path.join(runDir, "queue-latency.json");
const workspaceLatencyManifestPath = path.join(runDir, "workspace-latency.json");
const queueLatency = queueLatencyEnabled
  ? runQueueLatencyStep(queueLatencyManifestPath, env)
  : undefined;
const queueLatencyManifest = queueLatency ? readJsonIfPresent(queueLatencyManifestPath) : undefined;
const workspaceLatency = workspaceLatencyEnabled
  ? runWorkspaceLatencyStep(workspaceLatencyManifestPath, env)
  : undefined;
const workspaceLatencyManifest = workspaceLatency ? readJsonIfPresent(workspaceLatencyManifestPath) : undefined;
const hotkeyLatency = hotkeyLatencyEnabled
  ? runHotkeyLatencyStep(hotkeyLatencyManifestPath, env)
  : undefined;
const hotkeyLatencyManifest = hotkeyLatency ? readJsonIfPresent(hotkeyLatencyManifestPath) : undefined;

const checks = {
  dogfood_status_ok: dogfood.status === 0 && dogfoodManifest?.ok === true,
  latest_human_demo_proof_ok: template.status === 0 && templateJson?.ok === true,
  latest_human_demo_proof_fresh: latestHumanDemoFreshness.ok === true,
  latest_human_demo_queue_has_two_papers: Number(templateJson?.queue_count ?? 0) >= 2,
  ambient_autosave_proof_ok: templateJson?.ambient_autosave_ok === true,
  screen_sharing_capture_ok: skipScreenshot || (screenshot?.status === 0 && screenshotImage?.ok === true),
  queue_latency_ok: !queueLatencyEnabled || (queueLatency?.status === 0 && queueLatencyManifest?.ok === true),
  workspace_latency_ok: !workspaceLatencyEnabled || (workspaceLatency?.status === 0 && workspaceLatencyManifest?.ok === true),
  hotkey_feedback_latency_ok: !hotkeyLatencyEnabled || (hotkeyLatency?.status === 0 && hotkeyLatencyManifest?.ok === true),
};
const failedChecks = Object.entries(checks).filter(([, ok]) => ok !== true).map(([key]) => key);
const finishedAt = new Date().toISOString();
const manifest = {
  schema_version: 1,
  kind: "eventloopos.human_demo_ready",
  started_at: startedAt,
  finished_at: finishedAt,
  duration_ms: Date.parse(finishedAt) - Date.parse(startedAt),
  artifact_dir: runDir,
  ok: failedChecks.length === 0,
  passed: failedChecks.length === 0,
  profile: env.LAB_DOGFOOD_PROFILE,
  url: env.LAB_DOGFOOD_URL,
  queue_latency_required: queueLatencyEnabled,
  workspace_latency_required: workspaceLatencyEnabled,
  hotkey_latency_required: hotkeyLatencyEnabled,
  demo_proof_max_age_hours: demoProofMaxAgeHours,
  allow_stale_demo_proof: allowStaleDemoProof,
  checks,
  failed_checks: failedChecks,
  dogfood_status: dogfoodManifest ? {
    artifact_dir: dogfoodManifest.artifact_dir,
    ok: dogfoodManifest.ok === true,
    failed_checks: dogfoodManifest.failed_checks ?? [],
    checks: dogfoodManifest.checks ?? {},
  } : undefined,
  latest_human_demo: templateJson ? {
    manifest_path: templateJson.manifest_path,
    screenshot_path: templateJson.screenshot_path,
    ok: templateJson.ok === true,
    queue_count: templateJson.queue_count,
    ambient_autosave_ok: templateJson.ambient_autosave_ok === true,
    generated_at: templateJson.generated_at,
    freshness: latestHumanDemoFreshness,
  } : undefined,
  screen_sharing_capture: screenshot ? {
    ok: screenshot.status === 0,
    output: path.join(runDir, "screen-sharing.png"),
    exit_code: screenshot.status,
    image: screenshotImage,
  } : {
    skipped: true,
  },
  queue_latency: queueLatency ? {
    ok: queueLatency.status === 0 && queueLatencyManifest?.ok === true,
    manifest_path: queueLatencyManifestPath,
    exit_code: queueLatency.status,
    failed_budgets: queueLatencyManifest?.failed_budgets ?? [],
    summary: queueLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  workspace_latency: workspaceLatency ? {
    ok: workspaceLatency.status === 0 && workspaceLatencyManifest?.ok === true,
    manifest_path: workspaceLatencyManifestPath,
    exit_code: workspaceLatency.status,
    failed_budgets: workspaceLatencyManifest?.failed_budgets ?? [],
    summary: workspaceLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  hotkey_feedback_latency: hotkeyLatency ? {
    ok: hotkeyLatency.status === 0 && hotkeyLatencyManifest?.ok === true,
    manifest_path: hotkeyLatencyManifestPath,
    exit_code: hotkeyLatency.status,
    failed_budgets: hotkeyLatencyManifest?.failed_budgets ?? [],
    summary: hotkeyLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  steps,
};

const manifestPath = path.join(runDir, "manifest.json");
const readyPath = path.join(runDir, "READY.md");
writeFileSync(path.join(repoRoot, manifestPath), `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
writeFileSync(path.join(repoRoot, readyPath), renderReadyMarkdown(manifest), "utf8");

const output = {
  manifest: manifestPath,
  ready: readyPath,
  ok: manifest.ok,
  failed_checks: failedChecks,
  checks: manifest.checks,
  queue_latency_required: manifest.queue_latency_required,
  workspace_latency_required: manifest.workspace_latency_required,
  hotkey_latency_required: manifest.hotkey_latency_required,
  latest_human_demo: manifest.latest_human_demo,
  screen_sharing_capture: manifest.screen_sharing_capture,
  queue_latency: manifest.queue_latency,
  workspace_latency: manifest.workspace_latency,
  hotkey_feedback_latency: manifest.hotkey_feedback_latency,
};

if (jsonOnly) {
  console.log(JSON.stringify(output));
} else {
  console.log(`human demo ready manifest: ${manifestPath}`);
  console.log(`human demo ready note: ${readyPath}`);
  console.log(JSON.stringify(output, null, 2));
}

process.exit(manifest.ok ? 0 : 1);

function runStep(name, command, commandArgs, envOverride) {
  const result = spawnSync(command, commandArgs, {
    cwd: repoRoot,
    env: envOverride,
    encoding: "utf8",
    shell: false,
  });
  const safeName = name.replace(/[^a-z0-9]+/gi, "-").replace(/^-|-$/g, "").toLowerCase();
  const stdoutPath = path.join(runDir, "steps", `${safeName}.stdout`);
  const stderrPath = path.join(runDir, "steps", `${safeName}.stderr`);
  writeFileSync(path.join(repoRoot, stdoutPath), result.stdout ?? "", "utf8");
  writeFileSync(path.join(repoRoot, stderrPath), result.stderr ?? "", "utf8");
  const step = {
    name,
    command: [command, ...commandArgs],
    status: result.status ?? 1,
    signal: result.signal,
    stdout_path: stdoutPath,
    stderr_path: stderrPath,
  };
  steps.push(step);
  return {
    ...step,
    stdout: result.stdout ?? "",
    stderr: result.stderr ?? "",
  };
}

function numberOption(flag, defaultValue) {
  const index = args.indexOf(flag);
  const raw = index === -1 ? defaultValue : args[index + 1];
  const parsed = Number(raw);
  if (!Number.isFinite(parsed) || parsed <= 0) {
    console.error(`Invalid ${flag}: ${String(raw)}`);
    process.exit(2);
  }
  return parsed;
}

function runHotkeyLatencyStep(manifestPath, envOverride) {
  if (process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_TARGET === "local") {
    return runStep("hotkey feedback latency", "node", [
      "bin/macos-hotkey-feedback-latency",
      "--manifest",
      manifestPath,
    ], envOverride);
  }
  return runStep("hotkey feedback latency", "bin/lab-mac-hotkey-feedback-latency", [
    "--manifest",
    manifestPath,
  ], envOverride);
}

function runQueueLatencyStep(manifestPath, envOverride) {
  const args = [
    "bin/queue-latency-proof",
    "--url",
    envOverride.LAB_DOGFOOD_URL,
    "--runs",
    process.env.EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_RUNS ?? "3",
    "--read-only",
    "--manifest",
    manifestPath,
  ];
  if (process.env.EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_TARGET === "local") {
    return runStep("queue latency", "node", args, envOverride);
  }
  return runStep("queue latency", "bin/lab-mac-latency-proof", [
    "queue",
    "--manifest",
    manifestPath,
    ...args.slice(1, -2),
  ], envOverride);
}

function runWorkspaceLatencyStep(manifestPath, envOverride) {
  const args = [
    "bin/workspace-latency-proof",
    "--url",
    envOverride.LAB_DOGFOOD_URL,
    "--runs",
    process.env.EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_RUNS ?? "2",
    "--manifest",
    manifestPath,
  ];
  if (process.env.EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_TARGET === "local") {
    return runStep("workspace latency", "node", args, envOverride);
  }
  return runStep("workspace latency", "bin/lab-mac-latency-proof", [
    "workspace",
    "--manifest",
    manifestPath,
    ...args.slice(1, -2),
  ], envOverride);
}

function extractJsonObject(value) {
  if (!value.trim()) return undefined;
  const starts = [];
  for (let index = value.indexOf("{"); index !== -1; index = value.indexOf("{", index + 1)) {
    starts.push(index);
  }
  for (const start of starts) {
    const candidate = value.slice(start).trim();
    try {
      return JSON.parse(candidate);
    } catch {
      // Try next JSON-looking segment.
    }
  }
  return undefined;
}

function readJsonIfPresent(relativePath) {
  try {
    return JSON.parse(readFileSync(path.resolve(repoRoot, relativePath), "utf8"));
  } catch {
    return undefined;
  }
}

function imageArtifactSummary(relativePath) {
  const absolutePath = path.resolve(repoRoot, relativePath);
  if (!existsSync(absolutePath)) {
    return {
      ok: false,
      path: relativePath,
      reason: "missing",
    };
  }
  const bytes = statSync(absolutePath).size;
  if (bytes <= 0) {
    return {
      ok: false,
      path: relativePath,
      bytes,
      reason: "empty",
    };
  }
  try {
    const buffer = readFileSync(absolutePath);
    const parsed = parseImageDimensions(buffer);
    const ok = parsed.width > 0 && parsed.height > 0;
    return {
      ok,
      path: relativePath,
      bytes,
      format: parsed.format,
      width: parsed.width,
      height: parsed.height,
      dimensions: `${parsed.width}x${parsed.height}`,
      reason: ok ? "ok" : "invalid_dimensions",
    };
  } catch (error) {
    return {
      ok: false,
      path: relativePath,
      bytes,
      reason: error instanceof Error ? error.message : String(error),
    };
  }
}

function parseImageDimensions(buffer) {
  if (buffer.length >= 24
    && buffer[0] === 0x89
    && buffer[1] === 0x50
    && buffer[2] === 0x4e
    && buffer[3] === 0x47
    && buffer[4] === 0x0d
    && buffer[5] === 0x0a
    && buffer[6] === 0x1a
    && buffer[7] === 0x0a) {
    return {
      format: "png",
      width: buffer.readUInt32BE(16),
      height: buffer.readUInt32BE(20),
    };
  }
  if (buffer.length >= 4 && buffer[0] === 0xff && buffer[1] === 0xd8) {
    for (let offset = 2; offset + 8 < buffer.length;) {
      if (buffer[offset] !== 0xff) {
        offset += 1;
        continue;
      }
      const marker = buffer[offset + 1];
      if (marker === 0xd9 || marker === 0xda) break;
      const segmentLength = buffer.readUInt16BE(offset + 2);
      if (segmentLength < 2) throw new Error("invalid_jpeg_segment");
      if (isJpegStartOfFrame(marker)) {
        return {
          format: "jpeg",
          width: buffer.readUInt16BE(offset + 7),
          height: buffer.readUInt16BE(offset + 5),
        };
      }
      offset += 2 + segmentLength;
    }
  }
  throw new Error("unsupported_image_format");
}

function isJpegStartOfFrame(marker) {
  return (marker >= 0xc0 && marker <= 0xc3)
    || (marker >= 0xc5 && marker <= 0xc7)
    || (marker >= 0xc9 && marker <= 0xcb)
    || (marker >= 0xcd && marker <= 0xcf);
}

function renderReadyMarkdown(manifest) {
  const latest = manifest.latest_human_demo;
  const screenshot = manifest.screen_sharing_capture;
  const queueLatency = manifest.queue_latency;
  const workspaceLatency = manifest.workspace_latency;
  const hotkey = manifest.hotkey_feedback_latency;
  const freshness = latest?.freshness;
  return `# eventloopOS Human Demo Ready

- Ready: ${manifest.ok ? "yes" : "no"}
- Profile: ${manifest.profile}
- URL: ${manifest.url}
- Latest proof: ${latest?.manifest_path ?? ""}
- Latest proof screenshot: ${latest?.screenshot_path ?? ""}
- Latest proof freshness: ${freshness ? `${freshness.ok ? "ok" : "stale"} age=${freshness.age_hours ?? ""}h max=${freshness.max_age_hours}h${freshness.allowed_stale ? " allowed" : ""}` : ""}
- Fresh Screen Sharing capture: ${screenshot?.output ?? "skipped"}${screenshot?.image?.dimensions ? ` (${screenshot.image.dimensions}, ${screenshot.image.bytes} bytes)` : ""}
- Queue latency: ${queueLatency?.manifest_path ?? "skipped"}${manifest.queue_latency_required ? " (required)" : ""}
- Workspace latency: ${workspaceLatency?.manifest_path ?? "skipped"}${manifest.workspace_latency_required ? " (required)" : ""}
- Hotkey feedback latency: ${hotkey?.manifest_path ?? "skipped"}${manifest.hotkey_latency_required ? " (required)" : ""}
- Failed checks: ${manifest.failed_checks.length === 0 ? "none" : manifest.failed_checks.join(", ")}

Next: use \`docs/human-demo-walkthrough.md\`, then run \`bin/human-demo-result-template --write\` and fill the generated result after Jason finishes hands-on pass.
`;
}

function utcStamp() {
  return new Date().toISOString().replace(/[-:]/g, "").replace(/\.\d{3}Z$/, "Z");
}

function demoProofFreshness(generatedAt, nowIso, maxAgeHours, allowStale) {
  const generatedMs = Date.parse(String(generatedAt ?? ""));
  const nowMs = Date.parse(nowIso);
  if (!Number.isFinite(generatedMs) || !Number.isFinite(nowMs)) {
    return {
      ok: allowStale,
      generated_at: generatedAt ?? null,
      age_ms: null,
      age_hours: null,
      max_age_hours: maxAgeHours,
      allowed_stale: allowStale,
      reason: "missing_or_invalid_generated_at",
    };
  }
  const ageMs = Math.max(0, nowMs - generatedMs);
  const maxAgeMs = maxAgeHours * 60 * 60 * 1000;
  const fresh = ageMs <= maxAgeMs;
  return {
    ok: fresh || allowStale,
    generated_at: generatedAt,
    age_ms: ageMs,
    age_hours: Number((ageMs / 60 / 60 / 1000).toFixed(3)),
    max_age_hours: maxAgeHours,
    allowed_stale: allowStale && !fresh,
    reason: fresh ? "fresh" : "stale",
  };
}

function runSelfTest() {
  const noisyJson = `prefix\n{\"ok\":true,\"queue_count\":2,\"ambient_autosave_ok\":true}`;
  assert.deepEqual(extractJsonObject(noisyJson), { ok: true, queue_count: 2, ambient_autosave_ok: true });
  assert.equal(extractJsonObject("no json"), undefined);
  assert.deepEqual(demoProofFreshness("2026-06-03T10:00:00.000Z", "2026-06-03T20:00:00.000Z", 24, false), {
    ok: true,
    generated_at: "2026-06-03T10:00:00.000Z",
    age_ms: 36000000,
    age_hours: 10,
    max_age_hours: 24,
    allowed_stale: false,
    reason: "fresh",
  });
  assert.equal(demoProofFreshness("2026-06-03T10:00:00.000Z", "2026-06-04T20:00:00.000Z", 24, false).ok, false);
  assert.equal(demoProofFreshness("bad", "2026-06-04T20:00:00.000Z", 24, true).ok, true);
  const png = Buffer.from([
    0x89, 0x50, 0x4e, 0x47, 0x0d, 0x0a, 0x1a, 0x0a,
    0x00, 0x00, 0x00, 0x0d, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x07, 0x80,
    0x00, 0x00, 0x04, 0x38,
  ]);
  assert.deepEqual(parseImageDimensions(png), { format: "png", width: 1920, height: 1080 });
  const jpeg = Buffer.from([
    0xff, 0xd8,
    0xff, 0xe0, 0x00, 0x04, 0x00, 0x00,
    0xff, 0xc0, 0x00, 0x0b, 0x08,
    0x02, 0xd0,
    0x05, 0x00,
    0x03, 0x01, 0x11, 0x00,
  ]);
  assert.deepEqual(parseImageDimensions(jpeg), { format: "jpeg", width: 1280, height: 720 });
  const markdown = renderReadyMarkdown({
    ok: true,
    profile: "lab-human-demo",
    url: "http://127.0.0.1:4480",
    failed_checks: [],
    latest_human_demo: {
      manifest_path: "artifacts/lab-runs/demo/manifest.json",
      screenshot_path: "artifacts/lab-runs/demo/screen-sharing.png",
      freshness: { ok: true, age_hours: 1.25, max_age_hours: 24, allowed_stale: false },
    },
    screen_sharing_capture: {
      output: "artifacts/lab-runs/ready/screen-sharing.png",
      image: { dimensions: "1280x720", bytes: 2048 },
    },
    queue_latency: { manifest_path: "artifacts/lab-runs/ready/queue-latency.json" },
    queue_latency_required: true,
    workspace_latency: { manifest_path: "artifacts/lab-runs/ready/workspace-latency.json" },
    workspace_latency_required: true,
    hotkey_feedback_latency: { skipped: true },
  });
  assert.match(markdown, /Ready: yes/);
  assert.match(markdown, /artifacts\/lab-runs\/demo\/manifest\.json/);
  assert.match(markdown, /Latest proof freshness: ok age=1.25h max=24h/);
  assert.match(markdown, /Fresh Screen Sharing capture: artifacts\/lab-runs\/ready\/screen-sharing\.png \(1280x720, 2048 bytes\)/);
  assert.match(markdown, /Hotkey feedback latency: skipped/);
  assert.match(markdown, /Queue latency: artifacts\/lab-runs\/ready\/queue-latency\.json/);
  assert.match(markdown, /Workspace latency: artifacts\/lab-runs\/ready\/workspace-latency\.json/);
}
