#!/usr/bin/env node
import assert from "node:assert/strict";
import { existsSync, mkdirSync, readFileSync, statSync, writeFileSync } from "node:fs";
import { spawnSync } from "node:child_process";
import path from "node:path";
import process from "node:process";

const repoRoot = path.resolve(import.meta.dirname, "..");
process.chdir(repoRoot);

const args = process.argv.slice(2);
const skipScreenshot = args.includes("--skip-screenshot");
const allowStaleDemoProof = args.includes("--allow-stale-demo-proof") || process.env.EVENTLOOPOS_HUMAN_DEMO_ALLOW_STALE_PROOF === "1";
const demoProofMaxAgeHours = numberOption("--demo-proof-max-age-hours", process.env.EVENTLOOPOS_HUMAN_DEMO_PROOF_MAX_AGE_HOURS ?? "24");
const skipQueueLatency = args.includes("--skip-queue-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY === "0";
const queueLatencyEnabled = !skipQueueLatency;
const skipWorkspaceLatency = args.includes("--skip-workspace-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY === "0";
const workspaceLatencyEnabled = !skipWorkspaceLatency;
const skipHotkeyLatency = args.includes("--skip-hotkey-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY === "0";
const hotkeyLatencyRequested = args.includes("--hotkey-latency") || process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY === "1";
const hotkeyLatencyEnabled = !skipHotkeyLatency && (hotkeyLatencyRequested || process.platform === "darwin");
const jsonOnly = args.includes("--json");
const screenshotTarget = normalizeScreenshotTarget(process.env.EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET ?? "auto");

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/human-demo-ready [--skip-screenshot] [--skip-queue-latency] [--skip-workspace-latency] [--skip-hotkey-latency] [--hotkey-latency] [--demo-proof-max-age-hours n] [--allow-stale-demo-proof] [--json]

Check current Mac Studio human-demo readiness without resetting demo state.
Includes read-only queue/master and workspace capture/restore-plan latency gates
by default. On macOS, also includes a live queue-app hotkey feedback p95 gate by default.
Use skip flags only while bootstrapping remote host/Accessibility permission.

Environment:
  LAB_DOGFOOD_PROFILE  default: lab-human-demo
  LAB_DOGFOOD_URL      default: http://127.0.0.1:4480
  SCREEN_SHARING_TITLE default: Zeus
  EVENTLOOPOS_HUMAN_DEMO_PROOF_MAX_AGE_HOURS default: 24
  EVENTLOOPOS_HUMAN_DEMO_ALLOW_STALE_PROOF=1 skips demo proof freshness gate
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY=1 keeps queue latency on
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY=0 skips queue latency
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_TARGET=local runs queue latency on this Mac instead of the lab Mac
  EVENTLOOPOS_HUMAN_DEMO_QUEUE_LATENCY_RUNS default: 3
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY=1 keeps workspace latency on
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY=0 skips workspace latency
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_TARGET=local runs workspace latency on this Mac instead of the lab Mac
  EVENTLOOPOS_HUMAN_DEMO_WORKSPACE_LATENCY_RUNS default: 2
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY=1 forces hotkey latency on
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY=0 skips hotkey latency
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_TARGET=local runs latency on this Mac instead of the lab Mac
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_CHORD default: ctrl-option-r
  EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_EXPECT optional expected feedback substring (default for ctrl-option-r: Restoring paper:)
  EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET=auto|local|lab default: auto
    auto captures local Screen Sharing window first, then falls back to lab Mac desktop only
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  console.log("human-demo-ready self-test passed");
  process.exit(0);
}

const runDir = path.join("artifacts", "lab-runs", `${utcStamp()}-human-demo-ready`);
mkdirSync(path.join(repoRoot, runDir, "steps"), { recursive: true });

const startedAt = new Date().toISOString();
const env = {
  ...process.env,
  LAB_DOGFOOD_PROFILE: process.env.LAB_DOGFOOD_PROFILE ?? "lab-human-demo",
  LAB_DOGFOOD_URL: process.env.LAB_DOGFOOD_URL ?? "http://127.0.0.1:4480",
  SCREEN_SHARING_TITLE: process.env.SCREEN_SHARING_TITLE ?? "Zeus",
};

const steps = [];
const dogfood = runStep("dogfood status", "bin/lab-mac-dogfood", ["status"], env);
const dogfoodManifest = extractJsonObject(dogfood.stdout);
const template = runStep("human demo result template", "node", ["bin/human-demo-result-template", "--json"], env);
const templateJson = extractJsonObject(template.stdout);
const latestHumanDemoFreshness = demoProofFreshness(templateJson?.generated_at, startedAt, demoProofMaxAgeHours, allowStaleDemoProof);
const latestHumanDemoScreenshot = imageArtifactSummary(templateJson?.screenshot_path ?? "");

let screenshot;
let screenshotStage;
if (!skipScreenshot) {
  screenshotStage = runLabDemoScreenshotStageStep(env);
  screenshot = runScreenshotStep(path.join(runDir, "screen-sharing.png"), env);
}
const hotkeyLatencyManifestPath = path.join(runDir, "hotkey-latency.json");
const queueLatencyManifestPath = path.join(runDir, "queue-latency.json");
const workspaceLatencyManifestPath = path.join(runDir, "workspace-latency.json");
const queueLatency = queueLatencyEnabled
  ? runQueueLatencyStep(queueLatencyManifestPath, env)
  : undefined;
const queueLatencyManifest = queueLatency ? readJsonIfPresent(queueLatencyManifestPath) : undefined;
const workspaceLatency = workspaceLatencyEnabled
  ? runWorkspaceLatencyStep(workspaceLatencyManifestPath, env)
  : undefined;
const workspaceLatencyManifest = workspaceLatency ? readJsonIfPresent(workspaceLatencyManifestPath) : undefined;
const hotkeyLatency = hotkeyLatencyEnabled
  ? runHotkeyLatencyStep(hotkeyLatencyManifestPath, env)
  : undefined;
const hotkeyLatencyManifest = hotkeyLatency ? readJsonIfPresent(hotkeyLatencyManifestPath) : undefined;

const checks = {
  dogfood_status_ok: dogfood.status === 0 && dogfoodManifest?.ok === true,
  latest_human_demo_proof_ok: template.status === 0 && templateJson?.ok === true,
  latest_human_demo_proof_fresh: latestHumanDemoFreshness.ok === true,
  latest_human_demo_screenshot_ok: latestHumanDemoScreenshot.ok === true,
  latest_human_demo_queue_has_two_papers: Number(templateJson?.queue_count ?? 0) >= 2,
  ambient_autosave_proof_ok: templateJson?.ambient_autosave_ok === true,
  new_window_autosave_proof_ok: templateJson?.new_window_autosave_ok === true,
  foreign_window_containment_proof_ok: templateJson?.foreign_window_containment_ok === true,
  agent_spawn_window_containment_proof_ok: templateJson?.agent_spawn_window_containment_ok === true,
  screen_sharing_capture_ok: skipScreenshot || (screenshotStage?.ok === true && screenshot?.ok === true),
  queue_briefing_strip_visible: skipScreenshot || screenshotStage?.result?.queue_briefing_strip_present === true,
  paper_reminder_hud_visible: skipScreenshot || screenshotStage?.result?.paper_reminder_hud_present === true
    || screenshot?.lab_capture_summary?.queue_app?.paper_reminder_hud_present === true,
  queue_latency_ok: !queueLatencyEnabled || (queueLatency?.status === 0 && queueLatencyManifest?.ok === true),
  workspace_latency_ok: !workspaceLatencyEnabled || (workspaceLatency?.status === 0 && workspaceLatencyManifest?.ok === true),
  hotkey_feedback_latency_ok: !hotkeyLatencyEnabled || (hotkeyLatency?.status === 0 && hotkeyLatencyManifest?.ok === true),
};
const failedChecks = Object.entries(checks).filter(([, ok]) => ok !== true).map(([key]) => key);
const finishedAt = new Date().toISOString();
const manifest = {
  schema_version: 1,
  kind: "eventloopos.human_demo_ready",
  started_at: startedAt,
  finished_at: finishedAt,
  duration_ms: Date.parse(finishedAt) - Date.parse(startedAt),
  artifact_dir: runDir,
  ok: failedChecks.length === 0,
  passed: failedChecks.length === 0,
  profile: env.LAB_DOGFOOD_PROFILE,
  url: env.LAB_DOGFOOD_URL,
  queue_latency_required: queueLatencyEnabled,
  workspace_latency_required: workspaceLatencyEnabled,
  hotkey_latency_required: hotkeyLatencyEnabled,
  screenshot_target: screenshotTarget,
  demo_proof_max_age_hours: demoProofMaxAgeHours,
  allow_stale_demo_proof: allowStaleDemoProof,
  checks,
  failed_checks: failedChecks,
  dogfood_status: dogfoodManifest ? {
    artifact_dir: dogfoodManifest.artifact_dir,
    ok: dogfoodManifest.ok === true,
    failed_checks: dogfoodManifest.failed_checks ?? [],
    checks: dogfoodManifest.checks ?? {},
  } : undefined,
  latest_human_demo: templateJson ? {
    manifest_path: templateJson.manifest_path,
    screenshot_path: templateJson.screenshot_path,
    screenshot_image: latestHumanDemoScreenshot,
    suggested_result_path: templateJson.suggested_output_path,
    ok: templateJson.ok === true,
    queue_count: templateJson.queue_count,
    ambient_autosave_ok: templateJson.ambient_autosave_ok === true,
    new_window_autosave_ok: templateJson.new_window_autosave_ok === true,
    foreign_window_containment_ok: templateJson.foreign_window_containment_ok === true,
    agent_spawn_window_containment_ok: templateJson.agent_spawn_window_containment_ok === true,
    generated_at: templateJson.generated_at,
    freshness: latestHumanDemoFreshness,
  } : undefined,
  screen_sharing_capture: screenshot ? screenshot : {
    skipped: true,
  },
  screenshot_stage: screenshotStage ? screenshotStage : {
    skipped: true,
  },
  queue_latency: queueLatency ? {
    ok: queueLatency.status === 0 && queueLatencyManifest?.ok === true,
    manifest_path: queueLatencyManifestPath,
    exit_code: queueLatency.status,
    failed_budgets: queueLatencyManifest?.failed_budgets ?? [],
    summary: queueLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  workspace_latency: workspaceLatency ? {
    ok: workspaceLatency.status === 0 && workspaceLatencyManifest?.ok === true,
    manifest_path: workspaceLatencyManifestPath,
    exit_code: workspaceLatency.status,
    failed_budgets: workspaceLatencyManifest?.failed_budgets ?? [],
    summary: workspaceLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  hotkey_feedback_latency: hotkeyLatency ? {
    ok: hotkeyLatency.status === 0 && hotkeyLatencyManifest?.ok === true,
    manifest_path: hotkeyLatencyManifestPath,
    exit_code: hotkeyLatency.status,
    failed_budgets: hotkeyLatencyManifest?.failed_budgets ?? [],
    summary: hotkeyLatencyManifest?.summary,
  } : {
    skipped: true,
  },
  steps,
};

const manifestPath = path.join(runDir, "manifest.json");
const readyPath = path.join(runDir, "READY.md");
writeFileSync(path.join(repoRoot, manifestPath), `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
writeFileSync(path.join(repoRoot, readyPath), renderReadyMarkdown(manifest), "utf8");

const output = {
  manifest: manifestPath,
  ready: readyPath,
  ok: manifest.ok,
  failed_checks: failedChecks,
  checks: manifest.checks,
  queue_latency_required: manifest.queue_latency_required,
  workspace_latency_required: manifest.workspace_latency_required,
  hotkey_latency_required: manifest.hotkey_latency_required,
  latest_human_demo: manifest.latest_human_demo,
  screen_sharing_capture: manifest.screen_sharing_capture,
  screenshot_stage: manifest.screenshot_stage,
  queue_latency: manifest.queue_latency,
  workspace_latency: manifest.workspace_latency,
  hotkey_feedback_latency: manifest.hotkey_feedback_latency,
};

if (jsonOnly) {
  console.log(JSON.stringify(output));
} else {
  console.log(`human demo ready manifest: ${manifestPath}`);
  console.log(`human demo ready note: ${readyPath}`);
  console.log(JSON.stringify(output, null, 2));
}

process.exit(manifest.ok ? 0 : 1);

function runStep(name, command, commandArgs, envOverride, options = {}) {
  const result = spawnSync(command, commandArgs, {
    cwd: repoRoot,
    env: envOverride,
    encoding: "utf8",
    shell: false,
    input: options.input,
  });
  const safeName = name.replace(/[^a-z0-9]+/gi, "-").replace(/^-|-$/g, "").toLowerCase();
  const stdoutPath = path.join(runDir, "steps", `${safeName}.stdout`);
  const stderrPath = path.join(runDir, "steps", `${safeName}.stderr`);
  writeFileSync(path.join(repoRoot, stdoutPath), result.stdout ?? "", "utf8");
  writeFileSync(path.join(repoRoot, stderrPath), result.stderr ?? "", "utf8");
  const step = {
    name,
    command: [command, ...commandArgs],
    status: result.status ?? 1,
    signal: result.signal,
    stdout_path: stdoutPath,
    stderr_path: stderrPath,
  };
  steps.push(step);
  return {
    ...step,
    stdout: result.stdout ?? "",
    stderr: result.stderr ?? "",
  };
}

function numberOption(flag, defaultValue) {
  const index = args.indexOf(flag);
  const raw = index === -1 ? defaultValue : args[index + 1];
  const parsed = Number(raw);
  if (!Number.isFinite(parsed) || parsed <= 0) {
    console.error(`Invalid ${flag}: ${String(raw)}`);
    process.exit(2);
  }
  return parsed;
}

function runLabDemoScreenshotStageStep(envOverride) {
  const labHost = envOverride.LAB_MAC_HOST ?? "100.71.111.25";
  const labUser = envOverride.LAB_MAC_USER ?? "claw";
  const labKey = envOverride.LAB_MAC_KEY ?? path.join(osHome(), ".ssh", "eventloop_lab_mac");
  const remoteRepo = remoteRepoFromEnv(envOverride);
  const remote = `${labUser}@${labHost}`;
  const step = runStep("stage lab demo screenshot", "ssh", [
    "-i",
    labKey,
    "-o",
    "BatchMode=yes",
    "-o",
    "ConnectTimeout=20",
    "-o",
    "ServerAliveInterval=15",
    "-o",
    "ServerAliveCountMax=8",
    remote,
    "bash",
    "-s",
    "--",
    remoteRepo,
    envOverride.LAB_DOGFOOD_URL,
  ], envOverride, {
    input: labDemoScreenshotStageScript(),
  });
  const parsed = extractJsonObject(step.stdout);
  return {
    ok: step.status === 0 && parsed?.ok === true,
    target: "lab",
    exit_code: step.status,
    result: parsed,
    stdout_path: step.stdout_path,
    stderr_path: step.stderr_path,
  };
}

function labDemoScreenshotStageScript() {
  return `set -euo pipefail
repo="$1"
url="$2"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
EVENTLOOPOS_STAGE_URL="$url" node --input-type=module <<'NODE'
import { execFileSync } from "node:child_process";
import fs from "node:fs";
import path from "node:path";

const base = process.env.EVENTLOOPOS_STAGE_URL ?? "http://127.0.0.1:4480";

const queue = await getJson("/queue");
const items = Array.isArray(queue.items) ? queue.items : [];
const customer = items.find((item) => item.task_id === "task_demo_customer" && item.state === "ready")
  ?? items.find((item) => item.task_id === "task_demo_customer")
  ?? items.find((item) => item.task_id === "task_demo_metrics" && item.state === "ready")
  ?? items.find((item) => item.task_id === "task_demo_metrics");
if (!customer) throw new Error("missing demo queue item");

const context = Array.isArray(customer.review_packet?.context) ? customer.review_packet.context : [];
const snapshot = latestDemoProofSnapshot(customer.task_id)
  ?? context.find((entry) => entry?.kind === "workspace_snapshot")?.snapshot;
if (!snapshot) throw new Error(\`missing workspace snapshot for \${customer.id}\`);

const taskBody = await getJson(\`/tasks/\${customer.task_id}\`).catch(() => undefined);
const taskWorkspace = taskBody?.task?.aerospace_workspace_id;
if (taskWorkspace) snapshot.activeWorkspace = taskWorkspace;

const current = await postJson("/workspace/capture", { capture_frames: false });
const restore = await postJson("/workspace/restore", {
  confirm_execute: true,
  snapshot,
  current_windows: current.snapshot?.windows ?? [],
}, {
  "idempotency-key": \`human-demo-screenshot-stage-\${Date.now()}\`,
});

const workspace = snapshot.activeWorkspace ?? taskWorkspace ?? (customer.task_id === "task_demo_metrics" ? "demo-metrics" : "demo-customer");
execFileSync("aerospace", ["workspace", workspace], { stdio: "ignore" });
const focusedWindowIds = focusDemoWindows(snapshot);
const raisedWindowCount = raiseDemoApps();
execFileSync("aerospace", ["workspace", workspace], { stdio: "ignore" });
await delay(800);
const briefingStrip = queueBriefingStripStatus({
  title: customer.review_packet?.title,
  decision: customer.review_packet?.decision_needed ?? customer.review_packet?.recommended_action ?? "",
  taskId: customer.task_id,
  priority: customer.priority_score,
});
const paperReminderHud = paperReminderHudStatus();

console.log(JSON.stringify({
  ok: true,
  task_id: customer.task_id,
  queue_item_id: customer.id,
  workspace,
  focused_window_ids: focusedWindowIds,
  raised_window_count: raisedWindowCount,
  restore_command_count: restore.plan?.commands?.length ?? 0,
  queue_briefing_strip_present: briefingStrip.present,
  queue_briefing_strip_line: briefingStrip.line,
  queue_briefing_strip_error: briefingStrip.error,
  paper_reminder_hud_present: paperReminderHud.present,
  paper_reminder_hud_source: paperReminderHud.source,
  paper_reminder_hud_title: paperReminderHud.title,
  paper_reminder_hud_error: paperReminderHud.error,
}));

function latestDemoProofSnapshot(taskId) {
  const labRuns = path.join(process.cwd(), "artifacts", "lab-runs");
  let candidates = [];
  try {
    candidates = fs.readdirSync(labRuns, { withFileTypes: true })
      .filter((entry) => entry.isDirectory() && entry.name.endsWith("-human-demo"))
      .map((entry) => path.join(labRuns, entry.name, "manifest.json"))
      .filter((candidate) => fs.existsSync(candidate))
      .sort()
      .reverse();
  } catch {
    return undefined;
  }
  for (const candidate of candidates) {
    try {
      const manifest = JSON.parse(fs.readFileSync(candidate, "utf8"));
      const proof = taskId === "task_demo_metrics"
        ? manifest?.proofs?.metrics_restore
        : manifest?.proofs?.final_ready_customer_restore ?? manifest?.proofs?.ready_customer_restore;
      const windows = Array.isArray(proof?.windows) ? proof.windows : [];
      if (proof?.ok === true && proof?.expected_active_workspace && windows.length > 0) {
        return {
          backend: "aerospace",
          activeWorkspace: proof.expected_active_workspace,
          focusedWindowId: windows[0]?.id,
          windows,
        };
      }
    } catch {
      // Try older proof manifest.
    }
  }
  return undefined;
}

function focusDemoWindows(snapshot) {
  const focusIds = [];
  const windows = Array.isArray(snapshot.windows) ? snapshot.windows : [];
  const chrome = windows.find((window) => /Google Chrome/i.test(window.app) && /Human Demo/i.test(window.title));
  const textEdit = windows.find((window) => /TextEdit/i.test(window.app) && /Human Demo Shared Notes/i.test(window.title));
  for (const window of [chrome, textEdit]) {
    if (!window?.id) continue;
    focusWindow(window.id, focusIds);
  }
  const queueId = currentAerospaceWindows()
    .find(isQueueWindow)?.["window-id"];
  if (queueId) focusWindow(queueId, focusIds);
  return focusIds;
}

function focusWindow(windowId, output) {
  try {
    execFileSync("aerospace", ["focus", "--window-id", String(windowId)], { stdio: "ignore" });
    output.push(Number(windowId));
  } catch {
    // Focus is best-effort for screenshot staging; restore already did the
    // important workspace/window move work.
  }
}

function raiseDemoApps() {
  const script = [
    "set raisedWindows to 0",
    "tell application \\"System Events\\"",
    "  repeat with processName in {\\"Google Chrome\\", \\"TextEdit\\", \\"eventloopOS Queue\\"}",
    "    set processNameText to processName as string",
    "    if exists process processNameText then",
    "      tell process processNameText",
    "        set frontmost to true",
    "        delay 0.2",
    "        repeat with candidateWindow in windows",
    "          try",
    "            set windowName to name of candidateWindow as string",
    "            if windowName contains \\"Human Demo\\" or windowName is \\"eventloopOS Queue\\" then",
    "              perform action \\"AXRaise\\" of candidateWindow",
    "              set raisedWindows to raisedWindows + 1",
    "            end if",
    "          end try",
    "        end repeat",
    "      end tell",
    "    end if",
    "  end repeat",
    "end tell",
    "return raisedWindows as string",
  ].join("\\n");
  try {
    const output = execFileSync("osascript", [], { input: script, encoding: "utf8" }).trim();
    return Number.parseInt(output, 10) || 0;
  } catch {
    return 0;
  }
}

function queueBriefingStripStatus(expected) {
  const script = [
    "tell application \\"System Events\\"",
    "  if not (exists process \\"eventloopOS Queue\\") then return \\"missing:process\\"",
    "  tell process \\"eventloopOS Queue\\"",
    "    if (count of windows) is 0 then return \\"missing:window\\"",
    "    set allLines to {}",
    "    set stripName to \\"\\"",
    "    set briefingTitle to \\"\\"",
    "    set briefingDecision to \\"\\"",
    "    set briefingContext to \\"\\"",
    "    set flattenedElements to entire contents of window 1",
    "    set elementCount to count of flattenedElements",
    "    if elementCount is greater than 240 then set elementCount to 240",
    "    repeat with elementIndex from 1 to elementCount",
    "      set candidateElement to item elementIndex of flattenedElements",
    "      set identifierText to \\"\\"",
    "      set nameText to \\"\\"",
    "      set valueText to \\"\\"",
    "      try",
    "        set identifierText to (value of attribute \\"AXIdentifier\\" of candidateElement) as string",
    "      end try",
    "      try",
    "        set nameText to name of candidateElement as string",
    "      end try",
    "      try",
    "        set valueText to value of candidateElement as string",
    "      end try",
    "      set end of allLines to identifierText & \\" \\" & nameText & \\" \\" & valueText",
    "      set readableText to nameText",
    "      if readableText is \\"\\" then set readableText to valueText",
    "      if identifierText is \\"queue-paper-briefing-strip\\" then set stripName to readableText",
    "      if identifierText is \\"queue-paper-briefing-title\\" then set briefingTitle to readableText",
    "      if identifierText is \\"queue-paper-briefing-decision\\" then set briefingDecision to readableText",
    "      if identifierText is \\"queue-paper-briefing-context\\" then set briefingContext to readableText",
    "    end repeat",
    "    if briefingTitle is not \\"\\" and briefingDecision is not \\"\\" and briefingContext is not \\"\\" then return \\"present:parts:\\" & briefingTitle & \\" | \\" & briefingDecision & \\" | \\" & briefingContext",
    "    if stripName is not \\"\\" then return \\"present:identifier:\\" & stripName",
    "  end tell",
    "end tell",
    "set AppleScript's text item delimiters to linefeed",
    "return allLines as string",
  ].join("\\n");
  try {
    const output = execFileSync("osascript", [], { input: script, encoding: "utf8" }).trim();
    if (output.startsWith("present:parts:")) {
      return briefingLineStatus(output.slice("present:parts:".length), expected);
    }
    if (output.startsWith("present:identifier:")) {
      return briefingLineStatus(output.slice("present:identifier:".length), expected);
    }
    const line = matchingBriefingLine(output, expected);
    return {
      present: Boolean(line),
      line: line ?? "missing:briefing_label",
    };
  } catch (error) {
    return {
      present: false,
      line: "",
      error: String(error?.message ?? error),
    };
  }
}

function briefingLineStatus(line, expected) {
  const normalized = String(line ?? "").replace(/\s+/g, " ").trim();
  const comparable = briefingComparableText(normalized);
  const missing = expectedBriefingParts(expected).filter((part) => !comparable.includes(briefingComparableText(part)));
  return {
    present: missing.length === 0,
    line: normalized,
    error: missing.length > 0 ? "briefing missing expected parts: " + missing.join(", ") : undefined,
  };
}

function briefingComparableText(value) {
  // Lab AX reads have returned lowercase "s" as spaces for SwiftUI Text.
  return String(value ?? "")
    .toLowerCase()
    .replace(/[\\s]+/g, "")
    .replace(/s/g, "");
}

function expectedBriefingParts(expected) {
  const title = String(expected?.title ?? "").trim();
  const decision = String(expected?.decision ?? "").trim();
  const taskId = String(expected?.taskId ?? "").trim();
  const priority = String(expected?.priority ?? "").trim();
  return [
    title,
    decision,
    taskId,
    priority ? "P" + priority : "",
  ].filter(Boolean);
}

function matchingBriefingLine(output, expected) {
  const expectedParts = expectedBriefingParts(expected).map(briefingComparableText);
  if (expectedParts.length < 3) return undefined;
  return output
    .split(/\\r?\\n/)
    .map((line) => line.replace(/\\s+/g, " ").trim())
    .find((line) => {
      const comparable = briefingComparableText(line);
      return expectedParts.every((part) => comparable.includes(part));
    });
}

function delay(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function currentAerospaceWindows() {
  try {
    return JSON.parse(execFileSync("aerospace", [
      "list-windows",
      "--all",
      "--json",
      "--format",
      "%{window-id}%{app-name}%{window-title}%{workspace}",
    ], { encoding: "utf8" }));
  } catch {
    return [];
  }
}

function isQueueWindow(window) {
  return String(window?.["window-title"] ?? "") === "eventloopOS Queue";
}

function paperReminderHudStatus() {
  const aerospaceMatch = currentAerospaceWindows()
    .find((window) => String(window?.["window-title"] ?? "") === "eventloopOS Paper Reminder");
  if (aerospaceMatch) {
    return {
      present: true,
      source: "aerospace",
      title: String(aerospaceMatch["window-title"] ?? ""),
    };
  }
  try {
    const script = [
      "tell application \\"System Events\\"",
      "  if not (exists process \\"eventloopOS Queue\\") then return \\"missing:process\\"",
      "  tell process \\"eventloopOS Queue\\"",
      "    repeat with candidateWindow in windows",
      "      set windowName to name of candidateWindow as string",
      "      if windowName is \\"eventloopOS Paper Reminder\\" then return \\"ok:\\" & windowName",
      "    end repeat",
      "  end tell",
      "end tell",
      "return \\"missing:window\\"",
    ].join("\\n");
    const output = execFileSync("osascript", [], { input: script, encoding: "utf8" }).trim();
    if (output.startsWith("ok:")) {
      return { present: true, source: "system_events", title: output.slice(3) };
    }
    return { present: false, source: "system_events", title: "", error: output };
  } catch (error) {
    return {
      present: false,
      source: "system_events",
      title: "",
      error: error instanceof Error ? error.message : String(error),
    };
  }
}

async function getJson(pathname) {
  const response = await fetch(\`\${base}\${pathname}\`);
  const body = await response.json().catch(() => ({}));
  if (!response.ok) throw new Error(\`\${pathname} failed HTTP \${response.status}: \${JSON.stringify(body)}\`);
  return body;
}

async function postJson(pathname, body, headers = {}) {
  const response = await fetch(\`\${base}\${pathname}\`, {
    method: "POST",
    headers: { "content-type": "application/json", ...headers },
    body: JSON.stringify(body),
  });
  const responseBody = await response.json().catch(() => ({}));
  if (!response.ok) throw new Error(\`\${pathname} failed HTTP \${response.status}: \${JSON.stringify(responseBody)}\`);
  return responseBody;
}
NODE
`;
}

