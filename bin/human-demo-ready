    ...hotkeyArgs,
  ], envOverride);
}

function hotkeyLatencyArgs() {
  const chord = process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_CHORD ?? "ctrl-option-r";
  const args = [
    "--hotkey",
    chord,
  ];
  const expected = process.env.EVENTLOOPOS_HUMAN_DEMO_HOTKEY_LATENCY_EXPECT
    ?? (normalizeHotkeyText(chord) === "ctrl-option-r" ? "Restoring paper:" : undefined);
  if (expected) args.push("--expect", expected);
  return args;
}

function normalizeHotkeyText(value) {
  return String(value).trim().toLowerCase().replace(/\+/g, "-");
}

