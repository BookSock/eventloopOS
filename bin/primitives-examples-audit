#!/usr/bin/env node
import assert from "node:assert/strict";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";

const args = process.argv.slice(2);

if (args.includes("-h") || args.includes("--help")) {
  console.log(`Usage: bin/primitives-examples-audit [--self-test] [examples/primitives]

Checks builder-facing primitive examples so live examples keep using the shared
@eventloopos/shared/primitives operation client instead of drifting back to
hand-rolled fetch clients.
`);
  process.exit(0);
}

if (args.includes("--self-test")) {
  runSelfTest();
  process.exit(0);
}

const positional = args.filter((arg) => !arg.startsWith("-"));
const examplesDir = positional[0] ?? "examples/primitives";
const result = auditPrimitiveExamples(path.resolve(process.cwd(), examplesDir));
if (!result.ok) {
  for (const error of result.errors) console.error(error);
  process.exit(1);
}
console.log(`primitives examples audit passed: ${examplesDir} (${result.example_count} examples)`);

function auditPrimitiveExamples(examplesDir) {
  const errors = [];
  const liveExamples = [
    "agent-attention-queue.mjs",
    "restore-my-desk.mjs",
    "window-hotkey-router.mjs",
  ];
  const discoveryExamples = [
    "discover-primitives.mjs",
    "primitive-workbench-walkthrough.mjs",
    "operation-id-client.mjs",
  ];
  const allExamples = [
    ...discoveryExamples,
    ...liveExamples,
  ];
  const loaderPath = path.join(examplesDir, "lib", "primitive-sdk-loader.mjs");
  const loader = readText(loaderPath, errors);
  if (loader !== undefined) {
    requireIncludes(loader, "export async function loadPrimitiveSdk", "loader must export loadPrimitiveSdk", errors);
    requireIncludes(loader, "export async function createPrimitiveExampleOperations", "loader must export createPrimitiveExampleOperations", errors);
    requireIncludes(loader, "export async function createPrimitiveExampleOperationClient", "loader must export createPrimitiveExampleOperationClient", errors);
    requireIncludes(loader, "createPrimitiveOperationsClient", "loader must create shared primitive operations client", errors);
    requireIncludes(loader, "createPrimitiveOperationHttpClient", "loader must create shared primitive operation-id HTTP client", errors);
    requireIncludes(loader, "listPrimitiveOperations", "loader must expose shared primitive operation-list helper", errors);
    requireIncludes(loader, "primitiveRouteSideEffect", "loader must force rebuild for side-effect-aware SDKs", errors);
    requireIncludes(loader, "pnpm\", [\"--filter\", \"@eventloopos/shared\", \"build\"]", "loader must build shared SDK on demand", errors);
  }

  for (const file of allExamples) {
    const text = readText(path.join(examplesDir, file), errors);
    if (text === undefined) continue;
    requireIncludes(text, "--self-test", `${file} must expose a self-test`, errors);
    if (discoveryExamples.includes(file)) {
      if (file !== "operation-id-client.mjs") {
        requireIncludes(text, "loadPrimitiveSdk", `${file} must use shared SDK loader`, errors);
      }
      rejectIncludes(text, "execFileSync", "discover-primitives must not duplicate shared SDK build loader", errors);
      if (file === "primitive-workbench-walkthrough.mjs") {
        requireIncludes(text, "listPrimitiveOperations", "primitive-workbench-walkthrough must use shared operation-list helper", errors);
        requireIncludes(text, "buildPrimitiveProofPlan", "primitive-workbench-walkthrough must use shared proof-plan helper", errors);
        rejectIncludes(text, "buildPrimitiveApiIndex", "primitive-workbench-walkthrough must not rebuild workbench routes from the compact API index", errors);
        requireIncludes(text, "examples/primitives/fixtures/workbench-catalog.json", "primitive-workbench-walkthrough must have fixture-backed self-test", errors);
      }
      if (file === "operation-id-client.mjs") {
        requireIncludes(text, "createPrimitiveExampleOperationClient", "operation-id-client must use shared operation-id client loader", errors);
        requireIncludes(text, "listPrimitiveOperations", "operation-id-client must expose catalog-backed operation discovery through shared SDK helper", errors);
        rejectIncludes(text, "buildPrimitiveApiIndex", "operation-id-client must not rebuild operation discovery from the compact API index", errors);
        requireIncludes(text, "describeOperation", "operation-id-client must describe operation ids before live calls", errors);
        requireIncludes(text, "listOperations", "operation-id-client must list operation ids before live calls", errors);
        requireIncludes(text, "requestOperation", "operation-id-client must call primitives by operation id", errors);
        requireIncludes(text, "--side-effect", "operation-id-client must expose side-effect filter", errors);
        requireIncludes(text, "--read-only", "operation-id-client must expose read-only filter", errors);
        requireIncludes(text, "--timeout-ms", "operation-id-client must expose timeout option", errors);
        requireIncludes(text, "examples/primitives/fixtures/workbench-catalog.json", "operation-id-client must have fixture-backed self-test", errors);
      }
      continue;
    }

    requireIncludes(text, "createPrimitiveExampleOperations", `${file} must use shared primitive operations client`, errors);
    requireIncludes(text, "--timeout-ms", `${file} must expose timeout option`, errors);
    rejectIncludes(text, "fetch(", `${file} must not hand-roll fetch calls`, errors);
    rejectIncludes(text, "requestJson(", `${file} must not hand-roll requestJson calls`, errors);
  }

  return { ok: errors.length === 0, example_count: allExamples.length, errors };
}

function readText(filePath, errors) {
  try {
    return fs.readFileSync(filePath, "utf8");
  } catch (error) {
    errors.push(`${filePath} read failed: ${error instanceof Error ? error.message : String(error)}`);
    return undefined;
  }
}

function requireIncludes(text, needle, error, errors) {
  if (!text.includes(needle)) errors.push(error);
}

function rejectIncludes(text, needle, error, errors) {
  if (text.includes(needle)) errors.push(error);
}

function runSelfTest() {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), "eventloopos-primitives-examples-"));
  const examplesDir = path.join(root, "examples", "primitives");
  const libDir = path.join(examplesDir, "lib");
  fs.mkdirSync(libDir, { recursive: true });
  fs.writeFileSync(path.join(libDir, "primitive-sdk-loader.mjs"), `
export async function loadPrimitiveSdk() {}
export async function createPrimitiveExampleOperations() {}
export async function createPrimitiveExampleOperationClient() {}
const command = ["pnpm", ["--filter", "@eventloopos/shared", "build"]];
const helper = "createPrimitiveOperationsClient";
const operationHelper = "createPrimitiveOperationHttpClient";
const listHelper = "listPrimitiveOperations";
const sideEffectHelper = "primitiveRouteSideEffect";
`);
  fs.writeFileSync(path.join(examplesDir, "discover-primitives.mjs"), `
import { loadPrimitiveSdk } from "./lib/primitive-sdk-loader.mjs";
if (process.argv.includes("--self-test")) {}
`);
  fs.mkdirSync(path.join(examplesDir, "fixtures"), { recursive: true });
  fs.writeFileSync(path.join(examplesDir, "primitive-workbench-walkthrough.mjs"), `
import { loadPrimitiveSdk } from "./lib/primitive-sdk-loader.mjs";
const operationListHelper = "listPrimitiveOperations";
const proofPlanHelper = "buildPrimitiveProofPlan";
const fixture = "examples/primitives/fixtures/workbench-catalog.json";
if (process.argv.includes("--self-test")) {}
`);
  fs.writeFileSync(path.join(examplesDir, "operation-id-client.mjs"), `
import { loadPrimitiveSdk, createPrimitiveExampleOperationClient } from "./lib/primitive-sdk-loader.mjs";
const operationListHelper = "listPrimitiveOperations";
function describeOperation() {}
function listOperations() {}
const call = "requestOperation";
const usage = "--timeout-ms --side-effect --read-only";
const fixture = "examples/primitives/fixtures/workbench-catalog.json";
if (process.argv.includes("--self-test")) {}
`);
  for (const file of ["agent-attention-queue.mjs", "restore-my-desk.mjs", "window-hotkey-router.mjs"]) {
    fs.writeFileSync(path.join(examplesDir, file), `
import { createPrimitiveExampleOperations } from "./lib/primitive-sdk-loader.mjs";
if (process.argv.includes("--self-test")) {}
const usage = "--timeout-ms";
`);
  }
  const good = auditPrimitiveExamples(examplesDir);
  assert.equal(good.ok, true, good.errors.join("; "));
  const workbenchPath = path.join(examplesDir, "primitive-workbench-walkthrough.mjs");
  const originalWorkbench = fs.readFileSync(workbenchPath, "utf8");
  fs.appendFileSync(workbenchPath, "\nconst staleIndexHelper = \"buildPrimitiveApiIndex\";\n");
  const staleIndex = auditPrimitiveExamples(examplesDir);
  assert.equal(staleIndex.ok, false);
  assert.ok(
    staleIndex.errors.some((error) => error.includes("must not rebuild workbench routes from the compact API index")),
    staleIndex.errors.join("; ")
  );
  fs.writeFileSync(workbenchPath, originalWorkbench);
  fs.appendFileSync(path.join(examplesDir, "agent-attention-queue.mjs"), "\nawait fetch('http://127.0.0.1');\n");
  const bad = auditPrimitiveExamples(examplesDir);
  assert.equal(bad.ok, false);
  assert.ok(bad.errors.includes("agent-attention-queue.mjs must not hand-roll fetch calls"));
  fs.rmSync(root, { recursive: true, force: true });
  console.log("primitives-examples-audit self-test passed");
}
