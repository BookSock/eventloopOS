aerospace list-workspaces --focused >"\$capture_dir/focused-workspace-before-gui-screencapture.txt" 2>"\$capture_dir/focused-workspace-before-gui-screencapture.err" || true
screencapture -x "\$capture_dir/screen.png" >"\$capture_dir/gui-screencapture.out" 2>"\$capture_dir/gui-screencapture.err" || true
aerospace list-workspaces --focused >"\$capture_dir/focused-workspace-after-capture.txt" 2>"\$capture_dir/focused-workspace-after-capture.err" || true
if [[ "\$video_seconds" =~ ^[0-9]+$ && "\$video_seconds" -gt 0 ]]; then
  screencapture -x -v -V "\$video_seconds" "\$capture_dir/screen.mov" >"\$capture_dir/gui-screenrecord.out" 2>"\$capture_dir/gui-screenrecord.err" || true
fi
date -u +%Y-%m-%dT%H:%M:%SZ >"\$capture_dir/gui-screencapture.done"
printf "gui capture runner exited cleanly; cleanup closes non-busy Terminal windows later\n" >"\$capture_dir/gui-terminal-close.out"
EOF
  chmod +x "$gui_runner"
  rm -f "$capture_dir/gui-screencapture.done"
  open -a Terminal "$gui_runner" >"$capture_dir/gui-runner-open.out" 2>"$capture_dir/gui-runner-open.err" || true
  for _ in {1..60}; do
    [[ -f "$capture_dir/gui-screencapture.done" ]] && break
    sleep 1
  done
  gui_screen_bytes="0"
  gui_screen_sha=""
  gui_screen_dimensions=""
  gui_video_bytes="0"
  if [[ -f "$capture_dir/screen.png" ]]; then
    gui_screen_bytes="$(wc -c <"$capture_dir/screen.png" | tr -d ' ')"
    gui_screen_sha="$(shasum -a 256 "$capture_dir/screen.png" | awk '{print $1}')"
    gui_screen_dimensions="$(sips -g pixelWidth -g pixelHeight "$capture_dir/screen.png" 2>/dev/null | awk '/pixelWidth|pixelHeight/ {print $2}' | paste -sd x -)"
  fi
  if [[ -f "$capture_dir/screen.mov" ]]; then
    gui_video_bytes="$(wc -c <"$capture_dir/screen.mov" | tr -d ' ')"
  fi
  if [[ "$inject_accessibility_denied" != "1" ]]; then
    for ax_artifact in queue-menu-items queue-ax-summary queue-ax-tree; do
      if [[ -s "$capture_dir/gui-${ax_artifact}.txt" ]]; then
        cp "$capture_dir/gui-${ax_artifact}.txt" "$capture_dir/${ax_artifact}.txt"
        cp "$capture_dir/gui-${ax_artifact}.err" "$capture_dir/${ax_artifact}.err"
      fi
    done
  fi
  CAPTURE_DIR="$capture_dir" \
  SCREEN_BYTES="$gui_screen_bytes" \
  SCREEN_SHA="$gui_screen_sha" \
  SCREEN_DIMENSIONS="$gui_screen_dimensions" \
  VIDEO_BYTES="$gui_video_bytes" \
  node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const file = path.join(process.env.CAPTURE_DIR, "capture-summary.json");
const summary = JSON.parse(fs.readFileSync(file, "utf8"));
const read = (name) => {
  try {
    return fs.readFileSync(path.join(process.env.CAPTURE_DIR, name), "utf8").trim();
  } catch {
    return "";
  }
};
const parseJson = (name, fallback) => {
  try {
    return JSON.parse(read(name));
  } catch {
    return fallback;
  }
};
summary.screen = {
  ...summary.screen,
  bytes: Number(process.env.SCREEN_BYTES ?? 0),
  sha256: process.env.SCREEN_SHA ?? "",
  dimensions: process.env.SCREEN_DIMENSIONS ?? "",
  capture_mode: "gui_terminal_runner",
  error: [
    read("screencapture.err"),
    read("gui-screencapture.err"),
  ].filter(Boolean).join("\n"),
};
if (summary.screen.bytes > 0) {
  summary.screen.error = "";
  summary.screen.failure_hint = "";
}
summary.video = {
  ...summary.video,
  bytes: Number(process.env.VIDEO_BYTES ?? 0),
  error: [
    read("screenrecord.err"),
    read("gui-screenrecord.err"),
  ].filter(Boolean).join("\n"),
};
const windows = parseJson("windows.json", []);
const systemEventWindows = parseJson("windows-system-events.json", []);
const processes = read("processes-interesting.txt");
const queueMenu = read("queue-menu-items.txt");
const axSummary = read("queue-ax-summary.txt");
const axTree = read("queue-ax-tree.txt");
const axWindowCount = Number(axSummary.match(/(?:^|\n)windows=([0-9]+)/)?.[1] ?? 0);
const axWindowTitles = axSummary.match(/(?:^|\n)window_titles=(.*)$/)?.[1] ?? "";
const paperReminderHudWindowCount = Array.isArray(windows)
  ? windows.filter((window) => String(window["window-title"] ?? "") === "eventloopOS Paper Reminder").length
  : 0;
summary.queue_app = {
  ...summary.queue_app,
  process_present: /EventLoopQueueApp|eventloopOS Queue/.test(processes),
  aerospace_window_count: Array.isArray(windows)
    ? windows.filter((window) => /eventloop|queue/i.test(String(window["app-name"] ?? ""))).length
    : 0,
  system_events_window_count: Array.isArray(systemEventWindows)
    ? systemEventWindows.filter((window) => /eventloop|queue/i.test(String(window["app-name"] ?? ""))).length
    : 0,
  ax_window_count: axWindowCount,
  ax_window_titles: axWindowTitles,
  ax_window_title_present: /eventloopOS Queue/i.test(axWindowTitles),
  paper_reminder_hud_present: paperReminderHudWindowCount > 0 || axWindowTitles.includes("eventloopOS Paper Reminder"),
  paper_reminder_hud_window_count: paperReminderHudWindowCount,
  menu_items_present: queueMenu.includes("Pull Next Paper") && queueMenu.includes("Master Command"),
  ax_summary_present: /process=(EventLoopQueueApp|eventloopOS Queue)/.test(axSummary),
  ax_tree_present: axTree.includes("AXWindow") || axTree.includes("window"),
  ax_tree_bytes: Buffer.byteLength(axTree),
  harness_status_present: /queue-harness-status|eventloopOS harness status/.test(axTree),
  harness_status_line: axTree.split(/\r?\n/).find((line) => /queue-harness-status|eventloopOS harness status/.test(line)) ?? "",
  accessibility_error: [
    read("windows-system-events.err"),
    read("frontmost-app.err"),
    read("queue-menu-items.err"),
    read("queue-ax-summary.err"),
    read("queue-ax-tree.err"),
  ].filter(Boolean).join("\n"),
};
summary.gui_fallback = {
  used: true,
  done: fs.existsSync(path.join(process.env.CAPTURE_DIR, "gui-screencapture.done")),
  terminal_minimize: read("gui-terminal-minimize.out"),
  terminal_minimize_error: read("gui-terminal-minimize.err"),
  demo_raise: read("gui-demo-raise.out"),
  demo_raise_error: read("gui-demo-raise.err"),
  target_workspace: read("target-workspace.txt"),
  target_workspace_after_gui_switch: read("gui-target-workspace.out"),
  target_workspace_error: read("gui-target-workspace.err"),
  focused_workspace_before_gui_screencapture: read("focused-workspace-before-gui-screencapture.txt"),
  focused_workspace_after_capture: read("focused-workspace-after-capture.txt"),
};
fs.writeFileSync(file, `${JSON.stringify(summary, null, 2)}\n`);
NODE
  terminal_counts="$(run_osascript_with_timeout 5 <<'APPLESCRIPT' 2>/dev/null || true
tell application "Terminal"
  set totalWindows to count of windows
  set captureWindows to 0
  repeat with candidateWindow in windows
    try
      if (name of candidateWindow as string) contains "gui-screencapture.command" then set captureWindows to captureWindows + 1
    end try
  end repeat
end tell
return (totalWindows as string) & " " & (captureWindows as string)
APPLESCRIPT
)"
  terminal_total="$(printf "%s" "$terminal_counts" | awk '{print $1+0}')"
  terminal_capture="$(printf "%s" "$terminal_counts" | awk '{print $2+0}')"
  if [[ "$terminal_total" -gt 0 && "$terminal_total" -eq "$terminal_capture" ]]; then
    pkill -x Terminal >/dev/null 2>&1 || true
    printf "killed %s capture-only Terminal windows\n" "$terminal_capture" >"$capture_dir/gui-terminal-kill.out"
  elif [[ "$terminal_capture" -gt 0 ]]; then
    printf "left %s capture Terminal windows because %s total Terminal windows exist\n" "$terminal_capture" "$terminal_total" >"$capture_dir/gui-terminal-kill.out"
  fi
elif [[ "$screen_bytes" == "0" && "$terminal_screen_capture_tcc" == "denied" ]]; then
  CAPTURE_DIR="$capture_dir" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const file = path.join(process.env.CAPTURE_DIR, "capture-summary.json");
const summary = JSON.parse(fs.readFileSync(file, "utf8"));
summary.gui_fallback = {
  used: false,
  skipped_reason: "Terminal is denied kTCCServiceScreenCapture; opening a GUI Terminal runner would create stale windows without fixing capture.",
};
fs.writeFileSync(file, `${JSON.stringify(summary, null, 2)}\n`);
NODE
fi

