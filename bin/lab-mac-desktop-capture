osascript >"\$capture_dir/gui-queue-ax-summary.txt" 2>"\$capture_dir/gui-queue-ax-summary.err" <<'APPLESCRIPT' || true
tell application "System Events"
  if not (exists process "eventloopOS Queue") then error "eventloopOS Queue process not found"
