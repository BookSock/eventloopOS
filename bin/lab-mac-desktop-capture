osascript >"\$capture_dir/gui-queue-ax-tree.txt" 2>"\$capture_dir/gui-queue-ax-tree.err" <<'APPLESCRIPT' || true
tell application "System Events"
  if not (exists process "eventloopOS Queue") then error "eventloopOS Queue process not found"
  tell process "eventloopOS Queue"
    set allLines to {}
    set windowCount to count of windows
    if windowCount is greater than 3 then set windowCount to 3
    repeat with windowIndex from 1 to windowCount
      set candidateWindow to window windowIndex
      set end of allLines to "window role=" & ((role of candidateWindow) as string) & " name=" & ((name of candidateWindow) as string)
      try
        set flattenedElements to entire contents of candidateWindow
        set elementCount to count of flattenedElements
        if elementCount is greater than 160 then set elementCount to 160
        repeat with elementIndex from 1 to elementCount
          set candidateElement to item elementIndex of flattenedElements
          set roleText to ""
          set nameText to ""
          set descriptionText to ""
          set valueText to ""
          try
            set roleText to role of candidateElement as string
          end try
          try
            set nameText to name of candidateElement as string
          end try
          try
            set descriptionText to description of candidateElement as string
          end try
          try
            set valueText to value of candidateElement as string
          end try
          set end of allLines to "element role=" & roleText & " name=" & nameText & " description=" & descriptionText & " value=" & valueText
        end repeat
      end try
    end repeat
  end tell
end tell
set AppleScript's text item delimiters to linefeed
return allLines as string
APPLESCRIPT
fi
osascript >"\$capture_dir/gui-terminal-minimize.out" 2>"\$capture_dir/gui-terminal-minimize.err" <<'APPLESCRIPT' || true
