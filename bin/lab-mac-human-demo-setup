#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/lab-mac-human-demo-setup [--skip-screenshot]

Prepare Mac Studio for a hands-on eventloopOS human UX walkthrough.

Environment:
  LAB_MAC_HOST           default: 100.71.111.25
  LAB_MAC_USER           default: claw
  LAB_MAC_KEY            default: ~/.ssh/eventloop_lab_mac
  LAB_MAC_EVENTLOOP_PATH default: ~/dev/2026/eventloopOS
  LAB_DOGFOOD_PROFILE    default: lab-human-demo
  LAB_DOGFOOD_URL        default: http://127.0.0.1:4480
  SCREEN_SHARING_TITLE   default: Zeus
  EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET default: lab (lab|auto|local)
  EVENTLOOPOS_ALLOW_LOCAL_SCREEN_SHARING_CAPTURE default: 0; set 1 before any local Screen Sharing capture.
EOF
}

skip_screenshot=0
case "${1:-}" in
  "")
    ;;
  --skip-screenshot)
    skip_screenshot=1
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    echo "unknown argument: $1" >&2
    usage >&2
    exit 2
    ;;
esac

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

lab_host="${LAB_MAC_HOST:-100.71.111.25}"
lab_user="${LAB_MAC_USER:-claw}"
lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
eventloop_path="${LAB_MAC_EVENTLOOP_PATH:-~/dev/2026/eventloopOS}"
profile="${LAB_DOGFOOD_PROFILE:-lab-human-demo}"
url="${LAB_DOGFOOD_URL:-http://127.0.0.1:4480}"
screenshot_target="${EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET:-lab}"
allow_local_screen_sharing_capture="${EVENTLOOPOS_ALLOW_LOCAL_SCREEN_SHARING_CAPTURE:-0}"
remote="${lab_user}@${lab_host}"
run_dir="artifacts/lab-runs/$(date +%Y%m%d-%H%M%S)-human-demo"
manifest="$run_dir/manifest.json"

case "$profile" in
  ""|*[!A-Za-z0-9_.-]*)
    echo "unsafe LAB_DOGFOOD_PROFILE: $profile" >&2
    exit 2
    ;;
esac

case "$screenshot_target" in
  lab|auto|local)
    ;;
  *)
    echo "invalid EVENTLOOPOS_HUMAN_DEMO_SCREENSHOT_TARGET: $screenshot_target (use lab, auto, or local)" >&2
    exit 2
    ;;
esac

case "$eventloop_path" in
  "~"/*) remote_repo="/Users/$lab_user/${eventloop_path#"~/"}" ;;
  "~") remote_repo="/Users/$lab_user" ;;
  *) remote_repo="$eventloop_path" ;;
esac

ssh_opts=(-i "$lab_key" -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8)

ssh_remote() {
  ssh "${ssh_opts[@]}" "$remote" "$@"
}

sync_remote_artifact() {
  local remote_path="$1"
  local local_path="$2"
  mkdir -p "$(dirname "$local_path")"
  rsync -az -e "ssh -i '$lab_key' -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8" \
    "$remote:$remote_repo/$remote_path" "$local_path" >/dev/null
}

sync_remote_dir() {
  local remote_path="$1"
  local local_path="$2"
  mkdir -p "$local_path"
  rsync -az -e "ssh -i '$lab_key' -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8" \
    "$remote:$remote_repo/${remote_path%/}/" "$local_path/" >/dev/null
}

ensure_aerospace_ready() {
  ssh_remote "bash -lc 'set -euo pipefail
export PATH=\"/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\$PATH\"
cd \"$remote_repo\"
for attempt in {1..12}; do
  if aerospace list-workspaces --focused >/dev/null 2>&1; then
    aerospace reload-config >/dev/null 2>&1 || true
    exit 0
  fi
  sleep 1
done
self_heal_out=\"artifacts/lab-runs/human-demo-aerospace-self-heal.out\"
self_heal_err=\"artifacts/lab-runs/human-demo-aerospace-self-heal.err\"
mkdir -p artifacts/lab-runs
LAB_SELF_HEAL_SKIP_TAILSCALE_UP=1 bin/lab-mac-self-heal run >\"\$self_heal_out\" 2>\"\$self_heal_err\" || true
for attempt in {1..18}; do
  if aerospace list-workspaces --focused >/dev/null 2>&1; then
    aerospace reload-config >/dev/null 2>&1 || true
    exit 0
  fi
  sleep 1
done
echo \"AeroSpace server was not reachable after self-heal\" >&2
printf \"\\n== self-heal stdout ==\\n\" >&2
tail -n 120 \"\$self_heal_out\" >&2 || true
printf \"\\n== self-heal stderr ==\\n\" >&2
tail -n 120 \"\$self_heal_err\" >&2 || true
printf \"\\n== process list ==\\n\" >&2
pgrep -fl \"AeroSpace.app/Contents/MacOS/AeroSpace|AeroSpaceApp|run-aerospace\" >&2 || true
exit 1
'"
}

capture_local_screen_sharing() {
  if [[ "$allow_local_screen_sharing_capture" != "1" ]]; then
    echo "local Screen Sharing capture skipped: set EVENTLOOPOS_ALLOW_LOCAL_SCREEN_SHARING_CAPTURE=1 to opt in" >&2
    printf "%s\n" "skipped_not_opted_in" >"$run_dir/screen-sharing.exit"
    return 1
  fi
  echo "human demo local Screen Sharing capture"
  set +e
  SCREEN_SHARING_TITLE="${SCREEN_SHARING_TITLE:-Zeus}" \
    SCREEN_SHARING_RAISE=0 \
    EVENTLOOPOS_SCREEN_SHARING_RAISE=0 \
    SCREEN_SHARING_CAPTURE_ENGINE=coregraphics \
    SCREEN_SHARING_ASSERT_NO_FOCUS=1 \
    bin/local-screen-sharing-capture "$run_dir/screen-sharing.png" >"$run_dir/screen-sharing.out" 2>"$run_dir/screen-sharing.err"
  screenshot_exit=$?
  set -e
  printf "%s\n" "$screenshot_exit" >"$run_dir/screen-sharing.exit"
  if [[ "$screenshot_exit" == "0" && -s "$run_dir/screen-sharing.png" ]]; then
    printf "%s\n" "local_screen_sharing_window" >"$run_dir/screen-sharing.mode"
    return 0
  fi
  return 1
}

capture_lab_desktop() {
  echo "human demo lab desktop screenshot"
  set +e
  bin/lab-mac-desktop-capture "$run_dir" human-demo-setup >"$run_dir/lab-desktop-capture.out" 2>"$run_dir/lab-desktop-capture.err"
  capture_exit=$?
  set -e
  remote_capture_path="$(tail -n 1 "$run_dir/lab-desktop-capture.out")"
  printf "%s\n" "$capture_exit" >"$run_dir/lab-desktop-capture.exit"
  if [[ "$capture_exit" == "0" && -n "$remote_capture_path" ]]; then
    sync_remote_dir "$remote_capture_path" "$run_dir/captures/human-demo-setup"
    if [[ -s "$run_dir/captures/human-demo-setup/screen.png" ]]; then
      cp "$run_dir/captures/human-demo-setup/screen.png" "$run_dir/screen-sharing.png"
      printf "%s\n" "lab_desktop" >"$run_dir/screen-sharing.mode"
      return 0
    fi
  fi
  return 1
}

mkdir -p "$run_dir"
printf "%s\n" "$remote" >"$run_dir/remote.txt"
printf "%s\n" "$remote_repo" >"$run_dir/remote-repo.txt"

echo "human demo sync: $remote:$remote_repo"
bin/lab-mac-sync

echo "human demo profile install"
ssh_remote "bash -lc 'set -euo pipefail; export PATH=\"/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\$PATH\"; cd \"$remote_repo\"; node bin/macos-aerospace-profile install; aerospace reload-config || true'"

echo "human demo dogfood restart"
LAB_DOGFOOD_PROFILE="$profile" LAB_DOGFOOD_URL="$url" bin/lab-mac-dogfood stop >/dev/null 2>&1 || true
LAB_DOGFOOD_PROFILE="$profile" LAB_DOGFOOD_URL="$url" bin/lab-mac-dogfood cleanup >/dev/null 2>&1 || true
ssh_remote "bash -lc 'set -euo pipefail; cd \"$remote_repo\"; rm -rf -- \".eventloopos/$profile\" \"app/orchestrator/.eventloopos/$profile\"'"
LAB_DOGFOOD_PROFILE="$profile" LAB_DOGFOOD_URL="$url" LAB_DOGFOOD_AMBIENT_SAVE=1 LAB_DOGFOOD_FOLLOWS_WINDOWS=1 bin/lab-mac-dogfood start
LAB_DOGFOOD_PROFILE="$profile" LAB_DOGFOOD_URL="$url" bin/lab-mac-dogfood wait-ready

echo "human demo AeroSpace ready"
ensure_aerospace_ready

remote_run="$run_dir/remote-demo-setup"
echo "human demo remote setup"
ssh_remote "bash -lc 'set -euo pipefail; export PATH=\"/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\$PATH\"; cd \"$remote_repo\"; EVENTLOOPOS_ORCHESTRATOR_URL=\"$url\" EVENTLOOPOS_HUMAN_DEMO_RUN=\"$remote_run\" node bin/macos-human-demo-setup'" | tee "$run_dir/setup.stdout.json"

sync_remote_artifact "$remote_run/manifest.json" "$manifest"

if [[ "$skip_screenshot" == "0" ]]; then
  case "$screenshot_target" in
    lab)
      capture_lab_desktop || true
      ;;
    local)
      capture_local_screen_sharing || true
      ;;
    auto)
      if [[ "$allow_local_screen_sharing_capture" == "1" ]]; then
        capture_local_screen_sharing || capture_lab_desktop || true
      else
        capture_lab_desktop || true
      fi
      ;;
  esac
fi

cat "$manifest"
