#!/usr/bin/env node
import { spawn } from "node:child_process";
import { mkdir, readFile, writeFile } from "node:fs/promises";
import path from "node:path";
import process from "node:process";

const repoRoot = path.resolve(import.meta.dirname, "..");
const runId = `${utcStamp()}-codex-status-proof`;
const artifactDir = path.resolve(process.env.CODEX_STATUS_ARTIFACT_DIR ?? path.join(repoRoot, "artifacts", "codex-status", runId));
const logsDir = path.join(artifactDir, "logs");
const manifestPath = path.join(artifactDir, "manifest.json");

await mkdir(logsDir, { recursive: true });

const commands = {
  version: await runCommand("codex", ["--version"]),
  loginStatus: await runCommand("codex", ["login", "status"]),
  doctorJson: await runCommand("codex", ["doctor", "--json"]),
};

const doctorStdout = await readText(commands.doctorJson.stdout_path);
let doctor;
try {
  doctor = JSON.parse(doctorStdout);
} catch (error) {
  doctor = undefined;
}

const checks = doctor?.checks ?? {};
const auth = checks["auth.credentials"];
const websocket = checks["network.websocket_reachability"] ?? checks["connectivity.websocket"];
const reachability = checks["network.provider_reachability"] ?? checks["connectivity.reachability"];
const config = checks["config.load"];
const install = checks.installation;
const appServer = checks["app_server.status"];
const versionText = commands.version.stdout.trim() || commands.version.stderr.trim();
const loginText = commands.loginStatus.stdout.trim() || commands.loginStatus.stderr.trim();
const failures = [];

const assertions = [
  assertion("codex_cli_available", commands.version.code === 0, "Install Codex CLI, then verify `codex --version` works."),
  assertion("codex_login_status_ok", commands.loginStatus.code === 0 && /Logged in|authenticated|API key/i.test(loginText), "Run `codex login` on this Mac and finish device/browser auth."),
  assertion("codex_doctor_json_ok", commands.doctorJson.code === 0 && Boolean(doctor), "Run `codex doctor --json`; fix any JSON/error output before dogfood."),
  assertion("codex_auth_configured", auth?.status === "ok", auth?.remediation ?? "Run `codex login` and confirm `codex doctor --json` shows auth.credentials status ok."),
  assertion("codex_websocket_reachable", websocket?.status === "ok", websocket?.remediation ?? "Verify network access to Codex/ChatGPT backend and rerun `codex doctor --json`."),
  assertion("codex_provider_reachable", !reachability || reachability.status === "ok", reachability?.remediation ?? "Verify OpenAI/ChatGPT provider endpoints are reachable from this Mac."),
  assertion("codex_install_consistent", !install || install.status === "ok", install?.remediation ?? "Repair Codex installation or run `codex update`."),
];

for (const item of assertions) {
  if (!item.ok) {
    failures.push({
      requirement: item.name,
      fix: item.fix,
    });
  }
}

const manifest = {
  schema_version: 1,
  kind: "eventloopos.codex_status_proof",
  run_id: path.basename(artifactDir),
  generated_at: new Date().toISOString(),
  artifact_dir: artifactDir,
  ok: failures.length === 0,
  codex_version: versionText,
  login_status: loginText,
  doctor_overall_status: doctor?.overallStatus,
  doctor_codex_version: doctor?.codexVersion,
  model: config?.details?.model,
  model_provider: config?.details?.["model provider"],
  auth_mode: auth?.details?.["stored auth mode"],
  app_server_status: appServer?.details?.status,
  assertions,
  failures,
  commands,
};

await writeFile(manifestPath, `${JSON.stringify(manifest, null, 2)}\n`, "utf8");
console.log(`codex status proof manifest: ${manifestPath}`);
console.log(JSON.stringify({
  ok: manifest.ok,
  codex_version: manifest.codex_version,
  doctor_overall_status: manifest.doctor_overall_status,
  model: manifest.model,
  model_provider: manifest.model_provider,
  auth_mode: manifest.auth_mode,
  failures: manifest.failures,
}, null, 2));

if (!manifest.ok) {
  process.exit(1);
}

function assertion(name, ok, fix) {
  return {
    name,
    ok: Boolean(ok),
    fix,
  };
}

async function readText(filePath) {
  try {
    return await readFile(filePath, "utf8");
  } catch {
    return "";
  }
}

async function runCommand(file, args) {
  const safe = [file, ...args].join(" ").replace(/[^A-Za-z0-9._-]+/g, "-").replace(/^-|-$/g, "").slice(0, 96);
  const stdoutPath = path.join(logsDir, `${safe}.stdout.log`);
  const stderrPath = path.join(logsDir, `${safe}.stderr.log`);
  const startedAt = new Date().toISOString();
  const result = await new Promise((resolve) => {
    const child = spawn(file, args, {
      cwd: repoRoot,
      env: {
        ...process.env,
        NO_COLOR: "1",
      },
      stdio: ["ignore", "pipe", "pipe"],
    });
    let stdout = "";
    let stderr = "";
    child.stdout.on("data", (chunk) => {
      stdout += chunk.toString();
    });
    child.stderr.on("data", (chunk) => {
      stderr += chunk.toString();
    });
    child.on("error", (error) => {
      resolve({
        code: 127,
        signal: undefined,
        stdout,
        stderr: `${stderr}${error.message}`,
      });
    });
    child.on("exit", (code, signal) => {
      resolve({
        code: code ?? 1,
        signal: signal ?? undefined,
        stdout,
        stderr,
      });
    });
  });
  const finishedAt = new Date().toISOString();
  await writeFile(stdoutPath, result.stdout, "utf8");
  await writeFile(stderrPath, result.stderr, "utf8");
  return {
    command: [file, ...args],
    code: result.code,
    signal: result.signal,
    started_at: startedAt,
    finished_at: finishedAt,
    duration_ms: Date.parse(finishedAt) - Date.parse(startedAt),
    stdout_path: stdoutPath,
    stderr_path: stderrPath,
    stdout: result.stdout.slice(0, 2000),
    stderr: result.stderr.slice(0, 2000),
  };
}

function utcStamp() {
  return new Date().toISOString().replaceAll("-", "").replaceAll(":", "").replace(/\.\d{3}Z$/, "Z");
}
