run_remote_postgres_unavailable() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
main_url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

fault_port="45991"
fault_url="http://127.0.0.1:$fault_port"
bad_database_url="postgres://eventloopos:eventloopos@127.0.0.1:1/eventloopos"
printf "%s\n" "$fault_url" >"$run/fault-url.txt"
printf "%s\n" "$bad_database_url" >"$run/bad-database-url.txt"

curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-before.json" 2>"$run/main-health-before.err" || true

(
  set +e
  EVENTLOOPOS_DOGFOOD_PROFILE="lab-postgres-unavailable-proof" \
  EVENTLOOPOS_ORCHESTRATOR_URL="$fault_url" \
  EVENTLOOPOS_DOGFOOD_POSTGRES=1 \
  DATABASE_URL="$bad_database_url" \
  EVENTLOOPOS_DOGFOOD_QUEUE_APP=0 \
  EVENTLOOPOS_DOGFOOD_REQUIRE_AEROSPACE=0 \
  EVENTLOOPOS_DOGFOOD_SHARED_CODEX_APP_SERVER=0 \
  ORCHESTRATOR_TASK_SESSIONS=fake \
  ORCHESTRATOR_MCP_SOURCES=off \
    pnpm run dev:dogfood >"$run/dogfood-postgres-unavailable.out" 2>"$run/dogfood-postgres-unavailable.err"
  printf "%s\n" "$?" >"$run/dogfood-postgres-unavailable.rc"
) &
dogfood_pid="$!"
printf "%s\n" "$dogfood_pid" >"$run/dogfood-postgres-unavailable.pid"

for _ in {1..45}; do
  if [[ -f "$run/dogfood-postgres-unavailable.rc" ]]; then
    break
  fi
  if ! kill -0 "$dogfood_pid" 2>/dev/null; then
    wait "$dogfood_pid" || true
    break
  fi
  sleep 1
done

if [[ ! -f "$run/dogfood-postgres-unavailable.rc" ]]; then
  kill -TERM "$dogfood_pid" 2>/dev/null || true
  sleep 2
  kill -KILL "$dogfood_pid" 2>/dev/null || true
  printf "124\n" >"$run/dogfood-postgres-unavailable.rc"
fi
wait "$dogfood_pid" 2>/dev/null || true

curl -fsS --max-time 5 "$fault_url/health" >"$run/fault-health-after.json" 2>"$run/fault-health-after.err" || true
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
lsof -nP -iTCP:"$fault_port" -sTCP:LISTEN >"$run/fault-port-listeners.txt" 2>"$run/fault-port-listeners.err" || true
pgrep -fl "lab-postgres-unavailable-proof|45991|127.0.0.1:1/eventloopos" >"$run/fault-processes-after.txt" 2>"$run/fault-processes-after.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const stdout = read("dogfood-postgres-unavailable.out");
const stderr = read("dogfood-postgres-unavailable.err");
const combinedLog = `${stdout}\n${stderr}`;
const rc = Number(read("dogfood-postgres-unavailable.rc"));
const actionable = /Postgres unavailable|migrations failed|DATABASE_URL|EVENTLOOPOS_DOGFOOD_POSTGRES=0|ECONNREFUSED|connect ECONNREFUSED|database/i.test(combinedLog);
const mainHealthBefore = json("main-health-before.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const assertions = [
  {
    name: "main_dogfood_healthy_before_fault",
    ok: mainHealthBefore?.ok === true,
    details: mainHealthBefore,
  },
  {
    name: "bad_postgres_dogfood_exits_nonzero",
    ok: Number.isFinite(rc) && rc !== 0,
    details: { exit_code: rc },
  },
  {
    name: "bad_postgres_error_is_actionable",
    ok: actionable,
    details: {
      stdout_tail: stdout.slice(-2000),
      stderr_tail: stderr.slice(-2000),
    },
  },
  {
    name: "bad_postgres_orchestrator_not_listening",
    ok: read("fault-port-listeners.txt").length === 0,
    details: { listeners: read("fault-port-listeners.txt") },
  },
  {
    name: "bad_postgres_fault_processes_cleaned_up",
    ok: read("fault-processes-after.txt").length === 0,
    details: { processes: read("fault-processes-after.txt") },
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_before: mainHealthBefore,
  main_health_after: mainHealthAfter,
  fault_health_after: json("fault-health-after.json", null),
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "run dogfood with Postgres mode and a closed DATABASE_URL on an isolated port",
    recovery: "dogfood exits nonzero with actionable setup text and main stack remains healthy",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    dogfood_stdout: "dogfood-postgres-unavailable.out",
    dogfood_stderr: "dogfood-postgres-unavailable.err",
    dogfood_exit_code: "dogfood-postgres-unavailable.rc",
    fault_port_listeners: "fault-port-listeners.txt",
    fault_processes_after: "fault-processes-after.txt",
  },
}, null, 2));
NODE
REMOTE
}

patch_postgres_unavailable_capture_manifest() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run'" <<'REMOTE'
set -euo pipefail
repo="$1"
run="$2"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
RUN="$run" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const manifestPath = path.join(run, "manifest.json");
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const readJson = (relative, fallback) => {
  try {
    return JSON.parse(fs.readFileSync(path.join(run, relative), "utf8"));
  } catch {
    return fallback;
  }
};
const before = readJson("captures/before/capture-summary.json", {});
const after = readJson("captures/after/capture-summary.json", {});
manifest.assertions.push(
  {
    name: "desktop_capture_after_nonempty",
    ok: Number(after?.screen?.bytes ?? 0) > 10000,
    details: after?.screen,
  },
);
manifest.ok = manifest.assertions.every((assertion) => assertion.ok);
manifest.captures = {
  before: "captures/before/capture-summary.json",
  after: "captures/after/capture-summary.json",
};
manifest.artifacts = {
  ...manifest.artifacts,
  screenshot_before: Number(before?.screen?.bytes ?? 0) > 0 ? "captures/before/screen.png" : undefined,
  screenshot_after: Number(after?.screen?.bytes ?? 0) > 0 ? "captures/after/screen.png" : undefined,
  windows_after: "captures/after/windows.json",
};
fs.writeFileSync(manifestPath, JSON.stringify(manifest, null, 2) + "\n");
NODE
REMOTE
}

run_postgres_unavailable() {
  ensure_stack
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  capture_desktop before
  run_remote_postgres_unavailable
  capture_desktop after
  patch_postgres_unavailable_capture_manifest
  sync_artifacts

  echo "$remote_run"
  jq '{ok, scenario, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

run_remote_postgres_migration_mismatch() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
main_url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

fault_port="45992"
postgres_port="45993"
postgres_container="eventloopos-postgres-migration-mismatch"
fault_url="http://127.0.0.1:$fault_port"
bad_migrations_dir="$PWD/$run/bad-migrations"
mkdir -p "$bad_migrations_dir"
cat >"$bad_migrations_dir/0001_bad_migration.sql" <<'SQL'
CREATE TABLE eventloopos_migration_fault (
  id text PRIMARY KEY,
  broken syntax
);
SQL
printf "%s\n" "$fault_url" >"$run/fault-url.txt"
printf "%s\n" "$bad_migrations_dir" >"$run/bad-migrations-dir.txt"

curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-before.json" 2>"$run/main-health-before.err" || true

if ! command -v docker >/dev/null 2>&1; then
  printf "docker missing; install/start Docker Desktop or provide a Postgres runtime before running postgres-migration-mismatch proof\n" >"$run/postgres-runtime-check.txt"
  printf "126\n" >"$run/dogfood-postgres-migration-mismatch.rc"
else
  printf "docker available\n" >"$run/postgres-runtime-check.txt"
  set +e
  EVENTLOOPOS_POSTGRES_CONTAINER="$postgres_container" \
  EVENTLOOPOS_POSTGRES_PORT="$postgres_port" \
    pnpm run dev:postgres:up >"$run/dev-postgres-up.out" 2>"$run/dev-postgres-up.err"
  postgres_up_rc="$?"
  printf "%s\n" "$postgres_up_rc" >"$run/dev-postgres-up.rc"
  set -e

  database_url="$(awk '/^postgres:\/\// { value=$0 } END { print value }' "$run/dev-postgres-up.out")"
  printf "%s\n" "$database_url" >"$run/database-url.txt"
  if [[ "$postgres_up_rc" == "0" && -n "$database_url" ]]; then
    (
      set +e
      EVENTLOOPOS_DOGFOOD_PROFILE="lab-postgres-migration-mismatch-proof" \
      EVENTLOOPOS_ORCHESTRATOR_URL="$fault_url" \
      EVENTLOOPOS_DOGFOOD_POSTGRES=1 \
      DATABASE_URL="$database_url" \
      EVENTLOOPOS_POSTGRES_MIGRATIONS_DIR="$bad_migrations_dir" \
      EVENTLOOPOS_DOGFOOD_QUEUE_APP=0 \
      EVENTLOOPOS_DOGFOOD_REQUIRE_AEROSPACE=0 \
      EVENTLOOPOS_DOGFOOD_SHARED_CODEX_APP_SERVER=0 \
      ORCHESTRATOR_TASK_SESSIONS=fake \
      ORCHESTRATOR_MCP_SOURCES=off \
        pnpm run dev:dogfood >"$run/dogfood-postgres-migration-mismatch.out" 2>"$run/dogfood-postgres-migration-mismatch.err"
      printf "%s\n" "$?" >"$run/dogfood-postgres-migration-mismatch.rc"
    ) &
    dogfood_pid="$!"
    printf "%s\n" "$dogfood_pid" >"$run/dogfood-postgres-migration-mismatch.pid"

    for _ in {1..60}; do
      if [[ -f "$run/dogfood-postgres-migration-mismatch.rc" ]]; then
        break
      fi
      if ! kill -0 "$dogfood_pid" 2>/dev/null; then
        wait "$dogfood_pid" || true
        break
      fi
      sleep 1
    done

    if [[ ! -f "$run/dogfood-postgres-migration-mismatch.rc" ]]; then
      kill -TERM "$dogfood_pid" 2>/dev/null || true
      sleep 2
      kill -KILL "$dogfood_pid" 2>/dev/null || true
      printf "124\n" >"$run/dogfood-postgres-migration-mismatch.rc"
    fi
    wait "$dogfood_pid" 2>/dev/null || true
  fi

  EVENTLOOPOS_POSTGRES_CONTAINER="$postgres_container" \
  EVENTLOOPOS_POSTGRES_PORT="$postgres_port" \
    pnpm run dev:postgres:down >"$run/dev-postgres-down.out" 2>"$run/dev-postgres-down.err" || true
fi

curl -fsS --max-time 5 "$fault_url/health" >"$run/fault-health-after.json" 2>"$run/fault-health-after.err" || true
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
lsof -nP -iTCP:"$fault_port" -sTCP:LISTEN >"$run/fault-port-listeners.txt" 2>"$run/fault-port-listeners.err" || true
pgrep -fl "lab-postgres-migration-mismatch-proof|45992|45993|eventloopos-postgres-migration-mismatch" >"$run/fault-processes-after.txt" 2>"$run/fault-processes-after.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const stdout = read("dogfood-postgres-migration-mismatch.out");
const stderr = read("dogfood-postgres-migration-mismatch.err");
const combinedLog = `${stdout}\n${stderr}`;
const rc = Number(read("dogfood-postgres-migration-mismatch.rc"));
const dockerAvailable = /docker available/.test(read("postgres-runtime-check.txt"));
const postgresStarted = read("dev-postgres-up.rc") === "0" && read("database-url.txt").startsWith("postgres://");
const actionable = /Postgres unavailable|migrations failed|EVENTLOOPOS_POSTGRES_MIGRATIONS_DIR|DATABASE_URL|syntax error|broken syntax|migration/i.test(combinedLog);
const mainHealthBefore = json("main-health-before.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const assertions = [
  {
    name: "main_dogfood_healthy_before_fault",
    ok: mainHealthBefore?.ok === true,
    details: mainHealthBefore,
  },
  {
    name: "postgres_runtime_available",
    ok: dockerAvailable,
    details: {
      runtime_check: read("postgres-runtime-check.txt"),
      fix: "Install/start Docker Desktop on the lab Mac, or provide another Postgres runtime, then rerun bin/lab-mac-fault-proof postgres-migration-mismatch.",
    },
  },
  {
    name: "isolated_postgres_started",
    ok: postgresStarted,
    details: {
      dev_postgres_up_rc: read("dev-postgres-up.rc"),
      dev_postgres_up_stdout_tail: read("dev-postgres-up.out").slice(-1000),
      dev_postgres_up_stderr_tail: read("dev-postgres-up.err").slice(-1000),
    },
  },
  {
    name: "bad_migration_dogfood_exits_nonzero",
    ok: Number.isFinite(rc) && rc !== 0 && rc !== 126,
    details: { exit_code: rc },
  },
  {
    name: "bad_migration_error_is_actionable",
    ok: actionable,
    details: {
      stdout_tail: stdout.slice(-2000),
      stderr_tail: stderr.slice(-2000),
    },
  },
  {
    name: "bad_migration_orchestrator_not_listening",
    ok: read("fault-port-listeners.txt").length === 0,
    details: { listeners: read("fault-port-listeners.txt") },
  },
  {
    name: "bad_migration_fault_processes_cleaned_up",
    ok: read("fault-processes-after.txt").length === 0,
    details: { processes: read("fault-processes-after.txt") },
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_before: mainHealthBefore,
  main_health_after: mainHealthAfter,
  fault_health_after: json("fault-health-after.json", null),
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "run dogfood with Postgres mode and a deliberately broken migration directory on an isolated port",
    recovery: "dogfood exits nonzero with actionable migration text and main stack remains healthy",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    bad_migrations_dir: "bad-migrations",
    dev_postgres_up_stdout: "dev-postgres-up.out",
    dev_postgres_up_stderr: "dev-postgres-up.err",
    dogfood_stdout: "dogfood-postgres-migration-mismatch.out",
    dogfood_stderr: "dogfood-postgres-migration-mismatch.err",
    dogfood_exit_code: "dogfood-postgres-migration-mismatch.rc",
    fault_port_listeners: "fault-port-listeners.txt",
    fault_processes_after: "fault-processes-after.txt",
  },
}, null, 2));
NODE
REMOTE
}

run_postgres_migration_mismatch() {
  ensure_stack
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  capture_desktop before
  run_remote_postgres_migration_mismatch
  capture_desktop after
  patch_postgres_unavailable_capture_manifest
  sync_artifacts

  echo "$remote_run"
  jq '{ok, scenario, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

run_remote_aerospace_unavailable() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
main_url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
