pgrep -fl "lab-aerospace-unavailable-proof|45992" >"$run/fault-processes-after.txt" 2>"$run/fault-processes-after.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

