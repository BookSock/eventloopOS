#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/lab-mac-fault-proof [codex-app-server-down|orchestrator-crash-restart|duplicate-idempotency|postgres-unavailable|postgres-migration-mismatch|aerospace-unavailable|aerospace-permission-missing|ghostty-cleanup-failure|screen-capture-denied|queue-app-accessibility-denied|aerospace-restore-server-down]

Run a lab-safe fault injection proof on the remote Mac. The proof captures API,
process, window, and screenshot artifacts, then restores the dogfood stack.

Environment:
  LAB_MAC_HOST              default: 100.71.111.25
  LAB_MAC_USER              default: claw
  LAB_MAC_KEY               default: ~/.ssh/eventloop_lab_mac
  LAB_DOGFOOD_URL           default: http://127.0.0.1:4480
  LAB_DOGFOOD_POSTGRES      default: 0
  LAB_FAULT_RESTART_STACK   default: 1; restart first to pick up synced code
EOF
}

scenario="${1:-codex-app-server-down}"
case "$scenario" in
  codex-app-server-down|orchestrator-crash-restart|duplicate-idempotency|postgres-unavailable|postgres-migration-mismatch|aerospace-unavailable|aerospace-permission-missing|ghostty-cleanup-failure|screen-capture-denied|queue-app-accessibility-denied|aerospace-restore-server-down) ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    echo "unknown fault scenario: $scenario" >&2
    usage >&2
    exit 2
    ;;
esac

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

lab_host="${LAB_MAC_HOST:-100.71.111.25}"
lab_user="${LAB_MAC_USER:-claw}"
lab_key="${LAB_MAC_KEY:-$HOME/.ssh/eventloop_lab_mac}"
url="${LAB_DOGFOOD_URL:-http://127.0.0.1:4480}"
postgres="${LAB_DOGFOOD_POSTGRES:-0}"
restart_first="${LAB_FAULT_RESTART_STACK:-1}"
remote="${lab_user}@${lab_host}"
remote_repo="/Users/$lab_user/dev/2026/eventloopOS"
run_id="$(date +%Y%m%d-%H%M%S)-lab-fault-$scenario"
remote_run="artifacts/lab-runs/$run_id"
ssh_opts=(-i "$lab_key" -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8)
recover_needed=0

ssh_remote() {
  ssh "${ssh_opts[@]}" "$remote" "$@"
}

wait_for_health() {
  for _ in {1..90}; do
    if ssh_remote "curl -fsS --max-time 3 '$url/health' >/dev/null 2>&1"; then
      return 0
    fi
    sleep 2
  done
  echo "orchestrator did not become healthy at $url" >&2
  return 1
}

ensure_stack() {
  if ssh_remote "curl -fsS --max-time 3 '$url/health' >/dev/null 2>&1"; then
    return 0
  fi
  LAB_MAC_HOST="$lab_host" \
  LAB_MAC_USER="$lab_user" \
  LAB_MAC_KEY="$lab_key" \
  LAB_DOGFOOD_URL="$url" \
  LAB_DOGFOOD_REAL_CODEX=1 \
  LAB_DOGFOOD_POSTGRES="$postgres" \
  bin/lab-mac-dogfood start
  wait_for_health
}

restart_stack() {
  LAB_MAC_HOST="$lab_host" \
  LAB_MAC_USER="$lab_user" \
  LAB_MAC_KEY="$lab_key" \
  LAB_DOGFOOD_URL="$url" \
  bin/lab-mac-dogfood stop >/dev/null || true
  LAB_MAC_HOST="$lab_host" \
  LAB_MAC_USER="$lab_user" \
  LAB_MAC_KEY="$lab_key" \
  LAB_DOGFOOD_URL="$url" \
  LAB_DOGFOOD_REAL_CODEX=1 \
  LAB_DOGFOOD_POSTGRES="$postgres" \
  bin/lab-mac-dogfood start >/dev/null
  wait_for_health
}

restore_if_needed() {
  if [[ "$recover_needed" == "1" ]]; then
    echo "restoring dogfood stack after fault proof" >&2
    restart_stack >/dev/null 2>&1 || true
  fi
}
trap restore_if_needed EXIT

capture_desktop() {
  local label="$1"
  LAB_MAC_HOST="$lab_host" \
  LAB_MAC_USER="$lab_user" \
  LAB_MAC_KEY="$lab_key" \
  LAB_DOGFOOD_URL="$url" \
  bin/lab-mac-desktop-capture "$remote_run" "$label" >/dev/null
}

sync_artifacts() {
  mkdir -p "$remote_run"
  rsync -az -e "ssh -i '$lab_key' -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=15 -o ServerAliveCountMax=8" \
    "$remote:$remote_repo/$remote_run/" "$remote_run/"
}

run_remote_fault() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run/api/before" "$run/api/after_fault"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

json_endpoint() {
  local phase="$1"
  local endpoint="$2"
  local output_name
  output_name="$(printf "%s" "$endpoint" | tr '?/=&' '____')"
  curl -fsS --max-time 10 "$url/$endpoint" >"$run/api/$phase/$output_name.json" 2>"$run/api/$phase/$output_name.err" || true
}

collect_api_state() {
  local phase="$1"
  mkdir -p "$run/api/$phase"
  for endpoint in health metrics "activity?limit=120" "task-sessions" "task-messages?limit=120" "queue?state=ready" tasks; do
    json_endpoint "$phase" "$endpoint"
  done
}

post_json_allow_error() {
  local path="$1"
  local body_file="$2"
  local output_file="$3"
  local status_file="$4"
  local idempotency_key="$5"
  local tmp
  tmp="$(mktemp)"
  set +e
  status="$(curl -sS --max-time 60 -o "$tmp" -w "%{http_code}" \
    -H "content-type: application/json" \
    -H "idempotency-key: $idempotency_key" \
    -d @"$body_file" \
    "$url$path" 2>"$output_file.err")"
  code=$?
  set -e
  mv "$tmp" "$output_file"
  printf "%s\n" "$status" >"$status_file"
  printf "%s\n" "$code" >"$status_file.curl_rc"
}

collect_api_state before
pgrep -fl "[c]odex app-server" >"$run/codex-app-server-before.txt" 2>"$run/codex-app-server-before.err" || true

stamp="$(date +%Y%m%d%H%M%S)"
task_id="task_lab_fault_${scenario//-/_}_$stamp"
start_key="lab-fault-$scenario-start-$stamp"
followup_key="lab-fault-$scenario-followup-$stamp"
printf "%s\n" "$task_id" >"$run/task-id.txt"
printf "%s\n" "$followup_key" >"$run/followup-idempotency-key.txt"

cat >"$run/start-request.json" <<JSON
{
  "task_id": "$task_id",
  "prompt": "eventloopOS fault proof setup $stamp. Reply exactly: eventloopos-lab-fault-setup-ok.",
  "cwd": "$repo",
  "idempotency_key": "$start_key",
  "queue_paper": true
}
JSON
post_json_allow_error "/task-sessions" "$run/start-request.json" "$run/start-response.json" "$run/start-response.status" "$start_key"
task_session_id="$(jq -r '.started.task_session_id // empty' "$run/start-response.json" 2>/dev/null || true)"
printf "%s\n" "$task_session_id" >"$run/task-session-id.txt"

pkill -TERM -f "[c]odex app-server" 2>/dev/null || true
sleep 2
pkill -KILL -f "[c]odex app-server" 2>/dev/null || true
pgrep -fl "[c]odex app-server" >"$run/codex-app-server-after-kill.txt" 2>"$run/codex-app-server-after-kill.err" || true
curl -fsS --max-time 5 "$url/health" >"$run/health-after-fault.json" 2>"$run/health-after-fault.err" || true

if [[ -n "$task_session_id" ]]; then
  set +e
  EVENTLOOPOS_TASK_SESSION_SKIP_BUILD=1 bin/task-session followup \
    --base-url "$url" \
    --session "$task_session_id" \
    --event "evt_${task_id}_fault" \
    --idempotency-key "$followup_key" \
    "This followup should fail clearly because the Codex app-server was killed by the lab fault proof." \
    >"$run/followup-response.json" 2>"$run/followup-response.err"
  printf "%s\n" "$?" >"$run/followup-response.rc"
  set -e
else
  printf '{}\n' >"$run/followup-response.json"
  printf '1\n' >"$run/followup-response.rc"
fi

collect_api_state after_fault
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const start = json("start-response.json", {});
const followup = json("followup-response.json", {});
const taskMessages = json("api/after_fault/task-messages_limit_120.json", { messages: [] });
const activity = json("api/after_fault/activity_limit_120.json", { events: [] });
const health = json("health-after-fault.json", {});
const followupKey = read("followup-idempotency-key.txt");
const taskSessionId = read("task-session-id.txt");
const taskId = read("task-id.txt");
const messages = Array.isArray(taskMessages.messages) ? taskMessages.messages : [];
const events = Array.isArray(activity.events) ? activity.events : [];
const failedMessage = messages.find((message) => message.idempotency_key === followupKey);
const errorText = String(followup?.message?.error ?? failedMessage?.error ?? "");
const actionableError = /codex app-server|app-server|stream|websocket|closed|process|timed out|unavailable/i.test(errorText);
const assertions = [
  {
    name: "task_session_started_before_fault",
    ok: start?.ok === true && Boolean(taskSessionId),
    details: { task_id: taskId, task_session_id: taskSessionId, http_status: read("start-response.status") },
  },
  {
    name: "codex_app_server_process_present_before_fault",
    ok: read("codex-app-server-before.txt").length > 0,
    details: { before: read("codex-app-server-before.txt") },
  },
  {
    name: "codex_app_server_process_absent_after_fault",
    ok: read("codex-app-server-after-kill.txt").length === 0,
    details: { after: read("codex-app-server-after-kill.txt") },
  },
  {
    name: "orchestrator_stays_healthy_after_codex_fault",
    ok: health?.ok === true,
    details: health,
  },
  {
    name: "followup_returns_failed_message_not_crash",
    ok: followup?.ok === true && followup?.message?.status === "failed",
    details: followup?.message ?? followup,
  },
  {
    name: "failed_followup_has_actionable_error_text",
    ok: actionableError,
    details: { error: errorText },
  },
  {
    name: "failed_followup_is_durable",
    ok: failedMessage?.status === "failed",
    details: failedMessage,
  },
  {
    name: "activity_shows_failed_followup",
    ok: events.some((event) => event.type === "task_followup_failed" && event.task_session_id === taskSessionId),
    details: events
      .filter((event) => event.task_session_id === taskSessionId)
      .map((event) => ({
        type: event.type,
        status: event.status,
        summary: event.summary,
        task_session_id: event.task_session_id,
      })),
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  before: {
    health: json("api/before/health.json", null),
    task_sessions: json("api/before/task-sessions.json", null),
  },
  after_fault: {
    health: json("api/after_fault/health.json", null),
    activity,
    task_messages: taskMessages,
    task_sessions: json("api/after_fault/task-sessions.json", null),
  },
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  task_id: taskId,
  task_session_id: taskSessionId,
  fault: {
    injected: "kill codex app-server process",
    recovery: "caller restarts dogfood stack after artifact capture",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    codex_process_before: "codex-app-server-before.txt",
    codex_process_after_kill: "codex-app-server-after-kill.txt",
    start_response: "start-response.json",
    followup_response: "followup-response.json",
  },
}, null, 2));
NODE
REMOTE
}

patch_capture_manifest() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run'" <<'REMOTE'
set -euo pipefail
repo="$1"
run="$2"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
RUN="$run" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const manifestPath = path.join(run, "manifest.json");
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const readJson = (relative, fallback) => {
  try {
    return JSON.parse(fs.readFileSync(path.join(run, relative), "utf8"));
  } catch {
    return fallback;
  }
};
const after = readJson("captures/after-fault/capture-summary.json", {});
const before = readJson("captures/before/capture-summary.json", {});
manifest.assertions.push(
  {
    name: "desktop_capture_after_fault_nonempty",
    ok: Number(after?.screen?.bytes ?? 0) > 10000,
    details: after?.screen,
  },
  {
    name: "queue_app_still_visible_after_fault",
    ok: after?.queue_app?.process_present === true
      && after?.queue_app?.menu_items_present === true
      && after?.queue_app?.ax_tree_present === true,
    details: after?.queue_app,
  },
);
manifest.ok = manifest.assertions.every((assertion) => assertion.ok);
manifest.captures = {
  before: "captures/before/capture-summary.json",
  after_fault: "captures/after-fault/capture-summary.json",
};
manifest.artifacts = {
  ...manifest.artifacts,
  screenshot_before: Number(before?.screen?.bytes ?? 0) > 0 ? "captures/before/screen.png" : undefined,
  screenshot_after_fault: Number(after?.screen?.bytes ?? 0) > 0 ? "captures/after-fault/screen.png" : undefined,
  windows_after_fault: "captures/after-fault/windows.json",
};
fs.writeFileSync(manifestPath, JSON.stringify(manifest, null, 2) + "\n");
NODE
REMOTE
}

run_remote_orchestrator_crash_before() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run/api/before" "$run/api/down"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

json_endpoint() {
  local phase="$1"
  local endpoint="$2"
  local output_name
  output_name="$(printf "%s" "$endpoint" | tr '?/=&' '____')"
  curl -fsS --max-time 10 "$url/$endpoint" >"$run/api/$phase/$output_name.json" 2>"$run/api/$phase/$output_name.err" || true
}

collect_api_state() {
  local phase="$1"
  mkdir -p "$run/api/$phase"
  for endpoint in health metrics "activity?limit=120" "task-sessions" "task-messages?limit=120" "queue?state=ready" tasks; do
    json_endpoint "$phase" "$endpoint"
  done
}

post_json_allow_error() {
  local path="$1"
  local body_file="$2"
  local output_file="$3"
  local status_file="$4"
  local idempotency_key="$5"
  local tmp
  tmp="$(mktemp)"
  set +e
  status="$(curl -sS --max-time 60 -o "$tmp" -w "%{http_code}" \
    -H "content-type: application/json" \
    -H "idempotency-key: $idempotency_key" \
    -d @"$body_file" \
    "$url$path" 2>"$output_file.err")"
  code=$?
  set -e
  mv "$tmp" "$output_file"
  printf "%s\n" "$status" >"$status_file"
  printf "%s\n" "$code" >"$status_file.curl_rc"
}

collect_api_state before
pgrep -fl "[n]ode dist/src/index.js" >"$run/orchestrator-before.txt" 2>"$run/orchestrator-before.err" || true
pgrep -fl "[c]odex app-server" >"$run/codex-app-server-before.txt" 2>"$run/codex-app-server-before.err" || true

stamp="$(date +%Y%m%d%H%M%S)"
task_id="task_lab_fault_${scenario//-/_}_$stamp"
start_key="lab-fault-$scenario-start-$stamp"
followup_key="lab-fault-$scenario-followup-$stamp"
printf "%s\n" "$task_id" >"$run/task-id.txt"
printf "%s\n" "$followup_key" >"$run/followup-idempotency-key.txt"

cat >"$run/start-request.json" <<JSON
{
  "task_id": "$task_id",
  "prompt": "eventloopOS orchestrator restart proof setup $stamp. Reply exactly: eventloopos-orchestrator-restart-setup-ok.",
  "cwd": "$repo",
  "idempotency_key": "$start_key",
  "queue_paper": true
}
JSON
post_json_allow_error "/task-sessions" "$run/start-request.json" "$run/start-response.json" "$run/start-response.status" "$start_key"
task_session_id="$(jq -r '.started.task_session_id // empty' "$run/start-response.json" 2>/dev/null || true)"
queue_item_id="$(jq -r '.queue_item.id // empty' "$run/start-response.json" 2>/dev/null || true)"
printf "%s\n" "$task_session_id" >"$run/task-session-id.txt"
printf "%s\n" "$queue_item_id" >"$run/queue-item-id.txt"

collect_api_state before_crash
pkill -TERM -f "[n]ode dist/src/index.js" 2>/dev/null || true
sleep 2
pkill -KILL -f "[n]ode dist/src/index.js" 2>/dev/null || true
pgrep -fl "[n]ode dist/src/index.js" >"$run/orchestrator-after-kill.txt" 2>"$run/orchestrator-after-kill.err" || true
set +e
status="$(curl -sS --max-time 5 -o "$run/health-after-kill.json" -w "%{http_code}" "$url/health" 2>"$run/health-after-kill.err")"
code=$?
set -e
printf "%s\n" "$status" >"$run/health-after-kill.status"
printf "%s\n" "$code" >"$run/health-after-kill.curl_rc"
REMOTE
}

run_remote_orchestrator_crash_after() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run/api/after_restart"

json_endpoint() {
  local phase="$1"
  local endpoint="$2"
  local output_name
  output_name="$(printf "%s" "$endpoint" | tr '?/=&' '____')"
  curl -fsS --max-time 10 "$url/$endpoint" >"$run/api/$phase/$output_name.json" 2>"$run/api/$phase/$output_name.err" || true
}

collect_api_state() {
  local phase="$1"
  mkdir -p "$run/api/$phase"
  for endpoint in health metrics "activity?limit=120" "task-sessions" "task-messages?limit=120" "queue?state=ready" tasks; do
    json_endpoint "$phase" "$endpoint"
  done
}

task_session_id="$(cat "$run/task-session-id.txt" 2>/dev/null || true)"
followup_key="$(cat "$run/followup-idempotency-key.txt" 2>/dev/null || true)"

collect_api_state after_restart_before_followup
if [[ -n "$task_session_id" ]]; then
  set +e
  EVENTLOOPOS_TASK_SESSION_SKIP_BUILD=1 bin/task-session followup \
    --base-url "$url" \
    --session "$task_session_id" \
    --event "evt_${task_session_id}_after_orchestrator_restart" \
    --idempotency-key "$followup_key" \
    "This followup should still work after orchestrator restart because eventloopOS persisted task state." \
    >"$run/followup-response.json" 2>"$run/followup-response.err"
  printf "%s\n" "$?" >"$run/followup-response.rc"
  set -e
else
  printf '{}\n' >"$run/followup-response.json"
  printf '1\n' >"$run/followup-response.rc"
fi

if jq -e '.message.status == "failed" and (.message.error // "" | test("thread not found|not found"; "i"))' "$run/followup-response.json" >/dev/null 2>&1; then
  set +e
  EVENTLOOPOS_TASK_SESSION_SKIP_BUILD=1 bin/task-session replace \
    --base-url "$url" \
    --session "$task_session_id" \
    --idempotency-key "replacement-$followup_key" \
    "Restart recovery: replace missing Codex native thread for persisted task after orchestrator restart. Reply exactly: eventloopos-replacement-after-restart-ok." \
    >"$run/replacement-response.json" 2>"$run/replacement-response.err"
  printf "%s\n" "$?" >"$run/replacement-response.rc"
  set -e
else
  printf '{}\n' >"$run/replacement-response.json"
  printf '0\n' >"$run/replacement-response.rc"
fi

osascript >"$run/open-queue-window-after-restart.out" 2>"$run/open-queue-window-after-restart.err" <<'APPLESCRIPT' || true
on waitForMenuBarExtra()
  repeat with attempt from 1 to 80
    tell application "System Events"
      if exists process "EventLoopQueueApp" then
        tell process "EventLoopQueueApp"
          if (count of menu bars) is greater than or equal to 2 then return
        end tell
      end if
    end tell
    delay 0.1
  end repeat
  error "EventLoopQueueApp menu bar extra did not appear"
end waitForMenuBarExtra

on clickMenuItem(itemName)
  waitForMenuBarExtra()
  tell application "System Events"
    tell process "EventLoopQueueApp"
      tell menu bar item 1 of menu bar 2
        click
        delay 0.2
        click menu item itemName of menu 1
      end tell
    end tell
  end tell
end clickMenuItem

clickMenuItem("Refresh Queue")
delay 0.5
clickMenuItem("Open Queue")
delay 1.0
return "opened queue window after restart"
APPLESCRIPT

collect_api_state after_restart
pgrep -fl "[n]ode dist/src/index.js" >"$run/orchestrator-after-restart.txt" 2>"$run/orchestrator-after-restart.err" || true
pgrep -fl "[c]odex app-server" >"$run/codex-app-server-after-restart.txt" 2>"$run/codex-app-server-after-restart.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const start = json("start-response.json", {});
const followup = json("followup-response.json", {});
const replacement = json("replacement-response.json", {});
const taskMessages = json("api/after_restart/task-messages_limit_120.json", { messages: [] });
const tasks = json("api/after_restart/tasks.json", { tasks: [] });
const queueReady = json("api/after_restart/queue_state_ready.json", { items: [] });
const taskSessions = json("api/after_restart/task-sessions.json", { sessions: [] });
const health = json("api/after_restart/health.json", {});
const taskId = read("task-id.txt");
const taskSessionId = read("task-session-id.txt");
const queueItemId = read("queue-item-id.txt");
const followupKey = read("followup-idempotency-key.txt");
const messages = Array.isArray(taskMessages.messages) ? taskMessages.messages : [];
const persistedTask = Array.isArray(tasks.tasks) ? tasks.tasks.find((task) => task.task_id === taskId) : undefined;
const persistedQueueItem = Array.isArray(queueReady.items) ? queueReady.items.find((item) => item.id === queueItemId || item.task_id === taskId) : undefined;
const followupMessage = messages.find((message) => message.idempotency_key === followupKey);
const replacementStarted = replacement?.started;
const replacementMessage = messages.find((message) => message.idempotency_key === `replacement-${followupKey}`);
const followupSucceeded = followup?.ok === true && followup?.message?.status !== "failed";
const followupFailedClearly = followup?.ok === true
  && followup?.message?.status === "failed"
  && /thread not found|not found/i.test(String(followup?.message?.error ?? ""));
const assertions = [
  {
    name: "task_session_started_before_crash",
    ok: start?.ok === true && Boolean(taskSessionId),
    details: { task_id: taskId, task_session_id: taskSessionId, http_status: read("start-response.status") },
  },
  {
    name: "orchestrator_process_present_before_crash",
    ok: read("orchestrator-before.txt").length > 0,
    details: { before: read("orchestrator-before.txt") },
  },
  {
    name: "orchestrator_process_absent_after_fault",
    ok: read("orchestrator-after-kill.txt").length === 0,
    details: { after: read("orchestrator-after-kill.txt"), health_status: read("health-after-kill.status") },
  },
  {
    name: "orchestrator_healthy_after_restart",
    ok: health?.ok === true && read("orchestrator-after-restart.txt").length > 0,
    details: { health, process: read("orchestrator-after-restart.txt") },
  },
  {
    name: "task_record_survives_restart",
    ok: Boolean(persistedTask),
    details: persistedTask,
  },
  {
    name: "queue_item_survives_restart",
    ok: Boolean(persistedQueueItem),
    details: persistedQueueItem,
  },
  {
    name: "start_message_survives_restart",
    ok: messages.some((message) => message.task_id === taskId && message.origin === "task_session_start"),
    details: messages.filter((message) => message.task_id === taskId),
  },
  {
    name: "task_session_visible_after_restart",
    ok: Array.isArray(taskSessions.sessions) && taskSessions.sessions.some((session) => session.id === taskSessionId),
    details: taskSessions,
  },
  {
    name: "followup_after_restart_succeeds_or_fails_clearly",
    ok: followupSucceeded || followupFailedClearly,
    details: followup?.message ?? followup,
  },
  {
    name: "followup_after_restart_is_durable",
    ok: Boolean(followupMessage),
    details: followupMessage,
  },
  {
    name: "missing_thread_replacement_recovers_task",
    ok: followupSucceeded || (replacement?.ok === true && replacementStarted?.ok === true),
    details: replacement,
  },
  {
    name: "replacement_start_message_is_durable",
    ok: followupSucceeded || (Boolean(replacementMessage) && replacementMessage.status !== "failed"),
    details: replacementMessage,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  before_crash: {
    health: json("api/before_crash/health.json", null),
    task_sessions: json("api/before_crash/task-sessions.json", null),
    task_messages: json("api/before_crash/task-messages_limit_120.json", null),
    queue_ready: json("api/before_crash/queue_state_ready.json", null),
    tasks: json("api/before_crash/tasks.json", null),
  },
  after_restart: {
    health,
    task_sessions: taskSessions,
    task_messages: taskMessages,
    queue_ready: queueReady,
    tasks,
  },
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  task_id: taskId,
  task_session_id: taskSessionId,
  fault: {
    injected: "kill orchestrator process",
    recovery: "restart dogfood stack and verify persisted state",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    orchestrator_process_before: "orchestrator-before.txt",
    orchestrator_process_after_kill: "orchestrator-after-kill.txt",
    orchestrator_process_after_restart: "orchestrator-after-restart.txt",
    start_response: "start-response.json",
    followup_response: "followup-response.json",
    replacement_response: "replacement-response.json",
    open_queue_window_after_restart: "open-queue-window-after-restart.out",
  },
}, null, 2));
NODE
REMOTE
}

patch_orchestrator_crash_capture_manifest() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run'" <<'REMOTE'
set -euo pipefail
repo="$1"
run="$2"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
RUN="$run" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const manifestPath = path.join(run, "manifest.json");
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
const readJson = (relative, fallback) => {
  try {
    return JSON.parse(fs.readFileSync(path.join(run, relative), "utf8"));
  } catch {
    return fallback;
  }
};
const before = readJson("captures/before/capture-summary.json", {});
const after = readJson("captures/after-restart/capture-summary.json", {});
manifest.assertions.push(
  {
    name: "desktop_capture_after_restart_nonempty",
    ok: Number(after?.screen?.bytes ?? 0) > 10000,
    details: after?.screen,
  },
  {
    name: "queue_app_visible_after_restart",
    ok: after?.queue_app?.process_present === true
      && after?.queue_app?.menu_items_present === true
      && after?.queue_app?.ax_tree_present === true,
    details: after?.queue_app,
  },
);
manifest.ok = manifest.assertions.every((assertion) => assertion.ok);
manifest.captures = {
  before: "captures/before/capture-summary.json",
  after_restart: "captures/after-restart/capture-summary.json",
};
manifest.artifacts = {
  ...manifest.artifacts,
  screenshot_before: Number(before?.screen?.bytes ?? 0) > 0 ? "captures/before/screen.png" : undefined,
  screenshot_after_restart: Number(after?.screen?.bytes ?? 0) > 0 ? "captures/after-restart/screen.png" : undefined,
  windows_after_restart: "captures/after-restart/windows.json",
};
fs.writeFileSync(manifestPath, JSON.stringify(manifest, null, 2) + "\n");
NODE
REMOTE
}

run_orchestrator_crash_restart() {
  ensure_stack
  if [[ "$restart_first" != "0" ]]; then
    restart_stack >/dev/null
  fi
  LAB_MAC_HOST="$lab_host" LAB_MAC_USER="$lab_user" LAB_MAC_KEY="$lab_key" LAB_DOGFOOD_URL="$url" \
    bin/lab-mac-dogfood cleanup >/dev/null || true
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  capture_desktop before
  recover_needed=1
  run_remote_orchestrator_crash_before
  restart_stack >/dev/null
  run_remote_orchestrator_crash_after
  capture_desktop after-restart
  patch_orchestrator_crash_capture_manifest
  sync_artifacts
  recover_needed=0

  echo "$remote_run"
  jq '{ok, scenario, task_id, task_session_id, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

run_remote_duplicate_idempotency() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run/api/before" "$run/api/after"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

json_endpoint() {
  local phase="$1"
  local endpoint="$2"
  local output_name
  output_name="$(printf "%s" "$endpoint" | tr '?/=&' '____')"
  curl -fsS --max-time 10 "$url/$endpoint" >"$run/api/$phase/$output_name.json" 2>"$run/api/$phase/$output_name.err" || true
}

collect_api_state() {
  local phase="$1"
  mkdir -p "$run/api/$phase"
  for endpoint in health metrics "activity?limit=120" "task-sessions" "task-messages?limit=120" "queue?state=ready" "queue?state=deferred" "queue?state=dead" tasks; do
    json_endpoint "$phase" "$endpoint"
  done
}

post_json_allow_error() {
  local path="$1"
  local body_file="$2"
  local output_file="$3"
  local status_file="$4"
  local idempotency_key="$5"
  local tmp
  tmp="$(mktemp)"
  set +e
  status="$(curl -sS --max-time 60 -o "$tmp" -w "%{http_code}" \
    -H "content-type: application/json" \
    -H "idempotency-key: $idempotency_key" \
    -d @"$body_file" \
    "$url$path" 2>"$output_file.err")"
  code=$?
  set -e
  mv "$tmp" "$output_file"
  printf "%s\n" "$status" >"$status_file"
  printf "%s\n" "$code" >"$status_file.curl_rc"
}

collect_api_state before
stamp="$(date +%Y%m%d%H%M%S)"
task_id="task_lab_fault_${scenario//-/_}_$stamp"
start_key="lab-fault-$scenario-start-$stamp"
followup_key="lab-fault-$scenario-followup-$stamp"
printf "%s\n" "$task_id" >"$run/task-id.txt"
printf "%s\n" "$start_key" >"$run/start-idempotency-key.txt"
printf "%s\n" "$followup_key" >"$run/followup-idempotency-key.txt"

cat >"$run/start-request.json" <<JSON
{
  "task_id": "$task_id",
  "prompt": "eventloopOS duplicate idempotency proof setup $stamp. Reply exactly: eventloopos-duplicate-idempotency-setup-ok.",
  "cwd": "$repo",
  "idempotency_key": "$start_key",
  "queue_paper": true
}
JSON
post_json_allow_error "/task-sessions" "$run/start-request.json" "$run/start-response-1.json" "$run/start-response-1.status" "$start_key"
post_json_allow_error "/task-sessions" "$run/start-request.json" "$run/start-response-2.json" "$run/start-response-2.status" "$start_key"
task_session_id="$(jq -r '.started.task_session_id // empty' "$run/start-response-1.json" 2>/dev/null || true)"
printf "%s\n" "$task_session_id" >"$run/task-session-id.txt"

if [[ -n "$task_session_id" ]]; then
  set +e
  EVENTLOOPOS_TASK_SESSION_SKIP_BUILD=1 bin/task-session followup \
    --base-url "$url" \
    --session "$task_session_id" \
    --event "evt_${task_id}_duplicate_idempotency" \
    --idempotency-key "$followup_key" \
    "This followup is sent twice with the same idempotency key. eventloopOS should record one durable message." \
    >"$run/followup-response-1.json" 2>"$run/followup-response-1.err"
  printf "%s\n" "$?" >"$run/followup-response-1.rc"
  EVENTLOOPOS_TASK_SESSION_SKIP_BUILD=1 bin/task-session followup \
    --base-url "$url" \
    --session "$task_session_id" \
    --event "evt_${task_id}_duplicate_idempotency" \
    --idempotency-key "$followup_key" \
    "This followup is sent twice with the same idempotency key. eventloopOS should record one durable message." \
    >"$run/followup-response-2.json" 2>"$run/followup-response-2.err"
  printf "%s\n" "$?" >"$run/followup-response-2.rc"
  set -e
else
  printf '{}\n' >"$run/followup-response-1.json"
  printf '{}\n' >"$run/followup-response-2.json"
  printf '1\n' >"$run/followup-response-1.rc"
  printf '1\n' >"$run/followup-response-2.rc"
fi

collect_api_state after
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const start1 = json("start-response-1.json", {});
const start2 = json("start-response-2.json", {});
const followup1 = json("followup-response-1.json", {});
const followup2 = json("followup-response-2.json", {});
const taskMessages = json("api/after/task-messages_limit_120.json", { messages: [] });
const queueReady = json("api/after/queue_state_ready.json", { items: [] });
const tasks = json("api/after/tasks.json", { tasks: [] });
const health = json("api/after/health.json", {});
const taskId = read("task-id.txt");
const taskSessionId = read("task-session-id.txt");
const startKey = read("start-idempotency-key.txt");
const followupKey = read("followup-idempotency-key.txt");
const messages = Array.isArray(taskMessages.messages) ? taskMessages.messages : [];
const queueItems = Array.isArray(queueReady.items) ? queueReady.items : [];
const taskRecords = Array.isArray(tasks.tasks) ? tasks.tasks : [];
const startMessages = messages.filter((message) => message.idempotency_key === startKey);
const followupMessages = messages.filter((message) => message.idempotency_key === followupKey);
const queueItemsForTask = queueItems.filter((item) => item.task_id === taskId);
const taskRecordsForTask = taskRecords.filter((task) => task.task_id === taskId);
const assertions = [
  {
    name: "orchestrator_healthy",
    ok: health?.ok === true,
    details: health,
  },
  {
    name: "first_start_succeeds",
    ok: start1?.ok === true && start1?.started?.task_session_id === taskSessionId,
    details: start1?.started ?? start1,
  },
  {
    name: "second_start_dedupes",
    ok: start2?.ok === true && start2?.started?.deduped === true && start2?.started?.task_session_id === taskSessionId,
    details: start2?.started ?? start2,
  },
  {
    name: "single_start_message_for_idempotency_key",
    ok: startMessages.length === 1,
    details: startMessages,
  },
  {
    name: "single_queue_item_for_task_retry",
    ok: queueItemsForTask.length === 1,
    details: queueItemsForTask,
  },
  {
    name: "single_task_record_for_task_retry",
    ok: taskRecordsForTask.length === 1,
    details: taskRecordsForTask,
  },
  {
    name: "second_followup_dedupes",
    ok: followup1?.ok === true
      && followup2?.ok === true
      && followup1?.message?.idempotency_key === followupKey
      && followup2?.message?.idempotency_key === followupKey
      && followup1?.message?.id === followup2?.message?.id,
    details: { first: followup1?.message ?? followup1, second: followup2?.message ?? followup2 },
  },
  {
    name: "single_followup_message_for_idempotency_key",
    ok: followupMessages.length === 1,
    details: followupMessages,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  before: {
    health: json("api/before/health.json", null),
    task_messages: json("api/before/task-messages_limit_120.json", null),
    queue_ready: json("api/before/queue_state_ready.json", null),
    tasks: json("api/before/tasks.json", null),
  },
  after: {
    health,
    task_messages: taskMessages,
    queue_ready: queueReady,
    tasks,
  },
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  task_id: taskId,
  task_session_id: taskSessionId,
  fault: {
    injected: "repeat task start and followup with identical idempotency keys",
    recovery: "dedupe without duplicate queue items, task records, or durable messages",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    start_response_1: "start-response-1.json",
    start_response_2: "start-response-2.json",
    followup_response_1: "followup-response-1.json",
    followup_response_2: "followup-response-2.json",
  },
}, null, 2));
NODE
REMOTE
}

