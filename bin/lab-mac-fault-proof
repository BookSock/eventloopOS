patch_queue_app_accessibility_denied_manifest() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$scenario' '$url'" <<'REMOTE'
set -euo pipefail
repo="$1"
run="$2"
scenario="$3"
main_url="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const capture = json("captures/accessibility-denied/capture-summary.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const queueApp = capture?.queue_app ?? {};
const hint = String(queueApp.accessibility_failure_hint ?? "");
const error = String(queueApp.accessibility_error ?? "");
const assertions = [
  {
    name: "desktop_capture_still_nonempty",
    ok: Number(capture?.screen?.bytes ?? 0) > 10000,
    details: capture?.screen,
  },
  {
    name: "queue_app_process_still_visible",
    ok: queueApp.process_present === true,
    details: queueApp,
  },
  {
    name: "queue_app_ax_menu_blocked",
    ok: queueApp.menu_items_present === false && queueApp.ax_tree_present === false && queueApp.harness_status_present === false,
    details: queueApp,
  },
  {
    name: "queue_app_accessibility_tcc_status_reported",
    ok: queueApp.tcc_terminal_accessibility === "denied",
    details: queueApp,
  },
  {
    name: "queue_app_accessibility_error_is_actionable",
    ok: /Terminal denied|Accessibility|Privacy & Security|Grant Terminal|Queue UI proof/i.test(hint),
    details: {
      failure_hint: hint,
      error,
    },
  },
  {
    name: "capture_still_collects_window_process_and_tcc_artifacts",
    ok: Boolean(capture?.artifacts?.windows) && Boolean(capture?.artifacts?.process_list) && Boolean(capture?.artifacts?.tcc_user_capture_access),
    details: capture?.artifacts,
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_after: mainHealthAfter,
  capture_summary: capture,
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("captures/accessibility-denied/captured-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "simulate Terminal/System Events denied Accessibility while capturing Queue app UI",
    recovery: "capture records actionable Accessibility setup guidance while preserving screenshot/process/window/TCC artifacts",
  },
  assertions,
  captures: {
    accessibility_denied: "captures/accessibility-denied/capture-summary.json",
  },
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    capture_summary: "captures/accessibility-denied/capture-summary.json",
    screenshot: "captures/accessibility-denied/screen.png",
    windows: "captures/accessibility-denied/windows.json",
    process_list: "captures/accessibility-denied/ps.txt",
    tcc_user_capture_access: "captures/accessibility-denied/tcc-user-capture-access.txt",
    queue_menu_error: "captures/accessibility-denied/queue-menu-items.err",
    queue_ax_tree_error: "captures/accessibility-denied/queue-ax-tree.err",
  },
}, null, 2));
NODE
REMOTE
}

run_queue_app_accessibility_denied() {
  ensure_stack
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  LAB_MAC_HOST="$lab_host" \
  LAB_MAC_USER="$lab_user" \
  LAB_MAC_KEY="$lab_key" \
  LAB_DOGFOOD_URL="$url" \
  LAB_MAC_CAPTURE_INJECT_ACCESSIBILITY_DENIED=1 \
  bin/lab-mac-desktop-capture "$remote_run" accessibility-denied >/dev/null
  patch_queue_app_accessibility_denied_manifest
  sync_artifacts

  echo "$remote_run"
  jq '{ok, scenario, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

run_remote_aerospace_restore_server_down() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
main_url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

proof_dir="aerospace-restore-server-down-proof"
printf "%s\n" "$proof_dir" >"$run/proof-dir.txt"
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-before.json" 2>"$run/main-health-before.err" || true

set +e
EVENTLOOPOS_INJECT_AEROSPACE_RESTORE_FAILURE=1 \
EVENTLOOPOS_PROVE_FORCE_FLOATING=0 \
EVENTLOOPOS_ISOLATED_AEROSPACE_ARTIFACT_DIR="$PWD/$run/$proof_dir" \
  pnpm --filter @eventloopos/orchestrator run live:aerospace:isolated >"$run/proof.out" 2>"$run/proof.err"
proof_rc="$?"
set -e
printf "%s\n" "$proof_rc" >"$run/proof.rc"

aerospace list-windows --all --format "%{window-id}|%{app-name}|%{window-title}|%{workspace}" >"$run/windows-after-proof.txt" 2>"$run/windows-after-proof.err" || true
ps -axo pid,ppid,comm,args >"$run/ps-after-proof.txt" || true
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const proofDir = read("proof-dir.txt");
const proofManifest = json(path.join(proofDir, "manifest.json"), {});
const proofRc = Number(read("proof.rc"));
const proofStdout = read("proof.out");
const proofStderr = read("proof.err");
const combinedProofText = `${proofStdout}\n${proofStderr}\n${JSON.stringify(proofManifest)}`;
const mainHealthBefore = json("main-health-before.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const cleanup = proofManifest?.cleanup ?? {};
const detail = String(proofManifest?.detail ?? "");
const windowsAfter = read("windows-after-proof.txt");
const smokeTitleStillPresent = /eventloopOS-isolated-smoke/.test(windowsAfter);
const assertions = [
  {
    name: "main_dogfood_healthy_before_fault",
    ok: mainHealthBefore?.ok === true,
    details: mainHealthBefore,
  },
  {
    name: "aerospace_restore_fault_proof_exits_nonzero",
    ok: Number.isFinite(proofRc) && proofRc !== 0,
    details: { exit_code: proofRc },
  },
  {
    name: "aerospace_restore_failure_is_actionable",
    ok: proofManifest?.ok === false
      && proofManifest?.reason === "isolated_smoke_failed"
      && /AeroSpace server unavailable during restore|Restart AeroSpace|grant Accessibility|workspace restore proof/i.test(combinedProofText),
    details: {
      reason: proofManifest?.reason,
      detail,
      stdout_tail: proofStdout.slice(-2000),
      stderr_tail: proofStderr.slice(-2000),
    },
  },
  {
    name: "aerospace_restore_fault_cleanup_removed_smoke_window",
    ok: cleanup?.ok === true && proofManifest?.cleanup_verified === true && !smokeTitleStillPresent,
    details: {
      cleanup,
      cleanup_verified: proofManifest?.cleanup_verified,
      smoke_title_still_present: smokeTitleStillPresent,
    },
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_before: mainHealthBefore,
  main_health_after: mainHealthAfter,
  proof_manifest: proofManifest,
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "fail the second AeroSpace move-node-to-workspace command during isolated restore proof",
    recovery: "proof reports actionable restore failure and removes the smoke window",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    proof_manifest: `${proofDir}/manifest.json`,
    proof_stdout: "proof.out",
    proof_stderr: "proof.err",
    proof_exit_code: "proof.rc",
    windows_after_proof: "windows-after-proof.txt",
    processes_after_proof: "ps-after-proof.txt",
  },
}, null, 2));
NODE
REMOTE
}

run_aerospace_restore_server_down() {
  ensure_stack
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  capture_desktop before
  run_remote_aerospace_restore_server_down
  capture_desktop after
  patch_postgres_unavailable_capture_manifest
  sync_artifacts

  echo "$remote_run"
  jq '{ok, scenario, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

if [[ "$scenario" == "orchestrator-crash-restart" ]]; then
  run_orchestrator_crash_restart
  exit 0
fi

if [[ "$scenario" == "duplicate-idempotency" ]]; then
  run_duplicate_idempotency
  exit 0
fi

if [[ "$scenario" == "postgres-unavailable" ]]; then
  run_postgres_unavailable
  exit 0
fi

if [[ "$scenario" == "postgres-migration-mismatch" ]]; then
  run_postgres_migration_mismatch
  exit 0
fi

if [[ "$scenario" == "aerospace-unavailable" ]]; then
  run_aerospace_unavailable
  exit 0
fi

if [[ "$scenario" == "aerospace-permission-missing" ]]; then
  run_aerospace_permission_missing
  exit 0
fi

if [[ "$scenario" == "ghostty-cleanup-failure" ]]; then
  run_ghostty_cleanup_failure
  exit 0
fi

if [[ "$scenario" == "screen-capture-denied" ]]; then
  run_screen_capture_denied
  exit 0
fi

if [[ "$scenario" == "queue-app-accessibility-denied" ]]; then
  run_queue_app_accessibility_denied
  exit 0
fi

if [[ "$scenario" == "aerospace-restore-server-down" ]]; then
  run_aerospace_restore_server_down
  exit 0
fi

ensure_stack
if [[ "$restart_first" != "0" ]]; then
  restart_stack >/dev/null
fi
LAB_MAC_HOST="$lab_host" LAB_MAC_USER="$lab_user" LAB_MAC_KEY="$lab_key" LAB_DOGFOOD_URL="$url" \
  bin/lab-mac-dogfood cleanup >/dev/null || true
ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
capture_desktop before
recover_needed=1
run_remote_fault
capture_desktop after-fault
patch_capture_manifest
sync_artifacts
restart_stack >/dev/null
recover_needed=0

echo "$remote_run"
jq '{ok, scenario, task_id, task_session_id, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
  exit 1
fi
