run_remote_ghostty_cleanup_failure() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$url' '$scenario'" <<'REMOTE'
set -euo pipefail

repo="$1"
run="$2"
main_url="$3"
scenario="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
mkdir -p "$run"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/started-at.txt"

proof_dir="codex-completion-workspace-cleanup-fault"
printf "%s\n" "$proof_dir" >"$run/proof-dir.txt"
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-before.json" 2>"$run/main-health-before.err" || true

set +e
EVENTLOOPOS_PROOF_INJECT_GHOSTTY_CLEANUP_FAILURE=1 \
EVENTLOOPOS_CODEX_COMPLETION_WORKSPACE_ARTIFACT_DIR="$PWD/$run/$proof_dir" \
  pnpm test:e2e:event-loop:codex-completion-workspace >"$run/proof.out" 2>"$run/proof.err"
proof_rc="$?"
set -e
printf "%s\n" "$proof_rc" >"$run/proof.rc"

proof_manifest="$proof_dir/manifest.json"
if [[ -f "$proof_manifest" ]]; then
  jq -r '.ghostty_remote_tui.launcher_path // empty' "$proof_manifest" >"$run/ghostty-launcher-path.txt" || true
  jq -r '.ghostty_remote_tui.window_id // empty' "$proof_manifest" >"$run/ghostty-window-id.txt" || true
  jq -r '.ghostty_remote_tui.title // empty' "$proof_manifest" >"$run/ghostty-title.txt" || true
else
  : >"$run/ghostty-launcher-path.txt"
  : >"$run/ghostty-window-id.txt"
  : >"$run/ghostty-title.txt"
fi

aerospace list-windows --all --format "%{window-id}|%{app-name}|%{window-title}|%{workspace}" >"$run/windows-before-cleanup.txt" 2>"$run/windows-before-cleanup.err" || true
ps -axo pid,ppid,comm,args >"$run/ps-before-cleanup.txt" || true

launcher_path="$(cat "$run/ghostty-launcher-path.txt" 2>/dev/null || true)"
window_id="$(cat "$run/ghostty-window-id.txt" 2>/dev/null || true)"
title="$(cat "$run/ghostty-title.txt" 2>/dev/null || true)"

if [[ -n "$launcher_path" ]]; then
  pkill -f "$launcher_path" >"$run/pkill-launcher.out" 2>"$run/pkill-launcher.err" || true
fi
if [[ -n "$window_id" && "$window_id" != "null" ]]; then
  aerospace close --window-id "$window_id" >"$run/close-window-id.out" 2>"$run/close-window-id.err" || true
fi
if [[ -n "$title" && "$title" != "null" ]]; then
  aerospace list-windows --all --json --format "%{window-id}%{app-name}%{window-title}%{workspace}" 2>/dev/null \
    | jq -r --arg title "$title" '.[] | select(."app-name" == "Ghostty" and (."window-title" | contains($title))) | ."window-id"' \
    | while read -r matched_window_id; do
        [[ -z "$matched_window_id" ]] && continue
        aerospace close --window-id "$matched_window_id" >>"$run/close-title.out" 2>>"$run/close-title.err" || true
      done
fi
sleep 2

aerospace list-windows --all --format "%{window-id}|%{app-name}|%{window-title}|%{workspace}" >"$run/windows-after-cleanup.txt" 2>"$run/windows-after-cleanup.err" || true
ps -axo pid,ppid,comm,args >"$run/ps-after-cleanup.txt" || true
if [[ -n "$launcher_path" ]]; then
  pgrep -fl "$launcher_path" >"$run/launcher-processes-after-cleanup.txt" 2>"$run/launcher-processes-after-cleanup.err" || true
else
  : >"$run/launcher-processes-after-cleanup.txt"
fi
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"

SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const proofDir = read("proof-dir.txt");
const proofManifest = json(path.join(proofDir, "manifest.json"), {});
const proofRc = Number(read("proof.rc"));
const title = read("ghostty-title.txt");
const windowId = read("ghostty-window-id.txt");
const launcherPath = read("ghostty-launcher-path.txt");
const mainHealthBefore = json("main-health-before.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const proofError = String(proofManifest?.error ?? "");
const cleanup = proofManifest?.ghostty_cleanup ?? {};
const remainingWindows = Array.isArray(cleanup.remaining_windows) ? cleanup.remaining_windows : [];
const remainingPids = Array.isArray(cleanup.remaining_pids) ? cleanup.remaining_pids : [];
const afterWindowsText = read("windows-after-cleanup.txt");
const afterLauncherProcesses = read("launcher-processes-after-cleanup.txt");
const titleStillPresent = title.length > 0 && afterWindowsText.includes(title);
const windowIdStillPresent = windowId.length > 0 && new RegExp(`^${windowId.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\|`, "m").test(afterWindowsText);
const cleanupFailureVisible = proofManifest?.ghostty_cleanup_fault_injected === true
  && proofManifest?.ghostty_cleanup?.ok === false
  && /Ghostty cleanup verification failed/i.test(proofError);
const assertions = [
  {
    name: "main_dogfood_healthy_before_fault",
    ok: mainHealthBefore?.ok === true,
    details: mainHealthBefore,
  },
  {
    name: "cleanup_fault_proof_exits_nonzero",
    ok: Number.isFinite(proofRc) && proofRc !== 0,
    details: { exit_code: proofRc },
  },
  {
    name: "ghostty_cleanup_failure_is_detected",
    ok: cleanupFailureVisible,
    details: {
      proof_error: proofError,
      cleanup,
    },
  },
  {
    name: "ghostty_cleanup_failure_records_remaining_artifact",
    ok: remainingWindows.length > 0 || remainingPids.length > 0,
    details: {
      remaining_windows: remainingWindows,
      remaining_pids: remainingPids,
      title,
      window_id: windowId,
      launcher_path: launcherPath,
    },
  },
  {
    name: "ghostty_cleanup_fault_recovery_removed_orphans",
    ok: !titleStillPresent && !windowIdStillPresent && afterLauncherProcesses.length === 0,
    details: {
      title_still_present: titleStillPresent,
      window_id_still_present: windowIdStillPresent,
      launcher_processes_after_cleanup: afterLauncherProcesses,
    },
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_before: mainHealthBefore,
  main_health_after: mainHealthAfter,
  proof_manifest: proofManifest,
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("started-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "skip Ghostty cleanup in the real Codex completion/workspace proof",
    recovery: "proof fails with visible remaining Ghostty artifacts, then lab fault runner closes the orphaned window/process",
  },
  assertions,
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    proof_manifest: `${proofDir}/manifest.json`,
    proof_stdout: "proof.out",
    proof_stderr: "proof.err",
    proof_exit_code: "proof.rc",
    windows_before_cleanup: "windows-before-cleanup.txt",
    windows_after_cleanup: "windows-after-cleanup.txt",
    processes_before_cleanup: "ps-before-cleanup.txt",
    processes_after_cleanup: "ps-after-cleanup.txt",
  },
}, null, 2));
NODE
REMOTE
}

run_ghostty_cleanup_failure() {
  ensure_stack
  ssh_remote "cd '$remote_repo' && mkdir -p '$remote_run'"
  capture_desktop before
  run_remote_ghostty_cleanup_failure
