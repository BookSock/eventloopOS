  patch_postgres_unavailable_capture_manifest
  sync_artifacts

  echo "$remote_run"
  jq '{ok, scenario, assertions: [.assertions[] | {name, ok}]}' "$remote_run/manifest.json"
  if ! jq -e '.ok == true' "$remote_run/manifest.json" >/dev/null; then
    exit 1
  fi
}

patch_screen_capture_denied_manifest() {
  ssh_remote "bash -s -- '$remote_repo' '$remote_run' '$scenario' '$url'" <<'REMOTE'
set -euo pipefail
repo="$1"
run="$2"
scenario="$3"
main_url="$4"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
cd "$repo"
date -u +%Y-%m-%dT%H:%M:%SZ >"$run/finished-at.txt"
curl -fsS --max-time 5 "$main_url/health" >"$run/main-health-after.json" 2>"$run/main-health-after.err" || true
SCENARIO="$scenario" RUN="$run" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const path = require("node:path");
const run = process.env.RUN;
const scenario = process.env.SCENARIO;
const read = (relative) => {
  try {
    return fs.readFileSync(path.join(run, relative), "utf8").trim();
  } catch {
    return "";
  }
};
const json = (relative, fallback = undefined) => {
  const text = read(relative);
  if (!text) return fallback;
  try {
    return JSON.parse(text);
  } catch {
    return fallback;
  }
};
const capture = json("captures/screen-denied/capture-summary.json", {});
const mainHealthAfter = json("main-health-after.json", {});
const hint = String(capture?.screen?.failure_hint ?? "");
const error = String(capture?.screen?.error ?? "");
const assertions = [
  {
    name: "screen_capture_denied_has_zero_bytes",
    ok: Number(capture?.screen?.bytes ?? -1) === 0,
    details: capture?.screen,
  },
  {
    name: "screen_capture_denied_tcc_status_reported",
    ok: capture?.screen?.tcc_terminal_screen_capture === "denied",
    details: capture?.screen,
  },
  {
    name: "screen_capture_denied_error_is_actionable",
    ok: /Terminal denied|Screen & System Audio Recording|Privacy & Security|grant Terminal/i.test(hint),
    details: {
      failure_hint: hint,
      error,
    },
  },
  {
    name: "screen_capture_denied_skips_gui_fallback",
    ok: capture?.gui_fallback?.used === false && /Terminal is denied/.test(String(capture?.gui_fallback?.skipped_reason ?? "")),
    details: capture?.gui_fallback,
  },
  {
    name: "capture_still_collects_window_and_process_artifacts",
    ok: Boolean(capture?.artifacts?.windows) && Boolean(capture?.artifacts?.tcc_user_capture_access),
    details: capture?.artifacts,
  },
  {
    name: "main_dogfood_healthy_after_fault",
    ok: mainHealthAfter?.ok === true,
    details: mainHealthAfter,
  },
];
const ok = assertions.every((assertion) => assertion.ok);
fs.writeFileSync(path.join(run, "api-state.json"), JSON.stringify({
  main_health_after: mainHealthAfter,
  capture_summary: capture,
}, null, 2) + "\n");
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_fault_proof",
  scenario,
  run,
  started_at: read("captures/screen-denied/captured-at.txt"),
  finished_at: read("finished-at.txt"),
  ok,
  fault: {
    injected: "simulate Terminal denied Screen Recording during desktop capture",
    recovery: "capture records actionable TCC setup guidance and avoids GUI fallback that would leave stale Terminal windows",
  },
  assertions,
  captures: {
    screen_denied: "captures/screen-denied/capture-summary.json",
  },
  artifacts: {
    manifest: "manifest.json",
    api_state: "api-state.json",
    capture_summary: "captures/screen-denied/capture-summary.json",
    windows: "captures/screen-denied/windows.json",
    process_list: "captures/screen-denied/ps.txt",
    tcc_user_capture_access: "captures/screen-denied/tcc-user-capture-access.txt",
    screencapture_error: "captures/screen-denied/screencapture.err",
  },
}, null, 2));
NODE
REMOTE
}

