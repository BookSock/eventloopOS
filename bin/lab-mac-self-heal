#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bin/lab-mac-self-heal [install|status|uninstall|run]

Install or run a user LaunchAgent that helps the lab Mac recover after login or
reboot. It does not bypass macOS privacy prompts or admin-only Sharing settings;
it opens user apps, keeps the machine awake, and writes recovery artifacts with
exact fixes.

Environment:
  LAB_CONTROLLER_TAILSCALE_IP optional controller 100.x IP or MagicDNS name
  LAB_SELF_HEAL_START_INTERVAL default: 20 seconds
  LAB_SELF_HEAL_BOOT_DELAY_SECONDS default: 10; wait once per boot before first check
  LAB_SELF_HEAL_NO_LAUNCHCTL   default: 0; write plist without loading it
  LAB_SELF_HEAL_SKIP_OPEN      default: 0; do not open Tailscale/AeroSpace
  LAB_SELF_HEAL_AEROSPACE_MODE default: auto; auto|launchservices|custom|skip
  LAB_SELF_HEAL_AEROSPACE_CLI_TIMEOUT_SECONDS default: 5
  LAB_SELF_HEAL_SKIP_CAFFEINATE default: 0; do not start caffeinate
  LAB_SELF_HEAL_SKIP_TAILSCALE_UP default: 0; do not run tailscale up when disconnected
  LAB_SELF_HEAL_PROOF_LOCK_TTL_SECONDS default: 7200; proof lock age treated active
  LAB_SELF_HEAL_RECOVERY_COMMAND optional bash command for harness tests
EOF
}

if [[ "${1:-}" == "--" ]]; then
  shift
fi

action="${1:-status}"
case "$action" in
  install|status|uninstall|run) ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    echo "unknown action: $action" >&2
    usage >&2
    exit 2
    ;;
esac

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

label="com.eventloopos.lab-self-heal"
aerospace_label="dev.eventloopos.aerospace-debug-server"
terminal_aerospace_label="dev.eventloopos.aerospace-terminal-launcher"
agent_dir="$HOME/Library/LaunchAgents"
plist="$agent_dir/$label.plist"
aerospace_plist="$agent_dir/$aerospace_label.plist"
terminal_aerospace_plist="$agent_dir/$terminal_aerospace_label.plist"
log_dir="$HOME/Library/Logs/eventloopOS"
state_dir="$HOME/.eventloopos/lab-self-heal"
proof_lock_dir="artifacts/.locks/product-readiness-lab.lock"
start_interval="${LAB_SELF_HEAL_START_INTERVAL:-20}"
controller_tailnet_ip="${LAB_CONTROLLER_TAILSCALE_IP:-}"
aerospace_mode="${LAB_SELF_HEAL_AEROSPACE_MODE:-auto}"
custom_aerospace_runner="$HOME/.eventloop-lab/bin/run-aerospace.command"
aerospace_cli_timeout_seconds="${LAB_SELF_HEAL_AEROSPACE_CLI_TIMEOUT_SECONDS:-5}"
if ! [[ "$aerospace_cli_timeout_seconds" =~ ^[0-9]+$ ]] || [[ "$aerospace_cli_timeout_seconds" == "0" ]]; then
  aerospace_cli_timeout_seconds=5
fi

plist_escape() {
  sed \
    -e 's/&/\&amp;/g' \
    -e 's/</\&lt;/g' \
    -e 's/>/\&gt;/g' \
    -e 's/"/\&quot;/g' \
    -e "s/'/\&apos;/g"
}

run_with_timeout() {
  local seconds="$1"
  shift
  "$@" &
  local command_pid=$!
  (
    sleep "$seconds"
    kill "$command_pid" >/dev/null 2>&1 || true
  ) &
  local killer_pid=$!
  local command_code=0
  wait "$command_pid" || command_code=$?
  kill "$killer_pid" >/dev/null 2>&1 || true
  wait "$killer_pid" 2>/dev/null || true
  return "$command_code"
}

aerospace_cli_reachable() {
  command -v aerospace >/dev/null 2>&1 || return 1
  run_with_timeout "$aerospace_cli_timeout_seconds" aerospace list-workspaces --focused >/dev/null 2>&1
}

restart_custom_aerospace_agent() {
  if [[ ! -x "$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp" ]]; then
    echo "custom AeroSpace debug app missing; cannot restart: $HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp"
    return 1
  fi
  if [[ ! -f "$aerospace_plist" ]]; then
    echo "custom AeroSpace LaunchAgent plist missing; installing first: $aerospace_plist"
    install_custom_aerospace_agent
    return
  fi
  launchctl bootout "gui/$(id -u)" "$terminal_aerospace_plist" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$aerospace_plist" >/dev/null 2>&1 || true
  rm -f "$terminal_aerospace_plist"
  pkill -TERM -f "$HOME/.eventloop-lab/bin/run-aerospace.command" >/dev/null 2>&1 || true
  pkill -TERM -f "$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp" >/dev/null 2>&1 || true
  sleep 2
  pkill -KILL -f "$HOME/.eventloop-lab/bin/run-aerospace.command" >/dev/null 2>&1 || true
  pkill -KILL -f "$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp" >/dev/null 2>&1 || true
  rm -f "/tmp/bobko.aerospace.debug-$(whoami).sock" "/tmp/bobko.aerospace-$(whoami).sock"
  launchctl bootstrap "gui/$(id -u)" "$aerospace_plist"
  launchctl kickstart -k "gui/$(id -u)/$aerospace_label" >/dev/null 2>&1 || true
  echo "custom AeroSpace direct LaunchAgent restarted: $aerospace_plist"
}

write_manifest() {
  local run="$1"
  local ok="$2"
  local reason="$3"
  RUN="$run" OK="$ok" REASON="$reason" PLIST="$plist" LABEL="$label" REPO_ROOT="$repo_root" node <<'NODE' >"$run/manifest.json"
const fs = require("node:fs");
const localRecoveryManifestText = `${process.env.RUN}/local-recovery-manifest.txt`;
let localRecoveryManifestPath = "";
try {
  localRecoveryManifestPath = fs.readFileSync(localRecoveryManifestText, "utf8").trim();
} catch {}
const heartbeatPath = `${process.env.RUN}/heartbeat.json`;
let heartbeat;
try {
  heartbeat = JSON.parse(fs.readFileSync(heartbeatPath, "utf8"));
} catch {}
const manifest = {
  schema_version: 1,
  kind: "eventloopos.lab_mac_self_heal",
  run: process.env.RUN,
  generated_at: new Date().toISOString(),
  ok: process.env.OK === "1",
  label: process.env.LABEL,
  plist: process.env.PLIST,
  repo_root: process.env.REPO_ROOT,
  reason: process.env.REASON,
  heartbeat,
  local_recovery_manifest: localRecoveryManifestPath || undefined,
  artifacts: {
    stdout: `${process.env.RUN}/self-heal.stdout.log`,
    stderr: `${process.env.RUN}/self-heal.stderr.log`,
    heartbeat: heartbeatPath,
    local_recovery_manifest_text: localRecoveryManifestText,
  },
};
console.log(JSON.stringify(manifest, null, 2));
NODE
}

write_heartbeat() {
  local run="$1"
  local heartbeat_out="$run/heartbeat.out"
  local heartbeat_err="$run/heartbeat.err"
  set +e
  {
    echo "timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "hostname=$(hostname)"
    echo "whoami=$(whoami)"
    echo "controller=$controller_tailnet_ip"
    echo
    echo "== macos =="
    sw_vers 2>/dev/null || true
    echo
    echo "== tailscale =="
    if command -v tailscale >/dev/null 2>&1; then
      echo "tailscale_path=$(command -v tailscale)"
      tailscale version 2>/dev/null | head -3 || true
      echo "tailscale_ip=$(tailscale ip -4 2>/dev/null | tr '\n' ' ')"
      tailscale status --self 2>/dev/null || tailscale status 2>/dev/null | head -20 || true
      if [[ -n "$controller_tailnet_ip" ]]; then
        echo
        echo "== controller ping =="
        tailscale ping --timeout=2s --c 1 "$controller_tailnet_ip" 2>&1 || true
      fi
    else
      echo "tailscale_missing=1"
    fi
    echo
    echo "== aerospace =="
    if command -v aerospace >/dev/null 2>&1; then
      echo "aerospace_path=$(command -v aerospace)"
      if aerospace_cli_reachable; then
        echo "aerospace_cli_reachable=1"
      else
        echo "aerospace_cli_reachable=0"
      fi
      run_with_timeout "$aerospace_cli_timeout_seconds" aerospace --version 2>&1 | head -6 || true
    else
      echo "aerospace_cli_missing=1"
    fi
    echo
    echo "== listeners =="
    lsof -nP -iTCP:22 -sTCP:LISTEN 2>/dev/null || true
    lsof -nP -iTCP:5900 -sTCP:LISTEN 2>/dev/null || true
    if command -v tailscale >/dev/null 2>&1; then
      ip="$(tailscale ip -4 2>/dev/null | head -1 || true)"
      if [[ -n "$ip" ]]; then
        nc -G 3 -z "$ip" 22 >/dev/null 2>&1 && echo "ssh_tailnet_reachable=1" || echo "ssh_tailnet_reachable=0"
        nc -G 3 -z "$ip" 5900 >/dev/null 2>&1 && echo "vnc_tailnet_reachable=1" || echo "vnc_tailnet_reachable=0"
      fi
    fi
    echo
    echo "== processes =="
    pgrep -fl "Tailscale|AeroSpace|screensharingd|ARDAgent|sshd|caffeinate -dims" || true
  } >"$heartbeat_out" 2>"$heartbeat_err"
  local heartbeat_code=$?
  set -e
  RUN="$run" HEARTBEAT_OUT="$heartbeat_out" HEARTBEAT_ERR="$heartbeat_err" HEARTBEAT_CODE="$heartbeat_code" node <<'NODE' >"$run/heartbeat.json"
const fs = require("node:fs");
const out = fs.readFileSync(process.env.HEARTBEAT_OUT, "utf8");
const err = fs.readFileSync(process.env.HEARTBEAT_ERR, "utf8");
const tailscaleIpMatch = out.match(/tailscale_ip=([^\n]+)/);
const tailscaleIps = tailscaleIpMatch ? tailscaleIpMatch[1].trim().split(/\s+/).filter(Boolean) : [];
const checks = {
  command_completed: Number(process.env.HEARTBEAT_CODE) === 0,
  tailscale_cli_present: /tailscale_path=/.test(out),
  tailscale_ip_visible: tailscaleIps.some((ip) => ip.startsWith("100.")),
  ssh_listener_visible: /TCP.*:22 .*LISTEN/i.test(out) || /ssh_tailnet_reachable=1/.test(out),
  vnc_listener_visible: /TCP.*:5900 .*LISTEN/i.test(out) || /vnc_tailnet_reachable=1/.test(out),
  tailscale_process_visible: /Tailscale/i.test(out),
  aerospace_process_visible: /AeroSpace/i.test(out),
  aerospace_cli_present: /aerospace_path=/.test(out),
  aerospace_cli_reachable: /aerospace_cli_reachable=1/.test(out),
  controller_ping_ok: /pong from|pong in|via DERP|direct=true/i.test(out),
};
const fixes = [];
if (!checks.tailscale_ip_visible) fixes.push("Open Tailscale and confirm this lab Mac is connected to the tailnet with a 100.x IP.");
if (!checks.ssh_listener_visible) fixes.push("Enable Remote Login for administrators in System Settings > General > Sharing.");
if (!checks.vnc_listener_visible) fixes.push("Enable Screen Sharing or Remote Management and allow administrators to control the screen.");
if (!checks.aerospace_process_visible) fixes.push("Open AeroSpace and approve Accessibility if macOS prompts.");
if (checks.aerospace_cli_present && !checks.aerospace_cli_reachable) fixes.push("Restart the eventloopOS AeroSpace debug LaunchAgent; process is visible but the socket is not answering.");
const timestamp = out.match(/^timestamp=(.+)$/m)?.[1];
console.log(JSON.stringify({
  schema_version: 1,
  kind: "eventloopos.lab_mac_heartbeat",
  generated_at: timestamp || new Date().toISOString(),
  artifact_dir: process.env.RUN,
  checks,
  tailscale_ips: tailscaleIps,
  fixes,
  artifacts: {
    stdout: process.env.HEARTBEAT_OUT,
    stderr: process.env.HEARTBEAT_ERR,
  },
  stderr: err.trim(),
}, null, 2));
NODE
}

proof_lock_active() {
  [[ -d "$proof_lock_dir" ]] || return 1
  LOCK_DIR="$proof_lock_dir" TTL_SECONDS="${LAB_SELF_HEAL_PROOF_LOCK_TTL_SECONDS:-7200}" node <<'NODE'
const fs = require("node:fs");
const lockDir = process.env.LOCK_DIR;
const ttlSeconds = Number(process.env.TTL_SECONDS || "0");
try {
  const stat = fs.statSync(lockDir);
  const ageSeconds = (Date.now() - stat.mtimeMs) / 1000;
  process.exit(ttlSeconds > 0 && ageSeconds >= 0 && ageSeconds <= ttlSeconds ? 0 : 1);
} catch {
  process.exit(1);
}
NODE
}

tailscale_cli() {
  if command -v tailscale >/dev/null 2>&1; then
    command -v tailscale
    return 0
  fi
  if [[ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]]; then
    printf "%s\n" /Applications/Tailscale.app/Contents/MacOS/Tailscale
    return 0
  fi
  return 1
}

tailscale_has_tailnet_ip() {
  local cli="$1"
  TAILSCALE_BE_CLI=1 "$cli" ip -4 2>/dev/null | grep -E '^100\.' >/dev/null 2>&1
}

current_boot_key() {
  local key
  key="$(sysctl -n kern.boottime 2>/dev/null | sed -E 's/.*sec = ([0-9]+).*/\1/' || true)"
  if [[ -n "$key" && "$key" != *"{"* ]]; then
    printf "%s\n" "$key"
    return
  fi
  date +%s
}

maybe_wait_for_boot_network() {
  local delay="${LAB_SELF_HEAL_BOOT_DELAY_SECONDS:-10}"
  if ! [[ "$delay" =~ ^[0-9]+$ ]]; then
    delay=10
  fi
  if [[ "$delay" == "0" ]]; then
    echo "boot_delay_seconds=0"
    return
  fi
  local boot_key marker last_key
  boot_key="$(current_boot_key)"
  marker="$state_dir/last-boot-delay-key"
  last_key="$(cat "$marker" 2>/dev/null || true)"
  if [[ "$last_key" == "$boot_key" ]]; then
    echo "boot_delay_skipped=1 boot_key=$boot_key"
    return
  fi
  echo "boot_delay_seconds=$delay boot_key=$boot_key"
  sleep "$delay"
  printf "%s\n" "$boot_key" >"$marker"
}

ensure_tailscale_running() {
  local run="$1"
  local cli
  if ! cli="$(tailscale_cli)"; then
    echo "tailscale_cli_missing=1" | tee "$run/tailscale-autoconnect.out"
    : >"$run/tailscale-autoconnect.err"
    return 0
  fi
  {
    echo "tailscale_cli=$cli"
    echo "before_ips=$(TAILSCALE_BE_CLI=1 "$cli" ip -4 2>/dev/null | tr '\n' ' ')"
    TAILSCALE_BE_CLI=1 "$cli" status --json 2>/dev/null | node -e '
let input = "";
process.stdin.on("data", (chunk) => input += chunk);
process.stdin.on("end", () => {
  try {
    const status = JSON.parse(input);
    console.log(`before_backend_state=${status.BackendState ?? ""}`);
    console.log(`before_self_active=${status.Self?.Active ?? ""}`);
  } catch {
    console.log("before_status_json_unavailable=1");
  }
});
' || true
  } >"$run/tailscale-autoconnect.out" 2>"$run/tailscale-autoconnect.err"
  if tailscale_has_tailnet_ip "$cli"; then
    echo "tailscale_up_needed=0" >>"$run/tailscale-autoconnect.out"
    return 0
  fi
  echo "tailscale_up_needed=1" >>"$run/tailscale-autoconnect.out"
  if [[ "${LAB_SELF_HEAL_SKIP_TAILSCALE_UP:-0}" == "1" ]]; then
    echo "tailscale_up_skipped=1" >>"$run/tailscale-autoconnect.out"
    return 0
  fi
  open -gj -a Tailscale >/dev/null 2>&1 || true
  sleep 2
  TAILSCALE_BE_CLI=1 "$cli" up --timeout=20s >>"$run/tailscale-autoconnect.out" 2>>"$run/tailscale-autoconnect.err" || true
  echo "after_ips=$(TAILSCALE_BE_CLI=1 "$cli" ip -4 2>/dev/null | tr '\n' ' ')" >>"$run/tailscale-autoconnect.out"
}

install_agent() {
  mkdir -p "$agent_dir" "$log_dir" "$state_dir"
  local quoted_repo
  local quoted_controller
  quoted_repo="$(printf "%s" "$repo_root" | plist_escape)"
  quoted_controller="$(printf "%s" "$controller_tailnet_ip" | plist_escape)"
  cat >"$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd &quot;$quoted_repo&quot; &amp;&amp; LAB_CONTROLLER_TAILSCALE_IP=&quot;$quoted_controller&quot; bin/lab-mac-self-heal run</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>$start_interval</integer>
  <key>StandardOutPath</key>
  <string>$log_dir/lab-self-heal.out.log</string>
  <key>StandardErrorPath</key>
  <string>$log_dir/lab-self-heal.err.log</string>
  <key>WorkingDirectory</key>
  <string>$quoted_repo</string>
</dict>
</plist>
EOF
  if [[ "${LAB_SELF_HEAL_NO_LAUNCHCTL:-0}" == "1" ]]; then
    echo "lab self-heal plist written without launchctl: $plist"
    return
  fi
  launchctl bootout "gui/$(id -u)" "$plist" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$plist"
  launchctl kickstart -k "gui/$(id -u)/$label" >/dev/null 2>&1 || true
  echo "lab self-heal installed: $plist"
  install_custom_aerospace_agent
}

install_custom_aerospace_agent() {
  if [[ ! -x "$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp" ]]; then
    echo "custom AeroSpace debug app missing; skipped direct LaunchAgent: $HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp"
    return
  fi
  mkdir -p "$agent_dir" "$log_dir"
  cat >"$aerospace_plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$aerospace_label</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>export PATH=&quot;/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\$PATH&quot;; cd &quot;\$HOME/dev/2026/AeroSpace&quot; &amp;&amp; exec &quot;\$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp&quot;</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$log_dir/aerospace-debug-server.out.log</string>
  <key>StandardErrorPath</key>
  <string>$log_dir/aerospace-debug-server.err.log</string>
  <key>WorkingDirectory</key>
  <string>$HOME/dev/2026/AeroSpace</string>
</dict>
</plist>
EOF
  restart_custom_aerospace_agent
  echo "custom AeroSpace direct LaunchAgent installed: $aerospace_plist"
  if [[ -f "$terminal_aerospace_plist" ]]; then
    echo "old Terminal AeroSpace launcher unloaded: $terminal_aerospace_plist"
  else
    echo "old Terminal AeroSpace launcher removed: $terminal_aerospace_plist"
  fi
}

status_agent() {
  echo "plist=$plist"
  if [[ -f "$plist" ]]; then
    echo "plist_present=1"
  else
    echo "plist_present=0"
  fi
  launchctl print "gui/$(id -u)/$label" 2>/dev/null || true
  echo
  echo "aerospace_plist=$aerospace_plist"
  if [[ -f "$aerospace_plist" ]]; then
    echo "aerospace_plist_present=1"
  else
    echo "aerospace_plist_present=0"
  fi
  launchctl print "gui/$(id -u)/$aerospace_label" 2>/dev/null || true
  echo
  echo "recent_logs=$log_dir"
  tail -n 80 "$log_dir/lab-self-heal.out.log" 2>/dev/null || true
  tail -n 80 "$log_dir/lab-self-heal.err.log" 2>/dev/null || true
  tail -n 80 "$log_dir/aerospace-debug-server.out.log" 2>/dev/null || true
  tail -n 80 "$log_dir/aerospace-debug-server.err.log" 2>/dev/null || true
}

uninstall_agent() {
  launchctl bootout "gui/$(id -u)" "$plist" >/dev/null 2>&1 || true
  launchctl bootout "gui/$(id -u)" "$aerospace_plist" >/dev/null 2>&1 || true
  rm -f "$plist"
  rm -f "$aerospace_plist"
  echo "lab self-heal uninstalled: $plist"
}

run_once() {
  mkdir -p "$state_dir" "$log_dir"
  local run="artifacts/lab-runs/$(date +%Y%m%d-%H%M%S)-self-heal"
  mkdir -p "$run"
  local code
  local proof_active=0
  if proof_lock_active; then
    proof_active=1
  fi
  set +e
  {
    echo "eventloopOS lab self-heal run"
    date -u +%Y-%m-%dT%H:%M:%SZ
    echo "repo=$repo_root"
    echo "controller=$controller_tailnet_ip"
    echo "proof_lock_dir=$proof_lock_dir"
    echo "proof_lock_active=$proof_active"
    echo
    echo "== boot network wait =="
    maybe_wait_for_boot_network
    echo
    echo "== keep awake =="
    if [[ "${LAB_SELF_HEAL_SKIP_CAFFEINATE:-0}" == "1" ]]; then
      echo "skipped caffeinate"
    elif ! pgrep -fl "caffeinate -dims" >/dev/null 2>&1; then
      nohup caffeinate -dims >"$log_dir/caffeinate.out.log" 2>"$log_dir/caffeinate.err.log" &
      echo "started caffeinate pid=$!"
    else
      pgrep -fl "caffeinate -dims"
    fi
    echo
    echo "== open user agents =="
    if [[ "$proof_active" == "1" ]]; then
      echo "skipped opening Tailscale/AeroSpace because product-readiness proof lock is active"
    elif [[ "${LAB_SELF_HEAL_SKIP_OPEN:-0}" == "1" ]]; then
      echo "skipped opening Tailscale/AeroSpace"
    else
      if pgrep -fl "/Tailscale.app/Contents/MacOS/Tailscale" >/dev/null 2>&1; then
        echo "Tailscale already running"
      else
        open -gj -a Tailscale >/dev/null 2>&1 || true
      fi
      if [[ "$aerospace_mode" == "skip" ]]; then
        echo "skipped opening AeroSpace by LAB_SELF_HEAL_AEROSPACE_MODE=skip"
      elif [[ "$aerospace_mode" == "custom" || ( "$aerospace_mode" == "auto" && -x "$custom_aerospace_runner" ) ]]; then
        if pgrep -fl "/AeroSpace/.debug/AeroSpaceApp|run-aerospace.command" >/dev/null 2>&1; then
          echo "custom AeroSpace runner already visible"
        else
          echo "custom AeroSpace runner configured but not visible; relying on dev.eventloopos.aerospace-terminal-launcher LaunchAgent"
        fi
        while IFS= read -r release_pid; do
          [[ -n "$release_pid" ]] || continue
          echo "stopping duplicate LaunchServices AeroSpace pid=$release_pid while custom runner is active"
          kill "$release_pid" >/dev/null 2>&1 || true
        done < <(pgrep -f "/AeroSpace/.release/AeroSpace.app/Contents/MacOS/AeroSpace|/Applications/AeroSpace.app/Contents/MacOS/AeroSpace" || true)
      else
        if pgrep -fl "/AeroSpace.app/Contents/MacOS/AeroSpace|/AeroSpace/.debug/AeroSpaceApp|run-aerospace.command" >/dev/null 2>&1; then
          echo "AeroSpace already running"
        else
          open -gj -a AeroSpace >/dev/null 2>&1 || true
        fi
      fi
      sleep 3
      if [[ "$aerospace_mode" == "custom" || ( "$aerospace_mode" == "auto" && -x "$HOME/dev/2026/AeroSpace/.debug/AeroSpaceApp" ) ]]; then
        if aerospace_cli_reachable; then
          echo "custom AeroSpace CLI reachable"
        else
          echo "custom AeroSpace CLI unhealthy; restarting debug LaunchAgent"
          restart_custom_aerospace_agent
          sleep 5
          if aerospace_cli_reachable; then
            echo "custom AeroSpace CLI recovered"
          else
            echo "custom AeroSpace CLI still unreachable after restart"
          fi
        fi
      fi
    fi
    echo
    echo "== tailscale autoconnect =="
    ensure_tailscale_running "$run"
    cat "$run/tailscale-autoconnect.out" 2>/dev/null || true
    cat "$run/tailscale-autoconnect.err" 2>/dev/null || true
    echo
    echo "== heartbeat =="
    write_heartbeat "$run"
    jq '{checks, tailscale_ips, fixes}' "$run/heartbeat.json"
    echo
    echo "== local recovery =="
    if [[ "$proof_active" == "1" ]]; then
      echo "skipped local recovery because product-readiness proof lock is active"
    elif [[ -n "${LAB_SELF_HEAL_RECOVERY_COMMAND:-}" ]]; then
      bash -lc "$LAB_SELF_HEAL_RECOVERY_COMMAND"
    elif [[ -n "$controller_tailnet_ip" ]]; then
      LAB_CONTROLLER_TAILSCALE_IP="$controller_tailnet_ip" bin/lab-mac-local-recovery-check
    else
      bin/lab-mac-local-recovery-check
    fi
  } >"$run/self-heal.stdout.log" 2>"$run/self-heal.stderr.log"
  code=$?
  set -e
  if [[ "$code" == "0" ]] && jq -e '.checks.aerospace_cli_present == true and .checks.aerospace_cli_reachable == false' "$run/heartbeat.json" >/dev/null 2>&1; then
    code=1
    echo "aerospace_cli_unreachable_after_self_heal=1" >>"$run/self-heal.stderr.log"
  fi
  local recovery_run
  recovery_run="$(grep -E "^artifacts/lab-runs/.+-local-recovery-check$" "$run/self-heal.stdout.log" | tail -1 || true)"
  if [[ -n "$recovery_run" ]]; then
    printf "%s/manifest.json\n" "$recovery_run" >"$run/local-recovery-manifest.txt"
  else
    : >"$run/local-recovery-manifest.txt"
  fi
  if [[ "$code" == "0" ]]; then
    write_manifest "$run" 1 "self-heal local recovery checks passed"
  else
    write_manifest "$run" 0 "self-heal local recovery checks failed; inspect linked local recovery manifest and logs"
  fi
  echo "$run"
  jq '{ok, reason, artifacts}' "$run/manifest.json"
  exit "$code"
}

case "$action" in
  install) install_agent ;;
  status) status_agent ;;
  uninstall) uninstall_agent ;;
  run) run_once ;;
esac
