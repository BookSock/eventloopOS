#!/usr/bin/env node
import { mkdtemp, rm, writeFile } from "node:fs/promises";
import { tmpdir } from "node:os";
import { join } from "node:path";
import { spawn } from "node:child_process";
import {
  buildPackagedQueueAppBundle,
  openQueueApp,
  spawnChecked,
  terminateProcessByExecutablePath,
  waitForExit,
} from "./smoke-app-bundle.mjs";

if (process.platform !== "darwin") {
  console.log("macOS live task handoff smoke skipped: requires darwin");
  process.exit(0);
}

if (process.env.EVENTLOOPOS_ENABLE_MACOS_LIVE_HANDOFF_SMOKE !== "1") {
  console.log("macOS live task handoff smoke skipped: set EVENTLOOPOS_ENABLE_MACOS_LIVE_HANDOFF_SMOKE=1");
  process.exit(0);
}

const port = process.env.EVENTLOOPOS_MACOS_LIVE_HANDOFF_SMOKE_PORT ?? "4384";
const baseUrl = process.env.EVENTLOOPOS_ORCHESTRATOR_URL ?? `http://127.0.0.1:${port}`;
let server;
let bundle;
let app;
let tempDir;

try {
  tempDir = await mkdtemp(join(tmpdir(), "eventloopos-live-handoff-"));
  const seedFixture = join(tempDir, "seed-review-packets.json");
  await writeFile(seedFixture, JSON.stringify([buildTaskHandoffPacket()], null, 2));

  await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "build"]);
  server = spawn("pnpm", ["--filter", "@eventloopos/orchestrator", "start"], {
    env: {
      ...process.env,
      ORCHESTRATOR_HOST: "127.0.0.1",
      ORCHESTRATOR_PORT: port,
      ORCHESTRATOR_SEED_FIXTURE: seedFixture,
      ORCHESTRATOR_WORKSPACE: "off",
      ORCHESTRATOR_MCP_SOURCES: "off",
      ORCHESTRATOR_TASK_SESSIONS: "fake",
    },
    stdio: "inherit",
  });
  await waitForHealth(baseUrl, server);

  const initialReady = await fetchJson(new URL("/queue?state=ready", baseUrl));
  if (initialReady.count !== 1) {
    throw new Error(`expected 1 ready handoff queue item before app launch, got ${initialReady.count}`);
  }

  bundle = await buildPackagedQueueAppBundle({
    executableName: "EventLoopQueueHandoffSmoke",
    bundleIdentifier: "dev.eventloopos.queue.smoke.live-handoff",
    bundleName: "eventloopOS Queue Handoff Smoke",
  });
  app = openQueueApp(bundle.appBundle, {
    appArgs: ["--orchestrator-url", baseUrl],
    env: {
      EVENTLOOP_ORCHESTRATOR_URL: baseUrl,
    },
  });
  captureOutput(app);

  await waitForProcess(bundle.executablePath, 8_000);
  const uiProof = await runLiveHandoffProof(bundle.processName);

  const doneQueue = await waitForDoneQueueItem(baseUrl);
  const attempted = await waitForActivity(baseUrl, "task_followup_attempted");
  const sent = await waitForActivity(baseUrl, "task_followup_sent");
  const done = await waitForActivity(baseUrl, "queue_item_done");
  const taskSessions = await fetchJson(new URL("/task-sessions", baseUrl));
  const metrics = await fetchJson(new URL("/metrics", baseUrl));
  const blogSession = taskSessions.sessions?.find((session) => session.id === "task_session_blog");

  if (!blogSession) throw new Error("task_session_blog missing after handoff");
  if (blogSession.status !== "running") {
    throw new Error(`expected task_session_blog status running after handoff, got ${blogSession.status}`);
  }
  if ((metrics.metrics?.counters?.task_followups_sent_total ?? 0) !== 1) {
    throw new Error("expected task_followups_sent_total to be 1");
  }
  if ((metrics.metrics?.counters?.queue_items_done_total ?? 0) !== 1) {
    throw new Error("expected queue_items_done_total to be 1");
  }

  await cleanupApp();
  console.log(JSON.stringify({
    ok: true,
    base_url: baseUrl,
    ui_proof: uiProof,
    done_queue_count: doneQueue.count,
    done_queue_item_id: doneQueue.items[0]?.id,
    task_session_id: blogSession.id,
    task_session_status: blogSession.status,
    task_followup_attempted_activity_id: attempted.id,
    task_followup_sent_activity_id: sent.id,
    queue_item_done_activity_id: done.id,
    task_followups_sent_total: metrics.metrics.counters.task_followups_sent_total,
    queue_items_done_total: metrics.metrics.counters.queue_items_done_total,
  }, null, 2));
} catch (error) {
  if (app && bundle) {
    await tryTerminate(bundle.executablePath, app);
  }
  const output = app?.capturedOutput?.() ?? "";
  console.error(`${error instanceof Error ? error.message : String(error)}${output ? `\n${output}` : ""}`);
  process.exitCode = 1;
} finally {
  if (bundle) await bundle.cleanup();
  if (server && !server.killed) {
    server.kill("SIGTERM");
    await onceExit(server);
  }
  if (tempDir) {
    await rm(tempDir, { recursive: true, force: true });
  }
}

function buildTaskHandoffPacket() {
  return {
    id: "pkt_live_task_handoff",
    task_id: "task_blog_feedback",
    title: "Route blog feedback to task agent",
    summary: "Human approved routing this blog feedback packet back to the running task agent.",
    decision_needed: "Confirm the blog agent should continue with this feedback.",
    risk_level: "medium",
    confidence: "high",
    risk_tags: ["agent_handoff"],
    evidence: [
      {
        id: "ev_live_handoff_seed",
        kind: "test_run",
        title: "Live Mac handoff smoke fixture",
        url: "artifact://mac/live-task-handoff",
      },
    ],
    context: [
      {
        id: "ctx_live_handoff_doc",
        kind: "document",
        title: "Blog feedback draft",
        url: "file:///tmp/eventloopos/blog-feedback.md",
        restore_confidence: "medium",
      },
    ],
    recommended_action: {
      id: "act_live_task_handoff_resume",
      type: "resume_agent",
      label: "Route to task agent",
      requires_confirmation: false,
      side_effect: "local",
      payload: {},
    },
    alternate_actions: [
      {
        id: "act_live_task_handoff_done",
        type: "mark_done",
        label: "Mark done",
        requires_confirmation: false,
        side_effect: "none",
        payload: {},
      },
    ],
    created_at: "2026-05-07T00:00:00.000Z",
    updated_at: "2026-05-07T00:00:00.000Z",
  };
}

async function runLiveHandoffProof(processName) {
  const script = `
on waitForMenuBarExtra()
  repeat with attempt from 1 to 80
    tell application "System Events"
      if exists process "${processName}" then
        tell process "${processName}"
          if (count of menu bars) is greater than or equal to 2 then return
        end tell
      end if
    end tell
    delay 0.1
  end repeat
  error "EventLoopQueueApp menu bar extra did not appear"
end waitForMenuBarExtra

on clickMenuItem(itemName)
  waitForMenuBarExtra()
  tell application "System Events"
    tell process "${processName}"
      tell menu bar item 1 of menu bar 2
        click
        delay 0.2
        click menu item itemName of menu 1
      end tell
    end tell
  end tell
end clickMenuItem

on waitForEnabledMenuItem(expectedValue)
  repeat with attempt from 1 to 60
    waitForMenuBarExtra()
    tell application "System Events"
      tell process "${processName}"
        tell menu bar item 1 of menu bar 2
          click
          delay 0.2
          if exists menu item expectedValue of menu 1 then
            set itemEnabled to enabled of menu item expectedValue of menu 1
            key code 53
            if itemEnabled then return
          else
            key code 53
          end if
        end tell
      end tell
    end tell
    delay 0.1
  end repeat
  error "menu item never enabled: " & expectedValue
end waitForEnabledMenuItem

waitForEnabledMenuItem("Pull Next Paper")
clickMenuItem("Pull Next Paper")
delay 0.6
waitForEnabledMenuItem("Route to task agent")
clickMenuItem("Route to task agent")
delay 0.6
return "live task handoff clicked"
`;

  const result = await spawnChecked("osascript", ["-e", script]);
  return result.stdout.trim();
}

async function waitForDoneQueueItem(url) {
  const deadline = Date.now() + 5_000;
  while (Date.now() < deadline) {
    const queue = await fetchJson(new URL("/queue?state=done", url));
    if (queue.count === 1 && queue.items?.[0]?.state === "done") return queue;
    await sleep(200);
  }
  throw new Error("timed out waiting for done queue item after live handoff action");
}

async function waitForActivity(url, type) {
  const deadline = Date.now() + 5_000;
  while (Date.now() < deadline) {
    const activity = await fetchJson(new URL("/activity?limit=30", url));
    const found = activity.events?.find((event) => event.type === type);
    if (found) return found;
    await sleep(200);
  }
  throw new Error(`timed out waiting for activity ${type}`);
}

async function waitForHealth(url, child) {
  const deadline = Date.now() + 15_000;
  let exited = false;
  child.once("exit", () => {
    exited = true;
  });

  while (Date.now() < deadline) {
    if (exited) throw new Error("orchestrator exited before health check passed");
    try {
      const response = await fetch(new URL("/health", url));
      if (response.ok) return;
    } catch {
      // Server not ready yet.
    }
    await sleep(250);
  }
  throw new Error(`timed out waiting for orchestrator health at ${url}/health`);
}

async function waitForProcess(executablePath, timeoutMs) {
  const deadline = Date.now() + timeoutMs;
  while (Date.now() < deadline) {
    const ps = await spawnChecked("ps", ["-axo", "command="]);
    if (ps.stdout.includes(executablePath)) return;
    await sleep(100);
  }
  throw new Error(`EventLoopQueueApp process did not appear for ${executablePath}`);
}

async function fetchJson(url) {
  const response = await fetch(url);
  const body = await response.json();
  if (!response.ok) {
    throw new Error(`${response.status} ${url.pathname}: ${JSON.stringify(body)}`);
  }
  return body;
}

function captureOutput(child) {
  let output = "";
  child.stdout.on("data", (chunk) => {
    output += chunk.toString();
  });
  child.stderr.on("data", (chunk) => {
    output += chunk.toString();
  });
  child.capturedOutput = () => output;
  return output;
}

async function cleanupApp() {
  if (!bundle || !app) return;
  await terminateProcessByExecutablePath(bundle.executablePath);
  await waitForExit(app, 3_000);
}

async function tryTerminate(executablePath, child) {
  try {
    await terminateProcessByExecutablePath(executablePath);
    await waitForExit(child, 3_000);
  } catch {
    child.kill("SIGKILL");
  }
}

async function onceExit(child) {
  if (child.exitCode !== null || child.signalCode !== null) return;
  await new Promise((resolve) => child.once("exit", resolve));
}

async function sleep(ms) {
  await new Promise((resolve) => setTimeout(resolve, ms));
}
