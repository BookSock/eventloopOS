#!/usr/bin/env node
// V9c — proof that AppleSpeechVoiceTranscriptionService's buffer-fed code path
// works end-to-end against a fixture WAV. Mirrors the production service's
// shape: an `SFSpeechAudioBufferRecognitionRequest` is fed by a
// `VoiceBufferSource` that reads `AVAudioFile` -> `AVAudioPCMBuffer` and emits
// chunks via `request.append(buffer)`. After `endAudio()`, the recognizer
// finalizes and we assert the transcript contains the expected token.
//
// V9 (whisper.cpp) and V9b (`SFSpeechURLRecognitionRequest`) prove adjacent
// legs. This proof exercises the exact `SFSpeechAudioBufferRecognitionRequest`
// + `AVAudioPCMBuffer.append` flow that the production service uses; the only
// difference from production is that buffers come from an `AVAudioFile` rather
// than `AVAudioEngine.inputNode`. The refactor in
// `AppleSpeechVoiceTranscriptionService` moved that source behind a
// `VoiceBufferSource` protocol so the buffer-fed path can be driven by either
// `MicVoiceBufferSource` (production) or `FileVoiceBufferSource` (this proof).
//
// Gate: skipped unless EVENTLOOPOS_ENABLE_APPLE_SPEECH_BUFFER_SMOKE=1.
// Skips with PASS-NOOP on non-darwin, missing tools, or denied TCC consent.
//
// Optional env:
//   EVENTLOOPOS_VOICE_FAN_OUT_PHRASE       override fixture phrase
//   EVENTLOOPOS_VOICE_STT_SAY_VOICE        macOS `say` voice (default Samantha)
//   EVENTLOOPOS_APPLE_SPEECH_EXPECT_TOKEN  expected substring (default "email")
//   EVENTLOOPOS_APPLE_SPEECH_TIMEOUT_MS    recognition timeout (default 30000)

import { mkdtemp, rm, writeFile } from "node:fs/promises";
import { tmpdir } from "node:os";
import path from "node:path";
import { spawn } from "node:child_process";

if (process.env.EVENTLOOPOS_ENABLE_APPLE_SPEECH_BUFFER_SMOKE !== "1") {
  console.log("v9c apple speech buffer smoke skipped: set EVENTLOOPOS_ENABLE_APPLE_SPEECH_BUFFER_SMOKE=1");
  process.exit(0);
}

if (process.platform !== "darwin") {
  console.log("v9c apple speech buffer smoke skipped: requires darwin");
  process.exit(0);
}

const phrase = process.env.EVENTLOOPOS_VOICE_FAN_OUT_PHRASE
  ?? "all email tasks should use the new sign off";
const sayVoice = process.env.EVENTLOOPOS_VOICE_STT_SAY_VOICE ?? "Samantha";
const expectedToken = (process.env.EVENTLOOPOS_APPLE_SPEECH_EXPECT_TOKEN ?? "email").trim().toLowerCase();
const timeoutMs = Number.parseInt(process.env.EVENTLOOPOS_APPLE_SPEECH_TIMEOUT_MS ?? "30000", 10);

for (const tool of ["say", "ffmpeg", "swift"]) {
  if (!(await toolOnPath(tool))) {
    console.log(`v9c apple speech buffer smoke skipped: missing tool '${tool}' on PATH`);
    process.exit(0);
  }
}

let tempDir;
try {
  tempDir = await mkdtemp(path.join(tmpdir(), "eventloopos-v9c-apple-speech-"));
  const aiffPath = path.join(tempDir, "fixture.aiff");
  const wavPath = path.join(tempDir, "fixture.wav");
  const swiftPath = path.join(tempDir, "speech_buffer_proof.swift");

  console.log(`v9c phrase: ${JSON.stringify(phrase)}`);
  console.log(`v9c expected_token: ${JSON.stringify(expectedToken)}`);

  await spawnChecked("say", ["-v", sayVoice, "-o", aiffPath, phrase]);
  await spawnChecked("ffmpeg", ["-y", "-loglevel", "error", "-i", aiffPath, "-ar", "16000", "-ac", "1", wavPath]);

  await writeFile(swiftPath, swiftSource(timeoutMs));

  const swiftResult = await spawnAllowFail("swift", [swiftPath, wavPath]);
  process.stdout.write(swiftResult.stdout);
  if (swiftResult.stderr.trim().length > 0) {
    process.stderr.write(swiftResult.stderr);
  }

  const parsed = parseSwiftOutput(swiftResult.stdout);
  if (!parsed) {
    throw new Error(`swift proof produced no parseable result. exit=${swiftResult.exitCode}`);
  }

  console.log(`v9c swift_version: ${(await spawnChecked("swift", ["--version"])).stdout.split("\n")[0]}`);
  console.log(`v9c auth_status: ${parsed.authStatus}`);
  console.log(`v9c recognizer_available: ${parsed.recognizerAvailable}`);
  console.log(`v9c buffers_appended: ${parsed.buffersAppended ?? 0}`);
  console.log(`v9c transcript: ${JSON.stringify(parsed.transcript ?? "")}`);

  if (parsed.outcome === "skipped_unauthorized") {
    console.log("v9c apple speech buffer smoke: SKIP (Speech authorization not granted).");
    console.log("To grant consent, run this bin from Terminal.app interactively once:");
    console.log("  EVENTLOOPOS_ENABLE_APPLE_SPEECH_BUFFER_SMOKE=1 app/macos/bin/v9c-apple-speech-buffer-smoke");
    console.log("Then approve the prompt in System Settings -> Privacy & Security -> Speech Recognition.");
    process.exit(0);
  }

  if (parsed.outcome === "skipped_unavailable") {
    console.log("v9c apple speech buffer smoke: SKIP (SFSpeechRecognizer reports unavailable on this Mac).");
    process.exit(0);
  }

  if (parsed.outcome !== "ok") {
    throw new Error(`swift proof reported outcome=${parsed.outcome} error=${parsed.error ?? "<none>"}`);
  }

  if (typeof parsed.transcript !== "string" || parsed.transcript.length === 0) {
    throw new Error("Speech recognition returned empty transcript");
  }

  if (!parsed.transcript.toLowerCase().includes(expectedToken)) {
    throw new Error(`expected transcript to include "${expectedToken}", got ${JSON.stringify(parsed.transcript)}`);
  }

  if ((parsed.buffersAppended ?? 0) <= 0) {
    throw new Error("FileVoiceBufferSource appended zero buffers — buffer-fed path was not exercised");
  }

  console.log(JSON.stringify({
    ok: true,
    test: "v9c-apple-speech-buffer-smoke",
    phrase,
    transcript: parsed.transcript,
    auth_status: parsed.authStatus,
    expected_token: expectedToken,
    buffers_appended: parsed.buffersAppended,
  }, null, 2));
  console.log("v9c apple speech buffer smoke: PASS");
} catch (error) {
  console.error("v9c apple speech buffer smoke: FAIL");
  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
  process.exitCode = 1;
} finally {
  if (tempDir) {
    await rm(tempDir, { recursive: true, force: true });
  }
}

function swiftSource(timeoutMs) {
  return `import AVFoundation
import Foundation
import Speech

// Mirrors AppleSpeechVoiceTranscriptionService's buffer-fed code path:
//   - SFSpeechAudioBufferRecognitionRequest with shouldReportPartialResults
//   - VoiceBufferSource emits AVAudioPCMBuffer chunks
//   - request.append(buffer) for each chunk, then endAudio() when source ends
//   - recognitionTask resolves with bestTranscription.formattedString on isFinal
//
// FileVoiceBufferSource here is the same shape as
// app/macos/Sources/EventLoopQueueApp/FileVoiceBufferSource.swift (kept inline
// so this proof has zero build-graph dependency on the EventLoopQueueApp
// target, matching v9b's structure).

protocol VoiceBufferSource: AnyObject {
    var recordingFormat: AVAudioFormat { get }
    func start(onBuffer: @escaping (AVAudioPCMBuffer) -> Void) throws
    func stop()
}

final class FileVoiceBufferSource: VoiceBufferSource {
    private let audioFile: AVAudioFile
    private let chunkFrames: AVAudioFrameCount
    private var stopped = false
    private let stopLock = NSLock()

    init(url: URL, chunkFrames: AVAudioFrameCount = 1024) throws {
        self.audioFile = try AVAudioFile(forReading: url)
        self.chunkFrames = chunkFrames
    }

    var recordingFormat: AVAudioFormat { audioFile.processingFormat }

    func start(onBuffer: @escaping (AVAudioPCMBuffer) -> Void) throws {
        stopLock.lock(); stopped = false; stopLock.unlock()
        let format = audioFile.processingFormat
        let totalFrames = audioFile.length
        let chunk = chunkFrames
        let file = audioFile
        DispatchQueue(label: "v9c.file.emit").async { [weak self] in
            guard let self else { return }
            file.framePosition = 0
            var remaining = totalFrames
            while remaining > 0 {
                self.stopLock.lock(); let isStopped = self.stopped; self.stopLock.unlock()
                if isStopped { return }
                let frames = AVAudioFrameCount(min(Int64(chunk), remaining))
                guard let buffer = AVAudioPCMBuffer(pcmFormat: format, frameCapacity: frames) else { return }
                do { try file.read(into: buffer, frameCount: frames) } catch { return }
                if buffer.frameLength == 0 { return }
                onBuffer(buffer)
                remaining -= Int64(buffer.frameLength)
            }
        }
    }

    func stop() { stopLock.lock(); stopped = true; stopLock.unlock() }
}

let args = CommandLine.arguments
guard args.count >= 2 else {
    print("V9C_RESULT={\\"outcome\\":\\"error\\",\\"error\\":\\"missing_wav_path\\"}")
    exit(0)
}
let wavPath = args[1]
let wavURL = URL(fileURLWithPath: wavPath)
guard FileManager.default.fileExists(atPath: wavPath) else {
    print("V9C_RESULT={\\"outcome\\":\\"error\\",\\"error\\":\\"wav_missing\\"}")
    exit(0)
}

let authSemaphore = DispatchSemaphore(value: 0)
var authStatus: SFSpeechRecognizerAuthorizationStatus = .notDetermined
SFSpeechRecognizer.requestAuthorization { status in
    authStatus = status
    authSemaphore.signal()
}
authSemaphore.wait()

let authLabel: String
switch authStatus {
case .notDetermined: authLabel = "notDetermined"
case .denied: authLabel = "denied"
case .restricted: authLabel = "restricted"
case .authorized: authLabel = "authorized"
@unknown default: authLabel = "unknown"
}

func emit(_ payload: [String: Any]) {
    var merged = payload
    merged["authStatus"] = authLabel
    if let data = try? JSONSerialization.data(withJSONObject: merged, options: []),
       let json = String(data: data, encoding: .utf8) {
        print("V9C_RESULT=\\(json)")
    } else {
        print("V9C_RESULT={\\"outcome\\":\\"error\\",\\"error\\":\\"serialize_failed\\",\\"authStatus\\":\\"\\(authLabel)\\"}")
    }
}

guard authStatus == .authorized else {
    emit(["outcome": "skipped_unauthorized", "recognizerAvailable": false])
    exit(0)
}

guard let recognizer = SFSpeechRecognizer(locale: Locale(identifier: "en-US")) ?? SFSpeechRecognizer() else {
    emit(["outcome": "error", "error": "no_recognizer", "recognizerAvailable": false])
    exit(0)
}

if !recognizer.isAvailable {
    emit(["outcome": "skipped_unavailable", "recognizerAvailable": false])
    exit(0)
}

let request = SFSpeechAudioBufferRecognitionRequest()
request.shouldReportPartialResults = true

final class Box: @unchecked Sendable {
    var transcript: String?
    var error: String?
    var resolved = false
    var buffersAppended = 0
    let lock = NSLock()
}
let box = Box()

let source: VoiceBufferSource
do {
    source = try FileVoiceBufferSource(url: wavURL)
} catch {
    emit(["outcome": "error", "error": "open_audio_file_failed: \\(error.localizedDescription)", "recognizerAvailable": true])
    exit(0)
}

let recognitionQueue = DispatchQueue(label: "v9c.recognition")
recognitionQueue.async {
    _ = recognizer.recognitionTask(with: request) { result, error in
        box.lock.lock()
        defer { box.lock.unlock() }
        if box.resolved { return }
        if let error = error as NSError? {
            box.resolved = true
            box.error = "domain=\\(error.domain) code=\\(error.code) desc=\\(error.localizedDescription)"
            CFRunLoopStop(CFRunLoopGetMain())
            return
        }
        if let result = result, result.isFinal {
            box.resolved = true
            box.transcript = result.bestTranscription.formattedString
            CFRunLoopStop(CFRunLoopGetMain())
            return
        }
    }
}

do {
    try source.start { buffer in
        box.lock.lock(); box.buffersAppended += 1; box.lock.unlock()
        request.append(buffer)
    }
} catch {
    emit(["outcome": "error", "error": "source_start_failed: \\(error.localizedDescription)", "recognizerAvailable": true])
    exit(0)
}

// Read total file frames to estimate playback duration; signal endAudio after
// all buffers have been emitted. We schedule endAudio after enough wall time
// for the emitter to finish; the emitter is non-blocking and chunks ~1024
// frames at a time, so a tiny grace period is plenty.
let audioFileForLength = try? AVAudioFile(forReading: wavURL)
let durationSeconds = audioFileForLength.map { Double($0.length) / $0.processingFormat.sampleRate } ?? 1.0
let endAudioDelay = durationSeconds + 0.25

DispatchQueue.global().asyncAfter(deadline: .now() + endAudioDelay) {
    request.endAudio()
}

let deadline = Date().addingTimeInterval(${timeoutMs} / 1000.0)
var timedOut = false
DispatchQueue.global().async {
    Thread.sleep(until: deadline)
    box.lock.lock(); let stillRunning = !box.resolved; box.lock.unlock()
    if stillRunning {
        timedOut = true
        CFRunLoopStop(CFRunLoopGetMain())
    }
}

CFRunLoopRun()

source.stop()

box.lock.lock()
let outTranscript = box.transcript
let outError = box.error
let outBuffers = box.buffersAppended
box.lock.unlock()

if timedOut && outTranscript == nil && outError == nil {
    emit(["outcome": "error", "error": "timeout_after_${timeoutMs}ms", "recognizerAvailable": true, "buffersAppended": outBuffers])
    exit(0)
}

if let err = outError {
    emit(["outcome": "error", "error": err, "recognizerAvailable": true, "buffersAppended": outBuffers])
    exit(0)
}

guard let transcript = outTranscript else {
    emit(["outcome": "error", "error": "no_final_result", "recognizerAvailable": true, "buffersAppended": outBuffers])
    exit(0)
}

emit(["outcome": "ok", "transcript": transcript, "recognizerAvailable": true, "buffersAppended": outBuffers])
`;
}

function parseSwiftOutput(stdout) {
  const lines = stdout.split(/\r?\n/);
  for (let i = lines.length - 1; i >= 0; i--) {
    const line = lines[i];
    const idx = line.indexOf("V9C_RESULT=");
    if (idx === -1) continue;
    const json = line.slice(idx + "V9C_RESULT=".length).trim();
    try {
      return JSON.parse(json);
    } catch {
      return null;
    }
  }
  return null;
}

function toolOnPath(tool) {
  return new Promise((resolve) => {
    const child = spawn("which", [tool], { stdio: ["ignore", "ignore", "ignore"] });
    child.on("error", () => resolve(false));
    child.on("exit", (code) => resolve(code === 0));
  });
}

async function spawnChecked(file, args) {
  return await new Promise((resolve, reject) => {
    const child = spawn(file, args, { stdio: ["ignore", "pipe", "pipe"] });
    let stdout = "";
    let stderr = "";
    child.stdout.on("data", (chunk) => { stdout += chunk.toString(); });
    child.stderr.on("data", (chunk) => { stderr += chunk.toString(); });
    child.on("error", reject);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolve({ stdout, stderr });
        return;
      }
      reject(new Error(`${file} ${args.join(" ")} exited with ${signal ?? code}\n${stdout}${stderr}`));
    });
  });
}

async function spawnAllowFail(file, args) {
  return await new Promise((resolve, reject) => {
    const child = spawn(file, args, { stdio: ["ignore", "pipe", "pipe"] });
    let stdout = "";
    let stderr = "";
    child.stdout.on("data", (chunk) => { stdout += chunk.toString(); });
    child.stderr.on("data", (chunk) => { stderr += chunk.toString(); });
    child.on("error", reject);
    child.on("exit", (code, signal) => {
      resolve({ stdout, stderr, exitCode: code, signal });
    });
  });
}
