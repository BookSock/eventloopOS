{
  "manifest_version": 3,
  "name": "eventloopOS Browser Context",
  "version": "0.0.1",
  "description": "Captures and restores browser context for eventloopOS.",
  "permissions": ["activeTab", "alarms", "nativeMessaging", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Capture browser context"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
