#!/usr/bin/env node
import { execFile, spawn } from "node:child_process";
import { mkdtemp, mkdir, rm } from "node:fs/promises";
import net from "node:net";
import { tmpdir } from "node:os";
import path from "node:path";
import pg from "pg";

const { Client } = pg;

const command = process.argv[2] ?? "url";
const containerName = process.env.EVENTLOOPOS_POSTGRES_CONTAINER ?? "eventloopos-postgres";
const image = process.env.EVENTLOOPOS_POSTGRES_IMAGE ?? "postgres:16-alpine";
const port = process.env.EVENTLOOPOS_POSTGRES_PORT ?? "55432";
const databaseUrl = process.env.EVENTLOOPOS_TEST_DATABASE_URL
  ?? `postgres://eventloop:eventloop@127.0.0.1:${port}/eventloop_test`;

try {
  switch (command) {
    case "up":
      await up();
      console.log(databaseUrl);
      break;
    case "down":
      await down();
      break;
    case "url":
      console.log(databaseUrl);
      break;
    case "test":
      await up();
      await runDbTests();
      break;
    case "native-test":
      await runNativeDbTests();
      break;
    default:
      console.error("usage: eventloop-dev-postgres up|down|url|test|native-test");
      process.exit(2);
  }
} catch (error) {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
}

async function up() {
  if (await containerIsRunning()) {
    await waitForPostgres();
    return;
  }

  await execFileChecked("docker", [
    "run",
    "-d",
    "--rm",
    "--name",
    containerName,
    "-e",
    "POSTGRES_USER=eventloop",
    "-e",
    "POSTGRES_PASSWORD=eventloop",
    "-e",
    "POSTGRES_DB=eventloop_test",
    "-p",
    `127.0.0.1:${port}:5432`,
    image
  ]);
  await waitForPostgres();
}

async function down() {
  await execFileQuiet("docker", ["rm", "-f", containerName]);
}

async function containerIsRunning() {
  const result = await execFileQuiet("docker", ["inspect", "-f", "{{.State.Running}}", containerName]);
  return result.stdout.trim() === "true";
}

async function waitForPostgres() {
  const deadline = Date.now() + 30_000;
  let lastError;
  while (Date.now() < deadline) {
    const client = new Client({ connectionString: databaseUrl });
    try {
      await client.connect();
      await client.query("SELECT 1");
      await client.end();
      return;
    } catch (error) {
      lastError = error;
      await client.end().catch(() => {});
      await sleep(500);
    }
  }
  throw lastError ?? new Error("timed out waiting for Postgres");
}

async function runDbTests() {
  await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "test:db"], {
    ...process.env,
    EVENTLOOPOS_TEST_DATABASE_URL: databaseUrl
  });
}

async function runNativeDbTests() {
  const binDir = process.env.EVENTLOOPOS_POSTGRES_BIN_DIR;
  const initdb = await resolvePostgresBinary("initdb", binDir);
  const pgCtl = await resolvePostgresBinary("pg_ctl", binDir);
  const psql = await resolvePostgresBinary("psql", binDir);
  const nativePort = await freePort();
  const nativeUser = process.env.EVENTLOOPOS_POSTGRES_USER ?? process.env.USER ?? "postgres";
  const nativeDatabaseUrl = `postgres://${encodeURIComponent(nativeUser)}@127.0.0.1:${nativePort}/eventloop_test`;
  const tempDir = await mkdtemp(path.join(tmpdir(), "eventloopos-postgres-"));
  const dataDir = path.join(tempDir, "data");
  const socketDir = path.join(tempDir, "socket");
  let started = false;

  try {
    await mkdir(socketDir, { recursive: true });
    await execFileChecked(initdb, [
      "-D",
      dataDir,
      "--username",
      nativeUser,
      "--auth=trust",
      "--no-instructions"
    ]);
    await execFileChecked(pgCtl, [
      "-D",
      dataDir,
      "-l",
      path.join(tempDir, "postgres.log"),
      "-o",
      `-p ${nativePort} -k ${socketDir} -c listen_addresses=127.0.0.1`,
      "-w",
      "start"
    ]);
    started = true;
    await waitForDatabase(`postgres://${encodeURIComponent(nativeUser)}@127.0.0.1:${nativePort}/postgres`);
    await execFileChecked(psql, [
      "-h",
      "127.0.0.1",
      "-p",
      String(nativePort),
      "-U",
      nativeUser,
      "-d",
      "postgres",
      "-v",
      "ON_ERROR_STOP=1",
      "-c",
      "CREATE DATABASE eventloop_test"
    ]);
    await waitForDatabase(nativeDatabaseUrl);
    await spawnChecked("pnpm", ["--filter", "@eventloopos/orchestrator", "test:db"], {
      ...process.env,
      EVENTLOOPOS_TEST_DATABASE_URL: nativeDatabaseUrl
    });
  } finally {
    if (started) {
      await execFileQuiet(pgCtl, ["-D", dataDir, "-m", "fast", "-w", "stop"]);
    }
    await rm(tempDir, { recursive: true, force: true });
  }
}

async function waitForDatabase(connectionString) {
  const deadline = Date.now() + 30_000;
  let lastError;
  while (Date.now() < deadline) {
    const client = new Client({ connectionString });
    try {
      await client.connect();
      await client.query("SELECT 1");
      await client.end();
      return;
    } catch (error) {
      lastError = error;
      await client.end().catch(() => {});
      await sleep(500);
    }
  }
  throw lastError ?? new Error("timed out waiting for Postgres");
}

async function resolvePostgresBinary(name, binDir) {
  const candidates = [
    binDir ? path.join(binDir, name) : undefined,
    name,
    `/opt/homebrew/opt/postgresql@17/bin/${name}`,
    `/opt/homebrew/opt/postgresql@16/bin/${name}`,
    `/usr/local/opt/postgresql@17/bin/${name}`,
    `/usr/local/opt/postgresql@16/bin/${name}`
  ].filter(Boolean);

  for (const candidate of candidates) {
    const result = await execFileQuiet(candidate, ["--version"]);
    if (result.stdout || result.stderr) {
      return candidate;
    }
  }
  throw new Error(`could not find ${name}; set EVENTLOOPOS_POSTGRES_BIN_DIR`);
}

async function freePort() {
  return await new Promise((resolve, reject) => {
    const server = net.createServer();
    server.on("error", reject);
    server.listen(0, "127.0.0.1", () => {
      const address = server.address();
      server.close(() => {
        if (!address || typeof address === "string") {
          reject(new Error("could not allocate local port"));
          return;
        }
        resolve(address.port);
      });
    });
  });
}

async function execFileChecked(file, args) {
  return await new Promise((resolve, reject) => {
    execFile(file, args, { encoding: "utf8" }, (error, stdout, stderr) => {
      if (error) {
        reject(new Error(`${file} ${args.join(" ")} failed: ${stderr || error.message}`));
        return;
      }
      resolve({ stdout, stderr });
    });
  });
}

async function execFileQuiet(file, args) {
  return await new Promise((resolve) => {
    execFile(file, args, { encoding: "utf8" }, (_error, stdout, stderr) => {
      resolve({ stdout, stderr });
    });
  });
}

async function spawnChecked(file, args, env) {
  return await new Promise((resolve, reject) => {
    const child = spawn(file, args, {
      env,
      stdio: "inherit"
    });
    child.on("error", reject);
    child.on("exit", (code, signal) => {
      if (code === 0) {
        resolve();
        return;
      }
      reject(new Error(`${file} ${args.join(" ")} exited with ${signal ?? code}`));
    });
  });
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}
