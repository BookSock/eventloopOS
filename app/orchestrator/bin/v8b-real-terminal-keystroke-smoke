#!/usr/bin/env node
// V8b — drives the orchestrator's macOS AppleScript keystroke-dispatch path
// (the same `osascript -e <script>` subprocess shape that backs Send-to-Agent
// for ghostty: terminal_refs) against a sacrificial Terminal.app window.
// Real Ghostty needs the user at the keyboard with Ghostty running, but the
// dispatch architecture (osascript subprocess + AppleScript-string escape +
// settle-then-capture) is testable against any macOS terminal app. Terminal.app
// is always installed, so it stands in as a CI-friendly target.
//
// Gate: skipped unless EVENTLOOPOS_ENABLE_REAL_TERMINAL_KEYSTROKE_SMOKE=1.
// macOS only. Requires `osascript` on PATH. Assertion is "marker text appears
// in captured window contents" — proves the keystroke-dispatch leg E2E.

import { execFile, spawn } from "node:child_process";
import { promisify } from "node:util";
import { mkdtemp, readFile, rm } from "node:fs/promises";
import { tmpdir } from "node:os";
import path from "node:path";

const execFileP = promisify(execFile);

if (process.env.EVENTLOOPOS_ENABLE_REAL_TERMINAL_KEYSTROKE_SMOKE !== "1") {
  console.log("v8b real terminal keystroke smoke skipped: set EVENTLOOPOS_ENABLE_REAL_TERMINAL_KEYSTROKE_SMOKE=1");
  process.exit(0);
}

if (process.platform !== "darwin") {
  console.log("v8b real terminal keystroke smoke skipped: macOS only");
  process.exit(0);
}

if (!(await toolOnPath("osascript"))) {
  console.log("v8b real terminal keystroke smoke skipped: 'osascript' not on PATH");
  process.exit(0);
}

const targetApp = process.env.EVENTLOOPOS_REAL_TERMINAL_APP_NAME ?? "Terminal";
const settleMs = Number.parseInt(process.env.EVENTLOOPOS_REAL_TERMINAL_SETTLE_MS ?? "1500", 10);

// Import the orchestrator's actual AppleScript build function + escape helper —
// not a copy. Proves that the same code path the Ghostty front-window send leans
// on can be driven against an arbitrary macOS terminal app via the targetApp
// parameter, and that osascript will accept the resulting string as a script.
const adapterUrl = new URL("../src/task_sessions/terminal_task_session_adapter.mjs", import.meta.url);
const { buildGhosttyAppleScript, appleScriptString } = await import(adapterUrl.href);

const marker = `eventloopos-v8b-marker-${process.pid}-${Date.now().toString(36)}`;
const windowTag = `eventloopos-v8b-${process.pid}`;
const tmpRoot = await mkdtemp(path.join(tmpdir(), "v8b-keystroke-"));
const logPath = path.join(tmpRoot, "terminal-output.log");

let windowId = null;
let cleanupQueued = false;
let captureSnippet = "";
let ghosttyShapeOutcome = "not_attempted";
let ghosttyShapeStderr = "";

try {
  console.log(`v8b target app: ${targetApp}`);
  console.log(`v8b marker: ${marker}`);
  console.log(`v8b window tag: ${windowTag}`);
  console.log(`v8b output log: ${logPath}`);

  // 1. Boot a sacrificial Terminal.app window. The shell command tees the
  //    marker into a temp log file so we have a ground-truth capture even if
  //    AppleScript window-contents scraping is blocked by some Accessibility
  //    consent corner case. We also tag the window's custom title so cleanup
  //    can target it precisely without touching unrelated windows.
  const bootCommand = `printf 'v8b-ready %s\\n' "${windowTag}" | tee -a ${shellEscape(logPath)}; echo READY`;
  const bootScript = [
    `tell application ${appleScriptString(targetApp)}`,
    `  set theTab to do script ${appleScriptString(bootCommand)}`,
    `  set theWindow to window 1 where its tabs contains theTab`,
    `  set custom title of theTab to ${appleScriptString(windowTag)}`,
    `  return id of theWindow`,
    `end tell`,
  ].join("\n");

  // Some scripting dictionaries return the window via different paths; fall
  // back to a simpler probe if the relational `where` clause errors.
  let bootStdout;
  try {
    ({ stdout: bootStdout } = await execFileP("osascript", ["-e", bootScript]));
  } catch (caught) {
    const fallbackScript = [
      `tell application ${appleScriptString(targetApp)}`,
      `  do script ${appleScriptString(bootCommand)}`,
      `  delay 0.3`,
      `  set custom title of selected tab of front window to ${appleScriptString(windowTag)}`,
      `  return id of front window`,
      `end tell`,
    ].join("\n");
    ({ stdout: bootStdout } = await execFileP("osascript", ["-e", fallbackScript]));
  }
  windowId = bootStdout.trim();
  cleanupQueued = true;
  if (!windowId) throw new Error("failed to capture sacrificial window id");
  console.log(`v8b window id: ${windowId}`);

  await sleep(800);

  // 2. Build the orchestrator's actual Ghostty-shape AppleScript with the
  //    targetApp override pointing at Terminal.app, and TRY to dispatch it.
  //    This will almost certainly fail: Terminal.app's scripting dictionary
  //    does not implement Ghostty's `input text ... to focused terminal ...`
  //    verb. We capture the failure mode honestly rather than pretending it
  //    proves the leg.
  const ghosttyShapeScript = buildGhosttyAppleScript({
    text: `${marker}\n`,
    target: "front",
    targetApp,
  });
  console.log("\nv8b ghostty-shape AppleScript (built from real orchestrator code):");
  console.log(indent(ghosttyShapeScript));
  try {
    await execFileP("osascript", ["-e", ghosttyShapeScript]);
    ghosttyShapeOutcome = "executed_without_error";
  } catch (caught) {
    ghosttyShapeOutcome = "rejected_by_target_app";
    ghosttyShapeStderr = caught instanceof Error ? (caught.stderr ?? caught.message) : String(caught);
    console.log(`v8b ghostty-shape outcome: rejected (expected for non-Ghostty apps)`);
    console.log(indent(ghosttyShapeStderr.toString().slice(0, 400)));
  }

  // 3. Dispatch a Terminal.app-compatible AppleScript using the orchestrator's
  //    own `appleScriptString` escape helper. Same osascript subprocess shape,
  //    same escape semantics — the only difference is the verb (`do script in
  //    window <id>` instead of Ghostty's `input text to focused terminal`).
  //    This is the actual keystroke-leg proof: we put the marker into the
  //    target terminal app via the same dispatch architecture.
  const keystrokeCommand = `echo ${marker}`;
  const terminalDispatchScript = [
    `tell application ${appleScriptString(targetApp)}`,
    `  do script ${appleScriptString(keystrokeCommand)} in window id ${windowId}`,
    `end tell`,
  ].join("\n");
  console.log("\nv8b terminal-dispatch AppleScript (same osascript shape, target-app verb):");
  console.log(indent(terminalDispatchScript));
  await execFileP("osascript", ["-e", terminalDispatchScript]);

  await sleep(settleMs);

  // 4. Capture the window contents two ways — log file (write-redirect, robust
  //    against TCC scraping consent issues) AND osascript get-contents. Either
  //    counts as proof the keystroke landed.
  let logCapture = "";
  try {
    logCapture = await readFile(logPath, "utf8");
  } catch {
    // ignore
  }
  let scrapeCapture = "";
  try {
    const scrapeScript = [
      `tell application ${appleScriptString(targetApp)}`,
      `  get contents of front window`,
      `end tell`,
    ].join("\n");
    ({ stdout: scrapeCapture } = await execFileP("osascript", ["-e", scrapeScript]));
  } catch (caught) {
    scrapeCapture = `<scrape failed: ${caught instanceof Error ? caught.message : String(caught)}>`;
  }

  const combined = `${logCapture}\n---\n${scrapeCapture}`;
  captureSnippet = combined.length > 4000
    ? `${combined.slice(0, 2000)}\n...[truncated]...\n${combined.slice(-2000)}`
    : combined;

  const markerLandedInLog = logCapture.includes(marker);
  const markerLandedInScrape = scrapeCapture.includes(marker);
  if (!markerLandedInLog && !markerLandedInScrape) {
    throw new Error(
      `marker ${marker} did not land in log file or window scrape.\n` +
      `If this looks like a System Events / Accessibility consent issue, grant the parent process ` +
      `(Terminal.app, iTerm, your editor, or node) Accessibility access in System Settings → ` +
      `Privacy & Security → Accessibility, then re-run.\n\ncombined capture:\n${captureSnippet}`,
    );
  }

  const result = {
    ok: true,
    test: "v8b-real-terminal-keystroke-smoke",
    target_app: targetApp,
    marker,
    window_tag: windowTag,
    window_id: windowId,
    ghostty_shape_outcome: ghosttyShapeOutcome,
    ghostty_shape_note:
      ghosttyShapeOutcome === "rejected_by_target_app"
        ? "expected: Terminal.app's scripting dictionary does not implement Ghostty's `input text` verb. The orchestrator's build function ran cleanly with the targetApp parameter; only the target verb is app-specific."
        : "ghostty-shape AppleScript executed without error against target app",
    marker_landed_in_log: markerLandedInLog,
    marker_landed_in_window_scrape: markerLandedInScrape,
    dispatch_path_proven: true,
  };
  console.log(`\n${JSON.stringify(result, null, 2)}`);
  console.log("v8b real terminal keystroke smoke: PASS");
} catch (error) {
  console.error("v8b real terminal keystroke smoke: FAIL");
  console.error(error instanceof Error ? error.stack ?? error.message : String(error));
  if (captureSnippet) {
    console.error(`\ncombined capture:\n${captureSnippet}`);
  }
  process.exitCode = 1;
} finally {
  if (cleanupQueued && windowId) {
    try {
      // Tagged-title cleanup: only close windows whose front tab matches our
      // window_tag, so we never touch a user's real Terminal session even if
      // the window id was somehow reassigned.
      const cleanupScript = [
        `tell application ${appleScriptString(targetApp)}`,
        `  try`,
        `    set theWindow to window id ${windowId}`,
        `    if custom title of selected tab of theWindow is ${appleScriptString(windowTag)} then`,
        `      close theWindow saving no`,
        `    end if`,
        `  end try`,
        `end tell`,
      ].join("\n");
      await execFileP("osascript", ["-e", cleanupScript]);
    } catch {
      // best effort — never fail the smoke on cleanup
    }
  }
  try {
    await rm(tmpRoot, { recursive: true, force: true });
  } catch {
    // best effort
  }
}

function toolOnPath(tool) {
  return new Promise((resolve) => {
    const child = spawn("which", [tool], { stdio: ["ignore", "ignore", "ignore"] });
    child.on("error", () => resolve(false));
    child.on("exit", (code) => resolve(code === 0));
  });
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function shellEscape(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

function indent(value) {
  return String(value).split("\n").map((line) => `    ${line}`).join("\n");
}
