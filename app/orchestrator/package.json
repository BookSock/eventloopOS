{
  "name": "@eventloopos/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:doctor": "node dist/src/dev/doctor.js",
    "dev:postgres": "bin/dev-postgres",
    "poll:mcp:loop": "node dist/src/mcp_sources/poll_loop.js",
    "poll:mcp:once": "node dist/src/mcp_sources/poll_once.js",
    "voice:listen": "node dist/src/voice/listen_voice_commands.js",
    "voice:send": "node dist/src/voice/send_voice_command.js",
    "start": "node dist/src/index.js",
    "test": "pnpm run build && node --test dist/test/**/*.test.js dist/src/**/*.test.js src/agents/codex/*.test.mjs src/task_sessions/*.test.mjs",
    "test:db": "pnpm run build && node --test dist/test/db*.test.js",
    "test:db:docker": "bin/dev-postgres test",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --check bin/dev-postgres"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "^25.0.0",
    "@types/pg": "8.20.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "pg": "8.20.0"
  }
}
