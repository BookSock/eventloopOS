{
  "name": "@eventloopos/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:doctor": "node dist/src/dev/doctor.js",
    "dogfood:review": "node dist/src/dev/dogfood_review.js",
    "dogfood:check": "node dist/src/dev/dogfood_check.js",
    "dev:postgres": "bin/dev-postgres",
    "live:aerospace": "pnpm run build && node dist/src/workspace/live_aerospace_smoke.js",
    "mcp:agent-slack": "node dist/src/mcp_sources/agent_slack_events_server.js",
    "mcp:gh-notifications": "node dist/src/mcp_sources/gh_notifications_server.js",
    "mcp:local-events": "node dist/src/mcp_sources/local_events_server.js",
    "poll:mcp:loop": "node dist/src/mcp_sources/poll_loop.js",
    "poll:mcp:once": "node dist/src/mcp_sources/poll_once.js",
    "queue:add": "pnpm run build && node dist/src/manual/send_manual_review.js",
    "voice:listen": "node dist/src/voice/listen_voice_commands.js",
    "voice:listen-command": "node dist/src/voice/listen_transcript_command.js",
    "voice:send": "node dist/src/voice/send_voice_command.js",
    "voice:stt-smoke": "bin/voice-stt-smoke",
    "start": "node dist/src/index.js",
    "task:sessions": "pnpm run build && node dist/src/task_sessions/task_session_cli.js list",
    "task:bind": "pnpm run build && node dist/src/task_sessions/task_session_cli.js bind",
    "task:messages": "pnpm run build && node dist/src/task_sessions/task_session_cli.js messages",
    "test": "pnpm run build && node --test dist/test/**/*.test.js dist/src/**/*.test.js src/agents/codex/*.test.mjs src/task_sessions/*.test.mjs",
    "test:db": "pnpm run build && node --test dist/test/db*.test.js",
    "test:db:docker": "bin/dev-postgres test",
    "test:db:native": "bin/dev-postgres native-test",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --check bin/dev-postgres && node --check bin/voice-stt-smoke"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "^25.0.0",
    "@types/pg": "8.20.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "pg": "8.20.0",
    "zod": "3.25.76"
  }
}
