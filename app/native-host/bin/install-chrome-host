#!/usr/bin/env node
import { installChromeHostManifest } from "../src/install.js";

const args = process.argv.slice(2);
const dryRun = args.includes("--dry-run");
const browserFlagIndex = args.findIndex((arg) => arg === "--browser");
const browser = browserFlagIndex === -1 ? process.env.EVENTLOOPOS_CHROME_BROWSER ?? "chrome" : args[browserFlagIndex + 1];
const positionalArgs = args.filter((arg, index) =>
  !arg.startsWith("--") && !(browserFlagIndex !== -1 && index === browserFlagIndex + 1)
);
const extensionId = positionalArgs[0] ?? process.env.EVENTLOOPOS_CHROME_EXTENSION_ID;

if (browserFlagIndex !== -1 && !browser) {
  console.error("--browser requires a value");
  process.exit(2);
}

try {
  const result = await installChromeHostManifest({ extensionId, browser, dryRun });
  if (dryRun) {
    process.stdout.write(result.body);
  } else {
    process.stdout.write(`installed ${result.path}\nextension_id ${result.extensionId}\n`);
  }
} catch (error) {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
}
