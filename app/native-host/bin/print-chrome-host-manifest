#!/usr/bin/env node
import { realpathSync } from "node:fs";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const hostName = "com.eventloopos.browser_context";
const extensionId = process.argv[2] ?? process.env.EVENTLOOPOS_CHROME_EXTENSION_ID ?? "replace_with_extension_id";
const hostPath = realpathSync(resolve(dirname(fileURLToPath(import.meta.url)), "eventloop-native-host"));

const manifest = {
  name: hostName,
  description: "eventloopOS browser context native messaging host",
  path: hostPath,
  type: "stdio",
  allowed_origins: [`chrome-extension://${extensionId}/`]
};

process.stdout.write(`${JSON.stringify(manifest, null, 2)}\n`);
