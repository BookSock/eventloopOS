{
  "sources": [
    {
      "id": "local_events_source",
      "server": {
        "name": "eventloopos-local-events",
        "command": "node",
        "args": ["dist/src/mcp_sources/local_events_server.js"],
        "envAllowlist": ["EVENTLOOPOS_LOCAL_EVENTS_PATH"],
        "stderrLogPath": "var/log/mcp/local_events_source.stderr.log"
      },
      "poll": {
        "tool": "list_events",
        "args": {},
        "timeoutMs": 5000
      },
      "cursor": {
        "strategy": "hash",
        "dedupeWindow": 1000
      },
      "eventMapper": "generic_item_to_event",
      "riskPolicy": {
        "readOnly": true,
        "allowWriteTools": false,
        "maxRiskLevel": "low",
        "untrustedTextFields": ["title", "summary", "text"]
      }
    }
  ]
}
