{
  "sources": [
    {
      "id": "script_events_source",
      "server": {
        "name": "eventloopos-script-events",
        "command": "node",
        "args": ["dist/src/mcp_sources/script_events_server.js"],
        "envAllowlist": [
          "EVENTLOOPOS_SCRIPT_EVENTS_COMMAND",
          "EVENTLOOPOS_SCRIPT_EVENTS_ARGS",
          "EVENTLOOPOS_SCRIPT_EVENTS_CURSOR_ARG",
          "EVENTLOOPOS_SCRIPT_EVENTS_CURSOR_ENV",
          "EVENTLOOPOS_SCRIPT_EVENTS_TIMEOUT_MS",
          "EVENTLOOPOS_SCRIPT_EVENTS_MAX_BUFFER_BYTES",
          "PATH",
          "HOME",
          "XDG_CONFIG_HOME",
          "XDG_RUNTIME_DIR"
        ],
        "stderrLogPath": "var/log/mcp/script_events_source.stderr.log"
      },
      "poll": {
        "tool": "poll_script",
        "args": {},
        "timeoutMs": 15000
      },
      "cursor": {
        "strategy": "field",
        "field": "id",
        "dedupeWindow": 1000
      },
      "eventMapper": "generic_item_to_event",
      "riskPolicy": {
        "readOnly": true,
        "allowWriteTools": false,
        "maxRiskLevel": "low",
        "untrustedTextFields": ["title", "summary", "text"]
      }
    }
  ]
}
